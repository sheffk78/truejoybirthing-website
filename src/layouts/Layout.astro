---
// Base layout — True Joy Birthing feminine lavender + dusty rose design
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  schema?: object;
  breadcrumbList?: { name: string; url: string }[];
}

const { title, description = "True Joy Birthing — birth education and planning tools for moms, doulas, and midwives.", canonical, ogImage = "https://truejoybirthing.com/images/og-default.webp" } = Astro.props;
const breadcrumbList = Astro.props.breadcrumbList;
const currentPath = Astro.url.pathname;

const schemaBase = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["Organization", "ProfessionalService"],
      "@id": "https://truejoybirthing.com/#organization",
      "name": "True Joy Birthing",
      "legalName": "True Joy Birthing",
      "url": "https://truejoybirthing.com/",
      "email": "support@truejoybirthing.com",
      "description": "Birth education and planning tools — free for moms, Pro for doulas and midwives. Build your birth plan, learn your options, and feel confident about your delivery.",
      "logo": {
        "@type": "ImageObject",
        "@id": "https://truejoybirthing.com/#logo",
        "url": "https://truejoybirthing.com/images/logo.svg",
        "contentUrl": "https://truejoybirthing.com/images/logo.svg",
        "width": 480,
        "height": 128,
        "creditText": "True Joy Birthing",
        "copyrightHolder": { "@id": "https://truejoybirthing.com/#organization" }
      },
      "image": { "@id": "https://truejoybirthing.com/#logo" },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Dallas",
        "addressRegion": "TX",
        "addressCountry": "US"
      },
      "areaServed": [
        { "@type": "State", "name": "Texas" },
        { "@type": "Country", "name": "United States" }
      ],
      "priceRange": "Free–$29.99/mo",
      "foundingDate": "2025",
      "founder": {
        "@type": "Person",
        "@id": "https://truejoybirthing.com/about/#founder",
        "name": "Shelbi Kohler",
        "jobTitle": "Certified Birth Doula",
        "description": "Certified birth doula and founder of True Joy Birthing.",
        "url": "https://truejoybirthing.com/about/"
      },
      "sameAs": [
        "https://instagram.com/truejoybirthing",
        "https://apps.apple.com/app/true-joy-birthing/id6741691495"
      ],
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "32.7767",
        "longitude": "-96.7970"
      },
      "knowsAbout": [
        "Birth planning",
        "Birth doula support",
        "Doula services",
        "Birth plan template",
        "Pregnancy preparation",
        "Labor and delivery preferences",
        "Postpartum care",
        "Newborn care preferences",
        "Doula cost",
        "Medicaid doula coverage",
        "Hospital birth planning",
        "Birth center options",
        "VBAC planning",
        "Natural birth preparation",
        "Postpartum doula services"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Birth Planning Services",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "@id": "https://truejoybirthing.com/#birth-plan-service",
              "name": "Free Birth Plan",
              "url": "https://truejoybirthing.com/",
              "description": "A structured birth plan template free for expecting mothers.",
              "serviceType": "Birth Planning",
              "provider": { "@id": "https://truejoybirthing.com/#organization" },
              "areaServed": { "@type": "Country", "name": "United States" }
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "@id": "https://truejoybirthing.com/#guided-birth-plan-service",
              "name": "Guided Birth Plan Walkthrough",
              "url": "https://truejoybirthing.com/#download",
              "description": "Free guided walkthrough walking you through each section of your birth plan, available in the True Joy Birthing app.",
              "serviceType": "Birth Education",
              "provider": { "@id": "https://truejoybirthing.com/#organization" },
              "areaServed": { "@type": "Country", "name": "United States" }
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "@id": "https://truejoybirthing.com/#doula-support",
              "name": "Doula Directory and Birth Support",
              "url": "https://truejoybirthing.com/birth-support/",
              "description": "Virtual birth planning support with a certified birth doula, available in the True Joy Birthing app.",
              "serviceType": "Doula Directory",
              "provider": { "@id": "https://truejoybirthing.com/#organization" },
              "areaServed": { "@type": "Country", "name": "United States" }
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "@id": "https://truejoybirthing.com/#pro-mode-service",
              "name": "Pro Mode",
              "url": "https://truejoybirthing.com/",
              "description": "Professional tools for doulas and midwives to manage client birth plans.",
              "serviceType": "Professional Software",
              "provider": { "@id": "https://truejoybirthing.com/#organization" },
              "areaServed": { "@type": "Country", "name": "United States" }
            }
          }
        ]
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "support@truejoybirthing.com",
        "contactType": "customer service",
        "availableLanguage": ["English"]
      }
    },
    {
      "@type": "WebSite",
      "@id": "https://truejoybirthing.com/#website",
      "url": "https://truejoybirthing.com/",
      "name": "True Joy Birthing",
      "publisher": { "@id": "https://truejoybirthing.com/#organization" }
    }
  ]
};

// Merge page-level schema with base: combine @graph arrays, deduplicating by @id
// Page-level @id entries override base entries of the same @id
const pageSchema = Astro.props.schema;
let schema;
if (pageSchema) {
  const baseGraph = schemaBase["@graph"] || [];
  const pageGraph = pageSchema["@graph"] || [];
  const pageIds = new Set(pageGraph.map(e => e["@id"]).filter(Boolean));
  const mergedGraph = [...baseGraph.filter(e => !pageIds.has(e["@id"])), ...pageGraph];
  schema = { ...schemaBase, ...pageSchema, "@graph": mergedGraph };
} else {
  schema = schemaBase;
}
let finalSchema = schema;
if (breadcrumbList && breadcrumbList.length > 0) {
  finalSchema = {
    ...schema,
    "@graph": [
      ...((schema["@graph"] || [])),
      {
        "@type": "BreadcrumbList",
        "itemListElement": breadcrumbList.map((item, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "name": item.name,
          "item": item.url
        }))
      }
    ]
  };
}
const schemaJson = JSON.stringify(finalSchema);
const pageTitle = title.includes("True Joy Birthing") ? title : `${title} | True Joy Birthing`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="True Joy Birthing" />
    <meta property="og:url" content={canonical || `https://truejoybirthing.com${currentPath}`} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {canonical && <link rel="canonical" href={canonical} />}
    {!canonical && <link rel="canonical" href={`https://truejoybirthing.com${currentPath}`} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Source+Sans+3:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={schemaJson} />
    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-469670390"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-469670390');
    </script>
  </head>
  <body class="min-h-dvh flex flex-col font-sans">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-tjb-charcoal focus:text-white focus:px-4 focus:py-2 focus:rounded-lg">Skip to main content</a>
    <!-- Header -->
    <header class="bg-tjb-cream/95 backdrop-blur-sm sticky top-0 z-50 border-b border-tjb-lavender-300/30">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 group">
          <img 
            src="/images/logo.svg" 
            alt="True Joy Birthing" 
            class="h-10 max-w-[160px] w-auto transition-transform duration-300 group-hover:scale-[1.02]"
          />
        </a>
        <nav class="hidden md:flex gap-8 text-sm font-semibold tracking-wide text-tjb-gray" aria-label="Main">
          <a href="/" class="hover:text-tjb-rose-500 transition-colors duration-200 relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-tjb-rose-500 after:transition-all after:duration-300 hover:after:w-full">Home</a>
          <a href="/about" class="hover:text-tjb-rose-500 transition-colors duration-200 relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-tjb-rose-500 after:transition-all after:duration-300 hover:after:w-full">About</a>
          <a href="/blog" class="hover:text-tjb-rose-500 transition-colors duration-200 relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-tjb-rose-500 after:transition-all after:duration-300 hover:after:w-full">Blog</a>
          <a href="/contact" class="hover:text-tjb-rose-500 transition-colors duration-200 relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-tjb-rose-500 after:transition-all after:duration-300 hover:after:w-full">Contact</a>
        </nav>
        <a href="#download" id="nav-cta" class="hidden md:inline-block bg-tjb-lavender-600 text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:bg-tjb-rose-500 focus-visible:outline focus-visible:outline-3 focus-visible:outline-tjb-lavender-400 focus-visible:outline-offset-2 active:translate-y-0 transition-all duration-300">
          Get the free PDF
        </a>
        <button id="mobile-menu-btn" class="md:hidden text-tjb-charcoal p-2" aria-label="Open menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
      <div id="mobile-menu" class="hidden md:hidden px-6 pb-6 border-t border-tjb-lavender-300/20 bg-tjb-cream">
        <nav class="flex flex-col gap-4 pt-6 text-sm font-semibold tracking-wide text-tjb-gray" aria-label="Mobile">
          <a href="/" class="hover:text-tjb-rose-500 transition">Home</a>
          <a href="/about" class="hover:text-tjb-rose-500 transition">About</a>
          <a href="/blog" class="hover:text-tjb-rose-500 transition">Blog</a>
          <a href="/contact" class="hover:text-tjb-rose-500 transition">Contact</a>
          <a href="#download" class="bg-tjb-lavender-600 text-white px-6 py-2.5 rounded-full text-center font-semibold w-fit hover:bg-tjb-rose-500 focus-visible:outline focus-visible:outline-3 focus-visible:outline-tjb-lavender-400 focus-visible:outline-offset-2 active:translate-y-0 transition">Get the free PDF</a>
        </nav>
      </div>
    </header>

    <main class="flex-1" id="main">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-tjb-charcoal text-tjb-cream/80 mt-auto">
      <div class="max-w-6xl mx-auto px-6 py-16 grid gap-10 md:grid-cols-3">
        <div>
          <img src="/images/logo-white.svg" alt="True Joy Birthing" class="h-10 w-auto mb-4" />
          <p class="text-sm text-tjb-gray-300 leading-relaxed">Birth education and planning tools — free for moms, Pro for doulas and midwives.</p>
          <div class="mt-3 text-sm text-tjb-gray-300 space-y-1">
            <p>True Joy Birthing</p>
            <p><a href="mailto:support@truejoybirthing.com" class="hover:text-tjb-lavender-light transition">support@truejoybirthing.com</a></p>
          </div>
        </div>
        <div>
          <p class="font-semibold text-white mb-4 tracking-wide text-sm uppercase">Resources</p>
          <ul class="text-sm space-y-2">
            <li><a href="/blog" class="hover:text-tjb-lavender-light transition">Blog</a></li>
            <li><a href="/about" class="hover:text-tjb-lavender-light transition">About</a></li>
            <li><a href="/faq" class="hover:text-tjb-lavender-light transition">FAQ</a></li>
            <li><a href="/privacy" class="hover:text-tjb-lavender-light transition">Privacy</a></li>
            <li><a href="/terms" class="hover:text-tjb-lavender-light transition">Terms</a></li>
          </ul>
        </div>
        <div>
          <p class="font-semibold text-white mb-4 tracking-wide text-sm uppercase">Download the app — free for moms</p>
          <p class="text-sm text-tjb-gray-300 mb-4 leading-relaxed">Build your birth plan, learn your options, and feel confident.</p>
          <div class="flex flex-wrap gap-3">
            <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="inline-flex items-center gap-2 bg-tjb-lavender-600 text-white px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-tjb-rose-500 focus-visible:outline focus-visible:outline-3 focus-visible:outline-tjb-lavender-400 focus-visible:outline-offset-2 active:translate-y-0 transition-all duration-300">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.81-1.31.03-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.97-.09.06-2.17 1.28-2.15 3.8.03 3.02 2.65 4.03 2.68 4.04-.02.07-.42 1.45-1.39 2.88M12.03 6.37c.69-.82 1.15-1.97 1.03-3.11-1 .04-2.22.66-2.93 1.5-.64.74-1.2 1.93-1.05 3.07 1.12.09 2.26-.57 2.95-1.46"/></svg>
              App Store
            </a>
            <span class="inline-flex items-center gap-2 bg-tjb-gray-300/30 text-tjb-gray-400 px-5 py-2.5 rounded-full text-sm font-semibold cursor-not-allowed relative group">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3.61 1.814L13.793 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.61-.92zm10.89 9.48l2.71-1.572 2.525 4.363-2.71 1.572-2.525-4.363zm-2.75.412L5.28 4.772l8.346 4.833-2.877 1.101zM5.28 19.228l6.47-6.928 2.877 1.1-8.347 4.828zm14.074-5.543l-2.71-1.572 2.525-4.363 2.71 1.572-2.525 4.363z"/></svg>
              Google Play
              <span class="absolute -top-8 left-1/2 -translate-x-1/2 bg-white text-tjb-charcoal text-xs font-medium px-2.5 py-1 rounded shadow-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">Coming soon</span>
            </span>
          </div>
        </div>
      </div>
      <div class="border-t border-tjb-gray/20 max-w-6xl mx-auto px-6 py-5 text-xs text-tjb-gray-300">
        © {new Date().getFullYear()} True Joy Birthing. Built with intention.
        <span class="block mt-1">Not medical advice. Always consult your care provider.</span>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
        const isOpen = !menu?.classList.contains('hidden');
        btn?.setAttribute('aria-expanded', String(isOpen));
        btn?.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
      });
    </script>
  </body>
</html>
