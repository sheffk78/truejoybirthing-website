---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  date?: string;
  author?: string;
  featuredImage?: string;
  pageType?: string;
}

const { title, description, canonical, date, author = "Shelbi Kohler", featuredImage, pageType = "BlogPosting" } = Astro.props;

const pubDate = date ? new Date(date) : null;
const formattedDate = pubDate ? pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : '';

const pageTitle = `${title} | True Joy Birthing`;

const schema = {
  "@context": "https://schema.org",
  "@type": pageType,
  "headline": title,
  "description": description,
  "author": {
    "@type": "Person",
    "name": author,
    "url": "https://truejoybirthing.com/about"
  },
  "publisher": {
    "@type": "Organization",
    "name": "True Joy Birthing",
    "logo": { "@type": "ImageObject", "url": "https://truejoybirthing.com/images/logo.svg" }
  },
  "datePublished": date,
  ...(featuredImage && { "image": featuredImage }),
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonical || "https://truejoybirthing.com/blog/"
  }
};

const ogImage = featuredImage || "https://truejoybirthing.com/images/og/og-homepage.webp";
const pageUrl = canonical || `https://truejoybirthing.com${Astro.url.pathname}`;
const schemaJson = JSON.stringify(schema);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="True Joy Birthing" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="stylesheet" href="/fonts/fonts.css" />
    <!-- Preload critical font weights used above the fold -->
    <link rel="preload" href="/fonts/co3bmX5slCNuHLi8bLeY9MK7whWMhyjoq3FNsS8.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/nwpStKy2OAdR1K-IwhWudF-R7w0QYsrd.woff2" as="font" type="font/woff2" crossorigin />
    <ClientRouter />
    <!-- Preconnect to third-party analytics origins -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://www.redditstatic.com" />
    <script type="application/ld+json" set:html={schemaJson} />
    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-2RVZVN0F9T"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-2RVZVN0F9T');
    </script>
    <!-- Reddit Pixel -->
    <script is:inline>
      !function(w,d){if(!w.rdt){var p=w.rdt=function(){p.sendEvent?p.sendEvent.apply(p,arguments):p.callQueue.push(arguments)};p.callQueue=[];var t=d.createElement("script");t.src="https://www.redditstatic.com/ads/pixel.js?pixel_id=a2_j5hvsdn7sctb",t.async=!0;var s=d.getElementsByTagName("script")[0];s.parentNode.insertBefore(t,s)}}(window,document);rdt('init','a2_j5hvsdn7sctb');rdt('track', 'PageVisit');
    </script>
    <!-- DO NOT MODIFY UNLESS TO REPLACE A USER IDENTIFIER -->
    <!-- End Reddit Pixel -->
  </head>
  <body class="min-h-dvh flex flex-col font-sans bg-tjb-cream">
    <header class="bg-tjb-cream/95 backdrop-blur-sm sticky top-0 z-50 border-b border-tjb-lavender-300/30">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 group">
          <img src="/images/logo.svg" alt="True Joy Birthing" class="h-10 max-w-[160px] w-auto transition-transform duration-300 group-hover:scale-[1.02]"/>
        </a>
        <nav class="hidden md:flex gap-8 text-sm font-semibold tracking-wide text-tjb-gray">
          <a href="/" class="hover:text-tjb-rose-500 transition-colors duration-200" aria-label="Home">Home</a>
          <a href="/about" class="hover:text-tjb-rose-500 transition-colors duration-200">About</a>
          <a href="/blog" class="hover:text-tjb-rose-500 transition-colors duration-200">Blog</a>
          <a href="/contact" class="hover:text-tjb-rose-500 transition-colors duration-200">Contact</a>
        </nav>
        <a href="/birth-plan-template/" class="hidden md:inline-block bg-tjb-lavender-600 text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:bg-tjb-rose-500 focus-visible:outline focus-visible:outline-3 focus-visible:outline-tjb-lavender-400 focus-visible:outline-offset-2 active:translate-y-0 transition-all duration-300">
          Get Your Joyful Birth Plan
        </a>
        <button id="mobile-menu-btn" class="md:hidden text-tjb-charcoal p-2" aria-label="Open menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
      <div id="mobile-menu" class="hidden md:hidden px-6 pb-6 border-t border-tjb-lavender-300/20 bg-tjb-cream">
        <nav class="flex flex-col gap-4 pt-6 text-sm font-semibold tracking-wide text-tjb-gray">
          <a href="/" class="hover:text-tjb-rose-500 transition">Home</a>
          <a href="/about" class="hover:text-tjb-rose-500 transition">About</a>
          <a href="/blog" class="hover:text-tjb-rose-500 transition">Blog</a>
          <a href="/contact" class="hover:text-tjb-rose-500 transition">Contact</a>
          <a href="/birth-plan-template/" class="bg-tjb-lavender-600 text-white px-6 py-2.5 rounded-full text-center font-semibold w-fit hover:bg-tjb-rose-500 focus-visible:outline focus-visible:outline-3 focus-visible:outline-tjb-lavender-400 focus-visible:outline-offset-2 active:translate-y-0 transition">Get Your Joyful Birth Plan</a>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <!-- App Showcase — Blog conversion (matches Denver city page design) -->
    <section class="bg-tjb-cream-50 py-16 md:py-20 border-t border-tjb-lavender-300/20">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-10">
          <p class="eyebrow text-tjb-lavender-500 font-semibold text-sm tracking-widest uppercase mb-3">Free App</p>
          <h3 class="text-2xl md:text-3xl font-bold text-tjb-charcoal mb-3">Build Your Birth Plan Step by Step in the App</h3>
          <p class="text-tjb-gray max-w-2xl mx-auto">Nine guided sections. Hospital preferences, pain management, who's in the room — all walked through so nothing gets missed.</p>
        </div>

        <div class="flex flex-col md:flex-row items-center justify-center gap-8 mb-10">
          <div class="flex -space-x-4">
            <img src="/images/app-birth-plan.webp" alt="True Joy Birthing app birth plan showing completed sections" class="h-80 w-auto rounded-2xl shadow-xl" loading="lazy" />
            <img src="/images/app-mom-dashboard.webp" alt="True Joy Birthing app home screen with pregnancy week tracker" class="h-80 w-auto rounded-2xl shadow-xl" loading="lazy" />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-3xl mx-auto mb-10">
          <div class="text-center">
            <div class="w-12 h-12 bg-tjb-lavender-100 rounded-full flex items-center justify-center mx-auto mb-3">
              <svg class="w-6 h-6 text-tjb-lavender-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            </div>
            <p class="font-semibold text-tjb-charcoal text-sm">Step-by-Step Guidance</p>
            <p class="text-xs text-tjb-gray mt-1">Every section walks you through what each choice means.</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 bg-tjb-lavender-100 rounded-full flex items-center justify-center mx-auto mb-3">
              <svg class="w-6 h-6 text-tjb-lavender-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            </div>
            <p class="font-semibold text-tjb-charcoal text-sm">Update Anytime</p>
            <p class="text-xs text-tjb-gray mt-1">Your plan builds as you go — never just a static PDF.</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 bg-tjb-lavender-100 rounded-full flex items-center justify-center mx-auto mb-3">
              <svg class="w-6 h-6 text-tjb-lavender-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>
            </div>
            <p class="font-semibold text-tjb-charcoal text-sm">Share with Your Team</p>
            <p class="text-xs text-tjb-gray mt-1">Send your plan directly to your doula or care team.</p>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="inline-block focus-visible:outline focus-visible:outline-3 focus-visible:outline-tjb-lavender-400 focus-visible:outline-offset-2 transition-opacity hover:opacity-90" style="line-height:0">
            <img src="/images/app-store-badge.svg" alt="Download on the App Store" class="h-12 w-auto" />
          </a>
          <a href="/birth-plan-template/" class="btn-primary">Get the Joyful Birth Plan</a>
        </div>
        <p class="text-center text-sm text-tjb-gray mt-4">Free · No account needed · Works on iPhone</p>
      </div>
    </section>

    <!-- What the Free App Offers — Extended details -->
    <section class="bg-white py-16 border-t border-tjb-lavender-300/20">
      <div class="max-w-4xl mx-auto px-6">
        <h3 class="text-xl md:text-2xl font-bold text-tjb-charcoal text-center mb-10">What the Free App Offers</h3>
        <div class="grid md:grid-cols-2 gap-8">
          <div>
            <p class="font-semibold text-tjb-charcoal mb-1">9 Guided Sections</p>
            <p class="text-sm text-tjb-gray leading-relaxed">Hospital preferences, pain management options, who's in the room, feeding preferences, postpartum plans — each section walks you through what each choice means. Answer a few questions at a time, save your progress, and come back whenever you want.</p>
          </div>
          <div>
            <p class="font-semibold text-tjb-charcoal mb-1">Find Local Doulas</p>
            <p class="text-sm text-tjb-gray leading-relaxed">Browse and connect with doulas and midwives serving your area right inside the app. See their services, cost ranges, and availability without searching elsewhere.</p>
          </div>
          <div>
            <p class="font-semibold text-tjb-charcoal mb-1">Printable PDF Birth Plan</p>
            <p class="text-sm text-tjb-gray leading-relaxed">Export your finished plan as a PDF to share with your provider, doula, or hospital. Easy to update anytime — not a static document you fill out once.</p>
          </div>
          <div>
            <p class="font-semibold text-tjb-charcoal mb-1">Completely Free</p>
            <p class="text-sm text-tjb-gray leading-relaxed">No account needed, no credit card, no time limit. Works on iPhone. Download it, build your plan, share it — that's it.</p>
          </div>
        </div>
        <div class="text-center mt-10">
          <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="btn-primary">Download on the App Store →</a>
        </div>
      </div>
    </section>

    <footer class="bg-tjb-charcoal text-tjb-cream/80 mt-auto">
      <div class="max-w-6xl mx-auto px-6 py-16 grid gap-10 md:grid-cols-3">
        <div>
          <img src="/images/logo-white.svg" alt="True Joy Birthing" class="h-10 w-auto mb-4" />
          <p class="text-sm text-tjb-gray-300 leading-relaxed">Birth education and planning tools — free for moms, Pro for doulas and midwives.</p>
        </div>
        <div>
          <p class="font-semibold text-white mb-4 tracking-wide text-sm uppercase">Resources</p>
          <ul class="text-sm space-y-2">
            <li><a href="/blog" class="hover:text-tjb-lavender-light transition">Blog</a></li>
            <li><a href="/about" class="hover:text-tjb-lavender-light transition">About</a></li>
            <li><a href="/faq" class="hover:text-tjb-lavender-light transition">FAQ</a></li>
            <li><a href="/privacy" class="hover:text-tjb-lavender-light transition">Privacy</a></li>
            <li><a href="/terms" class="hover:text-tjb-lavender-light transition">Terms</a></li>
          </ul>
        </div>
        <div>
          <p class="font-semibold text-white mb-4 tracking-wide text-sm uppercase">Get the Free App</p>
          <p class="text-sm text-tjb-gray-300 mb-5 leading-relaxed">Build your birth plan, learn your options, and feel confident.</p>
          <div class="flex flex-wrap gap-3 items-center">
            <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="inline-block focus-visible:outline focus-visible:outline-3 focus-visible:outline-tjb-lavender-400 focus-visible:outline-offset-2 transition-opacity hover:opacity-90" style="line-height:0">
              <img src="/images/app-store-badge.svg" alt="Download on the App Store" class="h-12 w-auto" />
            </a>
            <div class="relative group inline-block cursor-not-allowed">
              <img src="/images/google-play-badge.png" alt="Get it on Google Play" class="h-12 w-auto" loading="lazy" />
              <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 bg-white text-tjb-charcoal text-xs font-medium px-2.5 py-1 rounded shadow-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">Coming soon</span>
            </div>
          </div>
        </div>
      </div>
      <div class="border-t border-tjb-gray/20 max-w-6xl mx-auto px-6 py-5 text-xs text-tjb-gray-300">
        © {new Date().getFullYear()} True Joy Birthing. Built with intention.
        <span class="block mt-1">Not medical advice. Always consult your care provider.</span>
      </div>
    </footer>

    <script>
      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
