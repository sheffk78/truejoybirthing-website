---
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  date?: string;
  author?: string;
  featuredImage?: string;
}

const { title, description, canonical, date, author = "Shelbi Kohler", featuredImage } = Astro.props;

const pubDate = date ? new Date(date) : null;
const formattedDate = pubDate ? pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : '';

const pageTitle = `${title} | True Joy Birthing`;

const schema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": title,
  "description": description,
  "author": {
    "@type": "Person",
    "name": author,
    "url": "https://truejoybirthing.com/about"
  },
  "publisher": {
    "@type": "Organization",
    "name": "True Joy Birthing",
    "logo": { "@type": "ImageObject", "url": "https://truejoybirthing.com/images/logo.png" }
  },
  "datePublished": date,
  ...(featuredImage && { "image": featuredImage }),
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonical || "https://truejoybirthing.com/blog/"
  }
};

const schemaJson = JSON.stringify(schema);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Source+Sans+3:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={schemaJson} />
  </head>
  <body class="min-h-dvh flex flex-col font-sans bg-tjb-cream">
    <header class="bg-tjb-cream/95 backdrop-blur-sm sticky top-0 z-50 border-b border-tjb-lavender-300/30">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 group">
          <img src="/images/logo.png" alt="True Joy Birthing" class="h-12 w-auto transition-transform duration-300 group-hover:scale-[1.02]"/>
        </a>
        <nav class="hidden md:flex gap-8 text-sm font-semibold tracking-wide text-tjb-gray">
          <a href="/" class="hover:text-tjb-rose-500 transition-colors duration-200 relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-tjb-rose-500 after:transition-all after:duration-300 hover:after:w-full">Home</a>
          <a href="/about" class="hover:text-tjb-rose-500 transition-colors duration-200 relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-tjb-rose-500 after:transition-all after:duration-300 hover:after:w-full">About</a>
          <a href="/blog" class="hover:text-tjb-rose-500 transition-colors duration-200 relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-tjb-rose-500 after:transition-all after:duration-300 hover:after:w-full">Blog</a>
          <a href="/birth-support" class="hover:text-tjb-rose-500 transition-colors duration-200 relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-tjb-rose-500 after:transition-all after:duration-300 hover:after:w-full">Find Support</a>
          <a href="/contact" class="hover:text-tjb-rose-500 transition-colors duration-200 relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-tjb-rose-500 after:transition-all after:duration-300 hover:after:w-full">Connect</a>
        </nav>
        <a href="/birth-plan-course" class="hidden md:inline-block btn-primary text-sm py-2 px-4">
          Get the Course
        </a>
        <button id="mobile-menu-btn" class="md:hidden text-tjb-charcoal p-2" aria-label="Open menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
      <div id="mobile-menu" class="hidden md:hidden px-6 pb-6 border-t border-tjb-lavender-300/20 bg-tjb-cream">
        <nav class="flex flex-col gap-4 pt-6 text-sm font-semibold tracking-wide text-tjb-gray">
          <a href="/" class="hover:text-tjb-rose-500 transition">Home</a>
          <a href="/about" class="hover:text-tjb-rose-500 transition">About</a>
          <a href="/blog" class="hover:text-tjb-rose-500 transition">Blog</a>
          <a href="/birth-support" class="hover:text-tjb-rose-500 transition">Find Support</a>
          <a href="/contact" class="hover:text-tjb-rose-500 transition">Connect</a>
          <a href="/birth-plan-course" class="btn-primary text-center w-fit">Get the Course</a>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-tjb-charcoal text-tjb-cream/80 mt-auto">
      <div class="max-w-6xl mx-auto px-6 py-16 grid gap-10 md:grid-cols-3">
        <div>
          <img src="/images/logo.png" alt="True Joy Birthing" class="h-10 w-auto mb-4 brightness-100 invert opacity-90" />
          <p class="text-sm text-tjb-gray-300 leading-relaxed">Birth education and planning tools — free for moms, Pro for doulas and midwives.</p>
        </div>
        <div>
          <p class="font-semibold text-white mb-4 tracking-wide text-sm uppercase">Resources</p>
          <ul class="text-sm space-y-2">
            <li><a href="/blog" class="hover:text-tjb-lavender-light transition">Blog</a></li>
            <li><a href="/birth-support" class="hover:text-tjb-lavender-light transition">Birth Support by City</a></li>
            <li><a href="/faq" class="hover:text-tjb-lavender-light transition">FAQ</a></li>
            <li><a href="/privacy" class="hover:text-tjb-lavender-light transition">Privacy</a></li>
            <li><a href="/terms" class="hover:text-tjb-lavender-light transition">Terms</a></li>
          </ul>
        </div>
        <div>
          <p class="font-semibold text-white mb-4 tracking-wide text-sm uppercase">Get the Free App</p>
          <p class="text-sm text-tjb-gray-300 mb-4 leading-relaxed">Build your birth plan, learn your options, and feel confident.</p>
          <div class="flex flex-wrap gap-3">
            <a href="https://apps.apple.com/app/true-joy-birthing" class="inline-block bg-tjb-lavender-500 text-white px-4 py-2 rounded-full text-xs font-semibold hover:bg-tjb-rose-500 transition">App Store</a>
            <a href="https://play.google.com/store/apps/details?id=com.truejoybirthing" class="inline-block bg-tjb-lavender-500 text-white px-4 py-2 rounded-full text-xs font-semibold hover:bg-tjb-rose-500 transition">Google Play</a>
          </div>
        </div>
      </div>
      <div class="border-t border-tjb-gray-200/20 max-w-6xl mx-auto px-6 py-5 text-xs text-tjb-gray-300">
        © {new Date().getFullYear()} True Joy Birthing. Built with intention.
        <span class="block mt-1">Not medical advice. Always consult your care provider.</span>
      </div>
    </footer>

    <script>
      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
