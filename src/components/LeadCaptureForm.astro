---
// Shared lead capture form — name + email → free PDF + guided app walkthrough.
// Used on every page that collects leads for the birth plan.
interface Props {
  heading?: string;
  body?: string;
  eyebrow?: string;
}
const {
  heading = 'Get Your Free Birth Plan',
  body = 'Enter your name and email and we\'ll send you the free fillable birth plan PDF plus a guided walkthrough in the app. No spam. Just the tools you need.',
  eyebrow = 'Free Download',
} = Astro.props;
---

<section id="download" class="bg-white border-y border-tjb-lavender-200/60 py-20 md:py-28">
  <div class="max-w-2xl mx-auto px-6 text-center">
    <p class="eyebrow mb-4">{eyebrow}</p>
    <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto mb-6"></div>
    <h2 class="mb-5 text-[2.25rem] md:text-[2.75rem] leading-[1.15]">{heading}</h2>
    <p class="text-tjb-gray mb-8 max-w-xl mx-auto leading-relaxed">{body}</p>

    <form id="lead-magnet-form" class="flex flex-col gap-3 max-w-lg mx-auto mb-4">
      <div class="flex flex-col sm:flex-row gap-3">
        <input
          id="lead-name"
          name="name"
          type="text"
          placeholder="Your first name"
          class="flex-1 px-5 py-3.5 rounded-full border border-tjb-lavender-300 focus:outline-none focus:border-tjb-rose-400 bg-white transition-colors text-[0.9375rem]"
          required
        />
        <input
          id="lead-email"
          name="email"
          type="email"
          placeholder="Your email"
          class="flex-1 px-5 py-3.5 rounded-full border border-tjb-lavender-300 focus:outline-none focus:border-tjb-rose-400 bg-white transition-colors text-[0.9375rem]"
          required
        />
      </div>
      <button type="submit" id="lead-submit" class="btn-primary whitespace-nowrap">
        Get the free PDF + app guide
      </button>
    </form>
    <p id="lead-status" class="text-xs hidden text-tjb-gray-300"></p>

    <!-- Success state -->
    <div id="lead-success" class="hidden">
      <p class="text-green-700 font-semibold mb-4">✓ Check your inbox: your birth plan is on its way.</p>
      <p class="text-tjb-gray mb-6">While you wait, get even more from the free app:</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6">
        <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="inline-flex items-center gap-2 text-tjb-lavender-600 font-semibold hover:text-tjb-lavender-700 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
          Get the free app: richer, updatable, shareable
        </a>
      </div>
    </div>

    <p class="text-xs text-tjb-gray-300 mt-2">No spam. Just your birth plan and occasional tips you can actually use.</p>

    <div class="mt-8 pt-6 border-t border-tjb-lavender-200/40">
      <p class="text-sm text-tjb-gray-400 mb-2">Prefer to skip the email?</p>
      <a href="/true-joy-birth-plan.pdf" download="true-joy-birth-plan.pdf" class="text-tjb-gray-400 hover:text-tjb-gray-300 text-sm border-b border-transparent hover:border-tjb-gray-300 transition-all inline-block pb-0.5">
        Download PDF directly
      </a>
    </div>
  </div>
</section>

<script>
  const leadForm = document.getElementById('lead-magnet-form') as HTMLFormElement;
  const leadStatus = document.getElementById('lead-status') as HTMLParagraphElement;
  const leadSuccess = document.getElementById('lead-success') as HTMLDivElement;
  const leadBtn = document.getElementById('lead-submit') as HTMLButtonElement;
  const leadName = document.getElementById('lead-name') as HTMLInputElement;
  const leadEmail = document.getElementById('lead-email') as HTMLInputElement;

  leadForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = leadName.value.trim();
    const email = leadEmail.value.trim();

    if (!email) return;

    leadBtn.disabled = true;
    leadBtn.textContent = 'Sending...';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: name || 'Lead Magnet', email, message: `Birth plan PDF request from: ${name || email}` }),
      });

      const data = await res.json();
      if (res.ok && data.success) {
        leadForm.classList.add('hidden');
        leadStatus.classList.add('hidden');
        leadSuccess.classList.remove('hidden');
        leadForm.reset();
      } else {
        leadStatus.textContent = 'Something went wrong. Please try again.';
        leadStatus.className = 'text-xs text-red-600 mt-2';
        leadStatus.classList.remove('hidden');
      }
    } catch {
      leadStatus.textContent = 'Network error. Please try again.';
      leadStatus.className = 'text-xs text-red-600 mt-2';
      leadStatus.classList.remove('hidden');
    } finally {
      leadBtn.disabled = false;
      leadBtn.textContent = 'Get the free PDF + app guide';
    }
  });
</script>