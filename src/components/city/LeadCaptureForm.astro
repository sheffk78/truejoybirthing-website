---
// City page lead capture — name + email → free PDF + app walkthrough.
// Email gate before PDF download, with a low-visibility bypass for accessibility.
interface Props {
  city?: string;
  class?: string;
}
const { city = '', class: wrapClass = '' } = Astro.props;
---

<section id="download-pdf" class={`bg-white border-y border-tjb-lavender-200/60 py-16 ${wrapClass}`}>
  <div class="max-w-2xl mx-auto px-6 text-center">
    <h2 class="text-2xl md:text-3xl font-bold mb-4">Get Your Free Birth Plan</h2>
    <p class="text-tjb-gray mb-8 max-w-xl mx-auto leading-relaxed">
      Enter your name and email and we'll send you the free fillable birth plan PDF plus a guided walkthrough in the app. No spam — just the tools you need.
    </p>

    <form id="city-lead-form" class="flex flex-col gap-3 max-w-lg mx-auto mb-4">
      <div class="flex flex-col sm:flex-row gap-3">
        <input
          id="city-lead-name"
          name="name"
          type="text"
          placeholder="Your first name"
          class="flex-1 px-5 py-3.5 rounded-full border border-tjb-lavender-300 focus:outline-none focus:border-tjb-rose-400 bg-white transition-colors text-[0.9375rem]"
          required
        />
        <input
          id="city-lead-email"
          name="email"
          type="email"
          placeholder="Your email"
          class="flex-1 px-5 py-3.5 rounded-full border border-tjb-lavender-300 focus:outline-none focus:border-tjb-rose-400 bg-white transition-colors text-[0.9375rem]"
          required
        />
      </div>
      <button type="submit" id="city-lead-submit" class="btn-primary whitespace-nowrap">
        Get the free PDF + app guide
      </button>
    </form>
    <p id="city-lead-status" class="text-xs hidden text-tjb-gray-300"></p>

    <!-- Success state -->
    <div id="city-lead-success" class="hidden">
      <p class="text-green-700 font-semibold mb-4">✓ Check your inbox — your birth plan is on its way.</p>
      <p class="text-tjb-gray mb-6">While you wait, get even more from the free app:</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6">
        <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="inline-flex items-center gap-2 text-tjb-lavender-600 font-semibold hover:text-tjb-lavender-700 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
          Get the free app — richer, updatable, shareable
        </a>
      </div>
    </div>

    <p class="text-xs text-tjb-gray-300 mt-2">No spam. Just your birth plan and occasional tips you can actually use.</p>

    <div class="mt-8 pt-6 border-t border-tjb-lavender-200/40">
      <p class="text-sm text-tjb-gray-400 mb-2">Prefer to skip the email?</p>
      <a href="/true-joy-birth-plan.pdf" download="true-joy-birth-plan.pdf" class="text-tjb-gray-400 hover:text-tjb-gray-300 text-sm border-b border-transparent hover:border-tjb-gray-300 transition-all inline-block pb-0.5">
        Download PDF directly
      </a>
    </div>
  </div>
</section>

<script>
  const cityForm = document.getElementById('city-lead-form') as HTMLFormElement;
  const cityStatus = document.getElementById('city-lead-status') as HTMLParagraphElement;
  const citySuccess = document.getElementById('city-lead-success') as HTMLDivElement;
  const cityBtn = document.getElementById('city-lead-submit') as HTMLButtonElement;
  const cityName = document.getElementById('city-lead-name') as HTMLInputElement;
  const cityEmail = document.getElementById('city-lead-email') as HTMLInputElement;

  cityForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = cityName.value.trim();
    const email = cityEmail.value.trim();

    if (!email) return;

    cityBtn.disabled = true;
    cityBtn.textContent = 'Sending...';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: name || 'City Lead', email, message: `Birth plan PDF request${name ? ' from: ' + name : ''} (city page)` }),
      });

      const data = await res.json();
      if (res.ok && data.success) {
        cityForm.classList.add('hidden');
        cityStatus.classList.add('hidden');
        citySuccess.classList.remove('hidden');
        cityForm.reset();
      } else {
        cityStatus.textContent = 'Something went wrong. Please try again.';
        cityStatus.className = 'text-xs text-red-600 mt-2';
        cityStatus.classList.remove('hidden');
      }
    } catch {
      cityStatus.textContent = 'Network error. Please try again.';
      cityStatus.className = 'text-xs text-red-600 mt-2';
      cityStatus.classList.remove('hidden');
    } finally {
      cityBtn.disabled = false;
      cityBtn.textContent = 'Get the free PDF + app guide';
    }
  });
</script>