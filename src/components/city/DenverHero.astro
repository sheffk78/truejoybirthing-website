---
interface Props {
  city: string;
  state: string;
  heroLocalDetail?: string;
}

const { city, state, heroLocalDetail } = Astro.props;
---

<section class="bg-tjb-cream">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row">
      <div class="md:w-[55%] px-6 md:px-12 py-16 md:py-20 flex flex-col justify-center">
        <p class="eyebrow mb-3">{city} Doula & Birth Support</p>
        <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
        <h1 class="font-bold text-tjb-charcoal leading-[1.15] mb-4" style="font-size: clamp(2.25rem, 5vw, 3.75rem);">
          {city} Doula — Costs, Hospitals & Medicaid Info
        </h1>
        <p class="text-lg text-tjb-charcoal font-semibold mb-3">
          You deserve to feel confident walking into your birth.
        </p>
        <p class="text-tjb-gray leading-relaxed mb-8 max-w-[36rem]">
          Doulas, midwives, hospital policies, and costs — broken down so you can walk in prepared. This guide covers what {city} moms actually need to know, from whether Medicaid covers a doula to which hospitals welcome birth partners.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center mb-3">
          <a href="/birth-plan-template/" class="btn-primary">
            Get Your Free Joyful Birth Plan
          </a>
          <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="btn-secondary">
            Or try the free app →
          </a>
        </div>
        <p class="text-sm text-tjb-gray">Free template · Prefer the app? Build the same joyful birth plan step by step on your phone.</p>
        {heroLocalDetail && (
          <p class="text-sm text-tjb-gray mt-6 italic border-l-2 border-tjb-lavender-300 pl-4" set:html={heroLocalDetail} />
        )}
      </div>
      <div class="md:w-[45%] flex items-center justify-center px-8 py-8 md:py-0">
        <div class="w-full max-w-md aspect-[3/4] rounded-xl shadow-md overflow-hidden">
          <img
            src="/images/denver-hero-front-range.webp"
            alt={`Denver birth support — pregnant woman with Colorado Front Range`}
            class="w-full h-full object-cover"
            width="900"
            height="1200"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </div>
</section>