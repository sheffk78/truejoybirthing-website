---
import { topicCities, stateNames, stateHubs } from '../data/city-links';
import { seededPick, seededPickOne } from '../utils/hash';

export interface Props {
  topic: string;
  limit?: number;
  showStateHubs?: boolean;
  stateHubsCount?: number;
  currentCitySlug?: string;
}

const { topic, limit = 15, showStateHubs = true, stateHubsCount = 4, currentCitySlug } = Astro.props;

// Get cities for this topic
const allCities = topicCities[topic] || topicCities['general'] || [];
const selectedCities = allCities.slice(0, limit);

// Group by state for rendering
const groupedByState: Record<string, typeof selectedCities> = {};
for (const city of selectedCities) {
  if (!groupedByState[city.state]) {
    groupedByState[city.state] = [];
  }
  groupedByState[city.state].push(city);
}

// Pick state hubs relevant to this topic's states
const topicStates = Object.keys(groupedByState);
const relevantHubs = stateHubs.filter(h => topicStates.some(s => h.slug.includes(`/${s}/`)));
const displayHubs = showStateHubs ? relevantHubs.slice(0, stateHubsCount) : [];

// Layout variant — deterministic by topic name
const variants = ['grid-2col', 'stacked', 'card-3col'] as const;
const variant = variants[topic.length % 3];
---

{
  variant === 'grid-2col' && (
    <section class="bg-tjb-cream-50 py-12 border-t border-tjb-lavender-200/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-2xl md:text-3xl font-bold text-tjb-charcoal mb-6">Birth Resources</h2>
        <div class="grid md:grid-cols-2 gap-4">
          {Object.entries(groupedByState).map(([stateCode, cities]) => (
            <div>
              <h3 class="font-semibold text-tjb-lavender-600 text-sm uppercase tracking-wide mb-2">
                {stateNames[stateCode] || stateCode.toUpperCase()}
              </h3>
              <ul class="space-y-1">
                {cities.map(city => (
                  <li>
                    <a
                      href={`/birth-support/${city.slug}/`}
                      class="text-tjb-rose-500 hover:text-tjb-rose-600 transition text-sm"
                    >Find a doula in {city.label}, {stateCode.toUpperCase()}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
          {displayHubs.length > 0 && (
            <div class="md:col-span-2 mt-4 pt-4 border-t border-tjb-lavender-300/30">
              <p class="text-sm text-tjb-gray">
                Explore more state resources: {displayHubs.map((hub, i) => (
                  <><a href={hub.slug} class="text-tjb-rose-500 hover:text-tjb-rose-600 transition font-semibold">{hub.label}</a>{i < displayHubs.length - 1 ? ' · ' : ''}</>
                ))}
              </p>
            </div>
          )}
        </div>
      </div>
    </section>
  )
}

{
  variant === 'stacked' && (
    <section class="bg-tjb-cream-50 py-12 border-t border-tjb-lavender-200/50">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-2xl md:text-3xl font-bold text-tjb-charcoal mb-6">Browse Birth Support by City</h2>
        {Object.entries(groupedByState).map(([stateCode, cities]) => (
          <div class="mb-6 last:mb-0">
            <h3 class="font-semibold text-tjb-lavender-600 mb-2">
              <a href={`/birth-support/${stateCode}/`} class="hover:text-tjb-rose-500 transition">
                {stateNames[stateCode] || stateCode.toUpperCase()}
              </a>
            </h3>
            <div class="flex flex-wrap gap-2">
              {cities.map(city => (
                <a
                  href={`/birth-support/${city.slug}/`}
                  class="inline-block px-3 py-1.5 bg-white rounded-full border border-tjb-lavender-200 text-sm text-tjb-charcoal hover:border-tjb-rose-400 hover:text-tjb-rose-500 transition"
                >{city.label}</a>
              ))}
            </div>
          </div>
        ))}
        {displayHubs.length > 0 && (
          <div class="mt-6 pt-4 border-t border-tjb-lavender-300/30">
            <p class="text-sm text-tjb-gray">
              Explore more: {displayHubs.map((hub, i) => (
                <><a href={hub.slug} class="text-tjb-rose-500 hover:text-tjb-rose-600 transition font-semibold">{hub.label}</a>{i < displayHubs.length - 1 ? ' · ' : ''}</>
              ))}
            </p>
          </div>
        )}
      </div>
    </section>
  )
}

{
  variant === 'card-3col' && (
    <section class="bg-tjb-cream-50 py-12 border-t border-tjb-lavender-200/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-2xl md:text-3xl font-bold text-tjb-charcoal mb-2">Local Birth Support Resources</h2>
        <p class="text-tjb-gray mb-8">Find doulas, hospitals, and birth support information for cities across the country.</p>
        <div class="grid md:grid-cols-3 gap-4">
          {Object.entries(groupedByState).slice(0, 2).map(([stateCode, cities]) => (
            <div class="bg-white rounded-xl p-5 border border-tjb-lavender-200">
              <h3 class="font-semibold text-tjb-lavender-600 text-sm uppercase tracking-wide mb-3">
                {stateNames[stateCode] || stateCode.toUpperCase()}
              </h3>
              <ul class="space-y-2">
                {cities.map(city => (
                  <li>
                    <a
                      href={`/birth-support/${city.slug}/`}
                      class="text-tjb-rose-500 hover:text-tjb-rose-600 transition text-sm"
                    >{city.label}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
          <div class="bg-tjb-lavender-50 rounded-xl p-5 border border-tjb-lavender-200">
            <h3 class="font-semibold text-tjb-lavender-600 text-sm uppercase tracking-wide mb-3">More States</h3>
            <ul class="space-y-1">
              {displayHubs.slice(0, 6).map(hub => (
                <li>
                  <a href={hub.slug} class="text-tjb-rose-500 hover:text-tjb-rose-600 transition text-sm">{hub.label}</a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  )
}