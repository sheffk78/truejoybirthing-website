---
import Layout from '../../layouts/Layout.astro';

const city = "McKinney";
const state = "TX";
const pageTitle = `Doula McKinney TX — Birth Support, Costs & Free Joyful Birth Plan`;
const pageDesc = `Find a doula in McKinney, TX — local hospital info, doula costs, Medicaid status, and the free Joyful Birth Plan for local families.`;
const pageUrl = `https://truejoybirthing.com/birth-support/mckinney-tx`;

const hospitals = ['Baylor Scott & White McKinney', 'Medical City McKinney'];
const birthCenters = ['Arise Birth Center'];
const costLow = 950;
const costHigh = 2700;
const medicaidNote = "Texas Medicaid's doula benefit is expanding statewide. As of 2026, doula services may be reimbursable in the McKinney area. Confirm with your Medicaid plan.";
const insuranceNote = "Some private insurers in the McKinney area now cover doula support as part of maternal wellness benefits. Contact your plan for details.";
const culture = "McKinney is one of the fastest-growing suburbs in North Texas, with a mix of established neighborhoods and new development. Families here tend to plan ahead and value detailed preparation — which makes birth planning especially relevant. The Collin County birth community is active and welcoming.";
const shelbiServesHere = true;

const faqs = [
  { q: "Does Medicaid cover doulas in McKinney?", a: "Texas is expanding Medicaid doula coverage statewide. Specific eligibility depends on your plan. Contact your Texas Medicaid managed care provider for current benefits in the McKinney area." },
  { q: "Which hospitals in McKinney accommodate birth plans?", a: "Baylor Scott & White McKinney and other area facilities generally accommodate birth plans, but policies vary. Always confirm your hospital's policy during your hospital tour." },
  { q: "How much does a doula cost in McKinney?", a: "$950 to $2,700 depending on experience and package. Doula services are often considered worthwhile by families who want continuous support through labor and delivery." },
  { q: "Does True Joy Birthing work with McKinney families?", a: "Shelbi is based in the DFW metro and can support McKinney-area families with virtual birth plan sessions. The free app and birth plan work for any McKinney hospital. the free birth plan course to prepare step by step." }
];
const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "Birth Support", "url": "https://truejoybirthing.com/birth-support/"}, {"name": "McKinney, TX", "url": "https://truejoybirthing.com/birth-support/mckinney-tx"}];
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "@id": "https://truejoybirthing.com/birth-support/mckinney-tx#faq",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    },
    {
      "@type": "LocalBusiness",
      "@id": "https://truejoybirthing.com/birth-support/mckinney-tx#local",
      "name": "True Joy Birthing",
      "url": "https://truejoybirthing.com/birth-support/mckinney-tx",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "McKinney",
        "addressRegion": "TX",
        "addressCountry": "US"
      },
      "areaServed": { "@type": "City", "name": "McKinney" },
      "parentOrganization": { "@id": "https://truejoybirthing.com/#organization" }
    }
  ]
};

---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}

  breadcrumbList={breadcrumbList}
  schema={schema}
>

  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div>
          <h1 class="text-3xl md:text-4xl font-bold mb-4">Find a Doula in McKinney, TX</h1>
          <p class="text-lg text-tjb-gray mb-6">
        If you're <a href="/what-is-a-doula/">looking for a doula</a> in McKinney, TX, this guide covers local hospital options, doula costs, Medicaid status, and the free Joyful Birth Plan families trust here.
      </p>
      <p class="text-tjb-gray mb-4">McKinney families delivering at Baylor Scott & White on Lake Forest Drive — US-75 construction has been a constant, and if you're coming from the west side of town, the detour routes add real time when you're not in any mood for surprises. Towne Lake's walking loop is where a lot of McKinney moms head for third-trimester evenings — the path around the lake is flat, well-lit, and close enough to both hospitals that you're not far if things start picking up.</p>
          <div class="flex flex-col sm:flex-row gap-3">
        <a href="#download-pdf" class="bg-tjb-lavender-500 text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-rose-500 transition">
          Download Free Birth Plan</a>
        <a href="https://apps.apple.com/app/true-joy-birthing" class="bg-tjb-cream-50 text-tjb-lavender-500 border-2 border-tjb-lavender-500 px-6 py-3 rounded-lg font-semibold hover:bg-tjb-cream transition">
          Get the Free App</a>
      </div>
        </div>
        <div class="relative">
          <img
            src="/images/mckinney-texas-birth-doula-skyline.webp"
            alt="Skyline of McKinney, Texas, where families search for birth doulas and plan their hospital births."
            class="w-full h-64 md:h-80 object-cover rounded-2xl shadow-lg"
            width="1200"
            height="800"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">

      <h2>What Birth Support Looks Like in McKinney</h2>
      <p>McKinney is one of the fastest-growing suburbs in North Texas, with a mix of established neighborhoods and new development. Families here tend to plan ahead and value detailed preparation — which makes birth planning especially relevant. The Collin County birth community is active and welcoming.</p>
      <p>Whether this is your first baby or you're preparing for a VBAC, <a href="/benefits-of-a-doula/">understanding the benefits of having a doula</a> can help you decide what support is right for your McKinney birth.</p>

      

      <p>Baylor Scott &amp; White McKinney, in the US-75/Lake Forest area, has scaled up fast alongside the city's growth with a Level III NICU and a strong obstetric program. It handles a high volume of births and they're used to working with informed families — bring your birth plan and they'll work with it. <a href="/birth-plan-template/">Use our free hospital birth plan template</a> to get started.</p>

      <p>Medical City McKinney, also serving northern Collin County, has a Level III NICU and a solid obstetric program. McKinney families are well-served by both hospitals — but both are busy, especially during peak delivery times. If we're being real, knowing your preferences before you're in labor beats figuring them out on the spot.</p>

      <p>Arise Birth Center is a freestanding, midwife-led birth center in the McKinney area offering a lower-intervention setting for low-risk pregnancies. It's a good option if you want a birth center experience close to home — and having a doula who knows the rhythm of that space makes it feel a lot less unknown.</p>

      <p class="text-sm text-tjb-gray italic">Hospitals and birth centers mentioned for context only. True Joy Birthing does not endorse any specific provider. Always confirm visitor and doula policies during your hospital tour.</p>


      

      <h2>Doula Costs in McKinney</h2>
      <p>In the McKinney area, doula services typically range from <strong>$950 to $2,700</strong> depending on:</p>
      <ul>
        <li>Experience and certifications (DONA, CAPPA, etc.)</li>
        <li>Package inclusions (prenatal visits, on-call period, postpartum check-ins)</li>
        <li>Whether the doula serves a wide area or focuses specifically on McKinney</li>
      </ul>

      <h2>Medicaid & Insurance Coverage</h2>
      <p>{medicaidNote}</p>
      <p>{insuranceNote}</p>
      <p><strong>HSA/FSA:</strong> Many families don't realize that doula services can often be paid for with HSA or FSA funds, since birth support qualifies as a medical expense under most plans. Check with your plan administrator to confirm what's eligible and whether you need a letter from your provider.</p>
      <p>Not sure what to look for? <a href="/how-to-choose-a-doula/">Here's how to choose a doula</a> who fits your birth preferences and budget.</p>
      


      <h2>Virtual Birth Plan Support for McKinney</h2>
      <p>Shelbi offers virtual 1:1 birth plan sessions for McKinney-area families. Whether you're delivering at Baylor Scott & White McKinney or planning a home birth, the session walks through your plan line by line — with the words to use when you want to slow things down or ask questions.</p>
      <div class="my-6 not-prose">
        <a href="/birth-plan-session" class="btn-accent inline-block">Book a 1:1 Session</a>
      <p class="text-sm text-tjb-gray mt-2">Or <a href="/birth-plan-course/">take the free birth plan course</a> to prepare step by step.</p>
      </div>

      <h2>Free Birth Plan for McKinney Families</h2>
      <p>Download the same birth plan template McKinney families use to prepare for hospital conversations — free, structured, and designed to be read by a nurse in two minutes. Then use the <a href="/birth-plan-checklist/">birth plan checklist</a> to make sure nothing gets missed.</p>
      <div class="my-8 not-prose">
        <a href="#download" class="btn-primary inline-block">Download Free Birth Plan</a>
      </div>

    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-tjb-cream-50">
    <div class="max-w-3xl mx-auto px-6">
      
      <div class="bg-white border-2 border-tjb-lavender-200 p-5 rounded-lg mb-6">
        <h3 class="font-semibold text-lg text-tjb-charcoal mb-2">What True Joy Birthing Actually Does for You</h3>
        <p class="text-tjb-gray mb-2">True Joy Birthing isn't a doula matching service, and we're not necessarily your in-person doula in McKinney. We're the step before — and alongside — all of that.</p>
        <p class="text-tjb-gray mb-2">Shelbi built the free Joyful Birth Plan because she saw families show up to the hospital without their preferences written down, every single time. The birth plan template, the checklist, the free course — these are the tools that help you walk in prepared, whether you end up hiring a local doula or going it alone.</p>
        <p class="text-tjb-gray">If you do find a doula in McKinney, great — bring your plan and use it together. If you're still looking, or if hiring a doula isn't in the budget right now, the birth plan is free and it works.</p>
      </div>

      <h2 class="text-2xl font-bold mb-8">Frequently Asked Questions — McKinney</h2>
      <div class="space-y-6">
        {faqs.map((faq, i) => (
          <div class="border border-tjb-lavender-200 rounded-lg p-5 bg-white">
            <h3 class="text-lg font-semibold mb-2">{faq.q}</h3>
            <p class="text-tjb-gray">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA band -->
  <section id="download-pdf" class="bg-tjb-lavender-100 py-16">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Get Your Free Birth Plan</h2>
      <p class="text-tjb-gray mb-8">Join families in McKinney and across Texas who walk into their births with a clear plan and the words to stand by it. <a href="/doula-cost/">See doula costs across Texas</a>.</p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto mb-4" action="#" method="POST">
        <input name="email" type="email" placeholder="Your email" class="flex-1 px-5 py-3.5 rounded-full border border-tjb-lavender-300 focus:outline-none focus:border-tjb-rose-400 bg-white text-[0.9375rem]" required />
        <button type="submit" class="btn-primary whitespace-nowrap">Get My Plan →</button>
      </form>
      <p class="text-xs text-tjb-gray-300">No spam. Just a free birth plan and occasional tips you can actually use.</p>
    </div>
  </section>

</Layout>
