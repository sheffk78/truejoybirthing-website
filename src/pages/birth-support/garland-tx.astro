---
import Layout from '../../layouts/Layout.astro';

const city = "Garland";
const state = "TX";
const pageTitle = `Birth Support in ${city}, ${state}`;
const pageDesc = `Find birth support resources in Garland, TX — local hospital info, doula costs, Medicaid status, and a free birth plan built for local families.`;
const pageUrl = `https://truejoybirthing.com/birth-support/garland-tx`;

const hospitals = ['Baylor Scott & White Garland'];
const birthCenters = [];
const costLow = 800;
const costHigh = 2400;
const medicaidNote = "Texas Medicaid's doula benefit is expanding statewide. As of 2026, doula services may be reimbursable in the Garland area. Confirm with your Medicaid plan.";
const insuranceNote = "Some private insurers in the Garland area now cover doula support as part of maternal wellness benefits. Contact your plan for details.";
const culture = "Garland is a large, established suburb northeast of Dallas with a working-class and family-oriented population. The city has one main hospital system but strong community birth support through independent doulas and midwives. Many Garland families seek out virtual birth planning support to supplement local resources.";
const shelbiServesHere = true;

const faqs = [
  { q: "Does Medicaid cover doulas in Garland?", a: "Texas is expanding Medicaid doula coverage statewide. Specific eligibility depends on your plan. Contact your Texas Medicaid managed care provider for current benefits in the Garland area." },
  { q: "Which hospitals in Garland accommodate birth plans?", a: "Baylor Scott & White Garland and other area facilities generally accommodate birth plans, but policies vary. Always confirm your hospital's policy during your hospital tour." },
  { q: "How much does a doula cost in Garland?", a: "$800 to $2,400 depending on experience and package. Doula services are often considered worthwhile by families who want continuous support through labor and delivery." },
  { q: "Does True Joy Birthing work with Garland families?", a: "Shelbi is based in the DFW metro and can support Garland-area families with virtual birth plan sessions. The free app and birth plan work for any Garland hospital." }
];
---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}
>

  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-4xl mx-auto px-6">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">Birth Support in Garland, TX</h1>
      <p class="text-lg text-tjb-gray mb-6">
        Local hospital options, doula costs, and Medicaid status — plus the free birth plan template families in Garland use to feel confident and prepared.
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="#download-pdf" class="bg-tjb-lavender-500 text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-rose-500 transition">
          Download Free Birth Plan</a>
        <a href="https://apps.apple.com/app/true-joy-birthing" class="bg-tjb-cream-50 text-tjb-lavender-500 border-2 border-tjb-lavender-500 px-6 py-3 rounded-lg font-semibold hover:bg-tjb-cream transition">
          Get the Free App</a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">

      <h2>What Birth Support Looks Like in Garland</h2>
      <p>Garland is a large, established suburb northeast of Dallas with a working-class and family-oriented population. The city has one main hospital system but strong community birth support through independent doulas and midwives. Many Garland families seek out virtual birth planning support to supplement local resources.</p>

      <p>Families in Garland often deliver at hospitals including:</p>
      <ul>
        <li>Baylor Scott & White Garland</li>
      </ul>
      <p class="text-sm text-tjb-gray italic">Hospitals mentioned for context only. True Joy Birthing does not endorse any specific provider.</p>



      <h2>Doula Costs in Garland</h2>
      <p>In the Garland area, doula services typically range from <strong>$800 to $2,400</strong> depending on:</p>
      <ul>
        <li>Experience and certifications (DONA, CAPPA, etc.)</li>
        <li>Package inclusions (prenatal visits, on-call period, postpartum check-ins)</li>
        <li>Whether the doula serves a wide area or focuses specifically on Garland</li>
      </ul>

      <h2>Medicaid & Insurance Coverage</h2>
      <p>{medicaidNote}</p>
      <p>{insuranceNote}</p>


      <h2>Virtual Birth Plan Support for Garland</h2>
      <p>Shelbi offers virtual 1:1 birth plan sessions for Garland-area families. Whether you're delivering at Baylor Scott & White Garland or planning a home birth, the session walks through your plan line by line — with the words to use when you want to slow things down or ask questions.</p>
      <div class="my-6 not-prose">
        <a href="/birth-plan-session" class="btn-accent inline-block">Book a 1:1 Session</a>
      </div>

      <h2>Free Birth Plan for Garland Families</h2>
      <p>Download the same birth plan template Garland families use to prepare for hospital conversations — free, structured, and designed to be read by a nurse in two minutes.</p>
      <div class="my-8 not-prose">
        <a href="#download" class="btn-primary inline-block">Download Free Birth Plan</a>
      </div>

    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-tjb-cream-50">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-2xl font-bold mb-8">Frequently Asked Questions — Garland</h2>
      <div class="space-y-6">
        {faqs.map((faq, i) => (
          <div class="border border-tjb-lavender-200 rounded-lg p-5 bg-white">
            <h3 class="text-lg font-semibold mb-2">{faq.q}</h3>
            <p class="text-tjb-gray">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA band -->
  <section id="download-pdf" class="bg-tjb-lavender-100 py-16">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Get Your Free Birth Plan</h2>
      <p class="text-tjb-gray mb-8">Join families in Garland and across Texas who walk into their births with a clear plan and the words to stand by it.</p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto mb-4" action="#" method="POST">
        <input name="email" type="email" placeholder="Your email" class="flex-1 px-5 py-3.5 rounded-full border border-tjb-lavender-300 focus:outline-none focus:border-tjb-rose-400 bg-white text-[0.9375rem]" required />
        <button type="submit" class="btn-primary whitespace-nowrap">Get My Plan →</button>
      </form>
      <p class="text-xs text-tjb-gray-300">No spam. Just a free birth plan and occasional tips you can actually use.</p>
    </div>
  </section>

</Layout>
