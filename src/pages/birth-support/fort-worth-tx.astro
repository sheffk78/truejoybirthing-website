---
import Layout from '../../layouts/Layout.astro';

const city = "Fort Worth";
const state = "TX";
const pageTitle = `Doula Fort Worth TX — Birth Support, Costs & Free Joyful Birth Plan`;
const pageDesc = `Find a doula in Fort Worth, TX — local hospital info, doula costs, Medicaid status, and the free Joyful Birth Plan for local families.`;
const pageUrl = `https://truejoybirthing.com/birth-support/fort-worth-tx`;

const hospitals = ["Texas Health Harris Methodist Hospital", "Cook Children's Medical Center", "JPS Health Network"];
const birthCenters = ["Fort Worth Birth Center"];
const costLow = 850;
const costHigh = 2400;
const medicaidNote = "Texas Medicaid doula benefits are expanding. In the Fort Worth area, check your Tarrant County or surrounding-area Medicaid plan for current doula coverage.";
const insuranceNote = "Some Fort Worth-area insurers offer maternal wellness benefits that include doula coverage. Contact your insurance representative to confirm.";
const culture = "Fort Worth blends a western heritage with a growing, modern healthcare scene. The city has strong hospital systems and an emerging birth center community. Fort Worth families often value both tradition and informed, empowered birth experiences.";
const shelbiServesHere = true;

const faqs = [
  { q: "Does True Joy Birthing serve Fort Worth families in person?", a: "Fort Worth is within Shelbi's DFW service area. In-person doula support may be available depending on availability. Virtual confidence sessions are always available." },
  { q: "How much does a doula cost in Fort Worth?", a: "$850 to $2,400. The Fort Worth market is generally more affordable than Dallas proper, with many experienced doulas serving both sides of the metro." },
  { q: "What hospitals do Fort Worth families use?", a: "Texas Health Harris Methodist Fort Worth is a major option. Cook Children's serves families needing NICU or pediatric support. JPS Health Network serves diverse communities across Tarrant County." },
  { q: "Does Medicaid cover doulas in Fort Worth?", a: "Texas' Medicaid doula expansion is statewide. Contact your Tarrant County or surrounding Medicaid plan to confirm current coverage status." }
];
const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "Birth Support", "url": "https://truejoybirthing.com/birth-support/"}, {"name": "Fort Worth, TX", "url": "https://truejoybirthing.com/birth-support/fort-worth-tx"}];
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "@id": "https://truejoybirthing.com/birth-support/fort-worth-tx#faq",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    },
    {
      "@type": "LocalBusiness",
      "@id": "https://truejoybirthing.com/birth-support/fort-worth-tx#local",
      "name": "True Joy Birthing",
      "url": "https://truejoybirthing.com/birth-support/fort-worth-tx",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Fort Worth",
        "addressRegion": "TX",
        "addressCountry": "US"
      },
      "areaServed": { "@type": "City", "name": "Fort Worth" },
      "parentOrganization": { "@id": "https://truejoybirthing.com/#organization" }
    }
  ]
};

---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}

  breadcrumbList={breadcrumbList}
  schema={schema}
>

  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div>
          <h1 class="text-3xl md:text-4xl font-bold mb-4">Find a Doula in Fort Worth, TX</h1>
          <p class="text-lg text-tjb-gray mb-6">
        If you're <a href="/what-is-a-doula/">looking for a doula</a> in Fort Worth, TX, this guide covers local hospital options, doula costs, Medicaid status, and the free Joyful Birth Plan families trust here.
      </p>
      <p class="text-tjb-gray mb-4">Texas Health Harris Methodist is right off University Drive downtown, and during TCU game days that whole area around the hospital gridlocks — if you're due in the fall, have your backup route mapped out before you need it. Clear Creek's walking trails up in Heritage Park are a quiet, shaded go-to for third-trimester walks — flat enough to be comfortable and close enough to the hospital district that you're not stranded if something picks up.</p>
          <div class="flex flex-col sm:flex-row gap-3">
        <a href="#download-pdf" class="bg-tjb-lavender-500 text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-rose-500 transition">Download Free Birth Plan</a>
        <a href="https://apps.apple.com/app/true-joy-birthing" class="bg-tjb-cream-50 text-tjb-lavender-500 border-2 border-tjb-lavender-500 px-6 py-3 rounded-lg font-semibold hover:bg-tjb-cream transition">Get the Free App</a>
      </div>
        </div>
        <div class="relative">
          <img
            src="/images/fort-worth-texas-birth-doula-skyline.webp"
            alt="Skyline of Fort Worth, Texas, where families search for birth doulas and plan their hospital births."
            class="w-full h-64 md:h-80 object-cover rounded-2xl shadow-lg"
            width="1200"
            height="800"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">

      <h2>What Birth Support Looks Like in Fort Worth</h2>
      <p>Fort Worth blends a western heritage with a growing, modern healthcare scene. The city has strong hospital systems and an emerging birth center community. Fort Worth families often value both tradition and informed, empowered birth experiences.</p>
      <p>Whether this is your first baby or you're preparing for a VBAC, <a href="/benefits-of-a-doula/">understanding the benefits of having a doula</a> can help you decide what support is right for your Fort Worth birth.</p>

      

      <p>Texas Health Harris Methodist Hospital, in downtown Fort Worth, is one of the busiest hospitals in Tarrant County with a Level III NICU and a high-volume L&amp;D unit. Doulas are generally welcome — they handle a huge volume of births and they've seen every kind of birth plan. Bring yours and they'll work with it. <a href="/birth-plan-template/">Use our free hospital birth plan template</a> to get started.</p>

      <p>Cook Children's Medical Center, just north of downtown, provides Level IV NICU care alongside the labor and delivery services at Cook Women's. JPS Health Network, Tarrant County's public hospital, handles more Medicaid births than almost anyone in the region — the care teams there know how to work with informed, prepared families, so bring your plan. If we're being real, delivering at JPS means walking into a very busy public hospital, and your birth plan is your voice in that room.</p>

      <p>Fort Worth Birth Center is a freestanding, midwife-led birth center for families seeking a lower-intervention setting. It's a good option for low-risk pregnancies — and having a doula who knows the birth center space makes the whole experience feel more supported.</p>

      <p class="text-sm text-tjb-gray italic">Hospitals and birth centers mentioned for context only. True Joy Birthing does not endorse any specific provider. Always confirm visitor and doula policies during your hospital tour.</p>

      <h2>How Much Does a Doula Cost in Fort Worth?</h2>
      <p>In Fort Worth, birth doula services typically range from <strong>$850 to $2,400</strong> depending on experience, package, and whether the doula offers add-on services like <a href="/postpartum-doula/">postpartum visits</a>. <a href="/doula-cost/">See our full doula cost guide</a> for what's typically included.</p>
      <p>Some Fort Worth-area insurers offer maternal wellness benefits that include doula coverage. Contact your insurance representative to confirm.</p>
      <p><strong>HSA/FSA:</strong> Many families don't realize that doula services can often be paid for with HSA or FSA funds, since birth support qualifies as a medical expense under most plans. Check with your plan administrator to confirm what's eligible and whether you need a letter from your provider.</p>
      <p>Not sure what to look for? <a href="/how-to-choose-a-doula/">Here's how to choose a doula</a> who fits your birth preferences and budget.</p>
      <p><strong>Medicaid Note:</strong> Texas Medicaid doula benefits are expanding. In the Fort Worth area, check your Tarrant County or surrounding-area Medicaid plan for current doula coverage.</p>

      <h2>Next Steps: Your Doula in Fort Worth, TX — Plan Your Birth</h2>
      <p>No matter where you deliver in Fort Worth, a clear, organized birth plan helps you communicate your preferences to the team in your birth room. Start with the <a href="/birth-plan-template/">free birth plan template</a>, then use the <a href="/birth-plan-checklist/">birth plan checklist</a> to make sure nothing gets missed.</p>
      <a href="#download-pdf" class="inline-block bg-tjb-lavender-500 text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-rose-500 transition mb-6">Download the Free Birth Plan</a>
      <p class="mt-2 text-sm text-tjb-gray">Or <a href="/birth-plan-course/">take the free birth plan course</a> step by step.</p>

      <div class="bg-tjb-cream p-4 rounded-lg mb-6">
        <p class="font-semibold text-tjb-lavender-500 mb-1">Shelbi serves local families in the Fort Worth area.</p>
        <p class="text-sm text-tjb-gray">Virtual confidence sessions are also available for families in Fort Worth. the free birth plan course to prepare step by step.</p>
        <a href="/birth-plan-session" class="text-tjb-lavender-500 font-semibold text-sm hover:underline">Book a session →</a>
      </div>

      
      <div class="bg-white border-2 border-tjb-lavender-200 p-5 rounded-lg mb-6">
        <h3 class="font-semibold text-lg text-tjb-charcoal mb-2">What True Joy Birthing Actually Does for You</h3>
        <p class="text-tjb-gray mb-2">True Joy Birthing isn't a doula matching service, and we're not necessarily your in-person doula in Fort Worth. We're the step before — and alongside — all of that.</p>
        <p class="text-tjb-gray mb-2">Shelbi built the free Joyful Birth Plan because she saw families show up to the hospital without their preferences written down, every single time. The birth plan template, the checklist, the free course — these are the tools that help you walk in prepared, whether you end up hiring a local doula or going it alone.</p>
        <p class="text-tjb-gray">If you do find a doula in Fort Worth, great — bring your plan and use it together. If you're still looking, or if hiring a doula isn't in the budget right now, the birth plan is free and it works.</p>
      </div>

      <h2>Common Questions in Fort Worth</h2>
      <div class="space-y-4">
        <div>
          <h3 class="font-semibold mb-1">Does True Joy Birthing serve Fort Worth families in person?</h3>
          <p class="text-tjb-gray">Fort Worth is within Shelbi's DFW service area. In-person doula support may be available depending on availability. Virtual confidence sessions are always available.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">How much does a doula cost in Fort Worth?</h3>
          <p class="text-tjb-gray">$850 to $2,400. The Fort Worth market is generally more affordable than Dallas proper, with many experienced doulas serving both sides of the metro.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">What hospitals do Fort Worth families use?</h3>
          <p class="text-tjb-gray">Texas Health Harris Methodist Fort Worth is a major option. Cook Children's serves families needing NICU or pediatric support. JPS Health Network serves diverse communities across Tarrant County.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">Does Medicaid cover doulas in Fort Worth?</h3>
          <p class="text-tjb-gray">Texas' Medicaid doula expansion is statewide. Contact your Tarrant County or surrounding Medicaid plan to confirm current coverage status.</p>
        </div>
      </div>

      <h2>Nearby Resources</h2>
      <a href="/birth-support" class="text-tjb-lavender-500 font-semibold hover:underline">See all cities →</a>

    </div>
  </section>

  <section id="download-pdf" class="py-16 bg-tjb-cream">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Get Your Free Joyful Birth Plan</h2>
      <p class="text-tjb-gray mb-8">Built by a doula for Fort Worth-area moms planning their birth.</p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" action="#" method="POST">
        <input name="email" type="email" placeholder="Your email" class="flex-1 px-4 py-3 rounded-lg border border-tjb-lavender-300 focus:outline-none focus:border-tjb-lavender-500" required />
        <button type="submit" class="bg-tjb-lavender-500 text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-rose-500 transition whitespace-nowrap">Get My Plan →</button>
      </form>
      <p class="text-xs text-tjb-gray/70 mt-4">No spam. Just a free birth plan and occasional tips you can actually use.</p>
    </div>
  </section>

</Layout>
