---
import Layout from '../../layouts/Layout.astro';
import { cities, citySlugs } from '../../data/cities';

const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "Birth Support", "url": "https://truejoybirthing.com/birth-support/"}];

// Group cities by state, sorted by count
const stateGroups: Record<string, { name: string; slug: string }[]> = {};
for (const slug of citySlugs) {
  const city = cities[slug];
  if (!city) continue;
  if (!stateGroups[city.state]) stateGroups[city.state] = [];
  stateGroups[city.state].push({ name: city.city, slug: city.slug });
}
// Sort state codes alphabetically, with TX first (largest group)
const stateOrder = Object.keys(stateGroups).sort((a, b) => {
  if (a === 'TX') return -1;
  if (b === 'TX') return 1;
  return a.localeCompare(b);
});
const stateNames: Record<string, string> = {
  AK: 'Alaska', AL: 'Alabama', AR: 'Arkansas', AZ: 'Arizona',
  CA: 'California', CO: 'Colorado', CT: 'Connecticut',
  DE: 'Delaware', FL: 'Florida', GA: 'Georgia',
  HI: 'Hawaii', IA: 'Iowa', ID: 'Idaho', IL: 'Illinois',
  IN: 'Indiana', KS: 'Kansas', KY: 'Kentucky',
  LA: 'Louisiana', MA: 'Massachusetts', MD: 'Maryland',
  MI: 'Michigan', MN: 'Minnesota', MO: 'Missouri', MS: 'Mississippi',
  MT: 'Montana', NC: 'North Carolina', ND: 'North Dakota',
  NE: 'Nebraska', NH: 'New Hampshire', NJ: 'New Jersey',
  NM: 'New Mexico', NV: 'Nevada', NY: 'New York',
  OH: 'Ohio', OK: 'Oklahoma', OR: 'Oregon',
  PA: 'Pennsylvania', RI: 'Rhode Island',
  SC: 'South Carolina', SD: 'South Dakota',
  TN: 'Tennessee', TX: 'Texas',
  UT: 'Utah', VA: 'Virginia', VT: 'Vermont',
  WA: 'Washington', WI: 'Wisconsin', WV: 'West Virginia',
  WY: 'Wyoming',
};
const totalCities = citySlugs.length;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": "https://truejoybirthing.com/birth-support/#collection",
      "name": "Birth Support by City — Doula Costs, Hospital Info & Joyful Birth Plans",
      "description": `Find local birth support resources in ${totalCities} cities — hospital info, doula costs, Medicaid coverage, and free birth planning tools, organized city by city across the US.`,
      "url": "https://truejoybirthing.com/birth-support/",
      "about": { "@id": "https://truejoybirthing.com/#organization" },
      "mainEntity": {
        "@type": "ItemList",
        "itemListElement": citySlugs.slice(0, 50).map((slug, i) => {
          const city = cities[slug];
          return {
            "@type": "ListItem",
            "position": i + 1,
            "name": `Birth Support in ${city?.city}, ${city?.state}`,
            "url": `https://truejoybirthing.com/birth-support/${slug}/`
          };
        })
      }
    }
  ]
};
---

<Layout
  title="Birth Support by City: Costs and Hospitals"
  description={`Find birth support resources in ${totalCities} cities — hospital info, doula costs, Medicaid coverage, and free birth planning tools, organized by state.`}
  canonical="https://truejoybirthing.com/birth-support/"
  breadcrumbList={breadcrumbList}
  schema={schema}
>
  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">Birth Support in {totalCities} Cities</h1>
      <p class="text-lg text-tjb-gray"><strong>Birth support</strong> is the network of people, tools, and information you rely on during pregnancy, labor, and postpartum — from doulas and hospital policies to birth plans and Medicaid coverage. Find resources for your city below.</p>
      <div class="mt-6 flex flex-wrap justify-center gap-3 text-sm">
        <a href="/what-is-a-doula/" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full border border-tjb-lavender-300 text-tjb-lavender-600 hover:bg-tjb-lavender-50 transition font-medium">What Is a Doula?</a>
        <a href="/benefits-of-a-doula/" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full border border-tjb-lavender-300 text-tjb-lavender-600 hover:bg-tjb-lavender-50 transition font-medium">Benefits of a Doula</a>
        <a href="/birth-plan-template/" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full border border-tjb-rose-400 text-tjb-rose-500 hover:bg-tjb-rose-50 transition font-medium">Free Birth Plan →</a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-6">

      <!-- Search all cities -->
      <div class="max-w-lg mx-auto mb-10">
        <div class="relative">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-tjb-gray-300 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="text"
            id="city-search"
            placeholder="Search your city or area..."
            class="w-full pl-11 pr-4 py-3 rounded-full border border-tjb-lavender-300 focus:outline-none focus:border-tjb-rose-400 bg-white transition-colors text-sm text-tjb-charcoal"
          />
        </div>
        <p id="city-search-status" class="text-center text-sm text-tjb-gray mt-3" style="display:none"></p>
      </div>

      <div id="city-directory">
      {stateOrder.map((stateCode) => {
        const stateCities = stateGroups[stateCode];
        const stateName = stateNames[stateCode] || stateCode;
        const stateSlug = stateCode.toLowerCase();
        return (
          <div class="mb-10 city-state-group">
            <h2 class="text-xl font-semibold mb-4">
              <a href={`/birth-support/${stateSlug}/`} class="hover:text-tjb-rose-500 transition">{stateName}</a>
              <span class="text-tjb-gray font-normal text-base ml-1">({stateCities.length} {stateCities.length === 1 ? 'city' : 'cities'})</span>
            </h2>
            <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
              {stateCities.map((c) => (
                <a href={`/birth-support/${c.slug}/`} class="border border-tjb-lavender-300 p-3 rounded-lg hover:border-tjb-lavender-500 hover:bg-tjb-lavender-50 transition text-sm font-medium text-tjb-charcoal city-link">
                  {c.name}, {stateCode}
                </a>
              ))}
            </div>
          </div>
        );
      })}
      </div>
  </section>

  <section class="py-12 bg-tjb-cream text-center">
    <h2 class="text-xl font-semibold mb-4">Don't see your city?</h2>
    <p class="text-tjb-gray mb-4">The free Joyful Birth Plan works anywhere — and we're adding new cities regularly. Download your plan and build it for your specific birth setting.</p>
    <a href="/birth-plan-template/" class="inline-block bg-tjb-lavender-600 text-white px-6 py-3 rounded-full font-semibold hover:bg-tjb-rose-500 focus-visible:outline focus-visible:outline-3 focus-visible:outline-tjb-lavender-400 focus-visible:outline-offset-2 active:translate-y-0 transition">Get Your Free Joyful Birth Plan</a>
  </section>

</Layout>

<script>
  const searchInput = document.getElementById('city-search');
  const statusEl = document.getElementById('city-search-status');
  const groups = document.querySelectorAll('.city-state-group');
  if (searchInput) {
    const allLinks = document.querySelectorAll('.city-link');
    searchInput.addEventListener('input', () => {
      const q = searchInput.value.toLowerCase().trim();
      let totalVisible = 0;
      allLinks.forEach(link => {
        const match = !q || link.textContent.toLowerCase().includes(q);
        link.style.display = match ? '' : 'none';
        if (match) totalVisible++;
      });
      groups.forEach(g => {
        const visible = Array.from(g.querySelectorAll('.city-link')).some(l => l.style.display !== 'none');
        g.style.display = visible ? '' : 'none';
        const heading = g.querySelector('h2');
        if (heading) heading.style.display = visible ? '' : 'none';
      });
      if (statusEl) {
        if (q && totalVisible === 0) {
          statusEl.textContent = 'We don\'t have that city yet — check back, we add new cities regularly.';
          statusEl.style.display = '';
        } else if (q) {
          statusEl.textContent = totalVisible + ' cit' + (totalVisible === 1 ? 'y' : 'ies') + ' found';
          statusEl.style.display = '';
        } else {
          statusEl.style.display = 'none';
        }
      }
    });
  }
</script>