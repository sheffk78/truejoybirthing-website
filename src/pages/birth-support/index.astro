---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Birth Support by City"
  description="Find local birth support resources — hospital info, doula costs, and Medicaid status — city by city."
  canonical="https://truejoybirthing.com/birth-support/"
>
  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">Birth Support by City</h1>
      <p class="text-lg text-tjb-gray">Local hospital info, doula costs, Medicaid status, and free birth planning tools — city by city.</p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-xl font-semibold mb-6">Texas</h2>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
        <a href="/birth-support/dallas-tx/" class="border border-tjb-lavender-300 p-4 rounded-lg hover:border-tjb-lavender-500 transition">Dallas, TX</a>
        <a href="/birth-support/houston-tx/" class="border border-tjb-lavender-300 p-4 rounded-lg hover:border-tjb-lavender-500 transition">Houston, TX</a>
        <a href="/birth-support/austin-tx/" class="border border-tjb-lavender-300 p-4 rounded-lg hover:border-tjb-lavender-500 transition">Austin, TX</a>
        <a href="/birth-support/san-antonio-tx/" class="border border-tjb-lavender-300 p-4 rounded-lg hover:border-tjb-lavender-500 transition">San Antonio, TX</a>
        <a href="/birth-support/fort-worth-tx/" class="border border-tjb-lavender-300 p-4 rounded-lg hover:border-tjb-lavender-500 transition">Fort Worth, TX</a>
      </div>
    </div>
  </section>

  <section class="py-12 bg-tjb-cream text-center">
    <h2 class="text-xl font-semibold mb-4">Can't find your city?</h2>
    <p class="text-tjb-gray mb-4">The free birth plan works anywhere. Download it and build your plan for your specific birth setting.</p>
    <a href="/" class="inline-block bg-tjb-lavender-500 text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-rose-500 transition">Download Free Birth Plan</a>
  </section>
</Layout>
