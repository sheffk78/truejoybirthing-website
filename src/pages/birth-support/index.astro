---
import Layout from '../../layouts/Layout.astro';

const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "Birth Support", "url": "https://truejoybirthing.com/birth-support/"}];

const cities = [
  { name: "Dallas", slug: "dallas-tx" },
  { name: "Fort Worth", slug: "fort-worth-tx" },
  { name: "Houston", slug: "houston-tx" },
  { name: "Austin", slug: "austin-tx" },
  { name: "San Antonio", slug: "san-antonio-tx" },
  { name: "El Paso", slug: "el-paso-tx" },
  { name: "Plano", slug: "plano-tx" },
  { name: "Frisco", slug: "frisco-tx" },
  { name: "McKinney", slug: "mckinney-tx" },
  { name: "Arlington", slug: "arlington-tx" },
  { name: "Garland", slug: "garland-tx" },
  { name: "Irving", slug: "irving-tx" },
  { name: "Carrollton", slug: "carrollton-tx" },
  { name: "Grand Prairie", slug: "grand-prairie-tx" },
  { name: "Denton", slug: "denton-tx" },
  { name: "Mesquite", slug: "mesquite-tx" },
  { name: "Lubbock", slug: "lubbock-tx" },
  { name: "Amarillo", slug: "amarillo-tx" },
  { name: "Corpus Christi", slug: "corpus-christi-tx" },
  { name: "Laredo", slug: "laredo-tx" },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": "https://truejoybirthing.com/birth-support/#collection",
      "name": "Birth Support by City",
      "description": "Find local birth support resources — hospital info, doula costs, Medicaid status — city by city across Texas.",
      "url": "https://truejoybirthing.com/birth-support/",
      "about": { "@id": "https://truejoybirthing.com/#organization" },
      "mainEntity": {
        "@type": "ItemList",
        "itemListElement": cities.map((c, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "name": `Birth Support in ${c.name}, TX`,
          "url": `https://truejoybirthing.com/birth-support/${c.slug}/`
        }))
      }
    }
  ]
};
---

<Layout
  title="Birth Support by City"
  description="Find local birth support resources — hospital info, doula costs, and Medicaid status — city by city across Texas."
  canonical="https://truejoybirthing.com/birth-support/"
  breadcrumbList={breadcrumbList}
  schema={schema}
>
  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">Birth Support by City</h1>
      <p class="text-lg text-tjb-gray">Local hospital info, doula costs, Medicaid status, and free birth planning tools — city by city.</p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-xl font-semibold mb-6">Texas</h2>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
        {cities.map(city => (
          <a href={`/birth-support/${city.slug}/`} class="border border-tjb-lavender-300 p-4 rounded-lg hover:border-tjb-lavender-500 transition">{city.name}, TX</a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-12 bg-tjb-cream text-center">
    <h2 class="text-xl font-semibold mb-4">Can't find your city?</h2>
    <p class="text-tjb-gray mb-4">The free birth plan works anywhere. Download it and build your plan for your specific birth setting.</p>
    <a href="/" class="inline-block bg-tjb-lavender-500 text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-rose-500 transition">Download Free Birth Plan</a>
  </section>
</Layout>