---
// ═══════════════════════════════════════════════════════════════
// Dynamic state birth-support hub page — intermediate topology layer
// Links to all cities in the state, provides state-level Medicaid info
// ═══════════════════════════════════════════════════════════════
import Layout from '../../layouts/Layout.astro';
import { cities, citySlugs } from '../../data/cities';

export function getStaticPaths() {
  // Group cities by state
  const stateMap: Record<string, string[]> = {};
  for (const slug of citySlugs) {
    const city = cities[slug];
    if (!city) continue;
    if (!stateMap[city.state]) stateMap[city.state] = [];
    stateMap[city.state].push(slug);
  }

  const stateNames: Record<string, string> = {
    AK: 'Alaska', AL: 'Alabama', AR: 'Arkansas', AZ: 'Arizona', CA: 'California',
    CO: 'Colorado', CT: 'Connecticut', DE: 'Delaware', FL: 'Florida', GA: 'Georgia',
    HI: 'Hawaii', IA: 'Iowa', ID: 'Idaho', IL: 'Illinois', IN: 'Indiana',
    KS: 'Kansas', KY: 'Kentucky', LA: 'Louisiana', MA: 'Massachusetts', MD: 'Maryland',
    MI: 'Michigan', MN: 'Minnesota', MO: 'Missouri', MS: 'Mississippi', MT: 'Montana',
    NC: 'North Carolina', ND: 'North Dakota', NE: 'Nebraska', NH: 'New Hampshire',
    NJ: 'New Jersey', NM: 'New Mexico', NV: 'Nevada', NY: 'New York', OH: 'Ohio',
    OK: 'Oklahoma', OR: 'Oregon', PA: 'Pennsylvania', RI: 'Rhode Island', SC: 'South Carolina',
    SD: 'South Dakota', TN: 'Tennessee', TX: 'Texas', UT: 'Utah', VA: 'Virginia',
    VT: 'Vermont', WA: 'Washington', WI: 'Wisconsin', WV: 'West Virginia', WY: 'Wyoming',
  };

  return Object.entries(stateMap).map(([stateCode, slugs]) => ({
    params: { state: stateCode.toLowerCase() },
    props: { stateCode, stateName: stateNames[stateCode] || stateCode, slugs },
  }));
}

const { stateCode, stateName, slugs } = Astro.props;

// Gather city data for each slug
const stateCities = slugs.map((s: string) => cities[s]).filter(Boolean);

// Derive state-level Medicaid info from city data
// Most cities in the same state share the same medicaid status, but extract the common thread
const medicaidCovers = !stateCities.some((c: any) => c.medicaidNote.toLowerCase().includes('does not'));
const sampleMedicaidNote = stateCities[0]?.medicaidNote || '';
const sampleInsuranceNote = stateCities[0]?.insuranceNote || '';

// Cost range across state
const costLow = Math.min(...stateCities.map((c: any) => c.costLow));
const costHigh = Math.max(...stateCities.map((c: any) => c.costHigh));

// Collect unique hospital names and birth center presence
const hasAnyBirthCenters = stateCities.some((c: any) => c.birthCenterDetails && c.birthCenterDetails.length > 0);
const hospitalCount = new Set(stateCities.flatMap((c: any) => c.hospitalDetails?.map((h: any) => h.name) || [])).size;
const doulaCount = stateCities.reduce((sum: number, c: any) => sum + (c.localDoulas?.length || 0), 0);

const pageTitle = `${stateName} Birth Doula & Support Guide | Doula Costs, Medicaid & Hospitals`;
const pageDesc = `Birth doula costs, Medicaid coverage, hospital info, and free birth planning tools for ${stateName} families. Covers ${slugs.length} ${slugs.length === 1 ? 'city' : 'cities'} across the state.`;
const pageUrl = `https://truejoybirthing.com/birth-support/${stateCode.toLowerCase()}/`;

const breadcrumbList = [
  { name: 'Home', url: 'https://truejoybirthing.com/' },
  { name: 'Birth Support', url: 'https://truejoybirthing.com/birth-support/' },
  { name: stateName, url: pageUrl },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      '@id': `${pageUrl}#collection`,
      name: `Birth Support in ${stateName} — Doula Costs, Hospital Info & Joyful Birth Plans`,
      description: pageDesc,
      url: pageUrl,
      about: { '@id': 'https://truejoybirthing.com/#organization' },
      mainEntity: {
        '@type': 'ItemList',
        itemListElement: stateCities.map((c: any, i: number) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: `Birth Support in ${c.city}, ${c.state}`,
          url: `https://truejoybirthing.com/birth-support/${c.slug}/`,
        })),
      },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageUrl}#breadcrumb`,
      itemListElement: breadcrumbList.map((crumb, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: crumb.name,
        item: crumb.url,
      })),
    },
  ],
};
---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}
  breadcrumbList={breadcrumbList}
  schema={schema}
>
  <!-- Hero -->
  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-4xl mx-auto px-6">
      <nav aria-label="Breadcrumb" class="not-prose mb-6 text-sm text-tjb-gray">
        <ol class="flex items-center gap-1.5 flex-wrap">
          {breadcrumbList.map((crumb, i) => (
            <li class="flex items-center gap-1.5">
              {i > 0 && <span aria-hidden="true" class="text-tjb-lavender-300">›</span>}
              {i < breadcrumbList.length - 1 ? (
                <a href={crumb.url} class="text-tjb-lavender-600 hover:underline">{crumb.name}</a>
              ) : (
                <span class="text-tjb-charcoal font-medium" aria-current="page">{crumb.name}</span>
              )}
            </li>
          ))}
        </ol>
      </nav>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">{stateName} Birth Doula & Hospital Guide</h1>
      <p class="text-lg text-tjb-gray mb-6">
        Whether you're in {stateCities.length === 1 ? stateCities[0].city : `a major metro or a smaller town`}, birth support in {stateName} looks different depending on where you are — different hospitals, different costs, different Medicaid rules. This state guide pulls it all together so you can find what's relevant to <em>your</em> city.
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="/birth-plan-template/" class="btn-primary text-center">
          Get Your Free Joyful Birth Plan
        </a>
        <a href="/medicaid-doula-coverage/" class="btn-secondary text-center">
          {stateName} Medicaid Coverage →
        </a>
      </div>
    </div>
  </section>

  <!-- At-a-glance stats -->
  <section class="py-10 bg-white border-b border-tjb-lavender-200/40">
    <div class="max-w-4xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
        <div class="bg-tjb-cream/50 rounded-xl p-4">
          <p class="text-2xl font-bold text-tjb-lavender-600">{slugs.length}</p>
          <p class="text-sm text-tjb-gray">{slugs.length === 1 ? 'City' : 'Cities'} Covered</p>
        </div>
        <div class="bg-tjb-cream/50 rounded-xl p-4">
          <p class="text-2xl font-bold text-tjb-lavender-600">${costLow.toLocaleString()}–${costHigh.toLocaleString()}</p>
          <p class="text-sm text-tjb-gray">Doula Cost Range</p>
        </div>
        <div class="bg-tjb-cream/50 rounded-xl p-4">
          <p class="text-2xl font-bold text-tjb-lavender-600">{hospitalCount}</p>
          <p class="text-sm text-tjb-gray">{hospitalCount === 1 ? 'Hospital' : 'Hospitals'} Listed</p>
        </div>
        <div class="bg-tjb-cream/50 rounded-xl p-4">
          <p class="text-2xl font-bold text-tjb-lavender-600">{medicaidCovers ? 'Yes — Covered' : 'Not Yet'}</p>
          <p class="text-sm text-tjb-gray">Medicaid Doula Coverage</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Medicaid & Insurance -->
  <section class="py-12 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">
      <h2>Does Medicaid Cover a Doula in {stateName}?</h2>
      <p>{medicaidCovers
        ? `${stateName} covers doula services through Medicaid — that's good news for families who need support and want it covered. See the details below, and for a full breakdown by state, check our Medicaid doula coverage guide.`
        : `${stateName} does not yet have statewide Medicaid doula coverage. That means if you're on Medicaid, doula services likely aren't covered directly — but some health plan pilots and community organizations may offer limited benefits or sliding-scale support. Don't let that stop you from planning ahead.`
      }</p>
      <p class="text-sm text-tjb-gray italic">{sampleMedicaidNote}</p>
      <p>{sampleInsuranceNote}</p>
      <p>For the full picture of which states cover doulas through Medicaid, see our <a href="/medicaid-doula-coverage/">Medicaid doula coverage guide</a>.</p>

      <div class="bg-tjb-cream/30 border border-tjb-lavender-200 rounded-lg p-4 not-prose mt-6">
        <p class="font-semibold text-tjb-lavender-600 mb-1">Can't afford a doula right now?</p>
        <p class="text-sm text-tjb-gray">Many {stateName} doulas offer payment plans, sliding-scale fees, or reduced packages. Student doulas in training often attend births at lower rates. And the free <a href="/birth-plan-template/" class="text-tjb-lavender-600 hover:underline">Joyful Birth Plan</a> works whether or not you hire a doula — it helps you think through your preferences and walk in prepared.</p>
      </div>
    </div>
  </section>

  <!-- City Grid -->
  <section class="py-12 bg-tjb-cream">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-2xl font-bold mb-2">{stateName} Cities — Find Your Local Guide</h2>
      <p class="text-tjb-gray mb-8">Each city page has hospital NICU info, doula cost ranges, Medicaid details, birth center listings, and a free birth plan template built for that community.</p>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
        {stateCities.map((c: any) => (
          <a href={`/birth-support/${c.slug}/`} class="border border-tjb-lavender-300 bg-white p-4 rounded-lg hover:border-tjb-lavender-500 hover:bg-tjb-lavender-50 transition group">
            <h3 class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">{c.city}, {c.state}</h3>
            <p class="text-sm text-tjb-gray mt-1">${c.costLow.toLocaleString()}–${c.costHigh.toLocaleString()} doula cost</p>
            <p class="text-xs text-tjb-gray mt-0.5">
              {c.hospitalDetails?.length || 0} hospital{(c.hospitalDetails?.length || 0) !== 1 ? 's' : ''}
              {c.birthCenterDetails?.length > 0 ? ' · birth center' : ''}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- What you'll find on each city page -->
  <section class="py-12 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">
      <h2>What's on Each {stateName} City Page</h2>
      <p>Every city guide in {stateName} includes:</p>
      <ul>
        <li><strong>Hospital & birth center details</strong> — NICU levels, visitor policies, and whether doulas are welcome</li>
        <li><strong>Doula cost range</strong> — what you'll typically pay in that city, and what's included</li>
        <li><strong>Medicaid & insurance coverage</strong> — what your plan covers and what it doesn't</li>
        <li><strong>Local doulas & midwives</strong> — verified providers serving that community</li>
        <li><strong>Free birth plan template</strong> — built for {stateName} families preparing for any birth setting</li>
      </ul>
      <p>Find your city above, or <a href="/birth-plan-template/">start with the free birth plan</a> — it works no matter where in {stateName} you're delivering.</p>
    </div>
  </section>

  <!-- Related Resources -->
  <section class="py-12 bg-white border-t border-tjb-lavender-200/40">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-2xl font-bold mb-6">Related Resources</h2>
      <div class="grid sm:grid-cols-2 gap-3">
        <a href="/birth-plan-template/" class="flex items-start gap-3 p-4 border border-tjb-lavender-200 rounded-lg hover:border-tjb-rose-400 hover:bg-tjb-rose-50/30 transition group">
          <svg class="w-5 h-5 mt-0.5 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          <div>
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">Free Birth Plan Template</span>
            <p class="text-sm text-tjb-gray mt-0.5">Downloadable fillable PDF for your hospital birth</p>
          </div>
        </a>
        <a href="/what-is-a-doula/" class="flex items-start gap-3 p-4 border border-tjb-lavender-200 rounded-lg hover:border-tjb-rose-400 hover:bg-tjb-rose-50/30 transition group">
          <svg class="w-5 h-5 mt-0.5 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">What Is a Doula?</span>
            <p class="text-sm text-tjb-gray mt-0.5">What doulas do, how they help, and whether you need one</p>
          </div>
        </a>
        <a href="/doula-cost/" class="flex items-start gap-3 p-4 border border-tjb-lavender-200 rounded-lg hover:border-tjb-rose-400 hover:bg-tjb-rose-50/30 transition group">
          <svg class="w-5 h-5 mt-0.5 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">Doula Cost Guide</span>
            <p class="text-sm text-tjb-gray mt-0.5">What doulas cost, what's included, and how to pay</p>
          </div>
        </a>
        <a href="/medicaid-doula-coverage/" class="flex items-start gap-3 p-4 border border-tjb-lavender-200 rounded-lg hover:border-tjb-rose-400 hover:bg-tjb-rose-50/30 transition group">
          <svg class="w-5 h-5 mt-0.5 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <div>
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">Medicaid Doula Coverage</span>
            <p class="text-sm text-tjb-gray mt-0.5">Which states cover doulas and how to get coverage</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 bg-tjb-cream text-center">
    <h2 class="text-xl font-semibold mb-4">Walk Into Your Birth Feeling Prepared</h2>
    <p class="text-tjb-gray mb-6 max-w-xl mx-auto">The free Joyful Birth Plan works for every {stateName} family — no matter which city you're in, which hospital you're delivering at, or whether you hire a doula. Start building yours now.</p>
    <div class="flex flex-col sm:flex-row justify-center gap-3">
      <a href="/birth-plan-template/" class="btn-primary">Get Your Free Joyful Birth Plan</a>
      <a href="/birth-support/" class="btn-secondary">See All Cities →</a>
    </div>
  </section>
</Layout>