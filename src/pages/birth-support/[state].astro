---
// ═══════════════════════════════════════════════════════════════
// Dynamic state birth-support hub page — intermediate topology layer
// Links to all city pages within a state + state-specific Medicaid info
// ═══════════════════════════════════════════════════════════════
import Layout from '../../layouts/Layout.astro';
import { cities, citySlugs, type CityData } from '../../data/cities';

const stateNames: Record<string, string> = {
  AK: 'Alaska', AL: 'Alabama', AR: 'Arkansas', AZ: 'Arizona',
  CA: 'California', CO: 'Colorado', CT: 'Connecticut',
  DE: 'Delaware', FL: 'Florida', GA: 'Georgia',
  HI: 'Hawaii', IA: 'Iowa', ID: 'Idaho', IL: 'Illinois',
  IN: 'Indiana', KS: 'Kansas', KY: 'Kentucky',
  LA: 'Louisiana', MA: 'Massachusetts', MD: 'Maryland',
  MI: 'Michigan', MN: 'Minnesota', MO: 'Missouri', MS: 'Mississippi',
  MT: 'Montana', NC: 'North Carolina', ND: 'North Dakota',
  NE: 'Nebraska', NH: 'New Hampshire', NJ: 'New Jersey',
  NM: 'New Mexico', NV: 'Nevada', NY: 'New York',
  OH: 'Ohio', OK: 'Oklahoma', OR: 'Oregon',
  PA: 'Pennsylvania', RI: 'Rhode Island',
  SC: 'South Carolina', SD: 'South Dakota',
  TN: 'Tennessee', TX: 'Texas',
  UT: 'Utah', VA: 'Virginia', VT: 'Vermont',
  WA: 'Washington', WI: 'Wisconsin', WV: 'West Virginia', WY: 'Wyoming',
};

export function getStaticPaths() {
  // Group cities by state — must be inline because Astro isolates getStaticPaths
  const groups: Record<string, CityData[]> = {};
  for (const slug of citySlugs) {
    const city = cities[slug];
    if (!city) continue;
    if (!groups[city.state]) groups[city.state] = [];
    groups[city.state].push(city);
  }

  return Object.keys(groups).map((stateCode) => ({
    params: { state: stateCode.toLowerCase() },
    props: { stateCode },
  }));
}

const { stateCode } = Astro.props;
const stateFullName = stateNames[stateCode] || stateCode;

// Re-derive groups for template rendering
const allStateGroups: Record<string, CityData[]> = {};
for (const slug of citySlugs) {
  const city = cities[slug];
  if (!city) continue;
  if (!allStateGroups[city.state]) allStateGroups[city.state] = [];
  allStateGroups[city.state].push(city);
}

const stateCities = allStateGroups[stateCode] || [];
const allStateCodes = Object.keys(allStateGroups);
const totalCities = stateCities.length;

// Derive aggregate state data from cities
const costLow = Math.min(...stateCities.map((c) => c.costLow));
const costHigh = Math.max(...stateCities.map((c) => c.costHigh));
const medicaidCovers = stateCities.some(
  (c) => !c.medicaidNote.includes('does not') && !c.medicaidNote.includes('does NOT')
);
const representativeMedicaidNote = stateCities[0]?.medicaidNote || '';
const representativeInsuranceNote = stateCities[0]?.insuranceNote || '';

const allHospitals = stateCities.flatMap((c) => c.hospitalDetails.map((h) => h.name));
const uniqueHospitals = [...new Set(allHospitals)];

const pageTitle = `${stateFullName} Doula Guide | Costs & Medicaid`;
const pageDesc = `Find doula support across ${totalCities} ${totalCities === 1 ? 'city' : 'cities'} in ${stateFullName}. Compare costs ($${costLow.toLocaleString()}–$${costHigh.toLocaleString()}), Medicaid, and hospital policies.`;
const pageUrl = `https://truejoybirthing.com/birth-support/${stateCode.toLowerCase()}/`;

const breadcrumbList = [
  { name: 'Home', url: 'https://truejoybirthing.com/' },
  { name: 'Birth Support', url: 'https://truejoybirthing.com/birth-support/' },
  { name: stateFullName, url: pageUrl },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      '@id': `${pageUrl}#collection`,
      name: `${stateFullName} Birth Doula & Support Guide`,
      description: pageDesc,
      url: pageUrl,
      about: { '@id': 'https://truejoybirthing.com/#organization' },
      mainEntity: {
        '@type': 'ItemList',
        itemListElement: stateCities.map((city, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: `Birth Support in ${city.city}, ${city.state}`,
          url: `https://truejoybirthing.com/birth-support/${city.slug}/`,
        })),
      },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageUrl}#breadcrumb`,
      itemListElement: breadcrumbList.map((crumb, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: crumb.name,
        item: crumb.url,
      })),
    },
  ],
};

const sortedCities = [...stateCities].sort((a, b) => a.city.localeCompare(b.city));
---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}
  breadcrumbList={breadcrumbList}
  schema={schema}
>
  <!-- Breadcrumb -->
  <section class="bg-tjb-cream pt-6">
    <div class="max-w-7xl mx-auto px-6">
      <nav aria-label="Breadcrumb" class="text-sm text-tjb-gray">
        <ol class="flex items-center gap-1.5 flex-wrap">
          {breadcrumbList.map((crumb, i) => (
            <li class="flex items-center gap-1.5">
              {i > 0 && <span aria-hidden="true" class="text-tjb-lavender-300">›</span>}
              {i < breadcrumbList.length - 1 ? (
                <a href={crumb.url} class="text-tjb-lavender-600 hover:underline">{crumb.name}</a>
              ) : (
                <span class="text-tjb-charcoal font-medium" aria-current="page">{crumb.name}</span>
              )}
            </li>
          ))}
        </ol>
      </nav>
    </div>
  </section>

  <!-- HERO — State overview -->
  <section class="bg-tjb-cream pb-12 pt-10">
    <div class="max-w-4xl mx-auto px-6">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">{stateFullName} Birth Doula & Hospital Guide</h1>
      <p class="text-lg text-tjb-gray leading-relaxed mb-6">
        Birth support resources for {totalCities} {totalCities === 1 ? 'city' : 'cities'} across {stateFullName} — doula costs range from <strong>${costLow.toLocaleString()} to ${costHigh.toLocaleString()}</strong>, and we've got the Medicaid details, hospital info, and local doula listings for each one. Pick your city below to dive in.
      </p>
      <div class="flex flex-wrap gap-3 text-sm">
        <a href="/birth-plan-template/" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full border border-tjb-rose-400 text-tjb-rose-500 hover:bg-tjb-rose-50 transition font-medium">Free Birth Plan →</a>
        <a href="/what-is-a-doula/" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full border border-tjb-lavender-300 text-tjb-lavender-600 hover:bg-tjb-lavender-50 transition font-medium">What Is a Doula?</a>
        <a href="/medicaid-doula-coverage/" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full border border-tjb-lavender-300 text-tjb-lavender-600 hover:bg-tjb-lavender-50 transition font-medium">Medicaid Coverage Guide</a>
      </div>
    </div>
  </section>

  <!-- STATE QUICK FACTS -->
  <section class="py-12 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-tjb-cream/50 border border-tjb-lavender-200 rounded-xl p-5 text-center">
          <svg class="w-7 h-7 text-tjb-sage mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.403 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.403-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <p class="text-2xl font-bold text-tjb-charcoal">${costLow.toLocaleString()}–${costHigh.toLocaleString()}</p>
          <p class="text-sm text-tjb-gray mt-1">Doula cost range in {stateFullName}</p>
        </div>
        <div class="bg-tjb-cream/50 border border-tjb-lavender-200 rounded-xl p-5 text-center">
          <svg class="w-7 h-7 text-tjb-lavender-500 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-2.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <p class="text-2xl font-bold text-tjb-charcoal">{medicaidCovers ? 'Yes' : 'Not Yet'}</p>
          <p class="text-sm text-tjb-gray mt-1">{medicaidCovers ? 'Medicaid covers doulas' : 'Medicaid doula coverage'}</p>
        </div>
        <div class="bg-tjb-cream/50 border border-tjb-lavender-200 rounded-xl p-5 text-center">
          <svg class="w-7 h-7 text-tjb-lavender-500 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <p class="text-2xl font-bold text-tjb-charcoal">{totalCities}</p>
          <p class="text-sm text-tjb-gray mt-1">{totalCities === 1 ? 'City covered' : 'Cities covered'}</p>
        </div>
        <div class="bg-tjb-cream/50 border border-tjb-lavender-200 rounded-xl p-5 text-center">
          <svg class="w-7 h-7 text-tjb-rose-400 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          <p class="text-2xl font-bold text-tjb-charcoal">{uniqueHospitals.length}</p>
          <p class="text-sm text-tjb-gray mt-1">{uniqueHospitals.length === 1 ? 'Hospital listed' : 'Hospitals listed'}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MEDICAID & INSURANCE — State-level overview -->
  <section class="py-12 bg-tjb-cream">
    <div class="max-w-5xl mx-auto px-6">
      <div class="flex flex-col md:flex-row gap-8 md:gap-12 items-start">
        <div class="md:w-[58%] prose">
          <h2 class="flex items-center gap-2.5 font-bold text-tjb-charcoal" style="font-size: clamp(1.5rem, 2.5vw, 1.875rem); font-family: 'Cormorant Garamond', Georgia, serif;">
            <svg class="w-6 h-6 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-2.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            Does Medicaid Cover a Doula in {stateFullName}?
          </h2>
          <p>{representativeMedicaidNote.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim()}</p>
          <p>For the full breakdown of which states cover doulas and how to get coverage, see our <a href="/medicaid-doula-coverage/" class="text-tjb-lavender-600 hover:underline">Medicaid doula coverage guide</a>.</p>
          {representativeInsuranceNote && (
            <p class="text-sm text-tjb-gray mt-2" set:html={representativeInsuranceNote} />
          )}
        </div>
        <div class="md:w-[42%] flex-shrink-0">
          <img
            src="/images/hands-on-belly.webp"
            alt="A newborn baby moments after birth — the reason good coverage matters"
            class="w-full rounded-xl shadow-md"
            width="1024"
            height="1536"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- CITY GRID — All cities in this state -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <p class="eyebrow mb-3">Cities in {stateFullName}</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
      <h2 class="text-2xl md:text-3xl font-bold mb-2">Find Your City in {stateFullName}</h2>
      <p class="text-tjb-gray mb-8">Select your city to see local doula costs, Medicaid details, hospital info, and birth center options.</p>

      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
        {sortedCities.map((city) => (
          <a
            href={`/birth-support/${city.slug}/`}
            class="block border border-tjb-lavender-200 rounded-xl p-5 hover:border-tjb-rose-400 hover:bg-tjb-rose-50/20 transition group"
          >
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">{city.city}</h3>
              <svg class="w-5 h-5 text-tjb-lavender-400 group-hover:text-tjb-rose-400 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </div>
            <p class="text-sm text-tjb-gray">${city.costLow.toLocaleString()}–${city.costHigh.toLocaleString()} · {city.hospitalDetails.length} {city.hospitalDetails.length === 1 ? 'hospital' : 'hospitals'}</p>
            {city.shelbiServesHere && (
              <span class="inline-block mt-2 text-xs font-medium bg-tjb-rose-50 text-tjb-rose-500 px-2 py-0.5 rounded-full">Shelbi serves this area</span>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA CARD -->
  <section class="py-16 bg-tjb-cream/50">
    <div class="max-w-3xl mx-auto px-6">
      <div class="bg-tjb-lavender-50 border-2 border-tjb-lavender-200 p-6 md:p-8 rounded-xl text-center">
        <h2 class="font-bold text-tjb-charcoal mb-3" style="font-size: clamp(1.5rem, 2.5vw, 1.875rem); font-family: 'Cormorant Garamond', Georgia, serif;">
          Prepare for Your Birth in {stateFullName}
        </h2>
        <p class="text-tjb-gray mb-5">No matter which {stateFullName} city you're in, the free Joyful Birth Plan walks you through every decision — who's in the room, pain management preferences, and what matters most to you.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/birth-plan-template/" class="btn-primary no-underline">Get Your Free Birth Plan</a>
          <a href="/what-is-a-doula/" class="btn-secondary no-underline">What Is a Doula?</a>
        </div>
      </div>
    </div>
  </section>

  <!-- RELATED RESOURCES -->
  <section class="py-12 bg-white border-t border-tjb-lavender-200/40">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-2xl font-bold mb-6">Related Resources</h2>
      <div class="grid sm:grid-cols-2 gap-3">
        <a href="/birth-plan-template/" class="flex items-start gap-3 p-4 border border-tjb-lavender-200 rounded-lg hover:border-tjb-rose-400 hover:bg-tjb-rose-50/30 transition group">
          <svg class="w-5 h-5 mt-0.5 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          <div>
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">Joyful Birth Plan Template</span>
            <p class="text-sm text-tjb-gray mt-0.5">Free downloadable birth plan for any hospital</p>
          </div>
        </a>
        <a href="/what-is-a-doula/" class="flex items-start gap-3 p-4 border border-tjb-lavender-200 rounded-lg hover:border-tjb-rose-400 hover:bg-tjb-rose-50/30 transition group">
          <svg class="w-5 h-5 mt-0.5 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">What Is a Doula?</span>
            <p class="text-sm text-tjb-gray mt-0.5">What doulas do, how they help, and whether you need one</p>
          </div>
        </a>
        <a href="/benefits-of-a-doula/" class="flex items-start gap-3 p-4 border border-tjb-lavender-200 rounded-lg hover:border-tjb-rose-400 hover:bg-tjb-rose-50/30 transition group">
          <svg class="w-5 h-5 mt-0.5 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          <div>
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">Benefits of a Doula</span>
            <p class="text-sm text-tjb-gray mt-0.5">How doulas improve birth outcomes and reduce anxiety</p>
          </div>
        </a>
        <a href="/doula-cost/" class="flex items-start gap-3 p-4 border border-tjb-lavender-200 rounded-lg hover:border-tjb-rose-400 hover:bg-tjb-rose-50/30 transition group">
          <svg class="w-5 h-5 mt-0.5 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">Doula Cost Guide</span>
            <p class="text-sm text-tjb-gray mt-0.5">What doulas cost, what's included, and how to pay</p>
          </div>
        </a>
        <a href="/medicaid-doula-coverage/" class="flex items-start gap-3 p-4 border border-tjb-lavender-200 rounded-lg hover:border-tjb-rose-400 hover:bg-tjb-rose-50/30 transition group">
          <svg class="w-5 h-5 mt-0.5 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-2.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <div>
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">Medicaid Doula Coverage</span>
            <p class="text-sm text-tjb-gray mt-0.5">Which states cover doulas and how to get coverage</p>
          </div>
        </a>
        <a href="/hospital-birth-plan/" class="flex items-start gap-3 p-4 border border-tjb-lavender-200 rounded-lg hover:border-tjb-rose-400 hover:bg-tjb-rose-50/30 transition group">
          <svg class="w-5 h-5 mt-0.5 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          <div>
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">Hospital Birth Plan</span>
            <p class="text-sm text-tjb-gray mt-0.5">How to plan for a hospital birth and advocate for your preferences</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- OTHER STATES -->
  <section class="py-12 bg-tjb-cream">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-xl font-bold mb-4">Explore Other States</h2>
      <div class="flex flex-wrap gap-2">
        {allStateCodes.sort((a, b) => {
          if (a === 'TX') return -1;
          if (b === 'TX') return 1;
          return (stateNames[a] || a).localeCompare(stateNames[b] || b);
        }).map((sc) => (
          <a
            href={`/birth-support/${sc.toLowerCase()}/`}
            class:list={[
              'px-3 py-1.5 rounded-full text-sm font-medium border transition',
              sc === stateCode
                ? 'bg-tjb-lavender-600 text-white border-tjb-lavender-600'
                : 'border-tjb-lavender-300 text-tjb-lavender-600 hover:bg-tjb-lavender-50 hover:border-tjb-lavender-500',
            ]}
          >
            {stateNames[sc] || sc}
          </a>
        ))}
      </div>
      <p class="mt-4 text-sm text-tjb-gray">
        <a href="/birth-support/" class="text-tjb-lavender-600 hover:underline">View all cities →</a>
      </p>
    </div>
  </section>
</Layout>