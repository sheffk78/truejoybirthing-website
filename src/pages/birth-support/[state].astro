---
// ═══════════════════════════════════════════════════════════════
// Dynamic state hub page — intermediate topology layer between
// /birth-support/ and individual /birth-support/[city]/ pages
// ═══════════════════════════════════════════════════════════════
import Layout from '../../layouts/Layout.astro';
import { cities, citySlugs } from '../../data/cities';

export function getStaticPaths() {
  // Group cities by state code — must be self-contained for Astro SSG
  const stateGroups: Record<string, string[]> = {};
  for (const slug of citySlugs) {
    const city = cities[slug];
    if (!city) continue;
    if (!stateGroups[city.state]) stateGroups[city.state] = [];
    stateGroups[city.state].push(slug);
  }

  return Object.keys(stateGroups).map((stateCode) => ({
    params: { state: stateCode.toLowerCase() },
    props: {
      stateCode,
      citySlugsInState: stateGroups[stateCode],
    },
  }));
}

const stateNames: Record<string, string> = {
  AL:'Alabama',AK:'Alaska',AZ:'Arizona',AR:'Arkansas',CA:'California',CO:'Colorado',CT:'Connecticut',DE:'Delaware',FL:'Florida',GA:'Georgia',HI:'Hawaii',ID:'Idaho',IL:'Illinois',IN:'Indiana',IA:'Iowa',KS:'Kansas',KY:'Kentucky',LA:'Louisiana',ME:'Maine',MD:'Maryland',MA:'Massachusetts',MI:'Michigan',MN:'Minnesota',MS:'Mississippi',MO:'Missouri',MT:'Montana',NE:'Nebraska',NV:'Nevada',NH:'New Hampshire',NJ:'New Jersey',NM:'New Mexico',NY:'New York',NC:'North Carolina',ND:'North Dakota',OH:'Ohio',OK:'Oklahoma',OR:'Oregon',PA:'Pennsylvania',RI:'Rhode Island',SC:'South Carolina',SD:'South Dakota',TN:'Tennessee',TX:'Texas',UT:'Utah',VT:'Vermont',VA:'Virginia',WA:'Washington',WV:'West Virginia',WI:'Wisconsin',WY:'Wyoming',DC:'District of Columbia',
};

const { stateCode, citySlugsInState } = Astro.props;
const stateName = stateNames[stateCode] || stateCode;
const stateCities = citySlugsInState.map((slug: string) => cities[slug]).filter(Boolean);

// Derive state-wide Medicaid status from city data
const firstCity = stateCities[0];
const medicaidNote = firstCity?.medicaidNote || '';
const hasMedicaidCoverage = medicaidNote.startsWith('Yes');

// Cost range across all cities in this state
const allCostLows = stateCities.map((c: any) => c.costLow).filter(Boolean);
const allCostHighs = stateCities.map((c: any) => c.costHigh).filter(Boolean);
const stateCostLow = allCostLows.length ? Math.min(...allCostLows) : 0;
const stateCostHigh = allCostHighs.length ? Math.max(...allCostHighs) : 0;

// Hospital and birth center counts
const totalHospitals = stateCities.reduce((sum: number, c: any) => sum + (c.hospitalDetails?.length || 0), 0);
const totalBirthCenters = stateCities.reduce((sum: number, c: any) => sum + (c.birthCenterDetails?.length || 0), 0);

const pageTitle = `${stateName} Birth Doula & Support Guide | Doula Costs, Medicaid & Hospitals`;
const pageDesc = `Find birth doula support in ${stateName} — doula costs ($${stateCostLow.toLocaleString()}–$${stateCostHigh.toLocaleString()}), Medicaid coverage, hospital info, and free birth plan resources across ${stateCities.length} cities.`;
const pageUrl = `https://truejoybirthing.com/birth-support/${stateCode.toLowerCase()}/`;

const breadcrumbList = [
  { name: 'Home', url: 'https://truejoybirthing.com/' },
  { name: 'Birth Support', url: 'https://truejoybirthing.com/birth-support/' },
  { name: stateName, url: pageUrl },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      '@id': `${pageUrl}#collection`,
      name: `Birth Support in ${stateName} — Doula Costs, Hospital Info & Joyful Birth Plans`,
      description: pageDesc,
      url: pageUrl,
      about: { '@id': 'https://truejoybirthing.com/#organization' },
      mainEntity: {
        '@type': 'ItemList',
        itemListElement: stateCities.map((c: any, i: number) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: `Birth Support in ${c.city}, ${stateCode}`,
          url: `https://truejoybirthing.com/birth-support/${c.slug}/`,
        })),
      },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageUrl}#breadcrumb`,
      itemListElement: breadcrumbList.map((item, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: item.name,
        item: item.url,
      })),
    },
  ],
};

// Sort cities alphabetically within the state
const sortedCities = [...stateCities].sort((a: any, b: any) => a.city.localeCompare(b.city));
---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}
  breadcrumbList={breadcrumbList}
  schema={schema}
>
  <!-- Hero -->
  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl">
        <h1 class="text-3xl md:text-4xl font-bold mb-4">{stateName} Birth Doula & Hospital Guide</h1>
        <p class="text-lg text-tjb-gray mb-4">
          Looking for birth support in {stateName}? This guide covers doula costs, Medicaid coverage, hospital policies, and birth center options across {stateCities.length} {stateName} cities — so you can find the support you need, wherever you are in the state.
        </p>
        <p class="text-base text-tjb-gray mb-6">
          Doulas in {stateName} typically charge <strong>${stateCostLow.toLocaleString()} to ${stateCostHigh.toLocaleString()}</strong>, and {hasMedicaidCoverage
            ? <><strong>{stateName} Medicaid covers doula services</strong> — <a href="/medicaid-doula-coverage/" class="text-tjb-lavender-600 hover:underline">see how to get coverage</a></>
            : <>{stateName} doesn't yet have statewide Medicaid doula coverage, though some health plan pilots offer limited benefits — <a href="/medicaid-doula-coverage/" class="text-tjb-lavender-600 hover:underline">learn about your options</a></>
          }.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/birth-plan-template/" class="bg-tjb-lavender-600 text-white px-6 py-3 rounded-full font-semibold hover:bg-tjb-rose-500 transition text-center">
            Get Your Free Joyful Birth Plan
          </a>
          <a href="/medicaid-doula-coverage/" class="bg-tjb-cream-50 text-tjb-lavender-600 border-2 border-tjb-lavender-600 px-6 py-3 rounded-full font-semibold hover:bg-tjb-cream transition text-center">
            {stateName} Medicaid Doula Coverage
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- State overview stats -->
  <section class="py-12 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-6 mb-12">
        <div class="bg-tjb-lavender-50 border border-tjb-lavender-200 rounded-lg p-5 text-center">
          <p class="text-3xl font-bold text-tjb-lavender-600">{stateCities.length}</p>
          <p class="text-sm text-tjb-gray mt-1">Cities with guides</p>
        </div>
        <div class="bg-tjb-lavender-50 border border-tjb-lavender-200 rounded-lg p-5 text-center">
          <p class="text-3xl font-bold text-tjb-lavender-600">{totalHospitals}</p>
          <p class="text-sm text-tjb-gray mt-1">Hospitals listed</p>
        </div>
        <div class="bg-tjb-lavender-50 border border-tjb-lavender-200 rounded-lg p-5 text-center">
          <p class="text-3xl font-bold text-tjb-lavender-600">{totalBirthCenters}</p>
          <p class="text-sm text-tjb-gray mt-1">Birth centers</p>
        </div>
        <div class="bg-tjb-lavender-50 border border-tjb-lavender-200 rounded-lg p-5 text-center">
          <p class="text-3xl font-bold text-tjb-lavender-600">${stateCostLow.toLocaleString()}–${stateCostHigh.toLocaleString()}</p>
          <p class="text-sm text-tjb-gray mt-1">Doula cost range</p>
        </div>
      </div>

      <!-- Medicaid & Insurance Section -->
      <div class="max-w-3xl mx-auto mb-12">
        <h2 class="text-2xl font-bold mb-4">Does {stateName} Medicaid Cover Doulas?</h2>
        {hasMedicaidCoverage ? (
          <p class="text-tjb-gray mb-3"><strong>Yes — {stateName} covers doula services through Medicaid.</strong> This means if you're on Medicaid, your doula may be covered at little or no cost to you. <a href="/medicaid-doula-coverage/" class="text-tjb-lavender-600 hover:underline">See our full Medicaid doula coverage guide</a> for details on how to apply and what's included.</p>
        ) : (
          <p class="text-tjb-gray mb-3"><strong>Not yet — {stateName} does not have statewide Medicaid doula coverage as of 2026.</strong> However, some health plan pilots and managed care plans offer limited doula benefits — it's worth calling your plan to ask directly. <a href="/medicaid-doula-coverage/" class="text-tjb-lavender-600 hover:underline">See our Medicaid doula coverage guide</a> for which states cover doulas and what to do if yours doesn't.</p>
        )}
        <p class="text-tjb-gray">Even without Medicaid coverage, there are ways to make doula support affordable:</p>
        <ul class="text-tjb-gray list-disc pl-6 space-y-1 mt-2">
          <li><strong>HSA/FSA funds:</strong> Many families use Health Savings Account or Flexible Spending Account funds to pay for doula services.</li>
          <li><strong>Sliding-scale doulas:</strong> Many {stateName} doulas offer payment plans or reduced fees — don't hesitate to ask.</li>
          <li><strong>Student doulas:</strong> Doulas in training often attend births at reduced rates.</li>
          <li><strong>Community programs:</strong> Some WIC offices and community health centers offer free volunteer doula programs.</li>
        </ul>
      </div>

      <!-- City Grid -->
      <h2 class="text-2xl font-bold mb-6">Find Birth Support in Your {stateName} City</h2>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 mb-12">
        {sortedCities.map((c: any) => (
          <a href={`/birth-support/${c.slug}/`} class="border border-tjb-lavender-300 p-4 rounded-lg hover:border-tjb-lavender-500 hover:bg-tjb-lavender-50 transition group">
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">{c.city}</span>
            <p class="text-sm text-tjb-gray mt-1">Doulas ${c.costLow.toLocaleString()}–${c.costHigh.toLocaleString()} · {c.hospitalDetails?.length || 0} hospital{(c.hospitalDetails?.length || 0) !== 1 ? 's' : ''}</p>
          </a>
        ))}
      </div>

      <!-- Birth Plan CTA -->
      <div class="bg-tjb-lavender-50 border-2 border-tjb-lavender-200 p-6 rounded-lg max-w-3xl mx-auto not-prose">
        <h3 class="font-semibold text-lg text-tjb-charcoal mb-2">Prepare for Your {stateName} Birth — Wherever You Deliver</h3>
        <p class="text-tjb-gray mb-3">The free Joyful Birth Plan works for every hospital and birth center in {stateName}. It walks you through every decision — who's in the room, what happens if things shift, what matters most to you — so you walk in confident.</p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/birth-plan-template/" class="bg-tjb-lavender-600 text-white px-6 py-3 rounded-full font-semibold hover:bg-tjb-rose-500 transition text-center">
            Get Your Free Joyful Birth Plan
          </a>
          <a href="/birth-plan-confidence-session/" class="bg-white text-tjb-lavender-600 border-2 border-tjb-lavender-600 px-6 py-3 rounded-full font-semibold hover:bg-tjb-cream transition text-center">
            Book a Birth Plan Confidence Session
          </a>
        </div>
        <p class="text-xs text-tjb-gray mt-3">Free. No email required. The app walks you through it step by step.</p>
      </div>
    </div>
  </section>

  <!-- Related Resources -->
  <section class="py-12 bg-white border-t border-tjb-lavender-200/40">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-2xl font-bold mb-6">Related Resources</h2>
      <div class="grid sm:grid-cols-2 gap-3">
        <a href="/birth-plan-template/" class="flex items-start gap-3 p-4 border border-tjb-lavender-200 rounded-lg hover:border-tjb-rose-400 hover:bg-tjb-rose-50/30 transition group">
          <svg class="w-5 h-5 mt-0.5 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          <div>
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">Free Birth Plan Template</span>
            <p class="text-sm text-tjb-gray mt-0.5">Downloadable fillable PDF for your hospital birth</p>
          </div>
        </a>
        <a href="/doula-cost/" class="flex items-start gap-3 p-4 border border-tjb-lavender-200 rounded-lg hover:border-tjb-rose-400 hover:bg-tjb-rose-50/30 transition group">
          <svg class="w-5 h-5 mt-0.5 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">Doula Cost Guide</span>
            <p class="text-sm text-tjb-gray mt-0.5">What doulas charge, what's included, and how to budget</p>
          </div>
        </a>
        <a href="/what-is-a-doula/" class="flex items-start gap-3 p-4 border border-tjb-lavender-200 rounded-lg hover:border-tjb-rose-400 hover:bg-tjb-rose-50/30 transition group">
          <svg class="w-5 h-5 mt-0.5 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">What Is a Doula?</span>
            <p class="text-sm text-tjb-gray mt-0.5">What doulas do, how they help, and whether you need one</p>
          </div>
        </a>
        <a href="/medicaid-doula-coverage/" class="flex items-start gap-3 p-4 border border-tjb-lavender-200 rounded-lg hover:border-tjb-rose-400 hover:bg-tjb-rose-50/30 transition group">
          <svg class="w-5 h-5 mt-0.5 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <div>
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">{hasMedicaidCoverage ? `${stateName} Medicaid Covers Doulas` : `Does ${stateName} Medicaid Cover Doulas?`}</span>
            <p class="text-sm text-tjb-gray mt-0.5">{hasMedicaidCoverage ? `Yes — ${stateName} covers doula services. See how to get coverage.` : `${stateName} doesn't yet cover doulas, but options exist. Learn more.`}</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Back to all cities -->
  <section class="py-8 bg-tjb-cream text-center">
    <a href="/birth-support/" class="text-tjb-lavender-600 font-semibold hover:underline">← See all birth support cities</a>
  </section>
</Layout>