---
import Layout from '../../layouts/Layout.astro';

const city = "Plano";
const state = "TX";
const pageTitle = `Doula Plano TX — Birth Support, Costs & Free Joyful Birth Plan`;
const pageDesc = `Find a doula in Plano, TX — local hospital info, doula costs, Medicaid status, and the free Joyful Birth Plan for local families.`;
const pageUrl = `https://truejoybirthing.com/birth-support/plano-tx`;

const hospitals = ['Texas Health Plano', 'Medical City Plano', 'Baylor Scott & White Plano'];
const birthCenters = ['The Birth Place'];
const costLow = 1000;
const costHigh = 2800;
const medicaidNote = "Texas Medicaid's doula benefit is expanding statewide. As of 2026, doula services may be reimbursable in the Plano area. Confirm with your Medicaid plan.";
const insuranceNote = "Some private insurers in the Plano area now cover doula support as part of maternal wellness benefits. Contact your plan for details.";
const culture = "Plano is a well-established, family-oriented city in Collin County with excellent healthcare access. The birth community is mature and diverse — you'll find everything from hospital-based midwifery to home birth support. Many Plano families invest in preparation and education for their births.";
const shelbiServesHere = true;

const faqs = [
  { q: "Does Medicaid cover doulas in Plano?", a: "Texas is expanding Medicaid doula coverage statewide. Specific eligibility depends on your plan. Contact your Texas Medicaid managed care provider for current benefits in the Plano area." },
  { q: "Which hospitals in Plano accommodate birth plans?", a: "Texas Health Plano and other area facilities generally accommodate birth plans, but policies vary. Always confirm your hospital's policy during your hospital tour." },
  { q: "How much does a doula cost in Plano?", a: "$1,000 to $2,800 depending on experience and package. Doula services are often considered worthwhile by families who want continuous support through labor and delivery." },
  { q: "Does True Joy Birthing work with Plano families?", a: "Shelbi is based in the DFW metro and can support Plano-area families with virtual birth plan sessions. The free app and birth plan work for any Plano hospital. the free birth plan course to prepare step by step." }
];
const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "Birth Support", "url": "https://truejoybirthing.com/birth-support/"}, {"name": "Plano, TX", "url": "https://truejoybirthing.com/birth-support/plano-tx"}];
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "@id": "https://truejoybirthing.com/birth-support/plano-tx#faq",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    },
    {
      "@type": "LocalBusiness",
      "@id": "https://truejoybirthing.com/birth-support/plano-tx#local",
      "name": "True Joy Birthing",
      "url": "https://truejoybirthing.com/birth-support/plano-tx",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Plano",
        "addressRegion": "TX",
        "addressCountry": "US"
      },
      "areaServed": { "@type": "City", "name": "Plano" },
      "parentOrganization": { "@id": "https://truejoybirthing.com/#organization" }
    }
  ]
};

---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}

  breadcrumbList={breadcrumbList}
  schema={schema}
>

  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div>
          <h1 class="text-3xl md:text-4xl font-bold mb-4">Find a Doula in Plano, TX</h1>
          <p class="text-lg text-tjb-gray mb-6">
        If you're <a href="/what-is-a-doula/">looking for a doula</a> in Plano, TX, this guide covers local hospital options, doula costs, Medicaid status, and the free Joyful Birth Plan families trust here.
      </p>
          <div class="flex flex-col sm:flex-row gap-3">
        <a href="#download-pdf" class="bg-tjb-lavender-500 text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-rose-500 transition">
          Download Free Birth Plan</a>
        <a href="https://apps.apple.com/app/true-joy-birthing" class="bg-tjb-cream-50 text-tjb-lavender-500 border-2 border-tjb-lavender-500 px-6 py-3 rounded-lg font-semibold hover:bg-tjb-cream transition">
          Get the Free App</a>
      </div>
        </div>
        <div class="relative">
          <img
            src="/images/plano-texas-birth-doula-skyline.webp"
            alt="Skyline of Plano, Texas, where families search for birth doulas and plan their hospital births."
            class="w-full h-64 md:h-80 object-cover rounded-2xl shadow-lg"
            width="1200"
            height="800"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">

      <h2>What Birth Support Looks Like in Plano</h2>
      <p>Plano is a well-established, family-oriented city in Collin County with excellent healthcare access. The birth community is mature and diverse — you'll find everything from hospital-based midwifery to home birth support. Many Plano families invest in preparation and education for their births.</p>
      <p>Whether this is your first baby or you're preparing for a VBAC, <a href="/benefits-of-a-doula/">understanding the benefits of having a doula</a> can help you decide what support is right for your Plano birth.</p>

      

      <p>Texas Health Plano, in West Plano on Legacy Drive, is one of the busiest L&amp;D units in Collin County with a Level III NICU and a strong maternal-fetal medicine program. It sees a huge volume of births — they're well-equipped and experienced, but that pace means having your preferences written down is the best way to make sure they don't get lost in the shuffle. <a href="/birth-plan-template/">Use our free hospital birth plan template</a> to get started.</p>

      <p>Medical City Plano, in Central Plano, also has a high-volume L&amp;D with a Level III NICU and a strong obstetric program. Baylor Scott &amp; White Plano serves the eastern side of the city as well. Plano families have access to three strong hospitals, which is more than most suburbs — but all three are busy. Your OB probably delivers at one of them, so ask which one and write your plan for that hospital.</p>

      <p>The Birth Place is a freestanding birth center in the Plano area offering a midwife-led, lower-intervention setting for low-risk pregnancies. It's a good option if you want a birth center experience without leaving the city — and having a doula who knows the space makes the whole thing feel more supported.</p>

      <p class="text-sm text-tjb-gray italic">Hospitals and birth centers mentioned for context only. True Joy Birthing does not endorse any specific provider. Always confirm visitor and doula policies during your hospital tour.</p>


      

      <h2>Doula Costs in Plano</h2>
      <p>In the Plano area, doula services typically range from <strong>$1,000 to $2,800</strong> depending on:</p>
      <ul>
        <li>Experience and certifications (DONA, CAPPA, etc.)</li>
        <li>Package inclusions (prenatal visits, on-call period, postpartum check-ins)</li>
        <li>Whether the doula serves a wide area or focuses specifically on Plano</li>
      </ul>

      <h2>Medicaid & Insurance Coverage</h2>
      <p>{medicaidNote}</p>
      <p>{insuranceNote}</p>
      <p><strong>HSA/FSA:</strong> Many families don't realize that doula services can often be paid for with HSA or FSA funds, since birth support qualifies as a medical expense under most plans. Check with your plan administrator to confirm what's eligible and whether you need a letter from your provider.</p>
      <p>Not sure what to look for? <a href="/how-to-choose-a-doula/">Here's how to choose a doula</a> who fits your birth preferences and budget.</p>
      


      <h2>Virtual Birth Plan Support for Plano</h2>
      <p>Shelbi offers virtual 1:1 birth plan sessions for Plano-area families. Whether you're delivering at Texas Health Plano or planning a home birth, the session walks through your plan line by line — with the words to use when you want to slow things down or ask questions.</p>
      <div class="my-6 not-prose">
        <a href="/birth-plan-session" class="btn-accent inline-block">Book a 1:1 Session</a>
      <p class="text-sm text-tjb-gray mt-2">Or <a href="/birth-plan-course/">take the free birth plan course</a> to prepare step by step.</p>
      </div>

      <h2>Free Birth Plan for Plano Families</h2>
      <p>Download the same birth plan template Plano families use to prepare for hospital conversations — free, structured, and designed to be read by a nurse in two minutes. Then use the <a href="/birth-plan-checklist/">birth plan checklist</a> to make sure nothing gets missed.</p>
      <div class="my-8 not-prose">
        <a href="#download" class="btn-primary inline-block">Download Free Birth Plan</a>
      </div>

    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-tjb-cream-50">
    <div class="max-w-3xl mx-auto px-6">
      
      <div class="bg-white border-2 border-tjb-lavender-200 p-5 rounded-lg mb-6">
        <h3 class="font-semibold text-lg text-tjb-charcoal mb-2">What True Joy Birthing Actually Does for You</h3>
        <p class="text-tjb-gray mb-2">True Joy Birthing isn't a doula matching service, and we're not necessarily your in-person doula in Plano. We're the step before — and alongside — all of that.</p>
        <p class="text-tjb-gray mb-2">Shelbi built the free Joyful Birth Plan because she saw families show up to the hospital without their preferences written down, every single time. The birth plan template, the checklist, the free course — these are the tools that help you walk in prepared, whether you end up hiring a local doula or going it alone.</p>
        <p class="text-tjb-gray">If you do find a doula in Plano, great — bring your plan and use it together. If you're still looking, or if hiring a doula isn't in the budget right now, the birth plan is free and it works.</p>
      </div>

      <h2 class="text-2xl font-bold mb-8">Frequently Asked Questions — Plano</h2>
      <div class="space-y-6">
        {faqs.map((faq, i) => (
          <div class="border border-tjb-lavender-200 rounded-lg p-5 bg-white">
            <h3 class="text-lg font-semibold mb-2">{faq.q}</h3>
            <p class="text-tjb-gray">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA band -->
  <section id="download-pdf" class="bg-tjb-lavender-100 py-16">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Get Your Free Birth Plan</h2>
      <p class="text-tjb-gray mb-8">Join families in Plano and across Texas who walk into their births with a clear plan and the words to stand by it. <a href="/doula-cost/">See doula costs across Texas</a>.</p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto mb-4" action="#" method="POST">
        <input name="email" type="email" placeholder="Your email" class="flex-1 px-5 py-3.5 rounded-full border border-tjb-lavender-300 focus:outline-none focus:border-tjb-rose-400 bg-white text-[0.9375rem]" required />
        <button type="submit" class="btn-primary whitespace-nowrap">Get My Plan →</button>
      </form>
      <p class="text-xs text-tjb-gray-300">No spam. Just a free birth plan and occasional tips you can actually use.</p>
    </div>
  </section>

</Layout>
