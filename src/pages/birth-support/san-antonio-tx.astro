---
import Layout from '../../layouts/Layout.astro';

const city = "San Antonio";
const state = "TX";
const pageTitle = `Doula San Antonio TX — Birth Support, Costs & Free Joyful Birth Plan`;
const pageDesc = `Find a doula in San Antonio, TX — local hospital info, doula costs, Medicaid status, and the free Joyful Birth Plan for local families.`;
const pageUrl = `https://truejoybirthing.com/birth-support/san-antonio-tx`;

const hospitals = ["University Hospital", "Baptist Medical Center", "CHRISTUS Santa Rosa Hospital"];
const birthCenters = [];
const costLow = 700;
const costHigh = 2200;
const medicaidNote = "Texas Medicaid doula coverage is expanding statewide. San Antonio-area families should check current coverage with their Medicaid managed care organization.";
const insuranceNote = "San Antonio's large military community (Joint Base San Antonio) means some families may have access to Tricare or VA maternity benefits. Coverage for doula support varies.";
const culture = "San Antonio has a rich, diverse birth community with strong cultural traditions around family-centered birth. The city has a mix of large hospital systems and a growing interest in midwife-attended and doula-supported births.";
const shelbiServesHere = false;

const faqs = [
  { q: "How much does a doula cost in San Antonio?", a: "$700 to $2,200. San Antonio's doula market tends to be more affordable than Austin or Dallas, with many experienced doulas offering sliding scale options." },
  { q: "Does Medicaid cover doulas in San Antonio?", a: "Texas is expanding Medicaid doula benefits statewide. Contact your San Antonio-area Medicaid plan for current coverage and eligibility." },
  { q: "Are there birth centers in San Antonio?", a: "San Antonio's birth center scene is smaller than Austin's, but options are growing. Most families deliver at University Hospital, Baptist Medical Center, or CHRISTUS Santa Rosa." },
  { q: "Does True Joy Birthing work with San Antonio families?", a: "Yes. the free birth plan course to prepare step by step. The free birth plan and app are designed for hospital and birth center births in any city, including San Antonio. Virtual confidence sessions available." }
];
const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "Birth Support", "url": "https://truejoybirthing.com/birth-support/"}, {"name": "San Antonio, TX", "url": "https://truejoybirthing.com/birth-support/san-antonio-tx"}];
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "@id": "https://truejoybirthing.com/birth-support/san-antonio-tx#faq",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    },
    {
      "@type": "LocalBusiness",
      "@id": "https://truejoybirthing.com/birth-support/san-antonio-tx#local",
      "name": "True Joy Birthing",
      "url": "https://truejoybirthing.com/birth-support/san-antonio-tx",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "San Antonio",
        "addressRegion": "TX",
        "addressCountry": "US"
      },
      "areaServed": { "@type": "City", "name": "San Antonio" },
      "parentOrganization": { "@id": "https://truejoybirthing.com/#organization" }
    }
  ]
};

---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}

  breadcrumbList={breadcrumbList}
  schema={schema}
>

  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div>
          <h1 class="text-3xl md:text-4xl font-bold mb-4">Find a Doula in San Antonio, TX</h1>
          <p class="text-lg text-tjb-gray mb-6">
        If you're <a href="/what-is-a-doula/">looking for a doula</a> in San Antonio, TX, this guide covers local hospital options, doula costs, Medicaid status, and the free Joyful Birth Plan families trust here.
      </p>
      <p class="text-tjb-gray mb-4">If you're heading to University Hospital from the North Side during rush hour, skip Loop 410 — take Babcock to Wurzbach to Medical Drive instead. It'll save you 15–20 minutes when you're already running late for an appointment. And if evening walks are helping with those Braxton Hicks contractions, the River Walk loop near the Pearl is shaded and flat — a lot of San Antonio moms swear by it in the third trimester.</p>
          <div class="flex flex-col sm:flex-row gap-3">
        <a href="#download-pdf" class="bg-tjb-lavender-500 text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-rose-500 transition">Download Free Birth Plan</a>
        <a href="https://apps.apple.com/app/true-joy-birthing" class="bg-tjb-cream-50 text-tjb-lavender-500 border-2 border-tjb-lavender-500 px-6 py-3 rounded-lg font-semibold hover:bg-tjb-cream transition">Get the Free App</a>
      </div>
        </div>
        <div class="relative">
          <img
            src="/images/san-antonio-texas-birth-doula-skyline.webp"
            alt="Skyline of San Antonio, Texas, where families search for birth doulas and plan their hospital births."
            class="w-full h-64 md:h-80 object-cover rounded-2xl shadow-lg"
            width="1200"
            height="800"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">

      <h2>What Birth Support Looks Like in San Antonio</h2>
      <p>San Antonio has a rich, diverse birth community with strong cultural traditions around family-centered birth. The city has a mix of large hospital systems and a growing interest in midwife-attended and doula-supported births.</p>
      <p>Whether this is your first baby or you're preparing for a VBAC, <a href="/benefits-of-a-doula/">understanding the benefits of having a doula</a> can help you decide what support is right for your San Antonio birth.</p>

      

      <p>University Hospital, affiliated with UT Health San Antonio, is the region's public teaching hospital with a Level IV NICU — the highest level — and handles the most complex pregnancies in South Texas alongside a large Medicaid population. Doulas are generally welcome, and having someone who knows how to navigate this busy system makes a real difference. <a href="/birth-plan-template/">Use our free hospital birth plan template</a> to get started.</p>

      <p>Baptist Medical Center, in downtown San Antonio, is a high-volume L&amp;D hospital with a Level III NICU. CHRISTUS Santa Rosa Hospital, in the Alamo Heights area, provides strong children's and women's services alongside birth care. If we're being real, San Antonio's hospital systems are big and busy — having your preferences written down before you walk in is the single best thing you can do for yourself.</p>

      <p class="text-sm text-tjb-gray italic">Hospitals and birth centers mentioned for context only. True Joy Birthing does not endorse any specific provider. Always confirm visitor and doula policies during your hospital tour.</p>

      <h2>How Much Does a Doula Cost in San Antonio?</h2>
      <p>In San Antonio, birth doula services typically range from <strong>$700 to $2,200</strong> depending on experience, package, and whether the doula offers add-on services like <a href="/postpartum-doula/">postpartum visits</a>. <a href="/doula-cost/">See our full doula cost guide</a> for what's typically included.</p>
      <p>San Antonio's large military community (Joint Base San Antonio) means some families may have access to Tricare or VA maternity benefits. Coverage for doula support varies.</p>
      <p><strong>HSA/FSA:</strong> Many families don't realize that doula services can often be paid for with HSA or FSA funds, since birth support qualifies as a medical expense under most plans. Check with your plan administrator to confirm what's eligible and whether you need a letter from your provider.</p>
      <p>Not sure what to look for? <a href="/how-to-choose-a-doula/">Here's how to choose a doula</a> who fits your birth preferences and budget.</p>
      <p><strong>Medicaid Note:</strong> Texas Medicaid doula coverage is expanding statewide. San Antonio-area families should check current coverage with their Medicaid managed care organization.</p>

      <h2>Next Steps: Your Doula in San Antonio, TX — Plan Your Birth</h2>
      <p>No matter where you deliver in San Antonio, a clear, organized birth plan helps you communicate your preferences to the team in your birth room. Start with the <a href="/birth-plan-template/">free birth plan template</a>, then use the <a href="/birth-plan-checklist/">birth plan checklist</a> to make sure nothing gets missed.</p>
      <a href="#download-pdf" class="inline-block bg-tjb-lavender-500 text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-rose-500 transition mb-6">Download the Free Birth Plan</a>
      <p class="mt-2 text-sm text-tjb-gray">Or <a href="/birth-plan-course/">take the free birth plan course</a> step by step.</p>

      
      <div class="bg-white border-2 border-tjb-lavender-200 p-5 rounded-lg mb-6">
        <h3 class="font-semibold text-lg text-tjb-charcoal mb-2">What True Joy Birthing Actually Does for You</h3>
        <p class="text-tjb-gray mb-2">True Joy Birthing isn't a doula matching service, and we're not necessarily your in-person doula in San Antonio. We're the step before — and alongside — all of that.</p>
        <p class="text-tjb-gray mb-2">Shelbi built the free Joyful Birth Plan because she saw families show up to the hospital without their preferences written down, every single time. The birth plan template, the checklist, the free course — these are the tools that help you walk in prepared, whether you end up hiring a local doula or going it alone.</p>
        <p class="text-tjb-gray">If you do find a doula in San Antonio, great — bring your plan and use it together. If you're still looking, or if hiring a doula isn't in the budget right now, the birth plan is free and it works.</p>
      </div>

      <h2>Common Questions in San Antonio</h2>
      <div class="space-y-4">
        <div>
          <h3 class="font-semibold mb-1">How much does a doula cost in San Antonio?</h3>
          <p class="text-tjb-gray">$700 to $2,200. San Antonio's doula market tends to be more affordable than Austin or Dallas, with many experienced doulas offering sliding scale options.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">Does Medicaid cover doulas in San Antonio?</h3>
          <p class="text-tjb-gray">Texas is expanding Medicaid doula benefits statewide. Contact your San Antonio-area Medicaid plan for current coverage and eligibility.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">Are there birth centers in San Antonio?</h3>
          <p class="text-tjb-gray">San Antonio's birth center scene is smaller than Austin's, but options are growing. Most families deliver at University Hospital, Baptist Medical Center, or CHRISTUS Santa Rosa.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">Does True Joy Birthing work with San Antonio families?</h3>
          <p class="text-tjb-gray">Yes. The free birth plan and app are designed for hospital and birth center births in any city, including San Antonio. Virtual confidence sessions available.</p>
        </div>
      </div>

      <h2>Nearby Resources</h2>
      <a href="/birth-support" class="text-tjb-lavender-500 font-semibold hover:underline">See all cities →</a>

    </div>
  </section>

  <section id="download-pdf" class="py-16 bg-tjb-cream">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Get Your Free Joyful Birth Plan</h2>
      <p class="text-tjb-gray mb-8">Built by a doula for San Antonio-area moms planning their birth.</p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" action="#" method="POST">
        <input name="email" type="email" placeholder="Your email" class="flex-1 px-4 py-3 rounded-lg border border-tjb-lavender-300 focus:outline-none focus:border-tjb-lavender-500" required />
        <button type="submit" class="bg-tjb-lavender-500 text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-rose-500 transition whitespace-nowrap">Get My Plan →</button>
      </form>
      <p class="text-xs text-tjb-gray/70 mt-4">No spam. Just a free birth plan and occasional tips you can actually use.</p>
    </div>
  </section>

</Layout>
