---
import Layout from '../../layouts/Layout.astro';

const city = "San Antonio";
const state = "TX";
const pageTitle = `Birth Support in ${city}, ${state}`;
const pageDesc = `Find birth support resources in San Antonio, TX — local hospital info, doula costs, Medicaid status, and a free birth plan built for local families.`;
const pageUrl = `https://truejoybirthing.com/birth-support/san-antonio-tx`;

const hospitals = ["University Hospital", "Baptist Medical Center", "CHRISTUS Santa Rosa Hospital"];
const birthCenters = [];
const costLow = 700;
const costHigh = 2200;
const medicaidNote = "Texas Medicaid doula coverage is expanding statewide. San Antonio-area families should check current coverage with their Medicaid managed care organization.";
const insuranceNote = "San Antonio's large military community (Joint Base San Antonio) means some families may have access to Tricare or VA maternity benefits. Coverage for doula support varies.";
const culture = "San Antonio has a rich, diverse birth community with strong cultural traditions around family-centered birth. The city has a mix of large hospital systems and a growing interest in midwife-attended and doula-supported births.";
const shelbiServesHere = false;

const faqs = [
  { q: "How much does a doula cost in San Antonio?", a: "$700 to $2,200. San Antonio's doula market tends to be more affordable than Austin or Dallas, with many experienced doulas offering sliding scale options." },
  { q: "Does Medicaid cover doulas in San Antonio?", a: "Texas is expanding Medicaid doula benefits statewide. Contact your San Antonio-area Medicaid plan for current coverage and eligibility." },
  { q: "Are there birth centers in San Antonio?", a: "San Antonio's birth center scene is smaller than Austin's, but options are growing. Most families deliver at University Hospital, Baptist Medical Center, or CHRISTUS Santa Rosa." },
  { q: "Does True Joy Birthing work with San Antonio families?", a: "Yes. The free birth plan and app are designed for hospital and birth center births in any city, including San Antonio. Virtual confidence sessions available." }
];
---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}
>

  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-4xl mx-auto px-6">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">Birth Support in San Antonio, TX</h1>
      <p class="text-lg text-tjb-gray mb-6">
        Local hospital options, doula costs, and Medicaid status — plus the free birth plan template families in San Antonio use to feel confident and prepared.
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="#download-pdf" class="bg-tjb-lavender-500 text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-rose-500 transition">Download Free Birth Plan</a>
        <a href="https://apps.apple.com/app/true-joy-birthing" class="bg-tjb-cream-50 text-tjb-lavender-500 border-2 border-tjb-lavender-500 px-6 py-3 rounded-lg font-semibold hover:bg-tjb-cream transition">Get the Free App</a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">

      <h2>What Birth Support Looks Like in San Antonio</h2>
      <p>San Antonio has a rich, diverse birth community with strong cultural traditions around family-centered birth. The city has a mix of large hospital systems and a growing interest in midwife-attended and doula-supported births.</p>

      <p>Families in San Antonio often deliver at hospitals including:</p>
      <ul>
        <li>University Hospital</li>
        <li>Baptist Medical Center</li>
        <li>CHRISTUS Santa Rosa Hospital</li>
      </ul>
      <p class="text-sm text-tjb-gray italic">Hospitals mentioned for context only. True Joy Birthing does not endorse any specific provider.</p>

      <h2>How Much Does a Doula Cost in San Antonio?</h2>
      <p>In San Antonio, birth doula services typically range from <strong>$700 to $2,200</strong> depending on experience, package, and whether the doula offers add-on services like postpartum visits.</p>
      <p>San Antonio's large military community (Joint Base San Antonio) means some families may have access to Tricare or VA maternity benefits. Coverage for doula support varies.</p>
      <p><strong>Medicaid Note:</strong> Texas Medicaid doula coverage is expanding statewide. San Antonio-area families should check current coverage with their Medicaid managed care organization.</p>

      <h2>Build Your Birth Plan for San Antonio</h2>
      <p>No matter where you deliver in San Antonio, a clear, organized birth plan helps you communicate your preferences to the team in your birth room.</p>
      <a href="#download-pdf" class="inline-block bg-tjb-lavender-500 text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-rose-500 transition mb-6">Download the Free Birth Plan</a>

      <h2>Common Questions in San Antonio</h2>
      <div class="space-y-4">
        <div>
          <h3 class="font-semibold mb-1">How much does a doula cost in San Antonio?</h3>
          <p class="text-tjb-gray">$700 to $2,200. San Antonio's doula market tends to be more affordable than Austin or Dallas, with many experienced doulas offering sliding scale options.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">Does Medicaid cover doulas in San Antonio?</h3>
          <p class="text-tjb-gray">Texas is expanding Medicaid doula benefits statewide. Contact your San Antonio-area Medicaid plan for current coverage and eligibility.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">Are there birth centers in San Antonio?</h3>
          <p class="text-tjb-gray">San Antonio's birth center scene is smaller than Austin's, but options are growing. Most families deliver at University Hospital, Baptist Medical Center, or CHRISTUS Santa Rosa.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">Does True Joy Birthing work with San Antonio families?</h3>
          <p class="text-tjb-gray">Yes. The free birth plan and app are designed for hospital and birth center births in any city, including San Antonio. Virtual confidence sessions available.</p>
        </div>
      </div>

      <h2>Nearby Resources</h2>
      <a href="/birth-support" class="text-tjb-lavender-500 font-semibold hover:underline">See all cities →</a>

    </div>
  </section>

  <section id="download-pdf" class="py-16 bg-tjb-cream">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Download Your Free Birth Plan</h2>
      <p class="text-tjb-gray mb-8">Built by a doula for hospital-planning moms everywhere.</p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" action="#" method="POST">
        <input name="email" type="email" placeholder="Your email" class="flex-1 px-4 py-3 rounded-lg border border-tjb-lavender-300 focus:outline-none focus:border-tjb-lavender-500" required />
        <button type="submit" class="bg-tjb-lavender-500 text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-rose-500 transition whitespace-nowrap">Get My Plan →</button>
      </form>
      <p class="text-xs text-tjb-gray/70 mt-4">No spam. Just a free birth plan and occasional tips you can actually use.</p>
    </div>
  </section>

</Layout>
