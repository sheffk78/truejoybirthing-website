      <h2 class="text-2xl font-bold mb-2" style="font-family: 'DM Sans', sans-serif;">Your Questions About Doulas & Midwives in {city}</h2>
      <p class="text-tjb-gray mb-8">The things {city} moms ask us most, answered honestly.</p>
      <div class="space-y-6">
        {faqs.map((faq) => (
          <details class="border border-tjb-lavender-200 rounded-xl p-5 bg-white group">
            <summary class="text-lg font-semibold text-tjb-charcoal cursor-pointer list-none flex justify-between items-center">
              <span>{faq.q}</span>
              <svg class="w-5 h-5 text-tjb-lavender-500 transition-transform group-open:rotate-180 flex-shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="text-tjb-gray mt-3 faq-answer" set:html={faq.a} />
          </details>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══ Lead Capture (with banner image) ═══ -->
  <CityLeadCaptureForm city={city} />

  {cityVideoEmbeds[slug] && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VideoObject",
      "name": `${cityVideoEmbeds[slug].title}`,
      "description": cityVideoEmbeds[slug].description,
      "thumbnailUrl": `https://truejoybirthing.com/images/yt-thumb-${slug}.png`,
      "uploadDate": data.publishedDate || "2026-06-11",
      "contentUrl": `https://www.youtube.com/watch?v=${cityVideoEmbeds[slug].videoId}`,
      "embedUrl": `https://www.youtube-nocookie.com/embed/${cityVideoEmbeds[slug].videoId}`
    })} />
  )}
</Layout>

