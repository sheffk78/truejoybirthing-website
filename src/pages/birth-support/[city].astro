---
// ═══════════════════════════════════════════════════════════════
// Dynamic city birth-support page — single template for all cities
// Written directly to expectant moms, especially first-time moms
// Denver flagship pattern (June 2026): split hero, app showcase,
// testimonials, two-column section illustrations, centered doula cards,
// hospital thumbnails, serif H2s for story sections, CTA card with
// booklet mockup, lead capture with banner image
// ═══════════════════════════════════════════════════════════════
import Layout from '../../layouts/Layout.astro';
import CityLeadCaptureForm from '../../components/city/LeadCaptureForm.astro';
import AppShowcase from '../../components/AppShowcase.astro';
import { cities, citySlugs, type CityData } from '../../data/cities';
import { cityVideoEmbeds } from '../../data/video-embeds';

export function getStaticPaths() {
  return citySlugs.map((slug) => ({
    params: { city: slug },
    props: { data: cities[slug]!, slug },
  }));
}

const { data, slug } = Astro.props;
const {
  city, state, costLow, costHigh, culture,
  heroLocalDetail, hospitalDetails, birthCenterDetails,
  localDoulas, medicaidNote, insuranceNote, faqs, nearbyCities,
  testimonials,
  heroImage: heroImageSlug, supportSceneImage, supportSceneAlt, ogImage: ogImageSlug,
  midwifeInfo,
}: CityData = data;

// Medicaid helper (must come before pageDesc)
const medicaidCovers = !medicaidNote.includes('does not') && !medicaidNote.includes('does NOT');
const stateHubSlug = state.toLowerCase().replace(/\s+/g, '-');
const hasBirthCenters = birthCenterDetails.some((bc) => !bc.name.toLowerCase().includes('no '));

// State full name for breadcrumbs (SEO: "Colorado" not "CO")
const stateNames: Record<string, string> = {
  AL: 'Alabama', AK: 'Alaska', AZ: 'Arizona', AR: 'Arkansas', CA: 'California',
  CO: 'Colorado', CT: 'Connecticut', DE: 'Delaware', FL: 'Florida', GA: 'Georgia',
  HI: 'Hawaii', ID: 'Idaho', IL: 'Illinois', IN: 'Indiana', IA: 'Iowa',
  KS: 'Kansas', KY: 'Kentucky', LA: 'Louisiana', ME: 'Maine', MD: 'Maryland',
  MA: 'Massachusetts', MI: 'Michigan', MN: 'Minnesota', MS: 'Mississippi', MO: 'Missouri',
  MT: 'Montana', NE: 'Nebraska', NV: 'Nevada', NH: 'New Hampshire', NJ: 'New Jersey',
  NM: 'New Mexico', NY: 'New York', NC: 'North Carolina', ND: 'North Dakota', OH: 'Ohio',
  OK: 'Oklahoma', OR: 'Oregon', PA: 'Pennsylvania', RI: 'Rhode Island', SC: 'South Carolina',
  SD: 'South Dakota', TN: 'Tennessee', TX: 'Texas', UT: 'Utah', VT: 'Vermont',
  VA: 'Virginia', WA: 'Washington', WV: 'West Virginia', WI: 'Wisconsin', WY: 'Wyoming',
  DC: 'District of Columbia',
};
const stateFullName = stateNames[state] || state;

const pageTitle = `${city}, ${state} Birth Doula & Midwife | Costs & Medicaid`;
const pageDesc = `Looking for a doula or midwife in ${city}? Costs $${costLow}–$${costHigh}, ${medicaidCovers ? 'Medicaid covers doulas' : 'Medicaid does not cover doulas'}, hospital policies, and the free Joyful Birth Plan included.`;
const pageUrl = `https://truejoybirthing.com/birth-support/${slug}/`;
const ogImage = ogImageSlug || `https://truejoybirthing.com/images/og-city-${slug}.webp`;
const heroImage = heroImageSlug || '/images/doula-breastfeeding.webp';
const heroAlt = `${city} birth doula: costs, Medicaid, and hospital info for ${state} families`;
const supportImage = supportSceneImage || '/images/doula-walking.webp';
const supportImageAlt = supportSceneAlt || `A doula walking alongside an expectant mom, offering continuous labor support`;

// Section images — same across all locations (Jeff approved keeping
// photos consistent across cities; 4:3 aspect ratio for proper fit)
// ANTI-DISTORTION RULE: Every <img> with a known aspect ratio uses explicit
// aspect-[X/Y] class + object-cover. Source images should match their container
// ratio. If they don't match exactly, object-cover crops gracefully — but large
// mismatches mean significant content loss. Prefer matching ratios when possible.
// OG images are composed design assets (text + image), NOT raw photo crops.
const doulaCostImage = '/images/doula-holding-hands.webp';
const medicaidImage = '/images/hands-on-belly.webp';
const midwifeImage = '/images/midwife-heartbeat.webp';

// Build structured-data
const breadcrumbList = [
  { name: 'Home', url: 'https://truejoybirthing.com/' },
  { name: 'Birth Support', url: 'https://truejoybirthing.com/birth-support/' },
  { name: stateFullName, url: `https://truejoybirthing.com/birth-support/${state.toLowerCase()}/` },
  { name: `${city}, ${state}`, url: pageUrl },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${pageUrl}#article`,
      headline: `${city} Doula & Midwife: Costs, Hospitals & Medicaid`,
      description: pageDesc,
      author: { '@type': 'Organization', '@id': 'https://truejoybirthing.com/#organization' },
      publisher: { '@type': 'Organization', '@id': 'https://truejoybirthing.com/#organization' },
      ...(data.publishedDate ? { datePublished: data.publishedDate } : {}),
      mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
    },
    {
      '@type': 'FAQPage',
      '@id': `${pageUrl}#faq`,
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        url: `${pageUrl}#faq-${f.q.toLowerCase().includes('cost') ? 'cost' : f.q.toLowerCase().includes('medicaid') ? 'medicaid' : f.q.toLowerCase().includes('true joy') ? 'brand' : 'hospital'}`,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
    {
      '@type': 'Service',
      '@id': `${pageUrl}#service`,
      name: `Joyful Birth Plan Resources for ${city} Families`,
      url: pageUrl,
      image: ogImage,
      areaServed: {
        '@type': 'City',
        name: city,
        ...(data.lat && data.lng ? {
          geo: {
            '@type': 'GeoCoordinates',
            latitude: data.lat,
            longitude: data.lng,
          },
        } : {}),
      },
      provider: { '@id': 'https://truejoybirthing.com/#organization' },
      serviceType: 'Birth Plan Resources',
      description: `Joyful Birth Plan tools, hospital info, and doula and midwife cost guides for families in ${city}, ${state}.`,
      ...(data.publishedDate ? { datePublished: data.publishedDate } : {}),
    },
    // MedicalOrganization for each hospital (schema helps Google understand
    // the medical facilities serving this city, whether or not they have a URL)
    ...hospitalDetails.map((h, i) => ({
      '@type': 'MedicalOrganization',
      '@id': `${pageUrl}#hospital-${i}`,
      name: h.name,
      ...(h.address ? {
        address: {
          '@type': 'PostalAddress',
          addressLocality: city,
          addressRegion: state,
          addressCountry: 'US',
          streetAddress: h.address.split(',')[0].trim(),
        },
      } : {}),
      ...(h.url ? { url: h.url } : { url: pageUrl }),
    })),
    {
      '@type': 'LocalBusiness',
      '@id': `${pageUrl}#local-business`,
      name: `True Joy Birthing — ${city}`,
      description: `Birth doula and midwife directory, hospital info, and Joyful Birth Plan resources for families in ${city}, ${state}.`,
      url: pageUrl,
      areaServed: {
        '@type': 'City',
        name: city,
        containedInPlace: { '@type': 'State', name: stateFullName },
      },
      parentOrganization: { '@id': 'https://truejoybirthing.com/#organization' },
      ...(data.lat && data.lng ? {
        geo: {
          '@type': 'GeoCoordinates',
          latitude: data.lat,
          longitude: data.lng,
        },
      } : {}),
    },
    {
      '@type': 'SpeakableSpecification',
      '@id': `${pageUrl}#speakable`,
      cssSelector: ['.prose h2', '.prose h3', '.faq-answer'],
    },
  ],
};
---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}
  ogImage={ogImage}
  breadcrumbList={breadcrumbList}
  schema={schema}
>

  
  <!-- ═══ Breadcrumb ═══ -->
  <nav aria-label="Breadcrumb" class="bg-tjb-cream pt-4 pb-2">
    <div class="max-w-7xl mx-auto px-6">
      <ol class="flex items-center gap-1.5 flex-wrap text-sm text-tjb-gray">
        <li class="flex items-center gap-1.5">
          <a href="https://truejoybirthing.com/" class="text-tjb-lavender-600 hover:underline">Home</a>
          <span class="text-tjb-gray/50">›</span>
        </li>
        <li class="flex items-center gap-1.5">
          <a href="https://truejoybirthing.com/birth-support/" class="text-tjb-lavender-600 hover:underline">Birth Support</a>
          <span class="text-tjb-gray/50">›</span>
        </li>
        <li class="flex items-center gap-1.5">
          <a href={`/birth-support/${stateHubSlug}/`} class="text-tjb-lavender-600 hover:underline">{stateFullName}</a>
          <span class="text-tjb-gray/50">›</span>
        </li>
        <li class="text-tjb-charcoal font-medium">{city}, {state}</li>
      </ol>
    </div>
  </nav>

  <!-- ═══ Hero — Split Layout (55% text / 45% image) ═══ -->
  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div>
          <p class="eyebrow text-tjb-rose-500 uppercase text-xs font-semibold tracking-widest mb-4">{city} Doula & Midwife Support</p>
          <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
          <h1 class="text-3xl md:text-4xl font-bold mb-4" style="font-family: 'DM Serif Display', Georgia, serif;">{city} Doula & Midwife: Costs, Hospitals & Medicaid</h1>
          <p class="text-lg text-tjb-charcoal font-semibold mb-2">True Joy Birthing is a free birth plan app and doula directory for first-time moms in {city}. Whether you're looking for a <strong>doula or midwife in {city}</strong>, building your birth plan, or figuring out what support even looks like — everything here is free.</p>
          <p class="text-tjb-gray mb-6">Doulas, midwives, hospital policies, and costs, broken down so you can walk in prepared. This guide covers <a href="/doula-cost/" class="text-tjb-rose-600 hover:underline">how much doulas cost</a>, <a href="/medicaid-doula-coverage/" class="text-tjb-rose-600 hover:underline">whether Medicaid covers a doula</a>, and which hospitals welcome birth partners. New here? <a href="/what-is-a-doula/" class="text-tjb-rose-600 hover:underline">Learn what a doula actually does</a>.</p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="btn-primary text-center">Build Your Birth Plan in the App</a>
            <a href="/birth-plan-template/" class="btn-secondary text-center">Or download the free PDF →</a>
          </div>
          <p class="text-xs text-tjb-gray mt-3">Free · No account needed · Works on iPhone</p>
          {heroLocalDetail && (
            <p class="text-sm text-tjb-gray/80 italic mt-4">{heroLocalDetail}</p>
          )}
        </div>
        <div class="relative">
          {heroImageSlug ? (
            <picture>
              <source
                type="image/avif"
                srcset={`/images/${slug}-birth-doula-skyline-600.avif 600w,
                        /images/${slug}-birth-doula-skyline.avif 1200w`}
                sizes="(max-width: 768px) 100vw, 50vw"
              />
              <source
                type="image/webp"
                srcset={`/images/${slug}-birth-doula-skyline-600.webp 600w,
                        /images/${slug}-birth-doula-skyline.webp 1200w`}
                sizes="(max-width: 768px) 100vw, 50vw"
              />
              <img
                src={heroImage}
                alt={heroAlt}
                class="w-full aspect-[3/2] object-cover rounded-2xl shadow-lg"
                width="1200"
                height="800"
                loading="eager"
                fetchpriority="high"
              />
            </picture>
          ) : (
            <picture>
              <source
                type="image/avif"
                srcset="/images/doula-breastfeeding-600.avif 600w,
                        /images/doula-breastfeeding.avif 1200w"
                sizes="(max-width: 768px) 100vw, 50vw"
              />
              <source
                type="image/webp"
                srcset="/images/doula-breastfeeding-600.webp 600w,
                        /images/doula-breastfeeding-1200.webp 1200w"
                sizes="(max-width: 768px) 100vw, 50vw"
              />
              <img
                src="/images/doula-breastfeeding.webp"
                alt={heroAlt}
                class="w-full aspect-[3/2] object-cover rounded-2xl shadow-lg"
                width="1200"
                height="800"
                loading="eager"
                fetchpriority="high"
              />
            </picture>
          )}
        </div>
      </div>
    </div>
  </section>


  <!-- ═══ App Showcase ═══ -->
  <AppShowcase variant="sans" />


  <!-- ═══ What the Free App Offers ═══ -->
  <section class="py-16 bg-tjb-cream-50">
    <div class="max-w-4xl mx-auto px-6">
      <p class="eyebrow text-tjb-rose-500 uppercase text-xs font-semibold tracking-widest mb-4 text-center">Free app</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto mb-6"></div>
      <h2 class="text-2xl md:text-3xl font-bold text-tjb-charcoal mb-6 text-center" style="font-family: 'DM Sans', sans-serif;">What the Free App Offers</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
          <p class="font-semibold text-tjb-charcoal mb-2">9 guided sections</p>
          <p class="text-sm text-tjb-gray">Hospital preferences, pain management options, who's in the room, feeding preferences, postpartum plans — each section walks you through what each choice means so nothing gets missed. Answer a few questions at a time, save your progress, and come back whenever you want. Your plan builds as you go, so it never feels overwhelming.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
          <p class="font-semibold text-tjb-charcoal mb-2">Find local doulas</p>
          <p class="text-sm text-tjb-gray">Browse and connect with doulas and midwives serving {city} right inside the app. See their services, cost ranges, and availability without searching elsewhere. Many {city} parents use the app to message providers directly and find someone who fits their schedule and personality.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
          <p class="font-semibold text-tjb-charcoal mb-2">Printable PDF birth plan</p>
          <p class="text-sm text-tjb-gray">Export your finished plan as a PDF to share with your provider, doula, or hospital. Easy to update anytime — not a static document you fill out once.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
          <p class="font-semibold text-tjb-charcoal mb-2">Completely free</p>
          <p class="text-sm text-tjb-gray">No account needed, no credit card, no time limit. Works on iPhone. Download it, build your plan, share it — that's it.</p>
        </div>
      </div>
      <div class="text-center mt-8">
        <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="btn-primary">Download on the App Store →</a>
      </div>
    </div>
  </section>


  <!-- ═══ City Video Guide (YouTube Embed) ═══ -->
  {cityVideoEmbeds[slug] && (
    <section class="py-12 bg-tjb-cream">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-8">
          <p class="eyebrow text-tjb-rose-500 uppercase text-xs font-semibold tracking-widest mb-4">Video guide</p>
          <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto mb-6"></div>
          <h2 class="text-2xl md:text-3xl font-bold text-tjb-charcoal mb-3" style="font-family: 'DM Sans', sans-serif;">{cityVideoEmbeds[slug].title}</h2>
          <p class="text-tjb-gray max-w-2xl mx-auto">{cityVideoEmbeds[slug].description}</p>
        </div>
        <div class="aspect-video rounded-xl overflow-hidden shadow-lg bg-black">
          <iframe
            width="100%"
            height="100%"
            src={`https://www.youtube-nocookie.com/embed/${cityVideoEmbeds[slug].videoId}`}
            title={cityVideoEmbeds[slug].title}
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </section>
  )}


  <!-- ═══ Doulas & Midwives Serving {city} ═══ -->
  {localDoulas && localDoulas.length > 0 ? (
    <section class="py-20 bg-tjb-cream">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-10">
          <p class="eyebrow text-tjb-rose-500 uppercase text-xs font-semibold tracking-widest mb-4">Local support</p>
          <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto mb-6"></div>
          <h2 class="text-2xl md:text-3xl font-bold text-tjb-charcoal mb-4" style="font-family: 'DM Sans', sans-serif;">Doulas & Midwives Serving {city}</h2>
          <p class="text-tjb-gray max-w-2xl mx-auto">Real people, real support: here are doulas and midwives who serve {city} families. Every listing is a practicing provider, not an ad.</p>
        </div>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 not-prose">
          {localDoulas.map((doula) => {
            const verified = doula.isVerified === true;
            return (
            <div class={`bg-white relative rounded-xl p-6 shadow-sm border hover:shadow-md transition-shadow duration-200 flex flex-col items-center text-center ${doula.isAmbassador ? 'border-2 border-tjb-rose-300 shadow-md' : 'border-tjb-lavender-200/50 hover:border-tjb-lavender-300'}`}>
              {/* Verified badge — sage corner pill */}
              {verified && (
                <span class="absolute top-3 right-3 inline-flex items-center gap-1 bg-tjb-sage-100 text-tjb-charcoal text-xs font-medium px-2.5 py-0.5 rounded-full border border-tjb-sage" role="status" aria-label="Verified listing">
                  <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M10 3L4.5 8.5L2 6" stroke="#2A2A2A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Verified
                </span>
              )}
              {/* Photo or initial monogram */}
              {doula.photo ? (
                <img src={doula.photo} alt={`${doula.name}, doula`} class="w-14 h-14 rounded-full object-cover mb-4" width="56" height="56" loading="lazy" />
              ) : (
                <div class={`w-14 h-14 rounded-full flex items-center justify-center mb-4 ${doula.isMidwife ? 'bg-tjb-lavender-100' : 'bg-tjb-lavender-100'}`}>
                  <span class="text-2xl font-semibold" style="font-family: 'Cormorant Garamond', Georgia, serif;" className={doula.isAmbassador ? 'text-tjb-rose-600' : doula.isMidwife ? 'text-tjb-lavender-700' : 'text-tjb-charcoal'}>{doula.name.split(' ').map((n: string) => n[0]).join('')}</span>
                </div>
              )}
              <h3 class="text-lg font-semibold text-tjb-charcoal leading-tight mb-1" style="font-family: 'Cormorant Garamond', Georgia, serif;">{doula.name}</h3>
              {doula.credential && <p class="text-sm text-tjb-lavender-600 font-medium mb-2">{doula.credential}</p>}
              {doula.practice && <p class="text-sm text-tjb-gray mb-1">{doula.practice}</p>}
              {doula.costRange && <p class="text-sm text-tjb-charcoal font-medium mb-2">{doula.costRange}</p>}
              {(doula.services && doula.services.length > 0) && (
                <div class="flex flex-wrap justify-center gap-1.5 mt-1 mb-2">
                  {/* Deduplicate — skip service tags that duplicate the credential text */}
                  {doula.services.filter((svc: string) => !doula.credential || svc !== doula.credential).map((svc: string) => (
                    <span class="inline-flex items-center bg-tjb-lavender-50 text-tjb-lavender-700 text-xs font-medium px-2 py-0.5 rounded-full border border-tjb-lavender-200">{svc}</span>
                  ))}
                </div>
              )}
              {doula.description && <p class="text-sm text-tjb-gray leading-relaxed mb-2">{doula.description}</p>}
              {doula.acceptsMedicaid && (
                <span class="inline-flex items-center bg-green-50 text-green-700 text-xs font-medium px-2.5 py-0.5 rounded-full border border-green-200 mb-2">
                  <svg class="w-3 h-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  Accepts Medicaid
                </span>
              )}
              {doula.serviceArea && doula.serviceArea.length > 0 && (
                <p class="text-xs text-tjb-gray/60 mb-2">Serves {doula.serviceArea.join(', ')}</p>
              )}
              <div class="flex-1"></div>
              <div class="flex flex-wrap justify-center gap-2 mt-2">
                {doula.isAmbassador && <span class="inline-flex items-center bg-tjb-lavender-100 text-tjb-lavender-700 text-xs font-medium px-2.5 py-0.5 rounded-full border border-tjb-lavender-200">Ambassador</span>}
                {doula.isMidwife && <span class="inline-flex items-center bg-tjb-lavender-100 text-tjb-lavender-700 text-xs font-medium px-2.5 py-0.5 rounded-full border border-tjb-lavender-200">Midwife</span>}
                <span class="inline-flex items-center bg-tjb-rose-50 text-tjb-rose-500 text-xs font-medium px-2.5 py-0.5 rounded-full border border-tjb-rose-200">{city}</span>
              </div>
              {doula.acceptingClients && (
                <div class="flex items-center justify-center gap-1.5 mt-2">
                  <span class="w-2 h-2 rounded-full bg-green-500"></span>
                  <span class="text-xs text-green-700 font-medium">{typeof doula.acceptingClients === 'string' ? doula.acceptingClients : 'Accepting clients'}</span>
                </div>
              )}
              {doula.url && <a href={doula.url} target="_blank" rel="noopener noreferrer" class="btn-primary mt-4 text-sm w-full">Visit website</a>}
            </div>
          )})}
        </div>
        <!-- Find a Doula CTA -->
        <div class="mt-10 max-w-5xl mx-auto not-prose">
          <div class="bg-tjb-lavender-50 border-2 border-tjb-lavender-200 rounded-xl p-6 md:p-8">
            <div class="flex flex-col md:flex-row gap-6 md:gap-8 items-center">
              <div class="md:w-[30%] flex-shrink-0 flex justify-center">
                <div class="phone-frame-sm w-[160px] md:w-[170px]">
                  <div class="phone-screen">
                    <img src="/images/tjb-app-birth-plan-builder.png" alt="True Joy Birthing app: find doulas and midwives near you" class="w-full h-full object-cover" width="390" height="844" loading="lazy" />
                  </div>
                </div>
              </div>
              <div class="md:w-[70%]">
                <h3 class="text-xl font-bold text-tjb-charcoal mb-3" style="font-family: 'DM Sans', sans-serif;">Find a doula or midwife near you</h3>
                <p class="text-tjb-gray leading-relaxed mb-4">The True Joy Birthing app lets you search for doulas, midwives, and birth professionals in your area. Filter by certification, services offered, and insurance coverage, so you can find the right support before your due date.</p>
                <a href="/birth-plan-app/" class="btn-primary">Try the free app →</a>
              </div>
            </div>
          </div>
        </div>
        <div class="text-center mt-6">
          <p class="text-sm text-tjb-gray">Listed providers are independent practitioners. True Joy Birthing does not endorse any specific provider.</p>
        </div>
      </div>
