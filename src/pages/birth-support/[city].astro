---
// ═══════════════════════════════════════════════════════════════
// Dynamic city birth-support page — single template for all cities
// ═══════════════════════════════════════════════════════════════
import Layout from '../../layouts/Layout.astro';
import { cities, citySlugs, type CityData } from '../../data/cities';

export function getStaticPaths() {
  return citySlugs.map((slug) => ({
    params: { city: slug },
    props: { data: cities[slug]!, slug },
  }));
}

const { data, slug } = Astro.props;
const {
  city, state, costLow, costHigh, culture,
  heroLocalDetail, hospitalDetails, birthCenterDetails,
  medicaidNote, insuranceNote, faqs, nearbyCities,
}: CityData = data;

const pageTitle = `Doula ${city} ${state} — Birth Support, Costs & Free Joyful Birth Plan`;
const pageDesc = `Free birth-plan resources for ${city}, ${state} families — hospital info, doula costs, Medicaid status, and the Joyful Birth Plan.`;
const pageUrl = `https://truejoybirthing.com/birth-support/${slug}`;
const heroImage = `/images/${slug.replace('-tx', '')}-texas-birth-doula-skyline.webp`;
const heroAlt = `Skyline of ${city}, Texas, where families search for birth doulas and plan their hospital births.`;

// Build structured-data
const breadcrumbList = [
  { name: 'Home', url: 'https://truejoybirthing.com/' },
  { name: 'Birth Support', url: 'https://truejoybirthing.com/birth-support/' },
  { name: `${city}, ${state}`, url: pageUrl },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'FAQPage',
      '@id': `${pageUrl}#faq`,
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
    {
      '@type': 'Service',
      '@id': `${pageUrl}#service`,
      name: `Free Birth-Plan Resources for ${city} Families`,
      url: pageUrl,
      areaServed: { '@type': 'City', name: city },
      provider: { '@id': 'https://truejoybirthing.com/#organization' },
      serviceType: 'Birth Plan Resources',
      description: `Free birth-plan tools, hospital info, and doula cost guides for families in ${city}, ${state}.`,
    },
  ],
};
---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}
  breadcrumbList={breadcrumbList}
  schema={schema}
>
  <!-- Hero -->
  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div>
          <h1 class="text-3xl md:text-4xl font-bold mb-4">Birth Plan Resources for {city}, {state} Families</h1>
          <p class="text-lg text-tjb-gray mb-6">
            Preparing for birth in {city}, {state}? This guide covers local hospital options, doula costs, Medicaid status, and the free Joyful Birth Plan families use here.
          </p>
          {heroLocalDetail && (
            <p class="text-lg text-tjb-gray mb-6">{heroLocalDetail}</p>
          )}
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="#download-pdf" class="bg-tjb-lavender-600 text-white px-6 py-3 rounded-full font-semibold hover:bg-tjb-rose-500 transition">
              Download Free Birth Plan
            </a>
            <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="bg-tjb-cream-50 text-tjb-lavender-600 border-2 border-tjb-lavender-600 px-6 py-3 rounded-full font-semibold hover:bg-tjb-cream transition">
              Get the Free App
            </a>
          </div>
        </div>
        <div class="relative">
          <img
            src={heroImage}
            alt={heroAlt}
            class="w-full h-64 md:h-80 object-cover rounded-2xl shadow-lg"
            width="1200"
            height="800"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Main content -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">

      <!-- What Birth Support Looks Like -->
      <h2>What Birth Support Looks Like in {city}</h2>
      <p>{culture}</p>
      <p>Whether this is your first baby or you're preparing for a VBAC, <a href="/benefits-of-a-doula/">understanding the benefits of having a doula</a> can help you decide what support is right for your {city} birth.</p>

      {hospitalDetails.map((h) => (
        <p set:html={h.paragraph} />
      ))}
      {birthCenterDetails.map((bc) => (
        <p set:html={bc.paragraph} />
      ))}

      <p class="text-sm text-tjb-gray italic">Hospitals mentioned for context only. True Joy Birthing does not endorse any specific provider. Always confirm visitor and doula policies during your hospital tour.</p>

      <!-- Doula Costs -->
      <h2>Doula Costs in {city}</h2>
      <p>In the {city} area, doula services typically range from <strong>${costLow.toLocaleString()} to ${costHigh.toLocaleString()}</strong> depending on experience, package, and whether the doula offers add-on services like <a href="/postpartum-doula/">postpartum visits</a>. <a href="/doula-cost/">See our full doula cost guide</a> for what's typically included.</p>

      <!-- Medicaid & Insurance -->
      <h2>Medicaid & Insurance Coverage</h2>
      <p>{medicaidNote}</p>
      <p>{insuranceNote}</p>
      <p><strong>HSA/FSA:</strong> Many families don't realize that doula services can often be paid for with HSA or FSA funds, since birth support qualifies as a medical expense under most plans. Check with your plan administrator to confirm what's eligible and whether you need a letter from your provider.</p>
      <p>Not sure what to look for? <a href="/how-to-choose-a-doula/">Here's how to choose a doula</a> who fits your birth preferences and budget.</p>

      <div>
        <h2>Next Steps: Plan Your Birth in {city}, {state}</h2>
        <p>No matter where you deliver in {city}, a clear, organized birth plan helps you communicate your preferences to the team in your birth room. Start with the <a href="/birth-plan-template/">free birth plan template</a>, then use the <a href="/birth-plan-checklist/">birth plan checklist</a> to make sure nothing gets missed.</p>
        <a href="#download-pdf" class="inline-block bg-tjb-lavender-600 text-white px-6 py-3 rounded-full font-semibold hover:bg-tjb-rose-500 transition mb-6">
          Download the Free Birth Plan
        </a>
        <p class="mt-2 text-sm text-tjb-gray">Or <a href="/#download">get the free birth plan walkthrough in the app</a> step by step.</p>
        <div class="bg-tjb-cream p-4 rounded-lg mt-6">
          <p class="font-semibold text-tjb-lavender-600 mb-1">Free birth-prep tools for {city} families</p>
          <p class="text-sm text-tjb-gray">True Joy Birthing helps you prepare and connect with local doulas and midwives in your area. <a href="/#download">Download the free birth plan</a> or <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180">use the free app</a> to walk through your preferences step by step.</p>
        </div>
      </div>

    </div>
  </section>

  <!-- TJBD card + Nearby + FAQ -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6">

      <!-- What True Joy Birthing Actually Does for You -->
      <div class="bg-white border-2 border-tjb-lavender-200 p-5 rounded-lg mb-6">
        <h3 class="font-semibold text-lg text-tjb-charcoal mb-2">What True Joy Birthing Actually Does for You</h3>
        <p class="text-tjb-gray mb-2">True Joy Birthing isn't a doula matching service, and we're not necessarily your in-person doula in {city}. We're the step before — and alongside — all of that.</p>
        <p class="text-tjb-gray mb-2">Shelbi built the free Joyful Birth Plan because she saw families show up to the hospital without their preferences written down, every single time. The birth plan template, the checklist, the free app walkthrough — these are the tools that help you walk in prepared, whether you end up hiring a local doula or going it alone.</p>
        <p class="text-tjb-gray">If you do find a doula in {city}, great — bring your plan and use it together. If you're still looking, or if hiring a doula isn't in the budget right now, the birth plan is free and it works.</p>
      </div>

      {nearbyCities.length > 0 && (
        <div class="mb-8">
          <h2 class="text-xl font-bold mb-3">Nearby Cities</h2>
          <div class="flex flex-wrap gap-2">
            {nearbyCities.map((nSlug) => {
              const near = cities[nSlug];
              return near ? (
                <a href={`/birth-support/${nSlug}`} class="inline-block px-4 py-2 rounded-full border border-tjb-lavender-300 text-tjb-lavender-600 hover:bg-tjb-lavender-50 transition text-sm font-medium">
                  {near.city}
                </a>
              ) : null;
            })}
          </div>
        </div>
      )}

      <a href="/birth-support" class="text-tjb-lavender-600 font-semibold hover:underline">See all cities →</a>

    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-tjb-cream-50">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-2xl font-bold mb-8">Frequently Asked Questions — {city}</h2>
      <div class="space-y-6">
        {faqs.map((faq) => (
          <div class="border border-tjb-lavender-200 rounded-lg p-5 bg-white">
            <h3 class="text-lg font-semibold mb-2">{faq.q}</h3>
            <p class="text-tjb-gray">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA band -->
  <section id="download-pdf" class="bg-white border-y border-tjb-lavender-200/60 py-16">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Download Your Free Birth Plan</h2>
      <p class="text-tjb-gray mb-8 max-w-xl mx-auto leading-relaxed">
        A fillable PDF you can print or edit — free. For the full experience with a guided walkthrough, live updates, and doula sharing,
        <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="text-tjb-lavender-600 font-semibold hover:text-tjb-lavender-700 border-b border-transparent hover:border-tjb-lavender-600 transition-all">get the free app</a>.
      </p>
      <a href="/true-joy-birth-plan.pdf" download="true-joy-birth-plan.pdf" class="btn-primary inline-block mb-6">
        Download free PDF
      </a>
      <p class="text-sm text-tjb-gray mb-3">Print it, fill it out, hand it to your nurse.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6">
        <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="inline-flex items-center gap-2 text-tjb-lavender-600 font-semibold hover:text-tjb-lavender-700 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
          Get the free app — richer, updatable, shareable
        </a>
      </div>
    </div>
  </section>

</Layout>

<!-- Email-gated form removed: direct PDF download replaces email collection -->