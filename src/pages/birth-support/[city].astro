---
// ═══════════════════════════════════════════════════════════════
// Dynamic city birth-support page — single template for all cities
// Written directly to expectant moms, especially first-time moms
// ═══════════════════════════════════════════════════════════════
import Layout from '../../layouts/Layout.astro';
import CityLeadCaptureForm from '../../components/city/LeadCaptureForm.astro';
import { cities, citySlugs, type CityData } from '../../data/cities';

export function getStaticPaths() {
  return citySlugs.map((slug) => ({
    params: { city: slug },
    props: { data: cities[slug]!, slug },
  }));
}

const { data, slug } = Astro.props;
const {
  city, state, costLow, costHigh, culture,
  heroLocalDetail, hospitalDetails, birthCenterDetails, localDoulas,
  medicaidNote, insuranceNote, faqs, nearbyCities,
}: CityData = data;

const pageTitle = `${city} Birth Doula | Costs & Hospital Info | TJB`;
const pageDesc = `Doula costs, hospital policies, and Medicaid coverage in ${city}, ${state}. Plus a free Joyful Birth Plan template to walk in prepared.`;
const pageUrl = `https://truejoybirthing.com/birth-support/${slug}/`;
const ogImage = `https://truejoybirthing.com/images/og-city-${slug}.webp`;
const heroImage = `/images/${slug}-birth-doula-skyline.webp`;
const heroAlt = `Birth doula supporting a family during labor in ${city}, ${state} — local hospital birth support and doula cost info`;
const supportImage = `/images/doula-teaching.webp`;
const supportImageAlt = `A certified birth doula helping expectant parents prepare for their hospital birth — professional birth support and education`;

// Full state name lookup for breadcrumbs and schema
const stateNames: Record<string, string> = {
  AK: 'Alaska', AL: 'Alabama', AR: 'Arkansas', AZ: 'Arizona', CA: 'California',
  CO: 'Colorado', CT: 'Connecticut', DE: 'Delaware', FL: 'Florida', GA: 'Georgia',
  HI: 'Hawaii', IA: 'Iowa', ID: 'Idaho', IL: 'Illinois', IN: 'Indiana',
  KS: 'Kansas', KY: 'Kentucky', LA: 'Louisiana', MA: 'Massachusetts', MD: 'Maryland',
  MI: 'Michigan', MN: 'Minnesota', MO: 'Missouri', MS: 'Mississippi', MT: 'Montana',
  NC: 'North Carolina', ND: 'North Dakota', NE: 'Nebraska', NH: 'New Hampshire',
  NJ: 'New Jersey', NM: 'New Mexico', NV: 'Nevada', NY: 'New York', OH: 'Ohio',
  OK: 'Oklahoma', OR: 'Oregon', PA: 'Pennsylvania', RI: 'Rhode Island', SC: 'South Carolina',
  SD: 'South Dakota', TN: 'Tennessee', TX: 'Texas', UT: 'Utah', VA: 'Virginia',
  VT: 'Vermont', WA: 'Washington', WI: 'Wisconsin', WV: 'West Virginia', WY: 'Wyoming',
};
const stateFullName = stateNames[state] || state;

// Build structured-data — 4-level breadcrumbs for local SEO
const breadcrumbList = [
  { name: 'Home', url: 'https://truejoybirthing.com/' },
  { name: 'Birth Support', url: 'https://truejoybirthing.com/birth-support/' },
  { name: stateFullName, url: `https://truejoybirthing.com/birth-support/${state.toLowerCase()}/` },
  { name: `${city}, ${state}`, url: pageUrl },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'FAQPage',
      '@id': `${pageUrl}#faq`,
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        url: `${pageUrl}#faq-${f.q.toLowerCase().includes('cost') ? 'cost' : f.q.toLowerCase().includes('medicaid') ? 'medicaid' : f.q.toLowerCase().includes('true joy') ? 'brand' : 'hospital'}`,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]*>/g, '') },
      })),
    },
    {
      '@type': 'Service',
      '@id': `${pageUrl}#service`,
      name: `Joyful Birth-Plan Resources for ${city} Families`,
      url: pageUrl,
      image: `https://truejoybirthing.com${heroImage}`,
      areaServed: {
        '@type': 'City',
        name: city,
        containedInPlace: { '@type': 'State', name: state },
      },
      provider: { '@id': 'https://truejoybirthing.com/#organization' },
      serviceType: 'Birth Plan Resources',
      description: `Free birth-plan tools, hospital info, and doula cost guides for families in ${city}, ${state}.`,
    },
    {
      '@type': 'SpeakableSpecification',
      '@id': `${pageUrl}#speakable`,
      cssSelector: ['.prose h2', '.prose h3', '.faq-answer'],
    },
  ],
};
---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}
  ogImage={ogImage}
  breadcrumbList={breadcrumbList}
  schema={schema}
>
  <!-- Hero -->
  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div>
          <h1 class="text-3xl md:text-4xl font-bold mb-4">{city}, {state} Birth Doula & Hospital Info</h1>
          <p class="text-lg text-tjb-gray mb-4">
            Whether you're wondering if a doula is worth it, whether your hospital will let one in, or how you'll afford it — you're in the right place. This guide covers what {city} moms actually need to know about doulas, midwives, hospital policies, and costs.
          </p>
          {heroLocalDetail && (
            <p class="text-base text-tjb-gray italic mb-6" set:html={heroLocalDetail} />
          )}
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/birth-plan-template/" class="btn-primary text-center">
              Get Your Free Joyful Birth Plan
            </a>
            <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="btn-secondary text-center">
              Download the Free App
            </a>
          </div>
        </div>
        <div class="relative">
          <img
            src={heroImage}
            alt={heroAlt}
            class="w-full h-64 md:h-80 object-cover rounded-2xl shadow-lg"
            width="1200"
            height="800"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Main content -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">

      <!-- Breadcrumb nav -->
      <nav aria-label="Breadcrumb" class="not-prose mb-6 text-sm text-tjb-gray">
        <ol class="flex items-center gap-1.5 flex-wrap">
          {breadcrumbList.map((crumb, i) => (
            <li class="flex items-center gap-1.5">
              {i > 0 && <span aria-hidden="true" class="text-tjb-lavender-300">›</span>}
              {i < breadcrumbList.length - 1 ? (
                <a href={crumb.url} class="text-tjb-lavender-600 hover:underline">{crumb.name}</a>
              ) : (
                <span class="text-tjb-charcoal font-medium" aria-current="page">{crumb.name}</span>
              )}
            </li>
          ))}
        </ol>
      </nav>

      <!-- What Birth Support Looks Like -->
      <h2>What Doula & Midwife Support Looks Like in {city}</h2>
      <p>{culture}</p>
      <img
        src={supportImage}
        alt={supportImageAlt}
        class="w-full max-w-md mx-auto h-auto rounded-xl shadow-md my-6"
        width="1024"
        height="1536"
        loading="lazy"
      />

      <!-- Quick clarification -->
      <div class="bg-tjb-cream p-4 rounded-lg mb-6 not-prose">
        <p class="font-semibold text-tjb-lavender-600 mb-1">Not sure what the difference is?</p>
        <p class="text-sm text-tjb-gray">A <strong>midwife</strong> is your medical provider — she can deliver your baby, write prescriptions, and monitor your health. A <strong>doula</strong> is your support person — she keeps you comfortable, informed, and emotionally held, but doesn't do medical tasks. You can have both, and many {city} moms do. <a href="/what-is-a-doula/" class="text-tjb-lavender-600 hover:underline">Learn more about what a doula actually does →</a></p>
      </div>

      <p>Whether this is your first baby or you're preparing for a VBAC, <a href="/what-is-a-doula/">understanding what a doula does</a> — and <a href="/benefits-of-a-doula/">how a doula can change your birth experience</a> — can help you decide what support is right for you.</p>

      <!-- Can My Doula Come With Me? -->
      <h2>Can My Doula Come to the Hospital With Me in {city}?</h2>
      <p>This is one of the top questions {city} moms ask — and the answer matters. Most hospitals in the {city} area <strong>do allow doulas</strong>, and many have explicit policies supporting continuous doula support during labor. Post-COVID visitor restrictions have mostly lifted, and hospitals generally recognize that doulas are not visitors — they're part of your care team.</p>
      <p>That said, it's smart to <strong>call your hospital before labor starts</strong> and ask directly about their doula policy. Some questions to ask:</p>
      <ul>
        <li>"How many support people can I have in the delivery room?"</li>
        <li>"Does your hospital have a written doula policy I can review?"</li>
        <li>"Are doulas counted as visitors or as part of my care team?"</li>
        <li>"Is there a limit on support people during a C-section?"</li>
      </ul>
      <p>Your doula will also know the policies at {city} hospitals and can help you navigate any hoops. And if your hospital pushes back, your birth plan gives you a written document that shows you've thought this through — <a href="/birth-plan-template/">grab the free template here</a>.</p>

      <!-- Local Doulas & Midwives -->
      {localDoulas.length > 0 && (
        <h2>Doulas & Midwives Serving {city}</h2>
      )}
      {localDoulas.length > 0 && (
        <div class="grid gap-4 my-6 not-prose">
          {localDoulas.map((d) => (
            <div class="bg-tjb-cream/50 border border-tjb-lavender-200 rounded-xl p-4 flex items-start gap-4">
              <div class="flex-1">
                <h3 class="text-lg font-semibold text-tjb-charcoal">
                  {d.url ? (
                    <a href={d.url} target="_blank" rel="noopener noreferrer" class="text-tjb-lavender-600 hover:underline">{d.name} ↗</a>
                  ) : (
                    <span>{d.name}</span>
                  )}
                  {d.credential && <span class="text-sm font-normal text-tjb-gray ml-1">— {d.credential}</span>}
                  {d.isAmbassador && <span class="ml-2 inline-flex items-center bg-tjb-lavender-100 text-tjb-lavender-700 text-xs font-medium px-2 py-0.5 rounded-full">TJB Ambassador</span>}
                </h3>
                {d.practice && <p class="text-sm text-tjb-gray mt-0.5">{d.practice}</p>}
              </div>
            </div>
          ))}
        </div>
      )}
      {localDoulas.length === 0 && (
        <div class="bg-tjb-cream/30 border border-tjb-lavender-100 rounded-xl p-4 my-6 not-prose">
          <p class="text-sm text-tjb-gray"><strong>Looking for a doula in {city}?</strong> We're building our local directory — <a href="/ambassador/" class="text-tjb-lavender-600 hover:underline">if you're a doula or midwife, apply to be listed here</a>. In the meantime, <a href="https://www.dona.org/get-a-doula/" target="_blank" rel="noopener noreferrer" class="text-tjb-lavender-600 hover:underline">search DONA International's directory ↗</a> or check with your hospital's referral list.</p>
        </div>
      )}

      <!-- Hospital & Birth Center Info -->
      {hospitalDetails.length > 0 && (
        <h2>Hospital & Birth Center Info in {city}</h2>
      )}
      <p>Here's what you need to know about the hospitals where {city} moms deliver — including NICU levels, which matters if your baby needs extra care after birth.</p>
      {hospitalDetails.map((h) => (
        <div class="mb-6">
          {h.url ? (
            <h3 class="text-lg font-semibold mb-1"><a href={h.url} target="_blank" rel="noopener noreferrer" class="text-tjb-lavender-600 hover:underline">{h.name} ↗</a></h3>
          ) : (
            <h3 class="text-lg font-semibold mb-1">{h.name}</h3>
          )}
          <p set:html={h.paragraph} />
        </div>
      ))}
      {birthCenterDetails.map((bc) => (
        <div class="mb-6">
          {bc.url ? (
            <h3 class="text-lg font-semibold mb-1"><a href={bc.url} target="_blank" rel="noopener noreferrer" class="text-tjb-lavender-600 hover:underline">{bc.name} ↗</a></h3>
          ) : (
            <h3 class="text-lg font-semibold mb-1">{bc.name}</h3>
          )}
          <p set:html={bc.paragraph} />
        </div>
      ))}

      <p class="text-sm text-tjb-gray italic">Hospitals listed for reference only. True Joy Birthing does not endorse any specific provider. Always call ahead to confirm doula and visitor policies during your hospital tour.</p>
      <p class="text-sm text-tjb-gray mt-1">Reviewed by <a href="/about/" class="text-tjb-lavender-600 hover:underline">Shelbi Kohler</a></p>

      <!-- Doula Costs -->
      <h2>How Much Does a Doula Cost in {city}?</h2>
      <p>In the {city} area, birth doula packages typically range from <strong>${costLow.toLocaleString()} to ${costHigh.toLocaleString()}</strong> — that usually includes prenatal visits, your birth, and postpartum follow-up. <a href="/doula-cost/">See our full doula cost breakdown</a> for what's included and what to ask about. If you're also thinking about support after baby arrives, <a href="/postpartum-doula/">learn what a postpartum doula does and how one can help</a>.</p>
      <p>If that number feels steep, you're not alone — and there are options:</p>
      <ul>
        <li><strong>Medicaid:</strong> {medicaidNote.includes('does not') || medicaidNote.includes('does NOT') ? 'Unfortunately, your state does not yet cover doulas through Medicaid. Some community organizations and volunteer doula programs offer free or reduced-cost support — ask at your local WIC office or community health center.' : 'Good news — your state covers doula services through Medicaid. See the details below.'}</li>
        <li><strong>HSA/FSA:</strong> Many families don't realize that doula services can often be paid for with HSA or FSA funds, since birth support qualifies as a medical expense under most plans. Check with your plan administrator.</li>
        <li><strong>Sliding-scale doulas:</strong> Many {city} doulas offer payment plans, sliding-scale fees, or reduced packages. Don't be afraid to ask.</li>
        <li><strong>Student doulas:</strong> Doulas in training often attend births at reduced rates. It's a great option if budget is tight.</li>
      </ul>

      <!-- Medicaid & Insurance -->
      <h2>Does Medicaid or Insurance Cover a Doula in {state}?</h2>
      <p>{medicaidNote}</p>
      <p>{insuranceNote}</p>
      <p>Not sure what to look for in a doula? <a href="/how-to-choose-a-doula/">Here's how to choose a doula</a> who fits your birth preferences, your personality, and your budget. For a full breakdown of which states cover doulas through Medicaid, see our <a href="/medicaid-doula-coverage/">Medicaid doula coverage guide</a>.</p>

      <!-- What About a Midwife? -->
      <h2>What About a Midwife in {city}?</h2>
      <p>If you're considering a midwife, you're in good company. More {city} moms are choosing midwifery care each year. Here's what to know:</p>
      <p>Not sure whether you need a doula, a midwife, or both? <a href="/doula-vs-midwife/">Our doula vs. midwife guide</a> breaks it down clearly.</p>
      <ul>
        <li><strong>Certified Nurse-Midwives (CNMs)</strong> work in hospitals and birth centers and are covered by Medicaid in all 50 states.</li>
        <li><strong>Midwives vs. OBs:</strong> Midwives spend more time with you — longer appointments, more conversation, less rushed. OBs are surgeons trained for complications. Both are valid choices for different situations.</li>
        <li><strong>You can have both:</strong> Many {city} practices pair midwives and OBs so you get midwifery-style care with a doctor backing you up if needed.</li>
        {birthCenterDetails.some((bc) => !bc.name.toLowerCase().includes('no ')) ? (
          <li><strong>Birth centers:</strong> {city} has freestanding birth centers where midwives attend births in a home-like setting. See the details above.</li>
        ) : (
          <li><strong>No birth centers locally:</strong> {city} doesn't currently have a freestanding birth center, but midwifery care at local hospitals is still a great option.</li>
        )}
      </ul>

      <!-- CTA: Your Birth Plan -->
      <div class="bg-tjb-lavender-50 border-2 border-tjb-lavender-200 p-6 rounded-lg mt-8 not-prose">
        <h3 class="font-semibold text-lg text-tjb-charcoal mb-2">Walk Into Your Birth Feeling Prepared — Not Anxious</h3>
        <p class="text-tjb-gray mb-3">The #1 thing {city} moms tell us they wish they'd had? <strong>A clear plan they'd actually thought through</strong> — not just a form, but a process that helped them understand their options before the contractions started.</p>
        <p class="text-tjb-gray mb-4">That's exactly what the free Joyful Birth Plan does. It walks you through every decision — who's in the room, what happens if things shift, what matters most to you — so you walk in confident.</p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/birth-plan-confidence-session/#book" class="btn-primary text-center no-underline">
            Request a Confidence Session
          </a>
          <a href="/birth-plan-template/" class="btn-secondary text-center">
            Get Your Free Joyful Birth Plan
          </a>
        </div>
        <p class="text-xs text-tjb-gray mt-3">Free. No email required for the template. The app walks you through it step by step.</p>
      </div>

    </div>
  </section>

  <!-- TJBD card + Nearby + FAQ -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6">

      <!-- What True Joy Birthing Actually Does for You -->
      <div class="bg-white border-2 border-tjb-lavender-200 p-5 rounded-lg mb-6">
        <h3 class="font-semibold text-lg text-tjb-charcoal mb-2">What True Joy Birthing Actually Does for You</h3>
        <p class="text-tjb-gray mb-2">True Joy Birthing isn't a doula matching service, and we're not necessarily your in-person doula in {city}. We're the step before — and alongside — all of that.</p>
        <p class="text-tjb-gray mb-2">Shelbi built the free Joyful Birth Plan because she saw families show up to the hospital without their preferences written down, <em>every single time</em>. The birth plan template, the checklist, the free app walkthrough — these are the tools that help you walk in prepared, whether you end up hiring a local doula or going it alone.</p>
        <p class="text-tjb-gray">If you do find a doula in {city}, great — bring your plan and use it together. If you're still looking, or if hiring a doula isn't in the budget right now, the birth plan is free and it works.</p>
      </div>

      {nearbyCities.length > 0 && (
        <div class="mb-8">
          <h2 class="text-xl font-bold mb-3">Looking at Nearby Cities?</h2>
          <div class="flex flex-wrap gap-2">
            {nearbyCities.map((nSlug) => {
              const near = cities[nSlug];
              return near ? (
                <a href={`/birth-support/${nSlug}/`} class="inline-flex items-center gap-1 px-4 py-2 rounded-full border border-tjb-lavender-300 text-tjb-lavender-600 hover:bg-tjb-lavender-50 hover:border-tjb-lavender-500 transition text-sm font-medium">
                  {near.city}, {near.state}
                </a>
              ) : null;
            })}
          </div>
        </div>
      )}

      <a href="/birth-support" class="text-tjb-lavender-600 font-semibold hover:underline">See all cities →</a>

    </div>
  </section>

  <!-- Related Resources -->
  <section class="py-12 bg-white border-t border-tjb-lavender-200/40">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-2xl font-bold mb-6">Related Resources</h2>
      <div class="grid sm:grid-cols-2 gap-3">
        <a href="/birth-plan-template/" class="flex items-start gap-3 p-4 border border-tjb-lavender-200 rounded-lg hover:border-tjb-rose-400 hover:bg-tjb-rose-50/30 transition group">
          <svg class="w-5 h-5 mt-0.5 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          <div>
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">Free Birth Plan Template</span>
            <p class="text-sm text-tjb-gray mt-0.5">Downloadable fillable PDF for your hospital birth</p>
          </div>
        </a>
        <a href="/what-is-a-doula/" class="flex items-start gap-3 p-4 border border-tjb-lavender-200 rounded-lg hover:border-tjb-rose-400 hover:bg-tjb-rose-50/30 transition group">
          <svg class="w-5 h-5 mt-0.5 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">What Is a Doula?</span>
            <p class="text-sm text-tjb-gray mt-0.5">What doulas do, how they help, and whether you need one</p>
          </div>
        </a>
        <a href="/benefits-of-a-doula/" class="flex items-start gap-3 p-4 border border-tjb-lavender-200 rounded-lg hover:border-tjb-rose-400 hover:bg-tjb-rose-50/30 transition group">
          <svg class="w-5 h-5 mt-0.5 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          <div>
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">Benefits of a Doula</span>
            <p class="text-sm text-tjb-gray mt-0.5">How doulas improve birth outcomes and reduce anxiety</p>
          </div>
        </a>
        <a href="/doula-cost/" class="flex items-start gap-3 p-4 border border-tjb-lavender-200 rounded-lg hover:border-tjb-rose-400 hover:bg-tjb-rose-50/30 transition group">
          <svg class="w-5 h-5 mt-0.5 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">Doula Cost Guide</span>
            <p class="text-sm text-tjb-gray mt-0.5">What doulas cost, what's included, and how to pay</p>
          </div>
        </a>
        <a href="/how-to-choose-a-doula/" class="flex items-start gap-3 p-4 border border-tjb-lavender-200 rounded-lg hover:border-tjb-rose-400 hover:bg-tjb-rose-50/30 transition group">
          <svg class="w-5 h-5 mt-0.5 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          <div>
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">How to Choose a Doula</span>
            <p class="text-sm text-tjb-gray mt-0.5">Questions to ask and what to look for in a birth doula</p>
          </div>
        </a>
        <a href="/medicaid-doula-coverage/" class="flex items-start gap-3 p-4 border border-tjb-lavender-200 rounded-lg hover:border-tjb-rose-400 hover:bg-tjb-rose-50/30 transition group">
          <svg class="w-5 h-5 mt-0.5 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <div>
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">Medicaid Doula Coverage</span>
            <p class="text-sm text-tjb-gray mt-0.5">Which states cover doulas and how to get coverage</p>
          </div>
        </a>
        <a href="/hospital-birth-plan/" class="flex items-start gap-3 p-4 border border-tjb-lavender-200 rounded-lg hover:border-tjb-rose-400 hover:bg-tjb-rose-50/30 transition group">
          <svg class="w-5 h-5 mt-0.5 text-tjb-lavender-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          <div>
            <span class="font-semibold text-tjb-charcoal group-hover:text-tjb-rose-500 transition">Hospital Birth Plan</span>
            <p class="text-sm text-tjb-gray mt-0.5">How to plan for a hospital birth and advocate for your preferences</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-tjb-cream-50">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-2xl font-bold mb-2">Your Questions About Doulas & Midwives in {city}</h2>
      <p class="text-tjb-gray mb-8">The things {city} moms ask us most — answered honestly. For even more questions and detailed answers, check out our <a href="/faq/" class="text-tjb-lavender-600 hover:underline">full doula FAQ</a>.</p>
      <div class="space-y-6">
        {faqs.map((faq) => (
          <div class="border border-tjb-lavender-200 rounded-lg p-5 bg-white">
             <h3 class="text-lg font-semibold mb-2" id={`faq-${faq.q.toLowerCase().includes('cost') ? 'cost' : faq.q.toLowerCase().includes('medicaid') ? 'medicaid' : faq.q.toLowerCase().includes('true joy') ? 'brand' : 'hospital'}`}>{faq.q}</h3>
             <p class="text-tjb-gray faq-answer" set:html={faq.a} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA band — email-gated PDF download -->
  <CityLeadCaptureForm city={city} />

</Layout>