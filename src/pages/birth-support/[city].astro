---
// ═══════════════════════════════════════════════════════════════
// Dynamic city birth-support page — single template for all cities
// Written directly to expectant moms, especially first-time moms
// Denver flagship pattern (June 2026): split hero, app showcase,
// testimonials, two-column section illustrations, centered doula cards,
// hospital thumbnails, serif H2s for story sections, CTA card with
// booklet mockup, lead capture with banner image
// ═══════════════════════════════════════════════════════════════
import Layout from '../../layouts/Layout.astro';
import CityLeadCaptureForm from '../../components/city/LeadCaptureForm.astro';
import AppShowcase from '../../components/AppShowcase.astro';
import { cities, citySlugs, type CityData } from '../../data/cities';

export function getStaticPaths() {
  return citySlugs.map((slug) => ({
    params: { city: slug },
    props: { data: cities[slug]!, slug },
  }));
}

const { data, slug } = Astro.props;
const {
  city, state, costLow, costHigh, culture,
  heroLocalDetail, hospitalDetails, birthCenterDetails,
  localDoulas, medicaidNote, insuranceNote, faqs, nearbyCities,
  testimonials,
  heroImage: heroImageSlug, supportSceneImage, supportSceneAlt, ogImage: ogImageSlug,
  midwifeInfo,
}: CityData = data;

// Medicaid helper (must come before pageDesc)
const medicaidCovers = !medicaidNote.includes('does not') && !medicaidNote.includes('does NOT');
const stateHubSlug = state.toLowerCase().replace(/\s+/g, '-');
const hasBirthCenters = birthCenterDetails.some((bc) => !bc.name.toLowerCase().includes('no '));

// State full name for breadcrumbs (SEO: "Colorado" not "CO")
const stateNames: Record<string, string> = {
  AL: 'Alabama', AK: 'Alaska', AZ: 'Arizona', AR: 'Arkansas', CA: 'California',
  CO: 'Colorado', CT: 'Connecticut', DE: 'Delaware', FL: 'Florida', GA: 'Georgia',
  HI: 'Hawaii', ID: 'Idaho', IL: 'Illinois', IN: 'Indiana', IA: 'Iowa',
  KS: 'Kansas', KY: 'Kentucky', LA: 'Louisiana', ME: 'Maine', MD: 'Maryland',
  MA: 'Massachusetts', MI: 'Michigan', MN: 'Minnesota', MS: 'Mississippi', MO: 'Missouri',
  MT: 'Montana', NE: 'Nebraska', NV: 'Nevada', NH: 'New Hampshire', NJ: 'New Jersey',
  NM: 'New Mexico', NY: 'New York', NC: 'North Carolina', ND: 'North Dakota', OH: 'Ohio',
  OK: 'Oklahoma', OR: 'Oregon', PA: 'Pennsylvania', RI: 'Rhode Island', SC: 'South Carolina',
  SD: 'South Dakota', TN: 'Tennessee', TX: 'Texas', UT: 'Utah', VT: 'Vermont',
  VA: 'Virginia', WA: 'Washington', WV: 'West Virginia', WI: 'Wisconsin', WY: 'Wyoming',
  DC: 'District of Columbia',
};
const stateFullName = stateNames[state] || state;

const pageTitle = `${city} Doula | Costs & Medicaid Info`;
const pageDesc = `Looking for a doula in ${city}? Costs $${costLow}–$${costHigh}, ${medicaidCovers ? 'Medicaid covers doulas' : 'Medicaid does not cover doulas'}, hospital policies, and the free Joyful Birth Plan to walk in prepared.`;
const pageUrl = `https://truejoybirthing.com/birth-support/${slug}/`;
const ogImage = ogImageSlug || `https://truejoybirthing.com/images/og-city-${slug}-v2.webp`;
const heroImage = heroImageSlug || '/images/doula-breastfeeding.webp';
const heroAlt = `${city} birth doula: costs, Medicaid, and hospital info for ${state} families`;
const supportImage = supportSceneImage || '/images/doula-walking.webp';
const supportImageAlt = supportSceneAlt || `A doula walking alongside an expectant mom, offering continuous labor support`;

// Section images — same across all locations (Jeff approved keeping
// photos consistent across cities; 4:3 aspect ratio for proper fit)
const doulaCostImage = '/images/doula-holding-hands.webp';
const medicaidImage = '/images/hands-on-belly.jpg';
const midwifeImage = '/images/midwife-heartbeat.webp';

// Build structured-data
const breadcrumbList = [
  { name: 'Home', url: 'https://truejoybirthing.com/' },
  { name: 'Birth Support', url: 'https://truejoybirthing.com/birth-support/' },
  { name: stateFullName, url: `https://truejoybirthing.com/birth-support/${state.toLowerCase()}/` },
  { name: `${city}, ${state}`, url: pageUrl },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'FAQPage',
      '@id': `${pageUrl}#faq`,
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        url: `${pageUrl}#faq-${f.q.toLowerCase().includes('cost') ? 'cost' : f.q.toLowerCase().includes('medicaid') ? 'medicaid' : f.q.toLowerCase().includes('true joy') ? 'brand' : 'hospital'}`,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
    {
      '@type': 'Service',
      '@id': `${pageUrl}#service`,
      name: `Joyful Birth Plan Resources for ${city} Families`,
      url: pageUrl,
      image: ogImage,
      areaServed: {
        '@type': 'City',
        name: city,
        ...(data.lat && data.lng ? {
          geo: {
            '@type': 'GeoCoordinates',
            latitude: data.lat,
            longitude: data.lng,
          },
        } : {}),
      },
      provider: { '@id': 'https://truejoybirthing.com/#organization' },
      serviceType: 'Birth Plan Resources',
      description: `Joyful Birth Plan tools, hospital info, and doula cost guides for families in ${city}, ${state}.`,
      ...(data.publishedDate ? { datePublished: data.publishedDate } : {}),
    },
    // MedicalOrganization for each hospital with a URL
    ...hospitalDetails.filter(h => h.url).map((h, i) => ({
      '@type': 'MedicalOrganization',
      '@id': `${pageUrl}#hospital-${i}`,
      name: h.name,
      address: {
        '@type': 'PostalAddress',
        addressLocality: city,
        addressRegion: state,
        addressCountry: 'US',
        ...(h.address ? { streetAddress: h.address.split(',')[0].trim() } : {}),
      },
      url: h.url,
    })),
    {
      '@type': 'SpeakableSpecification',
      '@id': `${pageUrl}#speakable`,
      cssSelector: ['.prose h2', '.prose h3', '.faq-answer'],
    },
  ],
};
---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}
  ogImage={ogImage}
  breadcrumbList={breadcrumbList}
  schema={schema}
>

  <!-- ═══ Breadcrumb ═══ -->
  <nav aria-label="Breadcrumb" class="bg-tjb-cream pt-4 pb-2">
    <div class="max-w-7xl mx-auto px-6">
      <ol class="flex items-center gap-1.5 flex-wrap text-sm text-tjb-gray">
        <li class="flex items-center gap-1.5">
          <a href="https://truejoybirthing.com/" class="text-tjb-lavender-600 hover:underline">Home</a>
          <span class="text-tjb-gray/50">›</span>
        </li>
        <li class="flex items-center gap-1.5">
          <a href="https://truejoybirthing.com/birth-support/" class="text-tjb-lavender-600 hover:underline">Birth Support</a>
          <span class="text-tjb-gray/50">›</span>
        </li>
        <li class="flex items-center gap-1.5">
          <a href={`/birth-support/${stateHubSlug}/`} class="text-tjb-lavender-600 hover:underline">{stateFullName}</a>
          <span class="text-tjb-gray/50">›</span>
        </li>
        <li class="text-tjb-charcoal font-medium">{city}, {state}</li>
      </ol>
    </div>
  </nav>

  <!-- ═══ Hero — Split Layout (55% text / 45% image) ═══ -->
  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div>
          <p class="eyebrow text-tjb-rose-500 uppercase text-xs font-semibold tracking-widest mb-4">{city} Doula & Birth Support</p>
          <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
          <h1 class="text-3xl md:text-4xl font-bold mb-4" style="font-family: 'DM Serif Display', Georgia, serif;">{city} Doula: Costs, Hospitals & Medicaid</h1>
          <p class="text-lg text-tjb-charcoal font-semibold mb-2">You deserve to feel confident walking into your birth.</p>
          <p class="text-tjb-gray mb-6">Doulas, midwives, hospital policies, and costs, broken down so you can walk in prepared. This guide covers <a href="/doula-cost/" class="text-tjb-rose-600 hover:underline">how much doulas cost</a>, <a href="/medicaid-doula-coverage/" class="text-tjb-rose-600 hover:underline">whether Medicaid covers a doula</a>, and which hospitals welcome birth partners. New here? <a href="/what-is-a-doula/" class="text-tjb-rose-600 hover:underline">Learn what a doula actually does</a>.</p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="btn-primary text-center">Build Your Birth Plan in the App</a>
            <a href="/birth-plan-template/" class="btn-secondary text-center">Or download the free PDF →</a>
          </div>
          <p class="text-xs text-tjb-gray mt-3">Free · No account needed · Works on iPhone</p>
          {heroLocalDetail && (
            <p class="text-sm text-tjb-gray/80 italic mt-4">{heroLocalDetail}</p>
          )}
        </div>
        <div class="relative">
          <img
            src={heroImage}
            alt={heroAlt}
            class="w-full aspect-[3/4] object-cover rounded-2xl shadow-lg"
            width="1200"
            height="1600"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ App Showcase ═══ -->
  <AppShowcase variant="sans" />

  <!-- ═══ What Doula & Midwife Support Looks Like ═══ -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <p class="eyebrow text-tjb-rose-500 uppercase text-xs font-semibold tracking-widest mb-4">How it works</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
      <h2 class="text-2xl md:text-3xl font-bold text-tjb-charcoal mb-8" style="font-family: 'DM Sans', sans-serif;">What Doula & Midwife Support Looks Like in {city}</h2>
      <div class="flex flex-col md:flex-row gap-8 md:gap-12 items-start">
        <div class="md:w-[45%]">
          <div class="bg-tjb-cream p-5 rounded-xl mb-4 not-prose">
            <p class="font-semibold text-tjb-lavender-600 mb-1">Not sure what the difference is?</p>
            <p class="text-sm text-tjb-gray">A <strong>midwife</strong> is your medical provider: she can deliver your baby, write prescriptions, and monitor your health. A <strong>doula</strong> is your support person: she keeps you comfortable, informed, and emotionally held, but doesn't do medical tasks. You can have both, and many {city} moms do. <a href="/what-is-a-doula/" class="text-tjb-lavender-600 hover:underline">Learn more about what a doula actually does →</a></p>
          </div>
          <img
            src={supportImage}
            alt={supportImageAlt}
            class="w-full rounded-xl shadow-md"
            width="1024"
            height="768"
            loading="lazy"
          />
        </div>
        <div class="md:w-[55%]">
          <p class="text-tjb-gray leading-relaxed mb-6">{culture}</p>
          <div class="space-y-4 pl-4 border-l-2 border-tjb-lavender-500">
            <div>
              <p class="font-semibold text-tjb-charcoal mb-1">Continuous labor support</p>
              <p class="text-sm text-tjb-gray">A doula stays with you from early labor through delivery. No shift changes, no leaving the room.</p>
            </div>
            <div>
              <p class="font-semibold text-tjb-charcoal mb-1">Evidence-based comfort techniques</p>
              <p class="text-sm text-tjb-gray">Breathing, counter-pressure, position changes, proven to reduce C-section rates and shorten labor.</p>
            </div>
            <div>
              <p class="font-semibold text-tjb-charcoal mb-1">Advocacy before and during birth</p>
              <p class="text-sm text-tjb-gray">Your doula helps you understand your options and practice saying what you want, before you're in the delivery room.</p>
            </div>
            <div>
              <p class="font-semibold text-tjb-charcoal mb-1">Postpartum follow-up, too</p>
              <p class="text-sm text-tjb-gray">Most {city} doula packages include at least one postpartum visit, because birth support doesn't end at delivery.</p>
            </div>
          </div>
          <p class="text-tjb-gray mt-6">Whether this is your first baby or you're preparing for a VBAC, <a href="/what-is-a-doula/" class="text-tjb-rose-600 hover:underline">understanding what a doula does</a>, and <a href="/benefits-of-a-doula/" class="text-tjb-rose-600 hover:underline">how a doula can change your birth experience</a>, can help you decide what support is right for you. Planning for a specific scenario? Read our <a href="/vbac-birth-plan/" class="text-tjb-rose-600 hover:underline">VBAC birth plan guide</a> or our <a href="/c-section-birth-plan/" class="text-tjb-rose-600 hover:underline">C-section birth plan template</a>.</p>
        </div>
      </div>
    <!-- ═══ Social Proof: Testimonials or Q&A ═══ -->
    {testimonials && testimonials.length > 0 ? (
      <section class="py-20 bg-white">
        <div class="max-w-5xl mx-auto px-6">
          <div class="text-center mb-10">
            <p class="eyebrow text-tjb-rose-500 uppercase text-xs font-semibold tracking-widest mb-4">What moms say</p>
            <h2 class="text-2xl md:text-3xl font-bold text-tjb-charcoal" style="font-family: 'DM Sans', sans-serif;">Real {city} moms, real birth stories</h2>
          </div>
          <div class="grid md:grid-cols-3 gap-6">
            {testimonials.map((t) => (
              <div class="bg-tjb-cream/40 rounded-xl p-6 text-center">
                <p class="text-lg text-tjb-charcoal mb-4" style="font-family: 'DM Serif Display', Georgia, serif;">&ldquo;{t.quote}&rdquo;</p>
                <p class="text-sm font-semibold text-tjb-lavender-600">{t.attribution}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    ) : (
      <section class="py-16 bg-white">
        <div class="max-w-3xl mx-auto px-6">
          <div class="text-center mb-10">
            <p class="eyebrow text-tjb-rose-500 uppercase text-xs font-semibold tracking-widest mb-4">What local moms ask</p>
            <h2 class="text-2xl md:text-3xl font-bold text-tjb-charcoal" style="font-family: 'Cormorant Garamond', Georgia, serif;">What {city} moms want to know</h2>
          </div>
          <div class="grid md:grid-cols-2 gap-4">
            <div class="bg-tjb-cream/40 rounded-lg p-4">
              <p class="font-semibold text-tjb-charcoal text-sm">How much does a doula cost in {city}?</p>
              <p class="text-sm text-tjb-gray mt-1">Expect ${costLow.toLocaleString()} to ${costHigh.toLocaleString()} for a birth doula. {medicaidCovers ? `${stateFullName} Medicaid covers doula services.` : 'Check with local doulas for sliding-scale options.'}</p>
            </div>
            <div class="bg-tjb-cream/40 rounded-lg p-4">
              <p class="font-semibold text-tjb-charcoal text-sm">Can my doula come to the hospital with me?</p>
              <p class="text-sm text-tjb-gray mt-1">Most {city} hospitals allow doulas. Always confirm your hospital's policy ahead of time.</p>
            </div>
            {medicaidCovers && (
              <div class="bg-tjb-cream/40 rounded-lg p-4">
                <p class="font-semibold text-tjb-charcoal text-sm">Does Medicaid cover a doula in {city}?</p>
                <p class="text-sm text-tjb-gray mt-1">Yes. {stateFullName} Medicaid covers doula services. See the details above.</p>
              </div>
            )}
            <div class="bg-tjb-cream/40 rounded-lg p-4">
              <p class="font-semibold text-tjb-charcoal text-sm">What does a birth plan actually do?</p>
              <p class="text-sm text-tjb-gray mt-1">It helps you think through your preferences before labor, so you can walk in confident instead of overwhelmed. <a href="/birth-plan-template/" class="text-tjb-lavender-600 hover:underline">Grab the free template</a>.</p>
            </div>
          </div>
        </div>
      </section>
    )}
  <section class="py-12 bg-tjb-cream">
    <div class="max-w-3xl mx-auto px-6 prose">
      <h2 class="font-bold text-tjb-charcoal" style="font-size: clamp(1.5rem, 2.5vw, 1.875rem); font-family: 'Cormorant Garamond', Georgia,-serif;">Can My Doula Come to the Hospital With Me in {city}?</h2>
      <p>This is one of the top questions {city} moms ask, and the answer matters. Most hospitals in the {city} area <strong>do allow doulas</strong>, and many have explicit policies supporting continuous doula support during labor. Post-COVID visitor restrictions have mostly lifted, and hospitals generally recognize that doulas are not visitors: they're part of your care team.</p>
      <p>That said, it's smart to <strong>call your hospital before labor starts</strong> and ask directly about their doula policy. Some questions to ask:</p>
      <ul>
        <li>"How many support people can I have in the delivery room?"</li>
        <li>"Does your hospital have a written doula policy I can review?"</li>
        <li>"Are doulas counted as visitors or as part of my care team?"</li>
        <li>"Is there a limit on support people during a C-section?"</li>
      </ul>
      <p>Your doula will also know the policies at {city} hospitals and can help you navigate any hoops. And if your hospital pushes back, your birth plan gives you a written document that shows you've thought this through. <a href="/birth-plan-template/" class="text-tjb-rose-600 hover:underline">grab the free template here</a>.</p>
    </div>
  </section>

  <!-- ═══ Doulas & Midwives Serving {city} ═══ -->
  {localDoulas && localDoulas.length > 0 ? (
    <section class="py-20 bg-tjb-cream">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-10">
          <p class="eyebrow text-tjb-rose-500 uppercase text-xs font-semibold tracking-widest mb-4">Local support</p>
          <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto mb-6"></div>
          <h2 class="text-2xl md:text-3xl font-bold text-tjb-charcoal mb-4" style="font-family: 'DM Sans', sans-serif;">Doulas & Midwives Serving {city}</h2>
          <p class="text-tjb-gray max-w-2xl mx-auto">Real people, real support: here are doulas and midwives who serve {city} families. Every listing is a practicing provider, not an ad.</p>
        </div>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 not-prose">
          {localDoulas.map((doula) => (
            <div class={`bg-white rounded-xl p-6 shadow-sm border hover:shadow-md transition-shadow duration-200 flex flex-col items-center text-center ${doula.isAmbassador ? 'border-2 border-tjb-rose-300 shadow-md' : 'border-tjb-lavender-200/50 hover:border-tjb-lavender-300'}`}>
              <div class={`w-14 h-14 rounded-full flex items-center justify-center mb-4 ${doula.isMidwife ? 'bg-tjb-lavender-100' : 'bg-tjb-lavender-100'}`}>
                <span class="text-2xl font-semibold" style="font-family: 'Cormorant Garamond', Georgia, serif;" className={doula.isAmbassador ? 'text-tjb-rose-600' : doula.isMidwife ? 'text-tjb-lavender-700' : 'text-tjb-charcoal'}>{doula.name.split(' ').map((n: string) => n[0]).join('')}</span>
              </div>
              <h3 class="text-lg font-semibold text-tjb-charcoal leading-tight mb-1" style="font-family: 'Cormorant Garamond', Georgia, serif;">{doula.name}</h3>
              {doula.credential && <p class="text-sm text-tjb-lavender-600 font-medium mb-2">{doula.credential}</p>}
              {doula.practice && <p class="text-sm text-tjb-gray mb-1">{doula.practice}</p>}
              {doula.costRange && <p class="text-sm text-tjb-charcoal font-medium mb-2">{doula.costRange}</p>}
              {(doula.services && doula.services.length > 0) && (
                <div class="flex flex-wrap justify-center gap-1.5 mt-1 mb-2">
                  {doula.services.map((svc: string) => (
                    <span class="inline-flex items-center bg-tjb-lavender-50 text-tjb-lavender-700 text-xs font-medium px-2 py-0.5 rounded-full border border-tjb-lavender-200">{svc}</span>
                  ))}
                </div>
              )}
              {doula.description && <p class="text-sm text-tjb-gray leading-relaxed mb-2">{doula.description}</p>}
              {doula.acceptsMedicaid && (
                <span class="inline-flex items-center bg-green-50 text-green-700 text-xs font-medium px-2.5 py-0.5 rounded-full border border-green-200 mb-2">
                  <svg class="w-3 h-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  Accepts Medicaid
                </span>
              )}
              {doula.serviceArea && doula.serviceArea.length > 0 && (
                <p class="text-xs text-tjb-gray/60 mb-2">Serves {doula.serviceArea.join(', ')}</p>
              )}
              <div class="flex-1"></div>
              <div class="flex flex-wrap justify-center gap-2 mt-2">
                {doula.isAmbassador && <span class="inline-flex items-center bg-tjb-lavender-100 text-tjb-lavender-700 text-xs font-medium px-2.5 py-0.5 rounded-full border border-tjb-lavender-200">Ambassador</span>}
                {doula.isMidwife && <span class="inline-flex items-center bg-tjb-lavender-100 text-tjb-lavender-700 text-xs font-medium px-2.5 py-0.5 rounded-full border border-tjb-lavender-200">Midwife</span>}
                <span class="inline-flex items-center bg-tjb-rose-50 text-tjb-rose-500 text-xs font-medium px-2.5 py-0.5 rounded-full border border-tjb-rose-200">{city}</span>
              </div>
              {doula.acceptingClients && (
                <div class="flex items-center justify-center gap-1.5 mt-2">
                  <span class="w-2 h-2 rounded-full bg-green-500"></span>
                  <span class="text-xs text-green-700 font-medium">{typeof doula.acceptingClients === 'string' ? doula.acceptingClients : 'Accepting clients'}</span>
                </div>
              )}
              {doula.url && <a href={doula.url} target="_blank" rel="noopener noreferrer" class="btn-primary mt-4 text-sm w-full">Visit website</a>}
            </div>
          ))}
        </div>
        <!-- Find a Doula CTA -->
        <div class="mt-10 max-w-5xl mx-auto not-prose">
          <div class="bg-tjb-lavender-50 border-2 border-tjb-lavender-200 rounded-xl p-6 md:p-8">
            <div class="flex flex-col md:flex-row gap-6 md:gap-8 items-center">
              <div class="md:w-[30%] flex-shrink-0 flex justify-center">
                <img src="/images/tjb-app-find-your-team.png" alt="True Joy Birthing app: find doulas and midwives near you" class="w-full max-w-[200px] rounded-2xl shadow-lg" width="200" height="433" loading="lazy" />
              </div>
              <div class="md:w-[70%]">
                <h3 class="text-xl font-bold text-tjb-charcoal mb-3" style="font-family: 'DM Sans', sans-serif;">Find a doula or midwife near you</h3>
                <p class="text-tjb-gray leading-relaxed mb-4">The True Joy Birthing app lets you search for doulas, midwives, and birth professionals in your area. Filter by certification, services offered, and insurance coverage, so you can find the right support before your due date.</p>
                <a href="/birth-plan-app/" class="btn-primary">Try the free app →</a>
              </div>
            </div>
          </div>
        </div>
        <div class="text-center mt-6">
          <p class="text-sm text-tjb-gray">Listed providers are independent practitioners. True Joy Birthing does not endorse any specific provider.</p>
        </div>
      </div>
    </section>
  ) : (
    <section class="py-20 bg-tjb-cream">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-10">
          <p class="eyebrow text-tjb-rose-500 uppercase text-xs font-semibold tracking-widest mb-4">Local support</p>
