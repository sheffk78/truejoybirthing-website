---
// ═══════════════════════════════════════════════════════════════
// Dynamic city birth-support page — single template for all cities
// Written directly to expectant moms, especially first-time moms
// ═══════════════════════════════════════════════════════════════
import Layout from '../../layouts/Layout.astro';
import CityLeadCaptureForm from '../../components/city/LeadCaptureForm.astro';
import DoulaCardGrid from '../../components/city/DoulaCardGrid.astro';
import { cities, citySlugs, type CityData } from '../../data/cities';

export function getStaticPaths() {
  return citySlugs.map((slug) => ({
    params: { city: slug },
    props: { data: cities[slug]!, slug },
  }));
}

const { data, slug } = Astro.props;
const {
  city, state, costLow, costHigh, culture,
  heroLocalDetail, hospitalDetails, birthCenterDetails, localDoulas,
  medicaidNote, insuranceNote, faqs, nearbyCities,
}: CityData = data;

const pageTitle = `${city} Birth Doula | Costs & Hospital Info | TJB`;
const pageDesc = `Doula costs, hospital policies, and Medicaid coverage in ${city}, ${state}. Plus a free Joyful Birth Plan template to walk in prepared.`;
const pageUrl = `https://truejoybirthing.com/birth-support/${slug}/`;
// OG image: Pattern B for denver-co (first city), Pattern C fallback for others
const ogImage = slug === 'denver-co'
  ? 'https://truejoybirthing.com/images/og/og-denver-co.png'
  : `https://truejoybirthing.com/images/og-city-${slug}.webp`;

// Hero image — doula-breastfeeding is portrait (2:3), passes safety check
// (correct cradle hold, proper latch alignment, no anatomical errors)
// Warm, hospital-relevant, fills the hero column properly
const heroImage = `/images/doula-breastfeeding.webp`;
const heroAlt = `Mother with newborn in ${city}, ${state} — breastfeeding support and local doula care for expectant moms`;

// Support section image — doula-walking passes safety check (no anatomical errors)
const supportImage = `/images/doula-walking.webp`;
const supportImageAlt = `Birth doula walking with an expectant mom in ${city}, ${state} — companionship and emotional support during pregnancy`;

// Full state name lookup for breadcrumbs and schema
const stateNames: Record<string, string> = {
  AK: 'Alaska', AL: 'Alabama', AR: 'Arkansas', AZ: 'Arizona', CA: 'California',
  CO: 'Colorado', CT: 'Connecticut', DE: 'Delaware', FL: 'Florida', GA: 'Georgia',
  HI: 'Hawaii', IA: 'Iowa', ID: 'Idaho', IL: 'Illinois', IN: 'Indiana',
  KS: 'Kansas', KY: 'Kentucky', LA: 'Louisiana', MA: 'Massachusetts', MD: 'Maryland',
  MI: 'Michigan', MN: 'Minnesota', MO: 'Missouri', MS: 'Mississippi', MT: 'Montana',
  NC: 'North Carolina', ND: 'North Dakota', NE: 'Nebraska', NH: 'New Hampshire',
  NJ: 'New Jersey', NM: 'New Mexico', NV: 'Nevada', NY: 'New York', OH: 'Ohio',
  OK: 'Oklahoma', OR: 'Oregon', PA: 'Pennsylvania', RI: 'Rhode Island', SC: 'South Carolina',
  SD: 'South Dakota', TN: 'Tennessee', TX: 'Texas', UT: 'Utah', VA: 'Virginia',
  VT: 'Vermont', WA: 'Washington', WI: 'Wisconsin', WV: 'West Virginia', WY: 'Wyoming',
};
const stateFullName = stateNames[state] || state;

// Build structured-data — 4-level breadcrumbs for local SEO
const breadcrumbList = [
  { name: 'Home', url: 'https://truejoybirthing.com/' },
  { name: 'Birth Support', url: 'https://truejoybirthing.com/birth-support/' },
  { name: stateFullName, url: `https://truejoybirthing.com/birth-support/${state.toLowerCase()}/` },
  { name: `${city}, ${state}`, url: pageUrl },
];

const hospitalThumbnails: Record<string, string> = {
  'UCHealth University of Colorado Hospital': '/images/denver-uchealth-university-colorado-exterior.webp',
  'Saint Joseph Hospital': '/images/denver-saint-joseph-exterior.webp',
};
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'FAQPage',
      '@id': `${pageUrl}#faq`,
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        url: `${pageUrl}#faq-${f.q.toLowerCase().includes('cost') ? 'cost' : f.q.toLowerCase().includes('medicaid') ? 'medicaid' : f.q.toLowerCase().includes('true joy') ? 'brand' : 'hospital'}`,
        acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]*>/g, '') },
      })),
    },
    {
      '@type': 'Service',
      '@id': `${pageUrl}#service`,
      name: `Joyful Birth-Plan Resources for ${city} Families`,
      url: pageUrl,
      image: `https://truejoybirthing.com${heroImage}`,
      areaServed: {
        '@type': 'City',
        name: city,
        containedInPlace: { '@type': 'State', name: state },
      },
      provider: { '@id': 'https://truejoybirthing.com/#organization' },
      serviceType: 'Birth Plan Resources',
      description: `Free birth-plan tools, hospital info, and doula cost guides for families in ${city}, ${state}.`,
    },
    {
      '@type': 'SpeakableSpecification',
      '@id': `${pageUrl}#speakable`,
      cssSelector: ['.prose h2', '.prose h3', '.faq-answer'],
    },
  ],
};
---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}
  ogImage={ogImage}
  breadcrumbList={breadcrumbList}
  schema={schema}
>
  <!-- ═══════════════════════════════════════════════════════════
       HERO — Warm, local, emotionally clear
       ═══════════════════════════════════════════════════════════ -->
  <section class="bg-tjb-cream">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row">
        <!-- Left: Text — 55% -->
        <div class="md:w-[55%] px-6 md:px-12 py-16 md:py-20 flex flex-col justify-center">
          <p class="eyebrow mb-3">Birth support in {city}, {state}</p>
          <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
          <h1 class="font-bold text-tjb-charcoal leading-[1.15] mb-4" style="font-size: clamp(2.25rem, 5vw, 3.75rem);">
            Your birth plan, your hospital, your team — all in {city}
          </h1>
          <p class="text-lg text-tjb-charcoal font-semibold mb-3">
            Doulas, midwives, hospital policies, and costs — broken down so you can walk in prepared.
          </p>
          <p class="text-tjb-gray leading-relaxed mb-8 max-w-[36rem]">
            Whether you're wondering if a doula is worth it, whether your hospital will let one in, or how you'll afford it — you're in the right place. This guide covers what {city} moms actually need to know.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center mb-3">
            <a href="/birth-plan-template/" class="btn-primary">
              Get Your Free Joyful Birth Plan
            </a>
            <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="btn-secondary">
              Or try the free app →
            </a>
          </div>
          <p class="text-sm text-tjb-gray">Free template (no email) · Prefer the app? Build the same joyful birth plan step by step on your phone.</p>
          {heroLocalDetail && (
            <p class="text-sm text-tjb-gray mt-6 italic border-l-2 border-tjb-lavender-300 pl-4" set:html={heroLocalDetail} />
          )}
        </div>
        <!-- Right: Image — 45% -->
        <div class="md:w-[45%] flex items-center justify-center px-8 py-8 md:py-0">
          <img
            src={heroImage}
            alt={heroAlt}
            class="w-full max-w-md rounded-xl shadow-md"
            width="1200"
            height="800"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       APP SHOWCASE — Two-phone overlap, CTA to download
       NOW PLACED RIGHT AFTER HERO FOR EARLY VISIBILITY
       ═══════════════════════════════════════════════════════════ -->
  <section class="py-16 bg-tjb-cream">
    <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-2 gap-10 items-center">
      <!-- Phones (left on desktop, stacks above on mobile) -->
      <div class="relative flex justify-center md:justify-end order-1 md:order-1">
        <!-- Background phone: Dashboard (offset) -->
        <div class="absolute top-8 -left-2 md:top-10 md:-left-4 w-[55%] z-0">
          <img
            src="/images/tjb-app-dashboard.png"
            alt="True Joy Birthing app dashboard showing birth plan progress and weekly pregnancy tips"
            class="w-full rounded-2xl shadow-lg opacity-85"
            loading="lazy"
          />
        </div>
        <!-- Foreground phone: Birth Plan Builder -->
        <div class="relative w-[60%] z-10">
          <img
            src="/images/tjb-app-birth-plan-builder.png"
            alt="True Joy Birthing app birth plan builder — 9 guided sections, step-by-step birth preferences"
            class="w-full rounded-2xl shadow-xl"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Text (right on desktop, below phones on mobile) -->
      <div class="order-2 md:order-2">
        <p class="eyebrow mb-3">Free App</p>
        <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
        <h2 class="font-bold text-tjb-charcoal leading-[1.15] mb-4" style="font-size: clamp(1.5rem, 3vw, 2.25rem);">
          Build your birth plan step by step in the app
        </h2>
        <p class="text-tjb-gray leading-relaxed mb-6">
          Nine guided sections. Hospital preferences, pain management, who's in the room — all walked through so nothing gets missed.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 items-start sm:items-center">
          <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" target="_blank" rel="noopener noreferrer">
            <img
              src="/images/app-store-badge.png"
              alt="Download on the App Store"
              class="h-10"
              loading="lazy"
            />
          </a>
          <div class="relative group inline-block cursor-not-allowed">
            <img
              src="/images/google-play-badge.png"
              alt="Get it on Google Play — coming soon"
              class="h-10"
              loading="lazy"
            />
            <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 bg-white text-tjb-charcoal text-xs font-medium px-2.5 py-1 rounded shadow-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">Coming soon</span>
          </div>
        </div>
        <p class="text-xs text-tjb-gray mt-3">Free · No account needed to start</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       BREADCRUMB
       ═══════════════════════════════════════════════════════════ -->
  <section class="bg-white pt-8">
    <div class="max-w-3xl mx-auto px-6">
      <nav aria-label="Breadcrumb" class="text-sm text-tjb-gray">
        <ol class="flex items-center gap-1.5 flex-wrap">
          {breadcrumbList.map((crumb, i) => (
            <li class="flex items-center gap-1.5">
              {i > 0 && <span aria-hidden="true" class="text-tjb-lavender-300">›</span>}
              {i < breadcrumbList.length - 1 ? (
                <a href={crumb.url} class="text-tjb-lavender-600 hover:underline">{crumb.name}</a>
              ) : (
                <span class="text-tjb-charcoal font-medium" aria-current="page">{crumb.name}</span>
              )}
            </li>
          ))}
        </ol>
      </nav>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       WHAT BIRTH SUPPORT LOOKS LIKE — Two-column story
       ═══════════════════════════════════════════════════════════ -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <p class="eyebrow mb-3">How it works</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-8"></div>
      <h2 class="text-2xl md:text-3xl font-bold mb-4">What Doula & Midwife Support Looks Like in {city}</h2>
      <p class="text-tjb-gray leading-relaxed mb-8 max-w-2xl">{culture}</p>

      <!-- Two-column: image + quick answers -->
      <div class="flex flex-col md:flex-row gap-8 md:gap-12 items-start">
        <div class="md:w-[45%] flex-shrink-0">
          <img
            src={supportImage}
            alt={supportImageAlt}
            class="w-full rounded-xl shadow-md"
            width="1024"
            height="1536"
            loading="lazy"
          />
        </div>
        <div class="md:w-[55%]">
          <!-- Quick clarification -->
          <div class="bg-tjb-cream p-5 rounded-lg mb-6">
            <p class="font-semibold text-tjb-lavender-600 mb-1">Not sure what the difference is?</p>
            <p class="text-sm text-tjb-gray">A <strong>midwife</strong> is your medical provider — she can deliver your baby, write prescriptions, and monitor your health. A <strong>doula</strong> is your support person — she keeps you comfortable, informed, and emotionally held, but doesn't do medical tasks. You can have both, and many {city} moms do. <a href="/what-is-a-doula/" class="text-tjb-lavender-600 hover:underline">Learn more about what a doula actually does →</a></p>
          </div>

          <!-- Scannable highlights -->
          <div class="space-y-4">
            <div class="border-l-2 border-tjb-lavender-500 pl-4">
              <p class="font-semibold text-tjb-charcoal">Continuous labor support</p>
              <p class="text-sm text-tjb-gray">A doula stays with you from early labor through delivery — no shift changes, no leaving the room.</p>
            </div>
            <div class="border-l-2 border-tjb-lavender-500 pl-4">
              <p class="font-semibold text-tjb-charcoal">Evidence-based comfort techniques</p>
              <p class="text-sm text-tjb-gray">Breathing, counter-pressure, position changes — proven to reduce C-section rates and shorten labor.</p>
            </div>
            <div class="border-l-2 border-tjb-lavender-500 pl-4">
              <p class="font-semibold text-tjb-charcoal">Advocacy before and during birth</p>
              <p class="text-sm text-tjb-gray">Your doula helps you understand your options and practice saying what you want — before you're in the delivery room.</p>
            </div>
            <div class="border-l-2 border-tjb-sage pl-4">
              <p class="font-semibold text-tjb-charcoal">Postpartum follow-up, too</p>
              <p class="text-sm text-tjb-gray">Most {city} doula packages include at least one postpartum visit — because birth support doesn't end at delivery.</p>
            </div>
          </div>

          <p class="text-sm text-tjb-gray mt-6">Whether this is your first baby or you're preparing for a VBAC, <a href="/what-is-a-doula/" class="text-tjb-lavender-600 hover:underline">understanding what a doula does</a> — and <a href="/benefits-of-a-doula/" class="text-tjb-lavender-600 hover:underline">how a doula can change your birth experience</a> — can help you decide what support is right for you.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       CAN MY DOULA COME WITH ME?
       ═══════════════════════════════════════════════════════════ -->
  <section class="py-16 bg-tjb-cream">
    <div class="max-w-3xl mx-auto px-6 prose">
      <h2>Can My Doula Come to the Hospital With Me in {city}?</h2>
      <p>This is one of the top questions {city} moms ask — and the answer matters. Most hospitals in the {city} area <strong>do allow doulas</strong>, and many have explicit policies supporting continuous doula support during labor. Post-COVID visitor restrictions have mostly lifted, and hospitals generally recognize that doulas are not visitors — they're part of your care team.</p>
      <p>That said, it's smart to <strong>call your hospital before labor starts</strong> and ask directly about their doula policy. Some questions to ask:</p>
      <ul>
        <li>"How many support people can I have in the delivery room?"</li>
        <li>"Does your hospital have a written doula policy I can review?"</li>
        <li>"Are doulas counted as visitors or as part of my care team?"</li>
        <li>"Is there a limit on support people during a C-section?"</li>
      </ul>
      <p>Your doula will also know the policies at {city} hospitals and can help you navigate any hoops. And if your hospital pushes back, your birth plan gives you a written document that shows you've thought this through — <a href="/birth-plan-template/">grab the free template here</a>.</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       LOCAL DOULAS
       ═══════════════════════════════════════════════════════════ -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">
      {localDoulas.length > 0 && (
        <h2>Doulas & Midwives Serving {city}</h2>
      )}
      <DoulaCardGrid doulas={localDoulas} city={city} />
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       HOSPITAL & BIRTH CENTER INFO — with subtle map background
       ═══════════════════════════════════════════════════════════ -->
  <section class="py-16 relative overflow-hidden">
    <!-- Map background: subtle street grid pattern for sense of location -->
    <div class="absolute inset-0" style="background-image: url('/images/map-bg-denver.svg'); background-repeat: repeat; background-size: 400px 400px; opacity: 0.55;" aria-hidden="true"></div>
    <!-- Cream overlay for readability -->
    <div class="absolute inset-0 bg-tjb-cream/80" aria-hidden="true"></div>
    <!-- Content -->
    <div class="max-w-3xl mx-auto px-6 relative z-10">
      {(hospitalDetails.length > 0 || birthCenterDetails.length > 0) && (
        <h2 class="text-2xl md:text-3xl font-bold mb-2">Hospital & Birth Center Info in {city}</h2>
      )}
      <p class="text-tjb-gray mb-8">Here's what you need to know about the hospitals where {city} moms deliver — including NICU levels, which matters if your baby needs extra care after birth.</p>

      <div class="space-y-6">
        {hospitalDetails.map((h) => {
          const thumb = hospitalThumbnails[h.name];
          return (
          <div class="bg-white border border-tjb-lavender-200 rounded-lg p-5 hover:border-tjb-rose-400/50 transition">
            {thumb ? (
              <div class="flex gap-4 items-start">
                <img
                  src={thumb}
                  alt={`${h.name} exterior`}
                  class="w-20 h-20 rounded-lg object-cover flex-shrink-0"
                  width="240"
                  height="240"
                  loading="lazy"
                />
                <div class="flex-1 min-w-0">
                  {h.url ? (
                    <h3 class="text-lg font-semibold mb-1 flex items-center gap-2">
                      <svg class="w-4.5 h-4.5 text-tjb-rose-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                      <a href={h.url} target="_blank" rel="noopener noreferrer" class="text-tjb-lavender-600 hover:underline">{h.name} ↗</a>
                    </h3>
                  ) : (
                    <h3 class="text-lg font-semibold mb-1 flex items-center gap-2">
                      <svg class="w-4.5 h-4.5 text-tjb-rose-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                      {h.name}
                    </h3>
                  )}
                  <p class="text-tjb-gray text-[0.9375rem] leading-relaxed" set:html={h.paragraph} />
                </div>
              </div>
            ) : (
              <div>
                {h.url ? (
                  <h3 class="text-lg font-semibold mb-1 flex items-center gap-2">
                    <svg class="w-4.5 h-4.5 text-tjb-rose-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                    <a href={h.url} target="_blank" rel="noopener noreferrer" class="text-tjb-lavender-600 hover:underline">{h.name} ↗</a>
                  </h3>
                ) : (
                  <h3 class="text-lg font-semibold mb-1 flex items-center gap-2">
                    <svg class="w-4.5 h-4.5 text-tjb-rose-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                    {h.name}
                  </h3>
                )}
                <p class="text-tjb-gray text-[0.9375rem] leading-relaxed" set:html={h.paragraph} />
              </div>
            )}
          </div>
          );
        })}
        {birthCenterDetails.map((bc) => (
          <div class="bg-white border border-tjb-lavender-200 rounded-lg p-5 hover:border-tjb-rose-400/50 transition">
            {bc.url ? (
              <h3 class="text-lg font-semibold mb-1 flex items-center gap-2">
                <svg class="w-4.5 h-4.5 text-tjb-sage flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                <a href={bc.url} target="_blank" rel="noopener noreferrer" class="text-tjb-lavender-600 hover:underline">{bc.name} ↗</a>
              </h3>
            ) : (
              <h3 class="text-lg font-semibold mb-1 flex items-center gap-2">
                <svg class="w-4.5 h-4.5 text-tjb-sage flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                {bc.name}
              </h3>
            )}
            <p class="text-tjb-gray text-[0.9375rem] leading-relaxed" set:html={bc.paragraph} />
          </div>
        ))}
      </div>

      <p class="text-sm text-tjb-gray italic mt-6">Hospitals listed for reference only. True Joy Birthing does not endorse any specific provider. Always call ahead to confirm doula and visitor policies during your hospital tour.</p>
      <p class="text-sm text-tjb-gray mt-1">Reviewed by <a href="/about/" class="text-tjb-lavender-600 hover:underline">Shelbi Kohler</a></p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       DOULA COSTS
       ═══════════════════════════════════════════════════════════ -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">
      <h2 class="flex items-center gap-2.5">
        <!-- Dollar/cost icon -->
