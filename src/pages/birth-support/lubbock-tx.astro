---
import Layout from '../../layouts/Layout.astro';

const city = "Lubbock";
const state = "TX";
const pageTitle = `Doula Lubbock TX — Birth Support, Costs & Free Joyful Birth Plan`;
const pageDesc = `Find a doula in Lubbock, TX — local hospital info, doula costs, Medicaid status, and the free Joyful Birth Plan for local families.`;
const pageUrl = `https://truejoybirthing.com/birth-support/lubbock-tx`;

const hospitals = ["Covenant Medical Center", "University Medical Center Lubbock", "Methodist Hospital Lubbock"];
const birthCenters = [];
const costLow = 700;
const costHigh = 2000;
const medicaidNote = "Texas Medicaid's doula benefit is expanding statewide. As of 2026, doula services may be reimbursable in the Lubbock area. Confirm with your Medicaid plan.";
const insuranceNote = "Some private insurers in the Lubbock region now cover doula support as part of maternal wellness benefits. Contact your plan.";
const culture = "Lubbock is a West Texas hub with a tight-knit birth community. Families typically deliver at one of the major hospital systems in the city.";
const shelbiServesHere = false;

const faqs = [{"q": "Does Medicaid cover doulas in Lubbock?", "a": "Texas is expanding Medicaid doula coverage statewide. Specific eligibility depends on your plan. Contact your Texas Medicaid managed care provider for current benefits."}, {"q": "How much does a doula cost in Lubbock?", "a": "$700 to $2,000 depending on experience and package. Costs in West Texas tend to be lower than in major metros."}, {"q": "Does True Joy Birthing work with Lubbock families?", "a": "The free app and birth plan work for any Lubbock birth setting. Virtual confidence sessions are available. Shelbi does not provide in-person doula services in Lubbock."}, {"q": "Are there birth centers in Lubbock?", "a": "Lubbock currently has limited standalone birth center options. Most families deliver at one of the major hospital systems. Ask your care provider about birth center alternatives."}];

const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "Birth Support", "url": "https://truejoybirthing.com/birth-support/"}, {"name": "Lubbock, TX", "url": pageUrl}];

const faqSchema = {
  "@context": "https://schema.org",
  "@graph": [
    ...faqs.map((f, i) => ({
      "@type": "Question",
      "@id": `https://truejoybirthing.com/birth-support/lubbock-tx/#question-${i+1}`,
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    })),
    {
      "@type": "FAQPage",
      "@id": `https://truejoybirthing.com/birth-support/lubbock-tx/#faq`,
      "mainEntity": faqs.map((_, i) => ({ "@id": `https://truejoybirthing.com/birth-support/lubbock-tx/#question-${i+1}` }))
    },
    {
      "@type": "LocalBusiness",
      "@id": `https://truejoybirthing.com/birth-support/lubbock-tx/#local`,
      "name": "True Joy Birthing",
      "url": pageUrl,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Lubbock",
        "addressRegion": "TX",
        "addressCountry": "US"
      },
      "areaServed": {
        "@type": "City",
        "name": "Lubbock"
      },
      "parentOrganization": { "@id": "https://truejoybirthing.com/#organization" }
    }
  ]
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [...faqSchema["@graph"]]
};
---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}
  breadcrumbList={breadcrumbList}
  schema={schema}
>

  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div>
          <h1 class="text-3xl md:text-4xl font-bold mb-4">Find a Doula in Lubbock, TX</h1>
          <p class="text-lg text-tjb-gray mb-6">
        If you're <a href="/what-is-a-doula/">looking for a doula</a> in Lubbock, TX, this guide covers local hospital options, doula costs, Medicaid status, and the free Joyful Birth Plan families trust here.
      </p>
      <p class="text-tjb-gray mb-4">Lubbock moms: Covenant and UMC are both on the west side of town off Slide Road and 4th Street, and during Texas Tech game days that whole area turns into a parking lot. If you're due in the fall, know your alternate routes before contractions start — the last thing you need is game-day traffic between you and the hospital. Clapp Park's walking trail is a go-to for third-trimester evening walks — flat, quiet, and close enough to both hospitals that you're not far if something picks up.</p>
          <div class="flex flex-col sm:flex-row gap-3">
        <a href="#download-pdf" class="bg-tjb-lavender-500 text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-rose-500 transition">
          Download Free Birth Plan</a>
        <a href="https://apps.apple.com/app/true-joy-birthing" class="bg-tjb-cream-50 text-tjb-lavender-500 border-2 border-tjb-lavender-500 px-6 py-3 rounded-lg font-semibold hover:bg-tjb-cream transition">
          Get the Free App</a>
      </div>
        </div>
        <div class="relative">
          <img
            src="/images/lubbock-texas-birth-doula-skyline.webp"
            alt="Skyline of Lubbock, Texas, where families search for birth doulas and plan their hospital births."
            class="w-full h-64 md:h-80 object-cover rounded-2xl shadow-lg"
            width="1200"
            height="800"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">

      <h2>What Birth Support Looks Like in Lubbock</h2>
      <p>Lubbock is a West Texas hub with a tight-knit birth community. Families typically deliver at one of the major hospital systems in the city.</p>

      

      <p>Covenant Medical Center, in northwest Lubbock, is the largest hospital in the region with a Level III NICU and a high-volume L&amp;D unit that serves the entire South Plains. Covenant handles more births than anyone in the region — they're experienced and well-equipped, but that volume means having your birth plan ready makes the intake process smoother. <a href="/birth-plan-template/">Use our free hospital birth plan template</a> to get started.</p>

      <p>University Medical Center Lubbock, the region's public teaching hospital affiliated with Texas Tech Health Sciences Center, handles many Medicaid births and complex cases. UMC serves a broad community — if you're delivering here, come with your plan in hand. Honestly, this hospital sees families from all over West Texas, so it moves fast.</p>

      <p class="text-sm text-tjb-gray italic">Hospitals and birth centers mentioned for context only. True Joy Birthing does not endorse any specific provider. Always confirm visitor and doula policies during your hospital tour.</p>

      {birthCenters.length > 0 && (
        <>
          <p>Birth center options in Lubbock may include:</p>
          <ul>
            {birthCenters.map(bc => <li>{bc}</li>)}
          </ul>
        </>
      )}

      <h2>How Much Does a Doula Cost in Lubbock?</h2>
      <p>
        In Lubbock, birth doula services typically range from <strong>${costLow.toLocaleString()} to ${costHigh.toLocaleString()}</strong> depending on experience, package, and whether the doula offers add-on services like <a href="/postpartum-doula/">postpartum visits</a>. <a href="/doula-cost/">See our full doula cost guide</a> for what's typically included.
      </p>
      <p>{insuranceNote}</p>
      <p><strong>HSA/FSA:</strong> Many families don't realize that doula services can often be paid for with HSA or FSA funds, since birth support qualifies as a medical expense under most plans. Check with your plan administrator to confirm what's eligible and whether you need a letter from your provider.</p>
      <p>Not sure what to look for? <a href="/how-to-choose-a-doula/">Here's how to choose a doula</a> who fits your birth preferences and budget.</p>
      
      <p><strong>Medicaid Note:</strong> {medicaidNote}</p>

      <h2>Next Steps: Your Doula in Lubbock, TX — Plan Your Birth</h2>
      <p>No matter where you deliver in Lubbock, a clear, organized birth plan helps you communicate your preferences to the team in your birth room. Start with the <a href="/birth-plan-template/">free birth plan template</a>, then use the <a href="/birth-plan-checklist/">birth plan checklist</a> to make sure nothing gets missed.</p>
      <a href="#download-pdf" class="inline-block bg-tjb-lavender-500 text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-rose-500 transition mb-6">
        Download the Free Birth Plan</a>
      <p class="mt-2 text-sm text-tjb-gray">Or <a href="/birth-plan-course/">take the free birth plan course</a> step by step.</p>

      {shelbiServesHere ? (
        <div class="bg-tjb-cream p-4 rounded-lg mb-6">
          <p class="font-semibold text-tjb-lavender-500 mb-1">Shelbi serves local families in the Lubbock area.</p>
          <p class="text-sm text-tjb-gray">Virtual confidence sessions are also available for families in Lubbock. the free birth plan course to prepare step by step.</p>
          <a href="/birth-plan-session" class="text-tjb-lavender-500 font-semibold text-sm hover:underline">Book a session →</a>
        </div>
      ) : (
        <div class="bg-tjb-cream p-4 rounded-lg mb-6">
          <p class="font-semibold text-tjb-lavender-500 mb-1">Virtual support available for Lubbock families.</p>
          <p class="text-sm text-tjb-gray">The free app and birth plan work for any Lubbock birth setting. Virtual confidence sessions are available with Shelbi. the free birth plan course to prepare step by step.</p>
          <a href="/birth-plan-session" class="text-tjb-lavender-500 font-semibold text-sm hover:underline">Book a virtual session →</a>
        </div>
      )}

      
      <div class="bg-white border-2 border-tjb-lavender-200 p-5 rounded-lg mb-6">
        <h3 class="font-semibold text-lg text-tjb-charcoal mb-2">What True Joy Birthing Actually Does for You</h3>
        <p class="text-tjb-gray mb-2">True Joy Birthing isn't a doula matching service, and we're not necessarily your in-person doula in Lubbock. We're the step before — and alongside — all of that.</p>
        <p class="text-tjb-gray mb-2">Shelbi built the free Joyful Birth Plan because she saw families show up to the hospital without their preferences written down, every single time. The birth plan template, the checklist, the free course — these are the tools that help you walk in prepared, whether you end up hiring a local doula or going it alone.</p>
        <p class="text-tjb-gray">If you do find a doula in Lubbock, great — bring your plan and use it together. If you're still looking, or if hiring a doula isn't in the budget right now, the birth plan is free and it works.</p>
      </div>

      <h2>Common Questions in Lubbock</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div>
            <h3 class="font-semibold mb-1">{f.q}</h3>
            <p class="text-tjb-gray">{f.a}</p>
          </div>
        ))}
      </div>

      <h2>Nearby Resources</h2>
      <a href="/birth-support" class="text-tjb-lavender-500 font-semibold hover:underline">See all cities →</a>

    </div>
  </section>

  <section id="download-pdf" class="py-16 bg-tjb-cream">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Get Your Free Joyful Birth Plan</h2>
      <p class="text-tjb-gray mb-8">Built by a doula for Lubbock-area moms planning their birth.</p>
      <form id="lead-magnet-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input id="lead-email" name="email" type="email" placeholder="Your email" class="flex-1 px-4 py-3 rounded-lg border border-tjb-lavender-300 focus:outline-none focus:border-tjb-lavender-500" required />
        <button id="lead-submit" type="submit" class="bg-tjb-lavender-500 text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-rose-500 transition whitespace-nowrap">Get My Plan →</button>
      </form>
      <p id="lead-status" class="text-sm mt-2 hidden"></p>
      <p class="text-xs text-tjb-gray/70 mt-4">No spam. Just a free birth plan and occasional tips you can actually use.</p>
    </div>
  </section>

  <script>
    const form = document.getElementById('lead-magnet-form');
    const emailInput = document.getElementById('lead-email');
    const status = document.getElementById('lead-status');
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = emailInput?.value;
        if (!email) return;
        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: 'Lead Magnet', email, message: 'Lead magnet download request from city page' })
          });
          const data = await res.json();
          if (data.success) {
            status.textContent = '✓ Check your email — your birth plan is on its way.';
            status.classList.remove('hidden', 'text-red-500');
            status.classList.add('text-green-600');
            emailInput.value = '';
          } else {
            status.textContent = 'Something went wrong. Please try again.';
            status.classList.remove('hidden', 'text-green-600');
            status.classList.add('text-red-500');
          }
        } catch {
          status.textContent = 'Network error. Please try again.';
          status.classList.remove('hidden', 'text-green-600');
          status.classList.add('text-red-500');
        }
      });
    }
  </script>

</Layout>
