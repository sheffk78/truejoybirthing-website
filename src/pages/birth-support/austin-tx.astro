---
import Layout from '../../layouts/Layout.astro';

const city = "Austin";
const state = "TX";
const pageTitle = `Birth Support in ${city}, ${state}`;
const pageDesc = `Find birth support resources in Austin, TX — local hospital info, doula costs, Medicaid status, and a free birth plan built for local families.`;
const pageUrl = `https://truejoybirthing.com/birth-support/austin-tx`;

const hospitals = ["St. David's South Austin", "Austin Area Birthing Center", "Seton Medical Center Austin"];
const birthCenters = ["Austin Area Birthing Center", "Natural Beginnings Birth and Wellness Center"];
const costLow = 1000;
const costHigh = 3000;
const medicaidNote = "Texas Medicaid doula expansion is underway. In the progressive Austin area, some Medicaid plans may already offer doula coverage. Check with your specific plan.";
const insuranceNote = "Austin's progressive health culture means more insurers offer alternative care benefits including doula support. Tech-sector employers in the area increasingly include maternity wellness in coverage.";
const culture = "Austin has a strong and vocal birth center community. Alongside major hospital systems, the city is known for its progressive approach to maternal wellness and integrative care. Austin families tend to be well-researched and engaged in their birth options.";
const shelbiServesHere = false;

const faqs = [
  { q: "Is Austin a good city for natural birth?", a: "Austin is known for its birth-friendly culture. The city has multiple birth centers and a community of providers who support varied birth preferences. Hospitals like St. David's South Austin accommodate diverse birth plans." },
  { q: "How much does a doula cost in Austin?", a: "$1,000 to $3,000. Austin's higher cost of living and strong doula community mean prices range higher than some Texas markets, but so does the level of experienced support." },
  { q: "Does True Joy Birthing serve Austin families?", a: "The free app and birth plan work for any Austin birth setting. Virtual confidence sessions are available. Shelbi does not provide in-person doula services in Austin." },
  { q: "What are Austin's birth center options?", a: "Austin Area Birthing Center and Natural Beginnings are two well-established options. Both have strong community ties. Always verify their transfer agreements with nearby hospitals." }
];
---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}
>

  <section class="bg-tjb-warm pt-16 pb-12">
    <div class="max-w-4xl mx-auto px-6">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">Birth Support in Austin, TX</h1>
      <p class="text-lg text-tjb-soft mb-6">
        Local hospital options, doula costs, and Medicaid status — plus the free birth plan template families in Austin use to feel confident and prepared.
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="#download-pdf" class="bg-tjb-forest text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-sage transition">Download Free Birth Plan</a>
        <a href="https://apps.apple.com/app/true-joy-birthing" class="bg-white text-tjb-forest border-2 border-tjb-forest px-6 py-3 rounded-lg font-semibold hover:bg-tjb-warm transition">Get the Free App</a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">

      <h2>What Birth Support Looks Like in Austin</h2>
      <p>Austin has a strong and vocal birth center community. Alongside major hospital systems, the city is known for its progressive approach to maternal wellness and integrative care. Austin families tend to be well-researched and engaged in their birth options.</p>

      <p>Families in Austin often deliver at hospitals including:</p>
      <ul>
        <li>St. David's South Austin</li>
        <li>Austin Area Birthing Center</li>
        <li>Seton Medical Center Austin</li>
      </ul>
      <p class="text-sm text-tjb-soft italic">Hospitals mentioned for context only. True Joy Birthing does not endorse any specific provider.</p>

      <p>Birth center options in Austin may include:</p>
      <ul>
        <li>Austin Area Birthing Center</li>
        <li>Natural Beginnings Birth and Wellness Center</li>
      </ul>

      <h2>How Much Does a Doula Cost in Austin?</h2>
      <p>In Austin, birth doula services typically range from <strong>$1,000 to $3,000</strong> depending on experience, package, and whether the doula offers add-on services like postpartum visits.</p>
      <p>Austin's progressive health culture means more insurers offer alternative care benefits including doula support. Tech-sector employers in the area increasingly include maternity wellness in coverage.</p>
      <p><strong>Medicaid Note:</strong> Texas Medicaid doula expansion is underway. In the progressive Austin area, some Medicaid plans may already offer doula coverage. Check with your specific plan.</p>

      <h2>Build Your Birth Plan for Austin</h2>
      <p>No matter where you deliver in Austin, a clear, organized birth plan helps you communicate your preferences to the team in your birth room.</p>
      <a href="#download-pdf" class="inline-block bg-tjb-forest text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-sage transition mb-6">Download the Free Birth Plan</a>

      <h2>Common Questions in Austin</h2>
      <div class="space-y-4">
        <div>
          <h3 class="font-semibold mb-1">Is Austin a good city for natural birth?</h3>
          <p class="text-tjb-soft">Austin is known for its birth-friendly culture. The city has multiple birth centers and a community of providers who support varied birth preferences. Hospitals like St. David's South Austin accommodate diverse birth plans.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">How much does a doula cost in Austin?</h3>
          <p class="text-tjb-soft">$1,000 to $3,000. Austin's higher cost of living and strong doula community mean prices range higher than some Texas markets, but so does the level of experienced support.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">Does True Joy Birthing serve Austin families?</h3>
          <p class="text-tjb-soft">The free app and birth plan work for any Austin birth setting. Virtual confidence sessions are available. Shelbi does not provide in-person doula services in Austin.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">What are Austin's birth center options?</h3>
          <p class="text-tjb-soft">Austin Area Birthing Center and Natural Beginnings are two well-established options. Both have strong community ties. Always verify their transfer agreements with nearby hospitals.</p>
        </div>
      </div>

      <h2>Nearby Resources</h2>
      <a href="/birth-support" class="text-tjb-forest font-semibold hover:underline">See all cities →</a>

    </div>
  </section>

  <section id="download-pdf" class="py-16 bg-tjb-cream">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Download Your Free Birth Plan</h2>
      <p class="text-tjb-soft mb-8">Built by a doula for hospital-planning moms everywhere.</p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" action="#" method="POST">
        <input name="email" type="email" placeholder="Your email" class="flex-1 px-4 py-3 rounded-lg border border-tjb-rose/50 focus:outline-none focus:border-tjb-forest" required />
        <button type="submit" class="bg-tjb-forest text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-sage transition whitespace-nowrap">Get My Plan →</button>
      </form>
      <p class="text-xs text-tjb-soft/70 mt-4">No spam. Just a free birth plan and occasional tips you can actually use.</p>
    </div>
  </section>

</Layout>
