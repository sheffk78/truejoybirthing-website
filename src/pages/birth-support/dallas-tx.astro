---
import Layout from '../../layouts/Layout.astro';

const city = "Dallas";
const state = "TX";
const pageTitle = `Birth Support in ${city}, ${state}`;
const pageDesc = `Find birth support resources in Dallas, TX — local hospital info, doula costs, Medicaid status, and a free birth plan built for local families.`;
const pageUrl = `https://truejoybirthing.com/birth-support/dallas-tx`;

const hospitals = ["Texas Health Dallas", "Baylor University Medical Center", "Parkland Memorial Hospital"];
const birthCenters = ["The Birth Place at Dallas Birth Center"];
const costLow = 900;
const costHigh = 2800;
const medicaidNote = "Texas Medicaid's doula benefit is expanding statewide. As of 2026, doula services may be reimbursable in the Dallas-Fort Worth area. Confirm with your Medicaid plan.";
const insuranceNote = "Some private insurers through the DFW metro area now cover doula support as part of maternal wellness benefits. Contact your plan.";
const culture = "Dallas is a large, diverse metro with a growing birth community. Families deliver at everything from high-volume hospitals to smaller community facilities and standalone birth centers. Medicaid expansion is making doula support more accessible.";
const shelbiServesHere = true;

const faqs = [
  { q: "Does Medicaid cover doulas in Dallas?", a: "Texas is expanding Medicaid doula coverage statewide. Specific eligibility depends on your plan. Contact your Texas Medicaid managed care provider for current benefits." },
  { q: "Which Dallas hospitals are birth-plan friendly?", a: "Many Dallas-area hospitals accommodate birth plans, but policies vary by facility. Texas Health Dallas and Baylor University Medical Center both see well-informed patients with clear preferences. Always confirm your hospital's policy during your hospital tour." },
  { q: "How much does a doula cost in Dallas?", a: "$900 to $2,800 depending on experience and package. Doula services are often considered worthwhile by families who want continuous support through labor and delivery." },
  { q: "Does True Joy Birthing work with Dallas families?", a: "Shelbi is based in the DFW metro and can support Dallas-area families with virtual birth plan sessions. The free app and birth plan work for any Dallas hospital." }
];
---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}
>

  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-4xl mx-auto px-6">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">Birth Support in Dallas, TX</h1>
      <p class="text-lg text-tjb-gray mb-6">
        Local hospital options, doula costs, and Medicaid status — plus the free birth plan template families in Dallas use to feel confident and prepared.
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="#download-pdf" class="bg-tjb-lavender-500 text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-rose-500 transition">
          Download Free Birth Plan</a>
        <a href="https://apps.apple.com/app/true-joy-birthing" class="bg-tjb-cream-50 text-tjb-lavender-500 border-2 border-tjb-lavender-500 px-6 py-3 rounded-lg font-semibold hover:bg-tjb-cream transition">
          Get the Free App</a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">

      <h2>What Birth Support Looks Like in Dallas</h2>
      <p>Dallas is a large, diverse metro with a growing birth community. Families deliver at everything from high-volume hospitals to smaller community facilities and standalone birth centers. Medicaid expansion is making doula support more accessible.</p>

      <p>Families in Dallas often deliver at hospitals including:</p>
      <ul>
        <li>Texas Health Dallas</li>
        <li>Baylor University Medical Center</li>
        <li>Parkland Memorial Hospital</li>
      </ul>
      <p class="text-sm text-tjb-gray italic">Hospitals mentioned for context only. True Joy Birthing does not endorse any specific provider.</p>

      <p>Birth center options in Dallas may include:</p>
      <ul>
        <li>The Birth Place at Dallas Birth Center</li>
      </ul>

      <h2>How Much Does a Doula Cost in Dallas?</h2>
      <p>
        In Dallas, birth doula services typically range from <strong>$900 to $2,800</strong> depending on experience, package, and whether the doula offers add-on services like postpartum visits.
      </p>
      <p>Some private insurers through the DFW metro area now cover doula support as part of maternal wellness benefits. Contact your plan.</p>
      <p><strong>Medicaid Note:</strong> Texas Medicaid's doula benefit is expanding statewide. As of 2026, doula services may be reimbursable in the Dallas-Fort Worth area. Confirm with your Medicaid plan.</p>

      <h2>Build Your Birth Plan for Dallas</h2>
      <p>No matter where you deliver in Dallas, a clear, organized birth plan helps you communicate your preferences to the team in your birth room.</p>
      <a href="#download-pdf" class="inline-block bg-tjb-lavender-500 text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-rose-500 transition mb-6">
        Download the Free Birth Plan</a>

      <div class="bg-tjb-cream p-4 rounded-lg mb-6">
        <p class="font-semibold text-tjb-lavender-500 mb-1">Shelbi serves local families in the Dallas area.</p>
        <p class="text-sm text-tjb-gray">Virtual confidence sessions are also available for families in Dallas.</p>
        <a href="/birth-plan-session" class="text-tjb-lavender-500 font-semibold text-sm hover:underline">Book a session →</a>
      </div>

      <h2>Common Questions in Dallas</h2>
      <div class="space-y-4">
        <div>
          <h3 class="font-semibold mb-1">Does Medicaid cover doulas in Dallas?</h3>
          <p class="text-tjb-gray">Texas is expanding Medicaid doula coverage statewide. Specific eligibility depends on your plan. Contact your Texas Medicaid managed care provider for current benefits.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">Which Dallas hospitals are birth-plan friendly?</h3>
          <p class="text-tjb-gray">Many Dallas-area hospitals accommodate birth plans, but policies vary by facility. Texas Health Dallas and Baylor University Medical Center both see well-informed patients with clear preferences. Always confirm your hospital's policy during your hospital tour.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">How much does a doula cost in Dallas?</h3>
          <p class="text-tjb-gray">$900 to $2,800 depending on experience and package. Doula services are often considered worthwhile by families who want continuous support through labor and delivery.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">Does True Joy Birthing work with Dallas families?</h3>
          <p class="text-tjb-gray">Shelbi is based in the DFW metro and can support Dallas-area families with virtual birth plan sessions. The free app and birth plan work for any Dallas hospital.</p>
        </div>
      </div>

      <h2>Nearby Resources</h2>
      <a href="/birth-support" class="text-tjb-lavender-500 font-semibold hover:underline">See all cities →</a>

    </div>
  </section>

  <section id="download-pdf" class="py-16 bg-tjb-cream">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Download Your Free Birth Plan</h2>
      <p class="text-tjb-gray mb-8">Built by a doula for hospital-planning moms everywhere.</p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" action="#" method="POST">
        <input name="email" type="email" placeholder="Your email" class="flex-1 px-4 py-3 rounded-lg border border-tjb-lavender-300 focus:outline-none focus:border-tjb-lavender-500" required />
        <button type="submit" class="bg-tjb-lavender-500 text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-rose-500 transition whitespace-nowrap">Get My Plan →</button>
      </form>
      <p class="text-xs text-tjb-gray/70 mt-4">No spam. Just a free birth plan and occasional tips you can actually use.</p>
    </div>
  </section>

</Layout>
