---
// 404 page — branded, helpful
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found — True Joy Birthing"
  description="The page you were looking for doesn't exist. Explore our birth planning resources, blog, or download a free birth plan."
  canonical="https://truejoybirthing.com/404"
>
  <section class="bg-tjb-cream py-20 md:py-32">
    <div class="max-w-xl mx-auto px-6 text-center">
      <!-- Large serif 404 — editorial, not robotic -->
      <p class="text-[8rem] md:text-[10rem] leading-none font-serif text-tjb-lavender-400 mb-2 select-none">404</p>
      
      <h1 class="text-2xl md:text-[1.75rem] mb-6">This page doesn't exist.</h1>
      
      <p class="text-tjb-gray leading-relaxed mb-10">
        It may have moved, been renamed, or never existed. 
        Try one of these instead.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-3 justify-center mb-12">
        <a href="/" class="btn-primary text-center">Go Home</a>
        <a href="/blog" class="btn-secondary text-center">Read the Blog</a>
      </div>
      
      <div class="border-t border-tjb-lavender-300/30 pt-8">
        <p class="eyebrow mb-3">Or try</p>
        <div class="flex flex-wrap justify-center gap-x-4 gap-y-2 text-sm text-tjb-gray">
          <a href="/birth-plan-course" class="hover:text-tjb-rose-500 transition border-b border-transparent hover:border-tjb-rose-500 pb-0.5">Birth Plan Course</a>
          <span class="text-tjb-rose-300">·</span>
          <a href="/birth-plan-session" class="hover:text-tjb-rose-500 transition border-b border-transparent hover:border-tjb-rose-500 pb-0.5">1:1 Session</a>
          <span class="text-tjb-rose-300">·</span>
          <a href="/faq" class="hover:text-tjb-rose-500 transition border-b border-transparent hover:border-tjb-rose-500 pb-0.5">FAQ</a>
          <span class="text-tjb-rose-300">·</span>
          <a href="/contact" class="hover:text-tjb-rose-500 transition border-b border-transparent hover:border-tjb-rose-500 pb-0.5">Contact</a>
        </div>
      </div>
    </div>
  </section>

</Layout>