<script>
  const form = document.getElementById('ambassador-form') as HTMLFormElement;
  const status = document.getElementById('amb-form-status') as HTMLDivElement;
  const btn = document.getElementById('amb-submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const data = new FormData(form);
    const body = Object.fromEntries(data.entries());

    btn.disabled = true;
    btn.textContent = 'Sending...';
    status.className = 'hidden text-sm mt-2';
    status.textContent = '';

    try {
      const res = await fetch('/api/ambassador', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      const result = await res.json();

      if (res.ok && result.success) {
        status.textContent = 'Got it! I\'ll review your application and reach out within 2-3 business days.';
        status.className = 'text-sm mt-2 text-green-700';
        form.reset();
      } else {
        status.textContent = result.error || 'Something went wrong. Please try again or email me directly.';
        status.className = 'text-sm mt-2 text-red-600';
      }
    } catch {
      status.textContent = 'Network error. Please try again or email shelbi@truejoybirthing.com directly.';
      status.className = 'text-sm mt-2 text-red-600';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Get Started';
    }
  });
</script>