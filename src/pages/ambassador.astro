---
import Layout from '../layouts/Layout.astro';

const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "Ambassador Program", "url": "https://truejoybirthing.com/ambassador/"}];

const faqs = [
  {
    q: "Who can become a True Joy Birthing ambassador?",
    a: "Any certified doula, midwife, childbirth educator, or lactation consultant with an active practice. If you care about better birth preparation and you want to share a tool that genuinely helps your clients, you're who this is for."
  },
  {
    q: "Is there a minimum number of posts or referrals required?",
    a: "No. None. You share when it's real and when it fits. I'll never count your posts or track your referrals. This is a relationship, not a performance contract."
  },
  {
    q: "How does free Pro Mode work?",
    a: "I flip Pro Mode on in your account. That's it. No credit card, no expiration date, no weird strings. If you ever leave the program, your account just goes back to the free plan. Nothing weird happens."
  },
  {
    q: "Is there a commission or affiliate program?",
    a: "No. I know how these programs usually work. They promise community and track you like a sales rep. I didn't want that for TJB, and I'm guessing you don't want it either. When you tell another doula about a tool that works, that's real. I won't turn your word-of-mouth into a number."
  },
  {
    q: "What does being featured on a city page mean?",
    a: "Your name, photo, and a short bio appear on the TJB city page for your area. When an expecting family searches for birth support in your city, they find you. It's free professional visibility on a page that already ranks in search."
  },
  {
    q: "How do I apply?",
    a: "Fill out the form on this page or email me directly at <a href=\"mailto:shelbi@truejoybirthing.com\" class=\"text-tjb-rose-500 hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all font-semibold\">shelbi@truejoybirthing.com</a>. I read every application myself. If it feels like a fit, I'll reach out by email to set up a quick 15-minute call so we can get to know each other."
  },
  {
    q: "How long does it take to hear back?",
    a: "I review applications within 2-3 business days. If it's a fit, I'll email you to schedule a short call. Pro Mode gets activated within 24 hours after that."
  },
  {
    q: "What if I want to leave the program?",
    a: "You leave whenever you want. No notice required, no questions asked. Your account goes back to the free plan, and that's it. No hard feelings ever."
  }
];

const faqSchema = {
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a.replace(/<[^>]*>/g, '')
    }
  }))
};

const articleSchema = {
  "@type": "Article",
  "headline": "TJB Ambassador Program — Free Pro Mode for Doulas and Midwives",
  "description": "Join the True Joy Birthing ambassador program. Free Pro Mode, featured placement on your city page, and a community of birth professionals making birth better.",
  "author": {
    "@type": "Organization",
    "name": "True Joy Birthing",
    "url": "https://truejoybirthing.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "True Joy Birthing",
    "logo": {
      "@type": "ImageObject",
      "url": "https://truejoybirthing.com/images/tjb-logo.svg"
    }
  },
  "datePublished": "2026-05-30",
  "dateModified": "2026-05-30",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://truejoybirthing.com/ambassador/"
  }
};
---

<Layout
  title="Ambassador Program — Free Pro for Doulas & Midwives"
  description="Join the True Joy Birthing ambassador program. Get free Pro Mode, be featured on your city page, and help more families have confident births. No quotas, no contracts."
  canonical="https://truejoybirthing.com/ambassador/"
  ogImage="https://truejoybirthing.com/images/og/true-joy-birthing-main.png"
  breadcrumbList={breadcrumbList}
  schema={[faqSchema, articleSchema]}
>

  <!-- ═══════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <p class="eyebrow mb-4">For Doulas & Midwives</p>
          <h1 class="text-[2.2rem] md:text-[3rem] leading-[1.12] font-bold text-tjb-charcoal mb-6">
            You Love the App. Other Birth Pros Should Know About It.
          </h1>
          <p class="text-lg text-tjb-gray leading-relaxed mb-8 max-w-xl">
            You already use TJB with your clients. You've probably told other doulas about it already. This just makes it official. Free Pro Mode, a listing on your city page, and a community that amplifies your work. No quotas. No contracts. No tracking.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#join" class="btn-primary text-center">
              Join the Ambassador Program
            </a>
            <a href="#what-you-get" class="btn-secondary text-center">
              See What's Included
            </a>
          </div>
        </div>
        <div class="relative flex justify-center md:justify-end">
          <div class="w-full max-w-sm rounded-2xl overflow-hidden shadow-xl shadow-tjb-lavender-300/40">
            <img
              src="/images/doula-teaching.webp"
              alt="Doula supporting an expecting family with birth preparation tools"
              class="w-full h-auto object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHY THIS IS DIFFERENT
       ═══════════════════════════════════════════ -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="eyebrow mb-4">Not Another Affiliate Program</p>
        <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto mb-6"></div>
        <h2 class="text-[2.25rem] md:text-[2.75rem] leading-[1.15] max-w-2xl mx-auto">
          This Is a Relationship, Not a Contract
        </h2>
        <p class="text-lg text-tjb-gray mt-6 max-w-2xl mx-auto">
          I know how these programs usually work. They promise community and track you like a sales rep. I didn't want that for TJB, and I'm guessing you don't want it either. Here's what makes this different.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-tjb-cream rounded-xl p-8 border border-tjb-lavender-200/50">
          <div class="w-12 h-12 rounded-full bg-tjb-lavender-100 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-tjb-lavender-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          </div>
          <h3 class="text-xl mb-3">No Tracking</h3>
          <p class="text-tjb-gray">I don't count your posts or track who you refer. When you tell another doula about a tool that works, that's real. I won't turn your word-of-mouth into a number.</p>
        </div>

        <div class="bg-tjb-cream rounded-xl p-8 border border-tjb-lavender-200/50">
          <div class="w-12 h-12 rounded-full bg-tjb-lavender-100 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-tjb-lavender-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-xl mb-3">No Renewal Clock</h3>
          <p class="text-tjb-gray">Free Pro Mode for as long as you're in the program. No 3-month expirations. No "post once or lose access." If you go quiet for a while, I check in like a friend, not a manager.</p>
        </div>

        <div class="bg-tjb-cream rounded-xl p-8 border border-tjb-lavender-200/50">
          <div class="w-12 h-12 rounded-full bg-tjb-lavender-100 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-tjb-lavender-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          </div>
          <h3 class="text-xl mb-3">No Quotas</h3>
          <p class="text-tjb-gray">No minimum posts. No referral targets. No tiers to climb. You share when it's real and when it fits. Authentic advocacy works because it's honest, not because it's measured.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHAT YOU GET
       ═══════════════════════════════════════════ -->
  <section id="what-you-get" class="py-20 md:py-28 bg-tjb-cream-50 border-y border-tjb-lavender-200/40">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="eyebrow mb-4">What You Get</p>
        <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto mb-6"></div>
        <h2 class="text-[2.25rem] md:text-[2.75rem] leading-[1.15] max-w-2xl mx-auto">
          Real Benefits, Not Discount Codes
        </h2>
      </div>

      <div class="space-y-0">
        <!-- 01: Free Pro Mode -->
        <div class="py-8 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-8 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-600 font-serif">01</span>
            <div>
              <h3 class="text-2xl mb-1">Free Pro Mode</h3>
              <p class="text-sm text-tjb-lavender-600 font-semibold mb-3">Free. For as long as you're in the program.</p>
              <p class="text-tjb-gray leading-relaxed">Full Pro Mode access. Client management, visit tracking, invoicing, birth plan collaboration, notes. Every feature, every update, no limits. You use it because it makes your practice better. I give it to you because that's the point.</p>
            </div>
          </div>
        </div>

        <!-- 02: Featured on your city page -->
        <div class="py-8 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-8 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-600 font-serif">02</span>
            <div>
              <h3 class="text-2xl mb-1">Featured on Your City Page</h3>
              <p class="text-sm text-tjb-lavender-600 font-semibold mb-3">Families in your area find you</p>
              <p class="text-tjb-gray leading-relaxed">Your name, photo, and a short bio on the TJB city page for your area. When an expecting family searches for birth support in your city, they find you. <a href="/doulas/salt-lake-city-ut/" class="text-tjb-rose-500 hover:underline font-medium">See what that looks like &rarr;</a> You get it because you're part of the community.</p>
            </div>
          </div>
        </div>

        <!-- 03: Cross-promotion -->
        <div class="py-8 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-8 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-600 font-serif">03</span>
            <div>
              <h3 class="text-2xl mb-1">More Eyes on Your Work</h3>
              <p class="text-sm text-tjb-lavender-600 font-semibold mb-3">I amplify your content, you amplify mine</p>
              <p class="text-tjb-gray leading-relaxed">I repost your content, tag you in stories, and feature you on TJB's pages. Your audience grows with ours. When you post about birth prep or client wins, I help more people see it. Cross-promotion, not one-way extraction.</p>
            </div>
          </div>
        </div>

        <!-- 04: Partner badge -->
        <div class="py-8 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-8 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-600 font-serif">04</span>
            <div>
              <h3 class="text-2xl mb-1">TJB Partner Badge</h3>
              <p class="text-sm text-tjb-lavender-600 font-semibold mb-3">A credential that actually means something</p>
              <p class="text-tjb-gray leading-relaxed">A clean credential for your website, social profiles, and business cards. "True Joy Birthing Partner" says you use professional tools and take your practice seriously. Simple, credible, and earned.</p>
            </div>
          </div>
        </div>

        <!-- 05: Early access -->
        <div class="py-8 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-8 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-600 font-serif">05</span>
            <div>
              <h3 class="text-2xl mb-1">You Help Build What Comes Next</h3>
              <p class="text-sm text-tjb-lavender-600 font-semibold mb-3">Early access and real input</p>
              <p class="text-tjb-gray leading-relaxed">New features come to ambassadors first. When you tell me something should work differently, I listen. You're not a user I market to. You're a professional I build with.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Mid-page CTA -->
      <div class="mt-12 text-center">
        <a href="#join" class="btn-primary">Join the Ambassador Program</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHAT WE ASK
       ═══════════════════════════════════════════ -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="eyebrow mb-4">What I Ask</p>
        <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto mb-6"></div>
        <h2 class="text-[2.25rem] md:text-[2.75rem] leading-[1.15] max-w-2xl mx-auto">
          Three Things. Nothing Complicated.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-tjb-rose-100 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-tjb-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <h3 class="text-xl mb-3">Use the App With Your Clients</h3>
          <p class="text-tjb-gray">Build birth plans, track visits, manage your practice. You do it because it works, not because I asked.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-tjb-rose-100 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-tjb-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <h3 class="text-xl mb-3">Tell Your Professional Network</h3>
          <p class="text-tjb-gray">When it comes up with other doulas and midwives, mention it. In person, in your groups, in your DMs. However you naturally share.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-tjb-rose-100 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-tjb-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4V2a1 1 0 011-1h8a1 1 0 011 1v2m0 0h4a1 1 0 110 2h-1v12a2 2 0 01-2 2H6a2 2 0 01-2-2V6H3a1 1 0 110-2h4zm-2 2v12h10V6H5z"/></svg>
          </div>
          <h3 class="text-xl mb-3">Mention TJB in Your Content</h3>
          <p class="text-tjb-gray">A birth story, a client prep post, a "tools I use" reel. When it fits, not on a schedule. Authentic moments reach more people than scheduled posts ever will.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       APPLY FORM
       ═══════════════════════════════════════════ -->
  <section id="join" class="py-20 md:py-28 bg-tjb-cream">
    <div class="max-w-2xl mx-auto px-6">
      <div class="text-center mb-12">
        <p class="eyebrow mb-4">Join the Program</p>
        <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto mb-6"></div>
        <h2 class="text-[2.25rem] md:text-[2.75rem] leading-[1.15]">
          Ready?
        </h2>
        <p class="text-lg text-tjb-gray mt-4 max-w-xl mx-auto">
          Tell me about yourself and your practice. I read every application myself. If it feels like a fit, I'll reach out by email to set up a quick 15-minute call so we can get to know each other.
        </p>
      </div>

      <div class="bg-white rounded-2xl p-8 md:p-10 shadow-sm border border-tjb-lavender-200/50">
        <form id="ambassador-form" class="space-y-5">
          <div>
            <label for="amb-name" class="block text-sm font-medium mb-1">Full Name</label>
            <input type="text" id="amb-name" name="name" class="w-full px-4 py-3 rounded-lg border border-tjb-lavender-300 focus:outline-none focus:border-tjb-lavender-500" required />
          </div>

          <div>
            <label for="amb-email" class="block text-sm font-medium mb-1">Email</label>
            <input type="email" id="amb-email" name="email" class="w-full px-4 py-3 rounded-lg border border-tjb-lavender-300 focus:outline-none focus:border-tjb-lavender-500" required />
          </div>

          <div>
            <label for="amb-role" class="block text-sm font-medium mb-1">Your Role</label>
            <select id="amb-role" name="role" class="w-full px-4 py-3 rounded-lg border border-tjb-lavender-300 focus:outline-none focus:border-tjb-lavender-500 bg-white" required>
              <option value="">Select your role</option>
              <option value="doula">Birth Doula</option>
              <option value="postpartum-doula">Postpartum Doula</option>
              <option value="midwife">Midwife</option>
              <option value="childbirth-educator">Childbirth Educator</option>
              <option value="lactation-consultant">Lactation Consultant (IBCLC)</option>
              <option value="other">Other Birth Professional</option>
            </select>
          </div>

          <div>
            <label for="amb-city" class="block text-sm font-medium mb-1">City & State</label>
            <input type="text" id="amb-city" name="city" placeholder="e.g., Austin, TX" class="w-full px-4 py-3 rounded-lg border border-tjb-lavender-300 focus:outline-none focus:border-tjb-lavender-500" required />
          </div>

          <div>
            <label for="amb-instagram" class="block text-sm font-medium mb-1">Instagram or Website <span class="text-tjb-gray font-normal">(optional)</span></label>
            <input type="text" id="amb-instagram" name="instagram" placeholder="@handle or URL" class="w-full px-4 py-3 rounded-lg border border-tjb-lavender-300 focus:outline-none focus:border-tjb-lavender-500" />
          </div>

          <div>
            <label for="amb-audience" class="block text-sm font-medium mb-1">How many people follow your work? <span class="text-tjb-gray font-normal">(optional)</span></label>
            <select id="amb-audience" name="audience" class="w-full px-4 py-3 rounded-lg border border-tjb-lavender-300 focus:outline-none focus:border-tjb-lavender-500 bg-white">
              <option value="">Select a range</option>
              <option value="under-100">Under 100</option>
              <option value="100-500">100 – 500</option>
              <option value="500-1000">500 – 1,000</option>
              <option value="1000-5000">1,000 – 5,000</option>
              <option value="5000-plus">5,000+</option>
            </select>
          </div>

          <div>
            <label for="amb-why" class="block text-sm font-medium mb-1">What interests you most about this? <span class="text-tjb-gray font-normal">(optional)</span></label>
            <textarea id="amb-why" name="why" rows="3" placeholder="A sentence or two about your practice and why TJB resonates with you..." class="w-full px-4 py-3 rounded-lg border border-tjb-lavender-300 focus:outline-none focus:border-tjb-lavender-500"></textarea>
          </div>

          <button type="submit" id="amb-submit-btn" class="w-full bg-tjb-lavender-600 text-white px-8 py-3 rounded-full font-semibold hover:bg-tjb-rose-500 focus-visible:outline focus-visible:outline-3 focus-visible:outline-tjb-lavender-400 focus-visible:outline-offset-2 active:translate-y-0 transition">
            Get Started
          </button>
          <div id="amb-form-status" class="hidden text-sm mt-2"></div>
          <p class="text-xs text-tjb-gray text-center mt-2">I'll never share your information. You can leave the program at any time.</p>
        </form>

        <div class="mt-8 pt-6 border-t border-tjb-lavender-200/50 text-center">
          <p class="text-tjb-gray text-sm">Prefer email? Reach out directly at <a href="mailto:shelbi@truejoybirthing.com" class="text-tjb-rose-500 hover:underline font-medium">shelbi@truejoybirthing.com</a></p>
        </div>
      </div>

      <!-- What happens next -->
      <div class="mt-10 bg-white rounded-2xl p-8 shadow-sm border border-tjb-lavender-200/50">
        <h3 class="text-lg font-semibold mb-4 text-center">What Happens Next</h3>
        <div class="grid md:grid-cols-3 gap-6 text-center">
          <div>
            <div class="w-10 h-10 rounded-full bg-tjb-lavender-100 flex items-center justify-center mx-auto mb-3">
              <span class="text-tjb-lavender-600 font-bold">1</span>
            </div>
            <p class="text-sm text-tjb-gray">I review your application within 2-3 business days</p>
          </div>
          <div>
            <div class="w-10 h-10 rounded-full bg-tjb-lavender-100 flex items-center justify-center mx-auto mb-3">
              <span class="text-tjb-lavender-600 font-bold">2</span>
            </div>
            <p class="text-sm text-tjb-gray">Quick 15-minute call to get to know each other</p>
          </div>
          <div>
            <div class="w-10 h-10 rounded-full bg-tjb-lavender-100 flex items-center justify-center mx-auto mb-3">
              <span class="text-tjb-lavender-600 font-bold">3</span>
            </div>
            <p class="text-sm text-tjb-gray">Pro Mode activated within 24 hours. You're in.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FAQ
       ═══════════════════════════════════════════ -->
  <section class="py-16 bg-tjb-cream-50 border-t border-tjb-lavender-200/50">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-2xl font-bold mb-8">Frequently Asked Questions</h2>
      <div class="space-y-6">
