<script>
  // ── Form submission ──
  const form = document.getElementById('ambassador-form') as HTMLFormElement;
  const status = document.getElementById('amb-form-status') as HTMLDivElement;
  const btn = document.getElementById('amb-submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const data = new FormData(form);
    const body = Object.fromEntries(data.entries());

    btn.disabled = true;
    btn.textContent = 'Sending...';
    status.className = 'hidden text-sm mt-2';
    status.textContent = '';

    try {
      const res = await fetch('/api/ambassador', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      const result = await res.json();

      if (res.ok && result.success) {
        status.textContent = 'Got it! I\'ll review your application and reach out within 2-3 business days.';
        status.className = 'text-sm mt-2 text-green-700';
        form.reset();
      } else {
        status.textContent = result.error || 'Something went wrong. Please try again or email me directly.';
        status.className = 'text-sm mt-2 text-red-600';
      }
    } catch {
      status.textContent = 'Network error. Please try again or email shelbi@truejoybirthing.com directly.';
      status.className = 'text-sm mt-2 text-red-600';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Get Started';
    }
  });

  // ── FAQ Accordion ──
  document.querySelectorAll('.faq-toggle').forEach((toggle) => {
    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      const answer = document.getElementById(toggle.getAttribute('aria-controls')!);
      const chevron = toggle.querySelector('.faq-chevron');

      // Close all others
      document.querySelectorAll('.faq-toggle').forEach((t) => {
        if (t !== toggle && t.getAttribute('aria-expanded') === 'true') {
          t.setAttribute('aria-expanded', 'false');
          const a = document.getElementById(t.getAttribute('aria-controls')!);
          if (a) {
            a.setAttribute('aria-hidden', 'true');
            a.style.maxHeight = '0';
            a.style.paddingBottom = '0';
          }
          const c = t.querySelector('.faq-chevron');
          if (c) c.classList.remove('rotate-180');
        }
      });

      if (isOpen) {
        toggle.setAttribute('aria-expanded', 'false');
        answer?.setAttribute('aria-hidden', 'true');
        if (answer) {
          answer.style.maxHeight = '0';
          answer.style.paddingBottom = '0';
        }
        chevron?.classList.remove('rotate-180');
      } else {
        toggle.setAttribute('aria-expanded', 'true');
        answer?.setAttribute('aria-hidden', 'false');
        if (answer) {
          answer.style.maxHeight = answer.scrollHeight + 'px';
          answer.style.paddingBottom = '1rem';
        }
        chevron?.classList.add('rotate-180');
      }
    });
  });
</script>
