---
import Layout from '../layouts/Layout.astro';
import LeadCaptureForm from '../components/LeadCaptureForm.astro';

const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "Birth Plan Checklist", "url": "https://truejoybirthing.com/birth-plan-checklist/"}];

const categories = [
  {
    title: "Labor Preferences",
    items: [
      "Who do you want in the delivery room?",
      "Do you want to be offered an induction, or only if medically necessary?",
      "How do you feel about continuous vs. intermittent monitoring?",
      "Do you want freedom to move and change positions during labor?",
      "Would you like to use a birthing ball, tub, or shower for comfort?",
      "Do you want to eat or drink during labor?",
      "How do you want your support team to encourage you?",
      "Do you want the room lights dimmed?"
    ]
  },
  {
    title: "Pain Management",
    items: [
      "What is your first response to being offered an epidural?",
      "Do you want to try unmedicated comfort measures first?",
      "Which comfort measures matter most to you? (breathing, massage, movement, water, etc.)",
      "If you plan to go unmedicated, do you want to be reminded of that goal — or supported in changing your mind?",
      "Do you want to be offered pain medication, or only receive it when you ask?",
      "How do you feel about Pitocin to speed up labor?"
    ]
  },
  {
    title: "Delivery Preferences",
    items: [
      "Do you have a preferred delivery position? (squatting, side-lying, hands-and-knees, etc.)",
      "Do you want a mirror to see the birth?",
      "Who do you want to announce the baby's sex?",
      "Do you want delayed cord clamping (1-3 minutes)?",
      "Who cuts the umbilical cord?",
      "Do you want immediate skin-to-skin contact?",
      "How do you feel about an episiotomy?",
      "If a cesarean becomes necessary, what are your preferences? (clear drape, partner present, skin-to-skin in OR)"
    ]
  },
  {
    title: "Postpartum Care",
    items: [
      "Do you want the placenta delivered naturally or with medication?",
      "Do you plan to breastfeed? Do you want lactation support?",
      "Who do you want in the recovery room?",
      "Do you want to delay certain postpartum procedures? (Vitamin K, eye ointment — discuss with your pediatrician)",
      "How do you feel about pacifiers or formula supplementation?",
      "Do you want help with perineal care and recovery?"
    ]
  },
  {
    title: "Newborn Care",
    items: [
      "Do you want your baby to room-in with you at all times?",
      "Do you want to decline the first bath so the vernix absorbs?",
      "What are your preferences for newborn vaccinations and screenings?",
      "Do you want your baby examined in your presence?",
      "Are there any religious or cultural practices you want observed?",
      "Do you have preferences for circumcision? (if applicable)"
    ]
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ItemList",
      "@id": "https://truejoybirthing.com/birth-plan-checklist/#checklist",
      "name": "Birth Plan Checklist",
      "description": "A comprehensive birth plan checklist organized by category: labor preferences, pain management, delivery, postpartum care, and newborn care.",
      "numberOfItems": 40,
      "itemListElement": categories.flatMap((cat, ci) =>
        cat.items.map((item, ii) => ({
          "@type": "ListItem",
          "position": ci * 10 + ii + 1,
          "name": item,
          "item": `https://truejoybirthing.com/birth-plan-checklist/#${cat.title.toLowerCase().replace(/\s+/g, '-')}`
        }))
      )
    },
    {
      "@type": "FAQPage",
      "@id": "https://truejoybirthing.com/birth-plan-checklist/#faq",
      "mainEntity": [
        { "@type": "Question", "name": "What should be on a birth plan checklist?", "acceptedAnswer": { "@type": "Answer", "text": "A birth plan checklist should cover labor preferences, pain management, delivery positions and procedures, postpartum care, and newborn care decisions. Each item should be a clear preference you can communicate to your care team." } },
        { "@type": "Question", "name": "How many items should a birth plan have?", "acceptedAnswer": { "@type": "Answer", "text": "Aim for 10-15 preferences that truly matter to you. A birth plan that's too long gets ignored. Focus on the items where you have a strong opinion — not every checkbox on a generic form." } },
        { "@type": "Question", "name": "Do I need to include everything on this checklist?", "acceptedAnswer": { "@type": "Answer", "text": "No. This checklist gives you options so you can decide what matters. Not every item will be relevant to your situation. Fill in what you care about and skip the rest." } },
        { "@type": "Question", "name": "What if my hospital doesn't allow something on the checklist?", "acceptedAnswer": { "@type": "Answer", "text": "Bring your checklist to your next prenatal appointment and review it with your care provider. They can tell you which preferences are possible at your specific hospital and help you adjust." } },
        { "@type": "Question", "name": "Is this checklist the same as a birth plan template?", "acceptedAnswer": { "@type": "Answer", "text": "The checklist helps you think through your options. The birth plan template is the document you actually share with your care team. Use the checklist first, then transfer your preferences to the template." } }
      ]
    }
  ]
};

const accentColors = ['text-tjb-lavender-500', 'text-tjb-rose-500', 'text-tjb-sage', 'text-tjb-lavender-500', 'text-tjb-rose-500'];
---

<Layout
  title="Birth Plan Checklist — Every Preference to Consider Before You Fill Out Your Birth Plan"
  description="A complete birth plan checklist covering labor preferences, pain management, delivery, postpartum care, and newborn care — organized so your care team can read it in 30 seconds."
  canonical="https://truejoybirthing.com/birth-plan-checklist/"
  ogImage="/images/og-birth-plan-checklist.webp"
  breadcrumbList={breadcrumbList}
  schema={schema}
>

  <!-- ═══════════════════════════════════════════
       HERO — Editorial two-column, 55/45
       Illustration right (clipboard + checklist)
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row">

        <!-- Left: Text — 55% -->
        <div class="md:w-[55%] px-6 md:px-12 py-16 md:py-24 flex flex-col justify-center">
          <p class="eyebrow mb-3">Birth Plan Checklist</p>
          <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
          <h1 class="font-bold text-tjb-charcoal leading-[1.15] mb-4" style="font-size: clamp(2.25rem, 5vw, 3.75rem);">
            Every Question to Answer Before You Write Your Birth Plan
          </h1>
          <!-- Author credibility strip -->
          <div class="flex items-center gap-2.5 mb-5">
            <img src="/images/shelbi-thumb.webp" alt="" width="32" height="32" class="w-8 h-8 rounded-full object-cover" />
            <p class="text-sm text-tjb-gray leading-snug">
              <a href="/about/" class="text-tjb-lavender-600 hover:text-tjb-lavender-700 font-medium no-underline">Shelbi Kohler</a>,
              certified birth doula — 500+ families supported
            </p>
          </div>
          <p class="text-tjb-gray text-lg leading-[1.7] mb-8 max-w-[36rem]">
            Every preference point you should consider — organized by category, written in plain language, and built by a certified doula. Mark what matters, skip what doesn't, then transfer your choices to the template.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="#download" class="btn-primary">Get the free birth plan</a>
            <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="btn-secondary">Get the free app for the full course</a>
          </div>
        </div>

        <!-- Right: Illustration — 45% -->
        <div class="md:w-[45%] flex items-center justify-center px-6 py-12 md:py-0">
          <img
            src="/images/birth-plan-checklist-portrait.webp"
            alt="A warm editorial illustration of a doula holding a clipboard labeled BIRTH PLAN with checkboxes, ready to help you think through each preference"
            class="w-full max-w-md rounded-md"
            loading="eager"
            fetchpriority="high"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PROVENANCE — Compact trust anchor
       ═══════════════════════════════════════════ -->
  <div class="bg-tjb-cream border-y border-tjb-lavender-200/40">
    <div class="max-w-3xl mx-auto px-6 py-4 flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-6">
      <span class="text-sm text-tjb-gray-300 tracking-wide">5 categories · 40 preference points</span>
      <span class="hidden sm:inline text-tjb-rose-400 text-sm">·</span>
      <span class="text-sm text-tjb-gray-300 tracking-wide">Plain language, no jargon</span>
      <span class="hidden sm:inline text-tjb-rose-400 text-sm">·</span>
      <span class="text-sm text-tjb-gray-300 tracking-wide">Built by a certified doula</span>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       HOW TO USE — Editorial explainer on white
       ═══════════════════════════════════════════ -->
  <section class="bg-white py-10 border-b border-tjb-lavender-200/50">
    <div class="max-w-3xl mx-auto px-6">
      <p class="eyebrow mb-4">How to use this checklist</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
      <p class="text-tjb-gray text-lg leading-relaxed mb-2">
        Don't try to answer every item. Read through each category, mark the preferences that matter most to you, and skip the ones you don't have strong feelings about.
      </p>
      <p class="text-tjb-gray text-lg leading-relaxed">
        Then <a href="/birth-plan-template/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">transfer your choices to the free template</a> so your care team can read it at a glance.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CHECKLIST CATEGORIES — Editorial numbered on alternating BG
       Each category: eyebrow + title + custom checkboxes
       ═══════════════════════════════════════════ -->
  {categories.map((cat, ci) => {
    const bg = ci % 2 === 0 ? 'bg-tjb-cream' : 'bg-white';
    const numColor = accentColors[ci];
    const anchor = cat.title.toLowerCase().replace(/\s+/g, '-');
    return (
  <section class={`${bg} py-16 md:py-20`} id={anchor}>
    <div class="max-w-3xl mx-auto px-6">

      <div class="flex items-baseline gap-3 mb-2">
        <span class={`text-3xl font-bold font-serif ${numColor}`}>0{ci + 1}</span>
        <p class="eyebrow mb-0">Category {ci + 1} of 5</p>
      </div>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-4"></div>
      <h2 class="font-semibold text-tjb-charcoal leading-[1.15] mb-8" style="font-size: clamp(1.5rem, 3.5vw, 2.25rem);">
        {cat.title}
      </h2>

      <ul class="space-y-4">
        {cat.items.map((item, ii) => (
          <li class="flex items-start gap-3 group">
            <span class="mt-1.5 w-4 h-4 rounded-sm border-2 border-tjb-lavender-400 flex-shrink-0 group-hover:border-tjb-rose-400 transition-colors"></span>
            <span class="text-tjb-gray group-hover:text-tjb-charcoal transition-colors leading-relaxed">{item}</span>
          </li>
        ))}
      </ul>

    </div>
  </section>
    );
  })}

  <!-- ═══════════════════════════════════════════
       AFTER THE CHECKLIST — Editorial numbered on cream
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-6">

      <p class="eyebrow mb-4">After the checklist</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
      <h2 class="font-semibold text-tjb-charcoal leading-[1.15] mb-10" style="font-size: clamp(1.75rem, 4vw, 2.75rem);">
        What to Do After You Fill It Out
      </h2>

      <div class="space-y-0">
        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">01</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Review with your partner.</p>
              <p class="text-tjb-gray leading-relaxed">Make sure you're aligned on the big items — who's in the room, pain management, and delivery preferences.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-rose-500 font-serif">02</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Bring it to your care provider.</p>
              <p class="text-tjb-gray leading-relaxed">Your OB or midwife needs to see your plan before you're in labor. They'll flag anything your hospital can't accommodate.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">03</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Transfer it to the template.</p>
              <p class="text-tjb-gray leading-relaxed">Use the <a href="/birth-plan-template/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">free birth plan template</a> or the free app to create a clean, one-page document your nurse can read in 30 seconds.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-sage font-serif">04</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">If you're being induced, adjust your plan.</p>
              <p class="text-tjb-gray leading-relaxed">A generic checklist won't cover everything you need. <a href="/birth-plan-for-induction/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">Read the induction birth plan guide</a> for scenario-specific language and what to skip.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-rose-500 font-serif">05</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">If a cesarean is possible, prepare for that too.</p>
              <p class="text-tjb-gray leading-relaxed">Consider filling out a <a href="/c-section-birth-plan/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">cesarean-specific birth plan guide</a> alongside your primary plan so you're ready for that scenario.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40 border-b">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">06</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Print copies.</p>
              <p class="text-tjb-gray leading-relaxed">One for your partner, one for your doula, one in your hospital bag. When you're in labor, you won't be searching for it.</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FAQ — Editorial on white
       ═══════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20" id="common-questions">
    <div class="max-w-3xl mx-auto px-6">

      <p class="eyebrow mb-4">Common questions</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>

      <div class="space-y-6">
        <div class="border-b border-tjb-lavender-300/40 pb-6">
          <h3 class="font-semibold text-tjb-charcoal text-lg mb-2">What should be on a birth plan checklist?</h3>
          <p class="text-tjb-gray leading-relaxed">A birth plan checklist should cover labor preferences, pain management, delivery positions and procedures, postpartum care, and newborn care decisions. Each item should be a clear preference you can communicate to your care team.</p>
        </div>
        <div class="border-b border-tjb-lavender-300/40 pb-6">
          <h3 class="font-semibold text-tjb-charcoal text-lg mb-2">How many items should a birth plan have?</h3>
          <p class="text-tjb-gray leading-relaxed">Aim for 10-15 preferences that truly matter to you. A birth plan that's too long gets ignored. Focus on the items where you have a strong opinion — not every checkbox on a generic form.</p>
        </div>
        <div class="border-b border-tjb-lavender-300/40 pb-6">
          <h3 class="font-semibold text-tjb-charcoal text-lg mb-2">Do I need to include everything on this checklist?</h3>
          <p class="text-tjb-gray leading-relaxed">No. This checklist gives you options so you can decide what matters. Not every item will be relevant to your situation. Fill in what you care about and skip the rest.</p>
        </div>
        <div class="border-b border-tjb-lavender-300/40 pb-6">
          <h3 class="font-semibold text-tjb-charcoal text-lg mb-2">What if my hospital doesn't allow something on the checklist?</h3>
          <p class="text-tjb-gray leading-relaxed">Bring your checklist to your next prenatal appointment and review it with your care provider. They can tell you which preferences are possible at your specific hospital and help you adjust.</p>
        </div>
        <div>
          <h3 class="font-semibold text-tjb-charcoal text-lg mb-2">Is this checklist the same as a birth plan template?</h3>
          <p class="text-tjb-gray leading-relaxed">The checklist helps you think through your options. The birth plan template is the document you actually share with your care team. Use the checklist first, then transfer your preferences to the template.</p>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       LEAD CAPTURE — Name + email → PDF + course
       ═══════════════════════════════════════════ -->
  <LeadCaptureForm />

</Layout>