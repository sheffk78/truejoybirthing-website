---
import Layout from '../layouts/Layout.astro';

const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "Contact", "url": "https://truejoybirthing.com/contact/"}];
---

<Layout
  title="Contact"
  description="Get in touch with True Joy Birthing. Questions about birth plans, doula support, or the app — we're here to help."
  canonical="https://truejoybirthing.com/contact"
  breadcrumbList={breadcrumbList}
>
  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">Contact</h1>
      <p class="text-lg text-tjb-gray">Questions, partnerships, or just want to say hi? We'd love to hear from you.</p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-2xl mx-auto px-6">
      <form id="contact-form" class="space-y-4">
        <div>
          <label for="contact-name" class="block text-sm font-medium mb-1">Name</label>
          <input type="text" id="contact-name" name="name" class="w-full px-4 py-3 rounded-lg border border-tjb-lavender-300 focus:outline-none focus:border-tjb-lavender-500" required />
        </div>
        <div>
          <label for="contact-email" class="block text-sm font-medium mb-1">Email</label>
          <input type="email" id="contact-email" name="email" class="w-full px-4 py-3 rounded-lg border border-tjb-lavender-300 focus:outline-none focus:border-tjb-lavender-500" required />
        </div>
        <div>
          <label for="contact-message" class="block text-sm font-medium mb-1">Message</label>
          <textarea id="contact-message" name="message" rows="5" class="w-full px-4 py-3 rounded-lg border border-tjb-lavender-300 focus:outline-none focus:border-tjb-lavender-500" required></textarea>
        </div>
        <button type="submit" id="submit-btn" class="bg-tjb-lavender-500 text-white px-8 py-3 rounded-full font-semibold hover:bg-tjb-rose-500 transition">Send Message</button>
        <div id="form-status" class="hidden text-sm mt-2"></div>
      </form>
    </div>
  </section>

  <section class="py-12 bg-tjb-cream-50 border-t border-tjb-lavender-200/50">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <p class="text-tjb-gray text-sm">You can also reach us directly at <a href="mailto:support@truejoybirthing.com" class="text-tjb-rose-500 hover:underline font-medium">support@truejoybirthing.com</a></p>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLDivElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const name = (document.getElementById('contact-name') as HTMLInputElement).value;
    const email = (document.getElementById('contact-email') as HTMLInputElement).value;
    const message = (document.getElementById('contact-message') as HTMLTextAreaElement).value;

    if (!email || !message) {
      status.textContent = 'Please fill in your email and message.';
      status.className = 'text-sm mt-2 text-red-600';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Sending...';
    status.className = 'hidden text-sm mt-2';
    status.textContent = '';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, message }),
      });

      const data = await res.json();

      if (res.ok && data.success) {
        status.textContent = 'Message sent! We\'ll get back to you soon.';
        status.className = 'text-sm mt-2 text-green-700';
        form.reset();
      } else {
        status.textContent = data.error || 'Something went wrong. Please try again or email us directly.';
        status.className = 'text-sm mt-2 text-red-600';
      }
    } catch {
      status.textContent = 'Network error. Please try again or email us directly.';
      status.className = 'text-sm mt-2 text-red-600';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send Message';
    }
  });
</script>