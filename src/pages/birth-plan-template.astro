---
import Layout from '../layouts/Layout.astro';
import LeadCaptureForm from '../components/LeadCaptureForm.astro';
import AppShowcase from '../components/AppShowcase.astro';
import ContextualCityLinks from '../components/ContextualCityLinks.astro';

const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "Free Birth Plan Template", "url": "https://truejoybirthing.com/birth-plan-template/"}];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "HowTo",
      "@id": "https://truejoybirthing.com/birth-plan-template/#howto",
      "name": "How to Use a Birth Plan Template",
      "description": "A step-by-step guide to building your birth plan using a free template — from choosing your preferences to sharing it with your care team.",
      "totalTime": "PT30M",
      "step": [
        {
          "@type": "HowToStep",
          "position": 1,
          "name": "Download the free fillable PDF",
          "text": "Download the free birth plan template as a fillable PDF. You can type directly into it, print it, or recreate it in the free True Joy Birthing app."
        },
        {
          "@type": "HowToStep",
          "position": 2,
          "name": "Review each section with your partner",
          "text": "Go through labor preferences, pain management, delivery, postpartum care, and newborn care. Talk through each section with your partner or support person so you're aligned."
        },
        {
          "@type": "HowToStep",
          "position": 3,
          "name": "Fill in your preferences",
          "text": "Mark what matters most to you. You don't need to answer every item — focus on the preferences that reflect what you actually want, not what you think you should want."
        },
        {
          "@type": "HowToStep",
          "position": 4,
          "name": "Bring it to your next appointment",
          "text": "Share your draft with your OB or midwife at your next visit. Ask them to flag anything that might not be possible at your specific hospital or birth center."
        },
        {
          "@type": "HowToStep",
          "position": 5,
          "name": "Pack it in your hospital bag",
          "text": "Print a few copies. Give one to your partner, one to your doula, and keep one in your hospital bag. When you're in labor, you won't be searching for it."
        }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": "https://truejoybirthing.com/birth-plan-template/#faq",
      "mainEntity": [
        { "@type": "Question", "name": "What should a birth plan template include?", "acceptedAnswer": { "@type": "Answer", "text": "A good birth plan template covers labor preferences, pain management options, delivery positions, postpartum care preferences, and newborn care decisions. It should be organized, concise, and easy for your care team to scan quickly." } },
        { "@type": "Question", "name": "Is this birth plan template really free?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. The fillable PDF and the full 5-video walkthrough are both completely free — just enter your name and email and youll get immediate access to everything. No payment, no trial, no upsell." } },
        { "@type": "Question", "name": "Can I edit the birth plan template?", "acceptedAnswer": { "@type": "Answer", "text": "The PDF is fillable, type directly into it or print it and fill it in by hand. For live updates, doula sharing, and a guided walkthrough, use the free True Joy Birthing app." } },
        { "@type": "Question", "name": "How is this different from a birth plan I find on Google?", "acceptedAnswer": { "@type": "Answer", "text": "Most free templates online are generic checklists. This one was built by a certified birth doula and organized around the decisions that actually come up in the delivery room, not just wish-list items." } },
        { "@type": "Question", "name": "When should I fill out my birth plan?", "acceptedAnswer": { "@type": "Answer", "text": "Most families start around 28-32 weeks. Earlier is fine too. The sooner you understand your options, the more confident you'll feel when the time comes." } },
        { "@type": "Question", "name": "What's the difference between the PDF and the app?", "acceptedAnswer": { "@type": "Answer", "text": "The PDF is free, fillable, and designed for print — write in your preferences and bring hard copies to the hospital. The free app goes further: it walks you through each section with guided videos, lets you update your plan anytime, and shares your live plan with your doula or partner directly. Both cover the same five sections; the app is for families who want an interactive, always-current experience." } },
        { "@type": "Question", "name": "Is the video walkthrough really free?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. The 5-video walkthrough is completely free — just enter your name and email and youll get immediate access to every module. No payment, no trial, no upsell. We ask for your email so we can send you the PDF and check in with tips as you fill out your plan." } },
        { "@type": "Question", "name": "How is the walkthrough different from the PDF?", "acceptedAnswer": { "@type": "Answer", "text": "The PDF is the template — the form you fill out. The walkthrough is a certified doula explaining what each section means, why each choice matters, and how to talk to your provider about it. They work together: download the PDF, then watch the videos as you fill it in." } }
      ]
    }
  ]
};
---

<Layout
  title="Free Birth Plan Template"
  description="Free fillable birth plan template by a certified doula. Structured, concise, and easy for your care team to read. Covers labor through newborn care."
  canonical="https://truejoybirthing.com/birth-plan-template/"
  ogImage="/images/og/og-birth-plan-template.webp?v=2"
  breadcrumbList={breadcrumbList}
  schema={schema}
>

  <!-- ═══════════════════════════════════════════
       HERO — Product-first two-column archetype
       Design spec: VISUAL-TOKENS.md hero archetype
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row">

        <!-- Left: Text — 55% -->
        <div class="md:w-[55%] px-6 md:px-12 py-16 md:py-24 flex flex-col justify-center">
          <p class="eyebrow mb-3">Free birth plan</p>
          <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
          <h1 class="font-bold text-tjb-charcoal leading-[1.15] mb-4" style="font-size: clamp(2.25rem, 5vw, 3.75rem);">
            A birth plan template that actually works in the delivery room
          </h1>
          <!-- Author credibility strip -->
          <div class="flex items-center gap-2.5 mb-5">
            <img src="/images/shelbi-thumb.webp" alt="Shelbi Kohler, certified birth doula" width="32" height="32" class="w-8 h-8 rounded-full object-cover" />
            <p class="text-sm text-tjb-gray leading-snug">
              <a href="/about/" class="text-tjb-lavender-600 hover:text-tjb-lavender-700 font-medium no-underline">Shelbi Kohler</a>,
              certified birth doula, 500+ families supported
            </p>
          </div>
          <p class="text-tjb-gray text-lg leading-[1.7] mb-8 max-w-[36rem]">
            A <strong>birth plan template</strong> is a structured form that helps you write down your preferences for labor, pain management, delivery, and newborn care, so your medical team can read it at a glance.
          </p>
          <p class="text-tjb-gray text-base leading-relaxed mb-8 max-w-[36rem]">
            This one is built by a certified doula, not a generic hospital form. <strong>Choose your path:</strong> print the fillable PDF, watch the free video walkthrough with Shelbi, or build your plan step by step in the <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">free app</a>.
          </p>
          <div>
            <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="btn-primary">
              Build your birth plan in the app
            </a>
            <a href="#download" class="btn-secondary mt-3 inline-block">
              Or download the free PDF →
            </a>
          </div>
        </div>

        <!-- Right: Product mockup — 45% -->
        <div class="md:w-[45%] flex items-center justify-center px-6 py-12 md:py-0">
          <img
            src="/images/birth-plan-preview.webp"
            alt="Preview of the free birth plan template — a structured multi-page document covering labor preferences, pain management, delivery, postpartum, and newborn care"
            class="w-full max-w-md rounded-md"
            loading="eager"
            fetchpriority="high"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PROVENANCE — Compact trust anchor
       ═══════════════════════════════════════════ -->
  <div class="bg-tjb-cream border-y border-tjb-lavender-200/40">
    <div class="max-w-3xl mx-auto px-6 py-4 flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-6">
      <span class="text-sm text-tjb-gray-300 tracking-wide">📄 Free PDF</span>
      <span class="hidden sm:inline text-tjb-rose-400 text-sm">·</span>
      <span class="text-sm text-tjb-gray-300 tracking-wide">🎬 Free video walkthrough</span>
      <span class="hidden sm:inline text-tjb-rose-400 text-sm">·</span>
      <span class="text-sm text-tjb-gray-300 tracking-wide">📱 Free app</span>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       THREE WAYS — Comparison block
       ═══════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-6">
      <p class="eyebrow mb-4 text-center">Three ways to build your birth plan</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-8 mx-auto"></div>
      <h2 class="font-semibold text-tjb-charcoal leading-[1.15] mb-12 text-center" style="font-size: clamp(1.5rem, 3.5vw, 2.25rem);">
        Choose how you want to get started — all three are free
      </h2>

      <div class="grid md:grid-cols-3 gap-6">
        <!-- PDF Column -->
        <div class="bg-tjb-cream rounded-xl p-6 text-center border border-tjb-lavender-200/50">
          <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-tjb-lavender-100 flex items-center justify-center">
            <svg class="w-7 h-7 text-tjb-lavender-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
          </div>
          <h3 class="font-semibold text-tjb-charcoal text-lg mb-2">Free PDF</h3>
          <p class="text-tjb-gray text-sm leading-relaxed mb-4">Download, fill in by hand or type. Print copies for your hospital bag. No email needed.</p>
          <a href="#download" class="btn-secondary">Get the PDF →</a>
        </div>

        <!-- Video Column — highlighted with thumbnail -->
        <div class="bg-white rounded-xl overflow-hidden border-2 border-tjb-rose-400 shadow-md relative">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-tjb-rose-500 text-white text-xs font-semibold px-3 py-1 rounded-full z-10">Most popular</span>
          <a href="/walkthrough/" class="block">
            <div class="relative">
              <img src="/images/video-thumbnails/module-01-intro.webp" alt="Free birth plan video walkthrough preview" class="w-full aspect-video object-cover" loading="lazy" width="640" height="360" />
              <div class="absolute inset-0 flex items-center justify-center bg-black/20 hover:bg-black/30 transition-colors">
                <div class="w-16 h-16 rounded-full bg-tjb-rose-500/90 flex items-center justify-center shadow-lg">
                  <svg class="w-8 h-8 text-white ml-1" viewBox="0 0 24 24" fill="currentColor"><polygon points="8,5 20,12 8,19" /></svg>
                </div>
              </div>
            </div>
          </a>
          <div class="p-5 text-center">
            <h3 class="font-semibold text-tjb-charcoal text-lg mb-2">Free Video Walkthrough</h3>
            <p class="text-tjb-gray text-sm leading-relaxed mb-4">5 short videos with a certified doula explaining every section. Watch in one evening.</p>
            <a href="/walkthrough/" class="btn-primary">Watch the walkthrough</a>
          </div>
        </div>

        <!-- App Column -->
        <div class="bg-tjb-cream rounded-xl p-6 text-center border border-tjb-lavender-200/50">
          <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-tjb-lavender-100 flex items-center justify-center">
            <svg class="w-7 h-7 text-tjb-lavender-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3"/></svg>
          </div>
          <h3 class="font-semibold text-tjb-charcoal text-lg mb-2">Free App</h3>
          <p class="text-tjb-gray text-sm leading-relaxed mb-4">Interactive step-by-step guide. Update your plan anytime, share with your care team and doula.</p>
          <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="btn-secondary">Get the app</a>
        </div>
      </div>

      <p class="text-center text-sm text-tjb-gray mt-6">All three cover the same five sections. Use them together or pick the one that works for you.</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       VIDEO MODULE PREVIEWS — Show what's inside the walkthrough
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-6">

      <p class="eyebrow mb-4">Free birth plan walkthrough</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
      <h2 class="font-semibold text-tjb-charcoal leading-[1.15] mb-4" style="font-size: clamp(1.75rem, 4vw, 2.75rem);">
        Walk through every section with a certified doula — free
      </h2>
      <p class="text-tjb-gray text-lg leading-relaxed mb-8">
        Want to understand <em>why</em> each section matters before you fill it out? These 5 short videos walk through the entire Joyful Birth Plan — from labor preferences to backup plans — so you fill it out with confidence, not confusion.
      </p>

      <div class="space-y-4 mb-8">
        <!-- Module 1 -->
        <div class="bg-white rounded-xl p-5 shadow-sm border border-tjb-lavender-200/50 hover:shadow-md transition-shadow cursor-pointer" onclick="window.location.href='/walkthrough/'">
          <div class="flex flex-col sm:flex-row gap-4">
            <div class="relative shrink-0 sm:w-44 w-full aspect-video rounded-lg overflow-hidden">
              <img src="/images/video-thumbnails/module-01-intro.webp" alt="Video thumbnail: Shelbi introduces the Joyful Birth Plan" class="w-full h-full object-cover" loading="lazy" width="440" height="248" />
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-12 h-12 rounded-full bg-tjb-rose-500/90 flex items-center justify-center shadow-md">
                  <svg class="w-5 h-5 text-white ml-0.5" viewBox="0 0 24 24" fill="currentColor"><polygon points="8,5 20,12 8,19" /></svg>
                </div>
              </div>
            </div>
            <div>
              <span class="text-sm font-semibold text-tjb-lavender-500">Module 1</span>
              <h3 class="font-semibold text-lg text-tjb-charcoal mb-1">About Me & Your Birth Plan</h3>
              <p class="text-tjb-gray text-sm leading-relaxed">How to fill in the section that helps your care team see you as a person. What to include in your flexibility statement and how to note your preferences.</p>
              <span class="text-xs text-tjb-gray-400 mt-1 inline-block">▶ ~5 min</span>
            </div>
          </div>
        </div>

        <!-- Module 2 -->
        <div class="bg-white rounded-xl p-5 shadow-sm border border-tjb-lavender-200/50 hover:shadow-md transition-shadow cursor-pointer" onclick="window.location.href='/walkthrough/'">
          <div class="flex flex-col sm:flex-row gap-4">
            <div class="relative shrink-0 sm:w-44 w-full aspect-video rounded-lg overflow-hidden">
              <img src="/images/video-thumbnails/module-02-labor.webp" alt="Video thumbnail: Labor, delivery, and pain management walkthrough" class="w-full h-full object-cover" loading="lazy" width="440" height="248" />
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-12 h-12 rounded-full bg-tjb-rose-500/90 flex items-center justify-center shadow-md">
                  <svg class="w-5 h-5 text-white ml-0.5" viewBox="0 0 24 24" fill="currentColor"><polygon points="8,5 20,12 8,19" /></svg>
                </div>
              </div>
            </div>
            <div>
              <span class="text-sm font-semibold text-tjb-rose-500">Module 2</span>
              <h3 class="font-semibold text-lg text-tjb-charcoal mb-1">Labor, Delivery & Pain Management</h3>
              <p class="text-tjb-gray text-sm leading-relaxed">Monitoring, IV, movement, environment, and the full pain management ladder — what each choice looks like in the room and how to talk to your provider about it.</p>
              <span class="text-xs text-tjb-gray-400 mt-1 inline-block">▶ ~8 min</span>
            </div>
          </div>
        </div>

        <!-- Module 3 -->
        <div class="bg-white rounded-xl p-5 shadow-sm border border-tjb-lavender-200/50 hover:shadow-md transition-shadow cursor-pointer" onclick="window.location.href='/walkthrough/'">
          <div class="flex flex-col sm:flex-row gap-4">
            <div class="relative shrink-0 sm:w-44 w-full aspect-video rounded-lg overflow-hidden">
              <img src="/images/video-thumbnails/module-03-post.webp" alt="Video thumbnail: Post-delivery preferences walkthrough" class="w-full h-full object-cover" loading="lazy" width="440" height="248" />
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-12 h-12 rounded-full bg-tjb-rose-500/90 flex items-center justify-center shadow-md">
                  <svg class="w-5 h-5 text-white ml-0.5" viewBox="0 0 24 24" fill="currentColor"><polygon points="8,5 20,12 8,19" /></svg>
                </div>
              </div>
            </div>
            <div>
              <span class="text-sm font-semibold text-tjb-lavender-500">Module 3</span>
              <h3 class="font-semibold text-lg text-tjb-charcoal mb-1">Post-Delivery Preferences</h3>
              <p class="text-tjb-gray text-sm leading-relaxed">Skin-to-skin, cord clamping, golden hour, feeding preferences — the decisions that happen fast after delivery, explained before you're in the moment.</p>
              <span class="text-xs text-tjb-gray-400 mt-1 inline-block">▶ ~6 min</span>
            </div>
          </div>
        </div>

        <!-- Module 4 -->
        <div class="bg-white rounded-xl p-5 shadow-sm border border-tjb-lavender-200/50 hover:shadow-md transition-shadow cursor-pointer" onclick="window.location.href='/walkthrough/'">
          <div class="flex flex-col sm:flex-row gap-4">
            <div class="relative shrink-0 sm:w-44 w-full aspect-video rounded-lg overflow-hidden">
              <img src="/images/video-thumbnails/module-04-newborn.webp" alt="Video thumbnail: Newborn care preferences walkthrough" class="w-full h-full object-cover" loading="lazy" width="440" height="248" />
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-12 h-12 rounded-full bg-tjb-rose-500/90 flex items-center justify-center shadow-md">
                  <svg class="w-5 h-5 text-white ml-0.5" viewBox="0 0 24 24" fill="currentColor"><polygon points="8,5 20,12 8,19" /></svg>
                </div>
              </div>
            </div>
            <div>
              <span class="text-sm font-semibold text-tjb-rose-500">Module 4</span>
              <h3 class="font-semibold text-lg text-tjb-charcoal mb-1">Newborn Care Preferences</h3>
              <p class="text-tjb-gray text-sm leading-relaxed">Vitamin K, Hep B, eye ointment, circumcision, rooming-in, newborn screenings — what's standard, what's optional, and how to state your preference clearly.</p>
              <span class="text-xs text-tjb-gray-400 mt-1 inline-block">▶ ~5 min</span>
            </div>
          </div>
        </div>

        <!-- Module 5 -->
        <div class="bg-white rounded-xl p-5 shadow-sm border border-tjb-lavender-200/50 hover:shadow-md transition-shadow cursor-pointer" onclick="window.location.href='/walkthrough/'">
          <div class="flex flex-col sm:flex-row gap-4">
            <div class="relative shrink-0 sm:w-44 w-full aspect-video rounded-lg overflow-hidden">
              <img src="/images/video-thumbnails/module-05-other.webp" alt="Video thumbnail: Advocacy, backup plans and flexibility language" class="w-full h-full object-cover" loading="lazy" width="440" height="248" />
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-12 h-12 rounded-full bg-tjb-rose-500/90 flex items-center justify-center shadow-md">
                  <svg class="w-5 h-5 text-white ml-0.5" viewBox="0 0 24 24" fill="currentColor"><polygon points="8,5 20,12 8,19" /></svg>
                </div>
              </div>
            </div>
            <div>
              <span class="text-sm font-semibold text-tjb-sage">Module 5</span>
              <h3 class="font-semibold text-lg text-tjb-charcoal mb-1">Advocacy, Backup Plans & More</h3>
              <p class="text-tjb-gray text-sm leading-relaxed">What to say when something unexpected comes up — consent phrases, flexibility language for when plans change, and how to stay in the conversation.</p>
              <span class="text-xs text-tjb-gray-400 mt-1 inline-block">▶ ~7 min</span>
            </div>
          </div>
        </div>
      </div>

      <div class="text-center">
        <a href="/walkthrough/" class="btn-primary">Watch the free walkthrough</a>
        <p class="text-sm text-tjb-gray mt-3">Free with your email. 5 short videos — watch in one evening or one module at a time.</p>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       APP SHOWCASE — Reusable component
       ═══════════════════════════════════════════ -->
  <AppShowcase variant="serif" />

  <!-- ═══════════════════════════════════════════
       WHAT'S INCLUDED — Editorial numbered list
       ═══════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-6">

      <p class="eyebrow mb-4">What's inside</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
      <h2 class="font-semibold text-tjb-charcoal leading-[1.15] mb-10" style="font-size: clamp(1.75rem, 4vw, 2.75rem);">
        Five sections your nurse actually needs
      </h2>

      <div class="space-y-0">
        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">01</span>
            <div>
              <h3 class="text-xl font-semibold text-tjb-charcoal mb-1">Labor preferences</h3>
              <p class="text-tjb-gray leading-relaxed">Who's in the room, movement during labor, monitoring, <a href="/birth-plan-for-induction/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 transition">induction birth plan</a> preferences, the decisions that come up first.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-rose-500 font-serif">02</span>
            <div>
              <h3 class="text-xl font-semibold text-tjb-charcoal mb-1">Pain management</h3>
              <p class="text-tjb-gray leading-relaxed">Epidural timing, alternative comfort measures, your stance on being offered pain medication, written in language your team understands.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">03</span>
            <div>
              <h3 class="text-xl font-semibold text-tjb-charcoal mb-1">Delivery preferences</h3>
              <p class="text-tjb-gray leading-relaxed">Positions, who cuts the cord, skin-to-skin, delayed cord clamping, what you want in the moment your baby arrives.</p>
