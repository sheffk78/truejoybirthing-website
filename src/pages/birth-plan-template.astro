---
import Layout from '../layouts/Layout.astro';
import LeadCaptureForm from '../components/LeadCaptureForm.astro';

const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "Joyful Birth Plan Template", "url": "https://truejoybirthing.com/birth-plan-template/"}];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "HowTo",
      "@id": "https://truejoybirthing.com/birth-plan-template/#howto",
      "name": "How to Use a Birth Plan Template",
      "description": "A step-by-step guide to building your birth plan using a free template — from choosing your preferences to sharing it with your care team.",
      "totalTime": "PT30M",
      "step": [
        {
          "@type": "HowToStep",
          "position": 1,
          "name": "Download the free fillable PDF",
          "text": "Download the free birth plan template as a fillable PDF. You can type directly into it, print it, or recreate it in the free True Joy Birthing app."
        },
        {
          "@type": "HowToStep",
          "position": 2,
          "name": "Review each section with your partner",
          "text": "Go through labor preferences, pain management, delivery, postpartum care, and newborn care. Talk through each section with your partner or support person so you're aligned."
        },
        {
          "@type": "HowToStep",
          "position": 3,
          "name": "Fill in your preferences",
          "text": "Mark what matters most to you. You don't need to answer every item — focus on the preferences that reflect what you actually want, not what you think you should want."
        },
        {
          "@type": "HowToStep",
          "position": 4,
          "name": "Bring it to your next appointment",
          "text": "Share your draft with your OB or midwife at your next visit. Ask them to flag anything that might not be possible at your specific hospital or birth center."
        },
        {
          "@type": "HowToStep",
          "position": 5,
          "name": "Pack it in your hospital bag",
          "text": "Print a few copies. Give one to your partner, one to your doula, and keep one in your hospital bag. When you're in labor, you won't be searching for it."
        }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": "https://truejoybirthing.com/birth-plan-template/#faq",
      "mainEntity": [
        { "@type": "Question", "name": "What should a birth plan template include?", "acceptedAnswer": { "@type": "Answer", "text": "A good birth plan template covers labor preferences, pain management options, delivery positions, postpartum care preferences, and newborn care decisions. It should be organized, concise, and easy for your care team to scan quickly." } },
        { "@type": "Question", "name": "Is this birth plan template really free?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. The fillable PDF is completely free, no email, no upsell, no catch. You can also use the free app for a richer, updatable experience." } },
        { "@type": "Question", "name": "Can I edit the birth plan template?", "acceptedAnswer": { "@type": "Answer", "text": "The PDF is fillable, type directly into it or print it and fill it in by hand. For live updates, doula sharing, and a guided walkthrough, use the free True Joy Birthing app." } },
        { "@type": "Question", "name": "How is this different from a birth plan I find on Google?", "acceptedAnswer": { "@type": "Answer", "text": "Most free templates online are generic checklists. This one was built by a certified birth doula and organized around the decisions that actually come up in the delivery room, not just wish-list items." } },
        { "@type": "Question", "name": "When should I fill out my birth plan?", "acceptedAnswer": { "@type": "Answer", "text": "Most families start around 28-32 weeks. Earlier is fine too. The sooner you understand your options, the more confident you'll feel when the time comes." } },
        { "@type": "Question", "name": "What's the difference between the PDF and the app?", "acceptedAnswer": { "@type": "Answer", "text": "The PDF is free, fillable, and designed for print — write in your preferences and bring hard copies to the hospital. The free app goes further: it walks you through each section with guided videos, lets you update your plan anytime, and shares your live plan with your doula or partner directly. Both cover the same five sections; the app is for families who want an interactive, always-current experience." } }
      ]
    }
  ]
};
---

<Layout
  title="Birth Plan Template — Free & Fillable"
  description="Free fillable birth plan template by a certified doula. Structured, concise, and easy for your care team to read. Covers labor through newborn care."
  canonical="https://truejoybirthing.com/birth-plan-template/"
  ogImage="/images/og/og-birth-plan-template.webp"
  breadcrumbList={breadcrumbList}
  schema={schema}
>

  <!-- ═══════════════════════════════════════════
       HERO — Product-first two-column archetype
       Design spec: VISUAL-TOKENS.md hero archetype
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row">

        <!-- Left: Text — 55% -->
        <div class="md:w-[55%] px-6 md:px-12 py-16 md:py-24 flex flex-col justify-center">
          <p class="eyebrow mb-3">Free birth plan</p>
          <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
          <h1 class="font-bold text-tjb-charcoal leading-[1.15] mb-4" style="font-size: clamp(2.25rem, 5vw, 3.75rem);">
            A birth plan template that actually works in the delivery room
          </h1>
          <!-- Author credibility strip -->
          <div class="flex items-center gap-2.5 mb-5">
            <img src="/images/shelbi-thumb.webp" alt="" width="32" height="32" class="w-8 h-8 rounded-full object-cover" />
            <p class="text-sm text-tjb-gray leading-snug">
              <a href="/about/" class="text-tjb-lavender-600 hover:text-tjb-lavender-700 font-medium no-underline">Shelbi Kohler</a>,
              certified birth doula, 500+ families supported
            </p>
          </div>
          <p class="text-tjb-gray text-lg leading-[1.7] mb-8 max-w-[36rem]">
            A <strong>birth plan template</strong> is a structured form that helps you write down your preferences for labor, pain management, delivery, and newborn care, so your medical team can read it at a glance. This one is built by a certified doula, not a generic hospital form. Download the fillable PDF free, or build your plan in the <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">free app</a>.
          </p>
          <div>
            <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="btn-primary">
              Build your birth plan in the app
            </a>
            <a href="#download" class="btn-secondary mt-3 inline-block">
              Or download the free PDF →
            </a>
          </div>
        </div>

        <!-- Right: Product mockup — 45% -->
        <div class="md:w-[45%] flex items-center justify-center px-6 py-12 md:py-0">
          <img
            src="/images/birth-plan-preview.webp"
            alt="Preview of the free birth plan template — a structured multi-page document covering labor preferences, pain management, delivery, postpartum, and newborn care"
            class="w-full max-w-md rounded-md"
            loading="eager"
            fetchpriority="high"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PROVENANCE — Compact trust anchor
       ═══════════════════════════════════════════ -->
  <div class="bg-tjb-cream border-y border-tjb-lavender-200/40">
    <div class="max-w-3xl mx-auto px-6 py-4 flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-6">
      <span class="text-sm text-tjb-gray-300 tracking-wide">5 sections · fillable PDF · nurse-readable format</span>
      <span class="hidden sm:inline text-tjb-rose-400 text-sm">·</span>
      <span class="text-sm text-tjb-gray-300 tracking-wide">Designed to be read in 30 seconds</span>
      <span class="hidden sm:inline text-tjb-rose-400 text-sm">·</span>
      <span class="text-sm text-tjb-gray-300 tracking-wide">Guided walkthroughs in the app</span>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       APP SHOWCASE — Free app with phone mockups
       ═══════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex flex-col md:flex-row items-center gap-12 md:gap-16">

        <!-- Left: Text — 55% -->
        <div class="md:w-[55%]">
          <p class="eyebrow mb-3">Free app</p>
          <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
          <h2 class="font-semibold text-tjb-charcoal leading-[1.15] mb-4" style="font-size: clamp(1.75rem, 4vw, 2.75rem); font-family: 'Cormorant Garamond', Georgia, serif;">
            Build your plan step by step
          </h2>
          <p class="text-tjb-gray text-lg leading-relaxed mb-6">
            Nine guided sections. Hospital preferences, pain management, who's in the room, all walked through so nothing gets missed.
          </p>
          <ul class="space-y-3 mb-6">
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-tjb-lavender-400 mt-2 flex-shrink-0"></span>
              <span class="text-tjb-gray leading-relaxed">Walkthrough videos for each section</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-tjb-lavender-400 mt-2 flex-shrink-0"></span>
              <span class="text-tjb-gray leading-relaxed">Update your plan anytime, not a static PDF</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-tjb-lavender-400 mt-2 flex-shrink-0"></span>
              <span class="text-tjb-gray leading-relaxed">Share with your doula directly</span>
            </li>
          </ul>
          <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180">
            <img src="/images/app-store-badge.svg" alt="Download on the App Store" class="h-12" loading="lazy" />
          </a>
          <p class="text-sm text-tjb-gray mt-2">Free · No account needed</p>
        </div>

        <!-- Right: Phone mockups — 45% -->
        <div class="md:w-[45%] flex justify-center">
          <div class="relative w-full max-w-sm">
            <!-- Back phone -->
            <div class="absolute top-0 left-0 w-[75%] z-0">
              <img
                src="/images/tjb-app-dashboard.png"
                alt="True Joy Birthing app dashboard showing birth plan sections"
                class="w-full rounded-2xl shadow-lg"
                width="390"
                height="844"
                loading="lazy"
              />
            </div>
            <!-- Front phone — offset right and down -->
            <div class="relative ml-[25%] mt-12 w-[75%] z-10">
              <img
                src="/images/tjb-app-birth-plan-builder.png"
                alt="True Joy Birthing app birth plan builder showing guided preferences"
                class="w-full rounded-2xl shadow-xl"
                width="390"
                height="844"
                loading="lazy"
              />
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHAT'S INCLUDED — Editorial numbered list
       ═══════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-6">

      <p class="eyebrow mb-4">What's inside</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
      <h2 class="font-semibold text-tjb-charcoal leading-[1.15] mb-10" style="font-size: clamp(1.75rem, 4vw, 2.75rem);">
        Five sections your nurse actually needs
      </h2>

      <div class="space-y-0">
        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">01</span>
            <div>
              <h3 class="text-xl font-semibold text-tjb-charcoal mb-1">Labor preferences</h3>
              <p class="text-tjb-gray leading-relaxed">Who's in the room, movement during labor, monitoring, <a href="/birth-plan-for-induction/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 transition">induction preferences</a>, the decisions that come up first.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-rose-500 font-serif">02</span>
            <div>
              <h3 class="text-xl font-semibold text-tjb-charcoal mb-1">Pain management</h3>
              <p class="text-tjb-gray leading-relaxed">Epidural timing, alternative comfort measures, your stance on being offered pain medication, written in language your team understands.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">03</span>
            <div>
              <h3 class="text-xl font-semibold text-tjb-charcoal mb-1">Delivery preferences</h3>
              <p class="text-tjb-gray leading-relaxed">Positions, who cuts the cord, skin-to-skin, delayed cord clamping, what you want in the moment your baby arrives.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-rose-500 font-serif">04</span>
            <div>
              <h3 class="text-xl font-semibold text-tjb-charcoal mb-1">Postpartum care</h3>
              <p class="text-tjb-gray leading-relaxed">Breastfeeding support, placenta delivery, who you want in recovery, the first hours after birth, documented.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40 border-b">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-sage font-serif">05</span>
            <div>
              <h3 class="text-xl font-semibold text-tjb-charcoal mb-1">Newborn care</h3>
              <p class="text-tjb-gray leading-relaxed">Circumcision, vaccinations, feeding preferences, rooming-in, what you want for your baby from the start.</p>
            </div>
          </div>
        </div>
      </div>

      <p class="text-tjb-gray mt-8 leading-relaxed">The best templates don't just list checkboxes. They help you think through <em>why</em> you prefer something, and give you the language to communicate it clearly.</p>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       HOW TO USE — Editorial numbered steps
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-6">

      <p class="eyebrow mb-4">How to use this template</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
      <h2 class="font-semibold text-tjb-charcoal leading-[1.15] mb-10" style="font-size: clamp(1.75rem, 4vw, 2.75rem);">
        Five steps from blank page to hospital bag
      </h2>

      <div class="space-y-0">
        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">01</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Download the fillable PDF.</p>
              <p class="text-tjb-gray leading-relaxed">It's free, no email required. Type directly into it, or print it and fill it in by hand. For live updates and doula sharing, use the <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">free app</a>.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-rose-500 font-serif">02</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Review each section with your partner.</p>
              <p class="text-tjb-gray leading-relaxed">Talk through labor preferences, pain management, delivery, postpartum care, and newborn care. Get aligned before the big day.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">03</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Fill in your preferences.</p>
              <p class="text-tjb-gray leading-relaxed">Mark what matters most to you. You don't need to answer every item, focus on what you actually want, not what you think you should want.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-rose-500 font-serif">04</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Bring it to your next appointment.</p>
              <p class="text-tjb-gray leading-relaxed">Share your draft with your OB or midwife. Ask them to flag anything that might not be possible at your specific hospital or birth center.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40 border-b">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-sage font-serif">05</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Pack it in your hospital bag.</p>
              <p class="text-tjb-gray leading-relaxed">Print a few copies. Give one to your partner, one to your doula, and keep one in your hospital bag. When you're in labor, you won't be searching for it.</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHY THIS ONE — Editorial explainer
       ═══════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="flex flex-col md:flex-row gap-10 md:gap-12">
        <!-- Left column — 58% -->
        <div class="md:w-[58%]">
          <p class="eyebrow mb-4">Why this template</p>
          <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
          <h2 class="font-semibold text-tjb-charcoal leading-[1.15] mb-6" style="font-size: clamp(1.75rem, 4vw, 2.75rem); font-family: 'Cormorant Garamond', Georgia, serif;">
            Built for the delivery room, not a Pinterest board
          </h2>
          <p class="text-tjb-gray text-lg leading-relaxed mb-4">
            Most free birth plan templates you find online are generic checklists, they ask if you want an epidural or not, if you want music or not, and leave it at that.
          </p>
          <p class="text-tjb-gray text-lg leading-relaxed mb-4">
            This template was built by <strong>Shelbi Kohler</strong>, a certified birth doula who has sat in delivery rooms across Texas. It's organized around <em>the decisions that actually come up</em> when you're in labor, the ones your care team needs to see at a glance, not the ones that look nice on a Pinterest board.
          </p>
          <p class="text-tjb-gray text-lg leading-relaxed mb-4">
            It's structured so a nurse can read it in 30 seconds. That matters. When you're 6 centimeters dilated and your nurse is covering for someone else's shift, your birth plan needs to speak for you immediately.
          </p>
          <p class="text-tjb-gray text-lg leading-relaxed">
            And if your birth plan needs to account for a specific situation, like being induced, the template still works. <a href="/birth-plan-for-induction/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 transition">See how to fill it out for an induction</a>. For surgical deliveries, see <a href="/c-section-birth-plan/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 transition">what to include if you end up needing a C-section</a>.
          </p>
        </div>
        <!-- Right column — 42% -->
        <div class="md:w-[42%] flex items-center">
          <img src="/images/doula-walking.webp" alt="Birth doula walking with expectant mother in hospital hallway, preparing for labor and delivery" class="w-full rounded-xl" loading="lazy" width="1024" height="768" />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CITY RESOURCES — Typographic link strip
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream py-12 border-y border-tjb-lavender-200/50">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="font-semibold text-tjb-charcoal text-lg mb-4">Tailor your plan for your hospital</h2>
      <p class="text-tjb-gray mb-6">Birth plans work best when they're tailored to your actual care setting. Our city pages include local hospital details, doula costs, and what Medicaid covers:</p>

      <h3 class="font-semibold text-tjb-charcoal text-sm mb-2">Colorado</h3>
      <ul class="grid grid-cols-2 md:grid-cols-3 gap-x-4 gap-y-2 mb-4">
        <li><a href="/birth-support/denver-co/" class="text-tjb-rose-500 hover:text-tjb-rose-600 transition text-sm">Denver</a></li>
        <li><a href="/birth-support/colorado-springs-co/" class="text-tjb-rose-500 hover:text-tjb-rose-600 transition text-sm">Colorado Springs</a></li>
      </ul>
      <p class="mb-6"><a href="/birth-support/co/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 transition text-sm">See all Colorado cities →</a></p>

      <h3 class="font-semibold text-tjb-charcoal text-sm mb-2">Texas</h3>
      <ul class="grid grid-cols-2 md:grid-cols-3 gap-x-4 gap-y-2 mb-4">
        <li><a href="/birth-support/dallas-tx/" class="text-tjb-rose-500 hover:text-tjb-rose-600 transition text-sm">Dallas</a></li>
        <li><a href="/birth-support/houston-tx/" class="text-tjb-rose-500 hover:text-tjb-rose-600 transition text-sm">Houston</a></li>
        <li><a href="/birth-support/austin-tx/" class="text-tjb-rose-500 hover:text-tjb-rose-600 transition text-sm">Austin</a></li>
        <li><a href="/birth-support/san-antonio-tx/" class="text-tjb-rose-500 hover:text-tjb-rose-600 transition text-sm">San Antonio</a></li>
        <li><a href="/birth-support/fort-worth-tx/" class="text-tjb-rose-500 hover:text-tjb-rose-600 transition text-sm">Fort Worth</a></li>
        <li><a href="/birth-support/el-paso-tx/" class="text-tjb-rose-500 hover:text-tjb-rose-600 transition text-sm">El Paso</a></li>
      </ul>
      <p class="mb-6"><a href="/birth-support/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 transition text-sm">See all 20 Texas cities →</a></p>

      <h3 class="font-semibold text-tjb-charcoal text-sm mb-2">More cities</h3>
      <ul class="grid grid-cols-2 md:grid-cols-3 gap-x-4 gap-y-2">
        <li><a href="/birth-support/phoenix-az/" class="text-tjb-rose-500 hover:text-tjb-rose-600 transition text-sm">Phoenix</a></li>
        <li><a href="/birth-support/las-vegas-nv/" class="text-tjb-rose-500 hover:text-tjb-rose-600 transition text-sm">Las Vegas</a></li>
        <li><a href="/birth-support/chicago-il/" class="text-tjb-rose-500 hover:text-tjb-rose-600 transition text-sm">Chicago</a></li>
      </ul>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WALKTHROUGH — Editorial callout on cream
