---
import Layout from '../layouts/Layout.astro';
import LeadCaptureForm from '../components/LeadCaptureForm.astro';
import ContextualCityLinks from '../components/ContextualCityLinks.astro';

const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "How Much Does a Doula Cost", "url": "https://truejoybirthing.com/doula-cost/"}];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "@id": "https://truejoybirthing.com/doula-cost/#service",
      "name": "Birth Doula Support",
      "description": "Non-medical emotional, physical, and informational support during labor and delivery.",
      "provider": { "@id": "https://truejoybirthing.com/#organization" },
      "areaServed": { "@type": "Country", "name": "United States" },
      "offers": {
        "@type": "AggregateOffer",
        "lowPrice": "650",
        "highPrice": "3000",
        "priceCurrency": "USD",
        "offerCount": "1000"
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://truejoybirthing.com/doula-cost/#faq",
      "mainEntity": [
        { "@type": "Question", "name": "How much does a birth doula cost?", "acceptedAnswer": { "@type": "Answer", "text": "In the US, birth doula services typically range from $650 to $3,000 depending on location, experience, and what's included. The national average is around $1,200–$1,500 for a standard birth package." } },
        { "@type": "Question", "name": "What's included in a doula's fee?", "acceptedAnswer": { "@type": "Answer", "text": "A standard birth doula package usually includes 1-2 prenatal visits, on-call availability from 37-38 weeks, continuous labor support, and 1-2 postpartum visits. Some include additional services like birth plan help, texting support, or lactation guidance." } },
        { "@type": "Question", "name": "Does insurance cover doula costs?", "acceptedAnswer": { "@type": "Answer", "text": "Some private insurers are starting to cover doula services, particularly as part of maternal wellness benefits. Medicaid coverage for doulas is also expanding in many states. You'll need to check directly with your plan." } },
        { "@type": "Question", "name": "Why do doulas cost so much?", "acceptedAnswer": { "@type": "Answer", "text": "Birth doulas are on-call for weeks, often leaving their own lives on hold. A standard package represents 30-50+ hours of work across prenatal visits, the birth itself (which can be 12-24+ hours), and postpartum visits. When you break it down hourly, the cost is often comparable to other professional support services." } },
        { "@type": "Question", "name": "Are there low-cost or free doula options?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Many communities have volunteer doula programs, and some doulas offer sliding-scale fees or payment plans. If cost is a barrier, look into local doula collectives or ask about reduced-rate packages." } },
        { "@type": "Question", "name": "Is a doula worth the cost?", "acceptedAnswer": { "@type": "Answer", "text": "Research consistently shows that continuous doula support leads to shorter labors, fewer interventions, and higher satisfaction with the birth experience. For many families, the investment pays off in confidence and outcomes." } }
      ]
    }
  ]
};
---

<Layout
  title="How Much Does a Doula Cost?"
  description="Birth doula costs range from $650 to $3,000 in the US. Learn what affects the price, what's included, insurance coverage, and how to find affordable support."
  canonical="https://truejoybirthing.com/doula-cost/"
  ogImage="/images/og/og-doula-cost.png"
  breadcrumbList={breadcrumbList}
  schema={schema}
>

  <!-- ═══════════════════════════════════════════
       HERO — Editorial two-column, 55/45
       Author photo right, text left
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row">

        <!-- Left: Text — 55% -->
        <div class="md:w-[55%] px-6 md:px-12 py-16 md:py-24 flex flex-col justify-center">
          <p class="eyebrow mb-3">Doula costs</p>
          <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
          <h1 class="font-bold text-tjb-charcoal leading-[1.15] mb-4" style="font-size: clamp(2.25rem, 5vw, 3.75rem);">
            How Much Does a Doula Cost?
          </h1>
          <!-- Author credibility strip -->
          <div class="flex items-center gap-2.5 mb-5">
            <img src="/images/shelbi-thumb.webp" alt="Shelbi Kohler, certified birth doula" width="32" height="32" class="w-8 h-8 rounded-full object-cover" />
            <p class="text-sm text-tjb-gray leading-snug">
              <a href="/about/" class="text-tjb-lavender-600 hover:text-tjb-lavender-700 font-medium no-underline">Shelbi Kohler</a>,
              certified birth doula — 500+ families supported
            </p>
          </div>
          <p class="text-tjb-gray text-lg leading-[1.7] mb-8 max-w-[36rem]">
            <strong>Doula costs</strong> in the US range from $650 to $3,000 for a standard birth package covering prenatal visits, labor support, and postpartum care. Here's what drives that range, what you're actually paying for, and how to find support that fits your budget.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/birth-plan-template/" class="btn-primary">Get the free birth plan</a>
            <a href="/birth-support/" class="btn-secondary">Find your city</a>
          </div>
        </div>

        <!-- Right: Photo — 45% -->
        <div class="md:w-[45%] flex items-center justify-center px-6 py-12 md:py-0">
          <img
            src="/images/hero-doula-cost.webp"
            alt="A birth doula providing hands-on support during labor — counter-pressure, encouragement, and continuous presence"
            class="w-full aspect-[3/4] object-cover rounded-2xl shadow-lg"
            width="900"
            height="1200"
            loading="eager"
            fetchpriority="high"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PROVENANCE — Compact trust anchor
       ═══════════════════════════════════════════ -->
  <div class="bg-tjb-cream border-y border-tjb-lavender-200/40">
    <div class="max-w-3xl mx-auto px-6 py-4 flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-6">
      <span class="text-sm text-tjb-gray-300 tracking-wide">$650–$3,000 typical range</span>
      <span class="hidden sm:inline text-tjb-rose-400 text-sm">·</span>
      <span class="text-sm text-tjb-gray-300 tracking-wide">30–50+ hours per package</span>
      <span class="hidden sm:inline text-tjb-rose-400 text-sm">·</span>
      <span class="text-sm text-tjb-gray-300 tracking-wide">Insurance may cover part or all</span>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       COST AT A GLANCE — Designed table on cream
       ═══════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-6">

      <p class="eyebrow mb-4">Cost at a glance</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
      <h2 class="font-semibold text-tjb-charcoal leading-[1.15] mb-4" style="font-size: clamp(1.75rem, 4vw, 2.75rem);">
        Birth doula costs by region
      </h2>
      <p class="text-tjb-gray leading-relaxed mb-8">
        In the United States, birth doula services typically range from <strong>$650 to $3,000</strong> depending on where you live, the doula's experience, and what's included in the package.
      </p>

      <!-- Designed cost table -->
      <div class="not-prose">
        <div class="bg-tjb-cream rounded-md overflow-hidden">
          <div class="grid grid-cols-[1fr_auto] border-b-2 border-tjb-lavender-300/60">
            <div class="py-3 px-5 text-sm font-semibold text-tjb-charcoal">Region</div>
            <div class="py-3 px-5 text-sm font-semibold text-tjb-charcoal text-right">Typical Range</div>
          </div>
          <div class="grid grid-cols-[1fr_auto] border-b border-tjb-lavender-200/50">
            <div class="py-3 px-5 text-sm text-tjb-gray">Major metros (NYC, LA, SF)</div>
            <div class="py-3 px-5 text-sm font-semibold text-tjb-charcoal text-right">$1,500–$3,000</div>
          </div>
          <div class="grid grid-cols-[1fr_auto] border-b border-tjb-lavender-200/50 bg-tjb-lavender-50/30">
            <div class="py-3 px-5 text-sm text-tjb-gray">Texas cities (Dallas, Houston, Austin)</div>
            <div class="py-3 px-5 text-sm font-semibold text-tjb-charcoal text-right">$800–$2,800</div>
          </div>
          <div class="grid grid-cols-[1fr_auto] border-b border-tjb-lavender-200/50">
            <div class="py-3 px-5 text-sm text-tjb-gray">Mid-size cities</div>
            <div class="py-3 px-5 text-sm font-semibold text-tjb-charcoal text-right">$700–$2,000</div>
          </div>
          <div class="grid grid-cols-[1fr_auto]">
            <div class="py-3 px-5 text-sm text-tjb-gray">Smaller towns and rural areas</div>
            <div class="py-3 px-5 text-sm font-semibold text-tjb-charcoal text-right">$650–$1,500</div>
          </div>
        </div>
        <p class="text-xs text-tjb-gray-300 mt-3 italic">These ranges reflect 2025-2026 market rates. Costs vary by individual doula and package.</p>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHAT'S INCLUDED — Editorial numbered list
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-6">

      <p class="eyebrow mb-4">What's included</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
      <h2 class="font-semibold text-tjb-charcoal leading-[1.15] mb-8" style="font-size: clamp(1.75rem, 4vw, 2.75rem);">
        30–50+ hours of support in a standard package
      </h2>

      <div class="space-y-0">
        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">01</span>
            <div>
              <h3 class="text-xl font-semibold text-tjb-charcoal mb-1">1–2 prenatal visits</h3>
              <p class="text-tjb-gray leading-relaxed">Getting to know you, discussing your birth plan, answering questions — building the relationship before labor starts.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-rose-500 font-serif">02</span>
            <div>
              <h3 class="text-xl font-semibold text-tjb-charcoal mb-1">On-call availability</h3>
              <p class="text-tjb-gray leading-relaxed">Usually starting at 37–38 weeks, your doula is available 24/7 until you deliver. That's weeks of being ready to drop everything.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">03</span>
            <div>
              <h3 class="text-xl font-semibold text-tjb-charcoal mb-1">Continuous labor support</h3>
              <p class="text-tjb-gray leading-relaxed">From the time you call them until 1–2 hours after delivery. No shift changes, no handoffs — one person who knows your plan and stays with you.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-rose-500 font-serif">04</span>
            <div>
              <h3 class="text-xl font-semibold text-tjb-charcoal mb-1">1–2 postpartum visits</h3>
              <p class="text-tjb-gray leading-relaxed">Processing the birth, breastfeeding support, newborn care help — the follow-up that most families don't realize they need. For dedicated postpartum support beyond these visits, see our <a href="/postpartum-doula-cost/" class="text-tjb-rose-500 hover:underline">postpartum doula cost guide</a>.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40 border-b">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-sage font-serif">05</span>
            <div>
              <h3 class="text-xl font-semibold text-tjb-charcoal mb-1">Phone and text support</h3>
              <p class="text-tjb-gray leading-relaxed">Throughout pregnancy and early postpartum — questions, check-ins, reassurance when you need it.</p>
            </div>
          </div>
        </div>
      </div>

      <p class="text-tjb-gray mt-8 leading-relaxed">
        When you add it up, a birth doula package often represents <strong>30–50+ hours</strong> of combined time. Broken down hourly, the rate is typically $25–50/hour — comparable to other professional support services.
      </p>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHAT AFFECTS THE COST — Editorial on white
       ═══════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-6">

      <p class="eyebrow mb-4">What affects the cost</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
      <h2 class="font-semibold text-tjb-charcoal leading-[1.15] mb-8" style="font-size: clamp(1.75rem, 4vw, 2.75rem);">
        Five factors that drive doula pricing
      </h2>

      <div class="space-y-0">
        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">01</span>
            <div>
              <h3 class="text-xl font-semibold text-tjb-charcoal mb-1">Location</h3>
              <p class="text-tjb-gray leading-relaxed">Cost of living drives pricing. Doulas in major metros charge more than those in smaller cities.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-rose-500 font-serif">02</span>
            <div>
              <h3 class="text-xl font-semibold text-tjb-charcoal mb-1">Experience</h3>
              <p class="text-tjb-gray leading-relaxed">A doula with 100+ births will charge more than someone recently certified. But experience matters — the <a href="/benefits-of-a-doula/" class="text-tjb-rose-500 hover:underline">evidence on doula benefits</a> is strongest for doulas who have supported a wide range of birth scenarios.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">03</span>
            <div>
              <h3 class="text-xl font-semibold text-tjb-charcoal mb-1">Package inclusions</h3>
              <p class="text-tjb-gray leading-relaxed">Some doulas include postpartum visits, lactation support, or childbirth education classes in their package.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-rose-500 font-serif">04</span>
            <div>
              <h3 class="text-xl font-semibold text-tjb-charcoal mb-1">Add-on services</h3>
              <p class="text-tjb-gray leading-relaxed">Placenta encapsulation, photography, aromatherapy, and other services increase the total.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40 border-b">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-sage font-serif">05</span>
            <div>
              <h3 class="text-xl font-semibold text-tjb-charcoal mb-1">Availability</h3>
              <p class="text-tjb-gray leading-relaxed">Doulas who take fewer clients or guarantee one-on-one attention may charge a premium.</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       INSURANCE — Three-column on cream
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-6">

      <p class="eyebrow mb-4">Insurance coverage</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
      <h2 class="font-semibold text-tjb-charcoal leading-[1.15] mb-8" style="font-size: clamp(1.75rem, 4vw, 2.75rem);">
        Does insurance cover doula costs?
      </h2>

      <div class="space-y-6">
        <div class="border-b border-tjb-lavender-300/40 pb-6">
          <h3 class="font-semibold text-tjb-charcoal text-lg mb-2">Private insurance</h3>
          <p class="text-tjb-gray leading-relaxed">Some insurers are beginning to cover doula services as part of maternal wellness benefits. This is especially true for employer-sponsored plans through companies prioritizing maternal health outcomes. Ask your plan directly — don't assume the answer is no.</p>
        </div>
        <div class="border-b border-tjb-lavender-300/40 pb-6">
          <h3 class="font-semibold text-tjb-charcoal text-lg mb-2">Medicaid</h3>
          <p class="text-tjb-gray leading-relaxed">Medicaid doula coverage is expanding state by state. As of 2026, several states including Texas are moving toward reimbursing doula services. Check with your Medicaid managed care plan for current benefits, or see our <a href="/medicaid-doula-coverage/" class="text-tjb-rose-500 hover:underline">state-by-state Medicaid doula coverage guide</a>.</p>
        </div>
        <div>
          <h3 class="font-semibold text-tjb-charcoal text-lg mb-2">FSA / HSA</h3>
          <p class="text-tjb-gray leading-relaxed">Many families use Flexible Spending Account or Health Savings Account funds for doula services. Ask your doula for an itemized receipt you can submit for reimbursement.</p>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       AFFORDABLE OPTIONS — Editorial numbered list on white
       ═══════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-6">

      <p class="eyebrow mb-4">Making it affordable</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
      <h2 class="font-semibold text-tjb-charcoal leading-[1.15] mb-8" style="font-size: clamp(1.75rem, 4vw, 2.75rem);">
        How to find affordable doula support
      </h2>

      <div class="space-y-0">
        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">01</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Ask about sliding-scale fees.</p>
              <p class="text-tjb-gray leading-relaxed">Many doulas offer reduced rates based on income.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-rose-500 font-serif">02</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Check local doula collectives.</p>
              <p class="text-tjb-gray leading-relaxed">Community-based organizations often provide lower-cost services.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">03</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Look into volunteer doula programs.</p>
              <p class="text-tjb-gray leading-relaxed">Some hospitals and nonprofits offer free doula support for families who qualify.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-rose-500 font-serif">04</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Consider a student doula.</p>
              <p class="text-tjb-gray leading-relaxed">Doulas completing their certification require a certain number of births and may offer reduced rates.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40 border-b">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-sage font-serif">05</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Use free birth plan tools.</p>
              <p class="text-tjb-gray leading-relaxed">Even without a doula, a structured birth plan helps you feel prepared. <a href="/birth-plan-template/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">Download the free template →</a></p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CITY COSTS — Typographic link strip
       ═══════════════════════════════════════════ -->
  <ContextualCityLinks topic="cost" />

  <!-- ═══════════════════════════════════════════
       FAQ — Editorial on white
       ═══════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-6">

      <p class="eyebrow mb-4">Common questions</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>

      <div class="space-y-6">
        <div class="border-b border-tjb-lavender-300/40 pb-6">
          <h3 class="font-semibold text-tjb-charcoal text-lg mb-2">How much does a birth doula cost?</h3>
          <p class="text-tjb-gray leading-relaxed">In the US, birth doula services typically range from $650 to $3,000 depending on location, experience, and what's included. The national average is around $1,200–$1,500 for a standard birth package.</p>
        </div>
        <div class="border-b border-tjb-lavender-300/40 pb-6">
          <h3 class="font-semibold text-tjb-charcoal text-lg mb-2">What's included in a doula's fee?</h3>
          <p class="text-tjb-gray leading-relaxed">A standard birth doula package usually includes 1-2 prenatal visits, on-call availability from 37-38 weeks, continuous labor support, and 1-2 postpartum visits. Some include additional services like birth plan help, texting support, or lactation guidance.</p>
        </div>
        <div class="border-b border-tjb-lavender-300/40 pb-6">
          <h3 class="font-semibold text-tjb-charcoal text-lg mb-2">Does insurance cover doula costs?</h3>
          <p class="text-tjb-gray leading-relaxed">Some private insurers are starting to cover doula services, particularly as part of maternal wellness benefits. Medicaid coverage for doulas is also expanding in many states. You'll need to check directly with your plan.</p>
        </div>
        <div class="border-b border-tjb-lavender-300/40 pb-6">
          <h3 class="font-semibold text-tjb-charcoal text-lg mb-2">Why do doulas cost so much?</h3>
          <p class="text-tjb-gray leading-relaxed">Birth doulas are on-call for weeks, often leaving their own lives on hold. A standard package represents 30-50+ hours of work across prenatal visits, the birth itself (which can be 12-24+ hours), and postpartum visits. When you break it down hourly, the cost is often comparable to other professional support services.</p>
        </div>
        <div class="border-b border-tjb-lavender-300/40 pb-6">
          <h3 class="font-semibold text-tjb-charcoal text-lg mb-2">Are there low-cost or free doula options?</h3>
          <p class="text-tjb-gray leading-relaxed">Yes. Many communities have volunteer doula programs, and some doulas offer sliding-scale fees or payment plans. If cost is a barrier, look into local doula collectives or ask about reduced-rate packages.</p>
        </div>
        <div>
          <h3 class="font-semibold text-tjb-charcoal text-lg mb-2">Is a doula worth the cost?</h3>
          <p class="text-tjb-gray leading-relaxed">Research consistently shows that continuous doula support leads to shorter labors, fewer interventions, and higher satisfaction with the birth experience. For many families, the investment pays off in confidence and outcomes.</p>
        </div>
      </div>

    </div>
  </section>

