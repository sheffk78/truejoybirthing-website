---
import Layout from '../layouts/Layout.astro';

const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "FAQ", "url": "https://truejoybirthing.com/faq/"}];
---

<Layout
  title="Birth Plan &amp; Doula FAQ"
  description="Answers to common questions about birth plans, doula costs, Medicaid doula coverage, and how the free Joyful Birth Plan template works."
    canonical="https://truejoybirthing.com/faq"
    ogImage="/images/og-faq.webp"
    breadcrumbList={breadcrumbList}
  schema={{
    "@graph": [
      {
        "@type": "FAQPage",
        "mainEntity": [
          {"@type":"Question","name":"What is a birth doula?","acceptedAnswer":{"@type":"Answer","text":"A trained, non-medical support person who provides emotional, physical, and informational support during birth. Doulas do not replace your doctor or midwife."}},
          {"@type":"Question","name":"Does True Joy Birthing replace having a doula?","acceptedAnswer":{"@type":"Answer","text":"No. Our tools complement doula support. The free app helps you build a plan. The guided walkthrough teaches you your options. For personalized help, connect with a doula in your area."}},
          {"@type":"Question","name":"Is the app really free for moms?","acceptedAnswer":{"@type":"Answer","text":"Yes. Parent Mode — the birth plan builder and education — is free. Pro Mode with tools for doulas and midwives is a paid subscription."}},
          {"@type":"Question","name":"What's the difference between a doula and a midwife?","acceptedAnswer":{"@type":"Answer","text":"A doula provides non-medical support. A midwife is a medical care provider who can deliver babies. You can have both."}},
          {"@type":"Question","name":"When should I start my birth plan?","acceptedAnswer":{"@type":"Answer","text":"Most families start around 28-32 weeks, but earlier is fine too. The sooner you understand your options, the more confident you'll feel."}},
          {"@type":"Question","name":"What's Pro Mode?","acceptedAnswer":{"@type":"Answer","text":"Pro Mode is our paid subscription for doulas and midwives. It includes client management, visit tracking, notes, and invoicing — all built around birth-specific workflows."}},
          {"@type":"Question","name":"What's the Joyful Birth Plan?","acceptedAnswer":{"@type":"Answer","text":"A free, fillable birth plan template designed by a certified doula — structured so a nurse can read it in two minutes. It covers every stage of birth: labor preferences, pain management, delivery, postpartum, and newborn care."}},
          {"@type":"Question","name":"What's the Guided Birth Plan Walkthrough?","acceptedAnswer":{"@type":"Answer","text":"A self-paced video walkthrough that picks up where the free plan leaves off. About 60 minutes of short lessons that walk you through each section of your birth plan — what each choice means, what the tradeoffs are, and what to say when your provider recommends something you didn't expect. Free with your email."}},
          {"@type":"Question","name":"What's the Birth Plan Confidence Session?","acceptedAnswer":{"@type":"Answer","text":"A 60–75 minute live Zoom call with a certified birth doula who reviews your completed birth plan with you line by line — including advocacy role-play and hospital-specific pushback practice. Bring your questions and your plan. $250 per session, limited spots."}}
        ]
      }
    ]
  }}
>
  <!-- Hero — Split Layout (55% text / 45% image) -->
  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div class="text-center md:text-left">
          <p class="eyebrow mb-3">Free Joyful Birth Plan</p>
          <h1 class="text-3xl md:text-4xl font-bold mb-4">FAQ</h1>
          <p class="text-lg text-tjb-gray">Common questions about birth plans, doulas, and the Joyful Birth Plan.</p>
        </div>
        <div class="relative">
          <img
            src="/images/hero-faq.webp"
            alt="Frequently asked questions about birth plans, doulas, and the Joyful Birth Plan"
            class="w-full aspect-[3/4] object-cover rounded-2xl shadow-lg"
            width="900"
            height="1200"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-2xl font-bold text-center mb-10 text-tjb-charcoal">Common Questions</h2>
      <div class="space-y-6">
      <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
        <h3 class="font-semibold text-lg mb-2">What is a birth doula?</h3>
        <p class="text-tjb-gray">A trained, non-medical support person who provides emotional, physical, and informational support during birth. Doulas do not replace your doctor or midwife. Think of a doula as your advocate and coach — someone who knows the system, helps you navigate decisions, and stays with you through every contraction when hospital staff rotates.</p>
      </div>
      <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
        <h3 class="font-semibold text-lg mb-2">Does True Joy Birthing replace having a doula?</h3>
        <p class="text-tjb-gray">No. Our tools complement doula support. The free app helps you build a plan. The guided walkthrough teaches you your options. For personalized help, connect with a doula in your area or find one at /birth-support/. A doula knows your specific situation and can adapt in real-time during labor — no app can do that.</p>
      </div>
      <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
        <h3 class="font-semibold text-lg mb-2">Is the app really free for moms?</h3>
        <p class="text-tjb-gray">Yes. Parent Mode — the birth plan builder and education — is free. Pro Mode with tools for doulas and midwives is a paid subscription available on the App Store and Google Play.</p>
      </div>
      <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
        <h3 class="font-semibold text-lg mb-2">What's the difference between a doula and a midwife?</h3>
        <p class="text-tjb-gray">A doula provides non-medical emotional and physical support. A midwife is a medical care provider who can deliver babies, prescribe, and perform clinical procedures. You can have both — they serve completely different roles on your birth team.</p>
      </div>
      <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
        <h3 class="font-semibold text-lg mb-2">When should I start my birth plan?</h3>
        <p class="text-tjb-gray">Most families start around 28-32 weeks, but earlier is fine too. The sooner you understand your options, the more confident you'll feel. Starting early also gives you time to have real conversations with your provider — and to course-correct if needed.</p>
      </div>
      <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
        <h3 class="font-semibold text-lg mb-2">What's Pro Mode?</h3>
        <p class="text-tjb-gray">Pro Mode is our paid subscription for doulas and midwives. It includes client management, visit tracking, notes, and simple invoicing — all built around birth-specific workflows. Available on the App Store and Google Play.</p>
      </div>
      <div class="bg-tjb-cream rounded-xl p-6 border border-tjb-lavender-200/50">
        <h3 class="font-semibold text-lg mb-2">What's the Joyful Birth Plan?</h3>
        <p class="text-tjb-gray">A free, fillable birth plan template designed by a certified doula — structured so a nurse can read it in two minutes. It covers every stage of birth: labor preferences, pain management, delivery, postpartum, and newborn care. <a href="/birth-plan-template/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">Download free birth plan</a></p>
      </div>
      <div class="bg-tjb-cream rounded-xl p-6 border border-tjb-lavender-200/50">
        <h3 class="font-semibold text-lg mb-2">What's the Guided Birth Plan Walkthrough?</h3>
        <p class="text-tjb-gray">A self-paced video walkthrough that picks up where the free plan leaves off. About 60 minutes of short lessons that walk you through each section of your birth plan — what each choice means, what the tradeoffs are, and what to say when your provider recommends something you didn't expect. Free with your email. <a href="/birth-plan-template/#walkthrough" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">Watch the free walkthrough</a></p>
      </div>
      <div class="bg-tjb-cream rounded-xl p-6 border border-tjb-lavender-200/50">
        <h3 class="font-semibold text-lg mb-2">What's the Birth Plan Confidence Session?</h3>
        <p class="text-tjb-gray">A 60–75 minute live Zoom call with a certified birth doula who reviews your completed birth plan with you line by line — including advocacy role-play and hospital-specific pushback practice. Bring your questions and your plan. $250 per session, limited spots. <a href="/birth-plan-confidence-session/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">Book a Birth Plan Confidence Session</a></p>
      </div>
      </div>
    </div>

    <div class="max-w-3xl mx-auto px-6 mt-16">
      <h2 class="text-2xl font-bold text-center mb-10 text-tjb-charcoal">Start here</h2>

      <div class="space-y-6">
        <a href="/birth-plan-template/" class="block bg-tjb-lavender-50 rounded-xl p-6 border-2 border-tjb-lavender-300 hover:border-tjb-rose-300 transition group">
          <h3 class="text-lg font-bold text-tjb-charcoal group-hover:text-tjb-rose-500 transition mb-1">Download free birth plan</h3>
          <p class="text-sm text-tjb-gray">The free Joyful Birth Plan — structured, fillable, and designed to be read by a nurse in two minutes.</p>
        </a>
        <a href="/birth-plan-template/#walkthrough" class="block bg-white rounded-xl p-6 border border-tjb-lavender-200/50 hover:border-tjb-rose-300 transition group">
          <h3 class="text-lg font-bold text-tjb-charcoal group-hover:text-tjb-rose-500 transition mb-1">Watch the free walkthrough</h3>
          <p class="text-sm text-tjb-gray">Walk through every section of your plan with a doula's context. Free with your email.</p>
        </a>
        <a href="/birth-plan-confidence-session/" class="block bg-white rounded-xl p-6 border border-tjb-lavender-200/50 hover:border-tjb-rose-300 transition group">
          <h3 class="text-lg font-bold text-tjb-charcoal group-hover:text-tjb-rose-500 transition mb-1">Book a Birth Plan Confidence Session</h3>
          <p class="text-sm text-tjb-gray">A 60–75 minute live Zoom call to review your plan with a doula line by line. $250 per session.</p>
        </a>
      </div>

      <p class="text-sm text-tjb-gray mt-8 text-center">Still have questions? <a href="/contact/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">Contact us</a></p>
    </div>
  </section>
</Layout>
