---
import Layout from '../layouts/Layout.astro';

const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "FAQ", "url": "https://truejoybirthing.com/faq/"}];
---

<Layout
  title="FAQ"
  description="Common questions about birth plans, doula support, and the True Joy Birthing app."
  canonical="https://truejoybirthing.com/faq"
  breadcrumbList={breadcrumbList}
>
  schema={{
    "@graph": [
      {
        "@type": "FAQPage",
        "mainEntity": [
          {"@type":"Question","name":"What is a birth doula?","acceptedAnswer":{"@type":"Answer","text":"A trained, non-medical support person who provides emotional, physical, and informational support during birth. Doulas do not replace your doctor or midwife."}},
          {"@type":"Question","name":"Does True Joy Birthing replace having a doula?","acceptedAnswer":{"@type":"Answer","text":"No. Our tools complement doula support. The free app helps you build a plan. The mini-course teaches you your options. A session with Shelbi is available if you want personalized help."}},
          {"@type":"Question","name":"Is the app really free for moms?","acceptedAnswer":{"@type":"Answer","text":"Yes. Parent Mode — the birth plan builder and education — is free. Pro Mode with tools for doulas and midwives is a paid subscription."}},
          {"@type":"Question","name":"What's the difference between a doula and a midwife?","acceptedAnswer":{"@type":"Answer","text":"A doula provides non-medical support. A midwife is a medical care provider who can deliver babies. You can have both."}},
          {"@type":"Question","name":"When should I start my birth plan?","acceptedAnswer":{"@type":"Answer","text":"Most families start around 28-32 weeks, but earlier is fine too. The sooner you understand your options, the more confident you'll feel."}},
          {"@type":"Question","name":"What's Pro Mode?","acceptedAnswer":{"@type":"Answer","text":"Pro Mode is our paid subscription for doulas and midwives. It includes client management, visit tracking, notes, and invoicing — all built around birth-specific workflows."}}
        ]
      }
    ]
  }}
>
  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">FAQ</h1>
      <p class="text-lg text-tjb-gray">Common questions about birth plans, doula support, and the True Joy Birthing app.</p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 space-y-6">
      <div>
        <h3 class="font-semibold text-lg">What is a birth doula?</h3>
        <p class="text-tjb-gray">A trained, non-medical support person who provides emotional, physical, and informational support during birth. Doulas do not replace your doctor or midwife.</p>
      </div>
      <div>
        <h3 class="font-semibold text-lg">Does True Joy Birthing replace having a doula?</h3>
        <p class="text-tjb-gray">No. Our tools complement doula support. The free app helps you build a plan. The mini-course teaches you your options. A session with Shelbi is available if you want personalized help.</p>
      </div>
      <div>
        <h3 class="font-semibold text-lg">Is the app really free for moms?</h3>
        <p class="text-tjb-gray">Yes. Parent Mode — the birth plan builder and education — is free. Pro Mode with tools for doulas and midwives is a paid subscription.</p>
      </div>
      <div>
        <h3 class="font-semibold text-lg">What's the difference between a doula and a midwife?</h3>
        <p class="text-tjb-gray">A doula provides non-medical support. A midwife is a medical care provider who can deliver babies. You can have both.</p>
      </div>
      <div>
        <h3 class="font-semibold text-lg">When should I start my birth plan?</h3>
        <p class="text-tjb-gray">Most families start around 28-32 weeks, but earlier is fine too. The sooner you understand your options, the more confident you'll feel.</p>
      </div>
      <div>
        <h3 class="font-semibold text-lg">What's Pro Mode?</h3>
        <p class="text-tjb-gray">Pro Mode is our paid subscription for doulas and midwives. It includes client management, visit tracking, notes, and invoicing — all built around birth-specific workflows. Available on the App Store and Google Play.</p>
      </div>
    </div>
  </section>
</Layout>
