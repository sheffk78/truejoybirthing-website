---
import Layout from '../layouts/Layout.astro';
import LeadCaptureForm from '../components/LeadCaptureForm.astro';

const breadcrumbList = [
  {"name": "Home", "url": "https://truejoybirthing.com/"},
  {"name": "Guided Birth Plan Walkthrough", "url": "https://truejoybirthing.com/guided-birth-plan-walkthrough/"}
];
---

<Layout
  title="Guided Birth Plan Walkthrough | True Joy Birthing"
  description="Walk through every section of your birth plan — what each choice means, what the tradeoffs are, and what to say when a provider surprises you. $47 one-time."
  canonical="https://truejoybirthing.com/guided-birth-plan-walkthrough/"
  ogImage="https://truejoybirthing.com/images/og-birth-plan-template.webp"
  breadcrumbList={breadcrumbList}
  schema={{
    "@graph": [
      {
        "@type": "WebPage",
        "@id": "https://truejoybirthing.com/guided-birth-plan-walkthrough/#webpage",
        "url": "https://truejoybirthing.com/guided-birth-plan-walkthrough/",
        "name": "Guided Birth Plan Walkthrough",
        "description": "Walk through every section of your birth plan — what each choice means, what the tradeoffs are, and what to say when a provider surprises you. $47 one-time.",
        "isPartOf": {"@id": "https://truejoybirthing.com/#website"},
        "about": {
          "@type": "Service",
          "name": "Guided Birth Plan Walkthrough",
          "provider": {"@id": "https://truejoybirthing.com/#organization"}
        }
      },
      {
        "@type": "Course",
        "@id": "https://truejoybirthing.com/guided-birth-plan-walkthrough/#course",
        "name": "Guided Birth Plan Walkthrough",
        "description": "A self-paced video course that walks you through every section of your birth plan — what each choice means, what the tradeoffs are, and what to say when a provider surprises you.",
        "provider": {"@id": "https://truejoybirthing.com/#organization"},
        "url": "https://truejoybirthing.com/guided-birth-plan-walkthrough/",
        "offers": {
          "@type": "Offer",
          "price": "47",
          "priceCurrency": "USD",
          "availability": "https://schema.org/OnlineOnly",
          "category": "Course"
        }
      }
    ]
  }}
>

  <!-- ═══════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-4xl mx-auto px-6">
      <p class="eyebrow mb-3">The next step after your free birth plan</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
      <h1 class="text-[2.5rem] md:text-[3.25rem] font-bold leading-[1.12] mb-4">Guided Birth Plan Walkthrough</h1>
      <p class="text-lg md:text-xl text-tjb-charcoal font-semibold mb-3">Go from a blank template to a plan you actually understand — in about an hour.</p>
      <p class="text-tjb-gray leading-relaxed max-w-2xl mb-6">
        You downloaded the free Joyful Birth Plan. Now a certified birth doula walks you through every section, every tradeoff, and every conversation you'll need to have — so your plan reflects what <em>you</em> want, not what the hospital assumes.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center">
        <a href="#enroll" class="btn-primary">Enroll in the birth plan course</a>
        <span class="text-sm text-tjb-gray">$47 one-time · ~60 min of short videos · Watch at your own pace</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHAT IT IS
       ═══════════════════════════════════════════ -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">
      <h2>What it is</h2>
      <p>The Guided Birth Plan Walkthrough is a self-paced video course that picks up where the free PDF leaves off.</p>
      <p>The Joyful Birth Plan gives you the template — the checkboxes, the blanks, the structure. But a template can't tell you why one option matters more than another, what your provider is actually asking when they recommend an intervention, or how to phrase your preferences so a busy nurse reads them in 30 seconds.</p>
      <p>That's what this course does. Each lesson maps directly to a section of your birth plan. You fill it in as you go, with context from someone who has been in that room hundreds of times.</p>

      <h3>What you get</h3>
      <ul>
        <li>~45 short lessons (~60 min total) you can watch in one sitting or a few at a time</li>
        <li>Plain-language explanations of every option in your birth plan — what it means, why it matters, what the tradeoffs are</li>
        <li>Example phrases and scripts for talking to your provider</li>
        <li>Built to match the Joyful Birth Plan section by section — your plan is the workbook</li>
      </ul>

      <h3>This is for you if</h3>
      <ul>
        <li>You've downloaded the free plan and stared at it thinking "I don't know what half of these mean"</li>
        <li>You're a first-time parent trying to understand what happens in a hospital birth</li>
        <li>You've had a birth before and want to make different choices this time</li>
        <li>You want to fill out your plan with real understanding — not just check boxes</li>
      </ul>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHAT YOU'LL LEARN
       ═══════════════════════════════════════════ -->
  <section class="py-16 bg-tjb-cream">
    <div class="max-w-3xl mx-auto px-6">
      <p class="eyebrow mb-3 fade-up">What you'll learn</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-8"></div>

      <div class="space-y-8">
        <div class="border-l-2 border-tjb-lavender-500 pl-6">
          <h3 class="text-lg font-semibold mb-2">01 — About me and my preferences</h3>
          <p class="text-tjb-gray leading-relaxed">How to fill in the "About Me" section so your care team sees you as a person, not a chart number. What to include in your flexibility statement. How to note trauma history, sensory needs, or religious preferences so they get read — not skipped.</p>
        </div>

        <div class="border-l-2 border-tjb-lavender-500 pl-6">
          <h3 class="text-lg font-semibold mb-2">02 — Labor and delivery</h3>
          <p class="text-tjb-gray leading-relaxed">The section that confuses most first-time parents. We walk through monitoring, IV, movement, environment, pain management, induction, and augmentation — what each choice actually looks like in the room, what your provider typically recommends and why, and how to say "I'd like to understand the reasoning" without feeling confrontational.</p>
        </div>

        <div class="border-l-2 border-tjb-lavender-500 pl-6">
          <h3 class="text-lg font-semibold mb-2">03 — Pain management preferences</h3>
          <p class="text-tjb-gray leading-relaxed">More than "epidural or unmedicated." We cover the full pain management ladder — from breathing techniques and position changes to IV meds and epidural placement — with honest context about timing, tradeoffs, and how to keep your options open at each stage.</p>
        </div>

        <div class="border-l-2 border-tjb-lavender-500 pl-6">
          <h3 class="text-lg font-semibold mb-2">04 — Post-delivery and newborn care</h3>
          <p class="text-tjb-gray leading-relaxed">Skin-to-skin, cord clamping, golden hour, feeding, Vitamin K, Hep B, eye ointment, circumcision, rooming-in, newborn screenings. These decisions happen fast after delivery. We make sure you know what each one is, what your hospital's default is, and how to state your preference clearly in advance.</p>
        </div>

        <div class="border-l-2 border-tjb-rose-500 pl-6">
          <h3 class="text-lg font-semibold mb-2">05 — Advocacy and consent phrases</h3>
          <p class="text-tjb-gray leading-relaxed">The part most birth plans skip entirely — what to actually say when something unexpected comes up. "I need a minute to think," "What happens if we wait?," "Can you explain the reasoning?" These aren't confrontational. They're calm, clear, and effective. We practice them so they're ready when you need them.</p>
        </div>

        <div class="border-l-2 border-tjb-sage pl-6">
          <h3 class="text-lg font-semibold mb-2">06 — Plan B, Plan C, and flexibility language</h3>
          <p class="text-tjb-gray leading-relaxed">Birth is unpredictable. That doesn't mean you shouldn't plan — it means your plan needs language for change. We help you write backup preferences for common scenario shifts (induction, C-section, extended monitoring) so you still have a voice even when things don't go as expected.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHY THIS MATTERS
       ═══════════════════════════════════════════ -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">
      <h2>Why this matters</h2>
      <p>You filled out the birth plan. You checked the boxes. You handed it to your provider. And then the delivery room felt like a conversation you weren't ready for.</p>
      <p>That gap — between a completed plan and a confident parent — is exactly what this course closes.</p>

      <p><strong>Less overwhelm, more clarity.</strong> When you understand what each choice means, filling out your plan stops being homework and starts feeling like real preparation. You're not guessing. You're deciding.</p>
      <p><strong>Better conversations with your provider.</strong> The course gives you language. Not medical jargon — plain, direct phrases that get heard in a 15-minute appointment and by a nurse who has three other patients.</p>
      <p><strong>Stronger preparation for the moments that matter.</strong> Most birth plans end up in the chart unread because they're too long, too vague, or too generic. We teach you how to write one that's specific, nurse-readable, and actually reflects what matters most to you.</p>
      <p><strong>Confidence even when plans change.</strong> Your birth plan is a starting point, not a contract. This course helps you build in flexibility language so that when things shift — and they often do — you still know what to ask for, what to consent to, and how to stay involved in your own care.</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FUNNEL CONTEXT
       ═══════════════════════════════════════════ -->
  <section class="py-16 bg-tjb-cream">
    <div class="max-w-3xl mx-auto px-6">
      <p class="eyebrow mb-3 fade-up">How it fits together</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-8"></div>
      <h2 class="text-2xl font-bold mb-8">Three steps, one goal</h2>

      <div class="space-y-6">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
          <p class="text-sm font-semibold text-tjb-lavender-600 mb-1">Step 1 — Start free</p>
          <p class="text-tjb-charcoal"><a href="/birth-plan-template/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">Download the Joyful Birth Plan</a>. It's the template. Fill out what you can. You don't need the course to start — but if you want to understand what you're checking and why, keep going.</p>
        </div>
        <div class="bg-tjb-lavender-50 rounded-xl p-6 border-2 border-tjb-lavender-300">
          <p class="text-sm font-semibold text-tjb-lavender-600 mb-1">Step 2 — Learn the why behind every choice</p>
          <p class="text-tjb-charcoal font-semibold">You're here. The Guided Birth Plan Walkthrough is the next step. Each lesson maps to a section of your plan, gives you context, and helps you fill it in with real understanding — not just hope. <strong>$47 one-time.</strong> Watch at your own pace.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
          <p class="text-sm font-semibold text-tjb-sage mb-1">Step 3 — Get personal support when you need it</p>
          <p class="text-tjb-charcoal">If you have a complicated situation, a trauma history, or specific provider concerns that a course can't cover — <a href="/birth-plan-confidence-session/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">book a Birth Plan Confidence Session</a>. A certified birth doula reviews your completed plan with you live and role-plays the conversations you're most worried about. <strong>$250 per session.</strong> Limited spots.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FAQ
       ═══════════════════════════════════════════ -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-2xl font-bold mb-8">Frequently asked questions</h2>
      <div class="space-y-6">
        <div class="bg-tjb-cream rounded-xl p-6">
          <h3 class="font-semibold text-lg mb-2">How long does it take?</h3>
          <p class="text-tjb-gray leading-relaxed">About 60 minutes total — broken into short lessons you can watch in one sitting or a few at a time. Most parents finish it in an evening or two.</p>
        </div>
        <div class="bg-tjb-cream rounded-xl p-6">
          <h3 class="font-semibold text-lg mb-2">Do I need to have downloaded the free plan first?</h3>
          <p class="text-tjb-gray leading-relaxed">Yes. This course is built to match the Joyful Birth Plan section by section. <a href="/birth-plan-template/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">Download the free PDF</a> first, then start the course. You'll fill in your plan as you go.</p>
        </div>
        <div class="bg-tjb-cream rounded-xl p-6">
          <h3 class="font-semibold text-lg mb-2">Can my partner watch too?</h3>
          <p class="text-tjb-gray leading-relaxed">Absolutely. Partners who understand the plan are partners who can advocate for you in the moment. Watch together, discuss as you go, and leave with a shared understanding of what matters most.</p>
        </div>
        <div class="bg-tjb-cream rounded-xl p-6">
          <h3 class="font-semibold text-lg mb-2">Is this medical advice?</h3>
          <p class="text-tjb-gray leading-relaxed">No. This is birth planning education — context, explanations, and language for talking to your provider. Always discuss your specific medical situation with your OB, midwife, or care team.</p>
        </div>
        <div class="bg-tjb-cream rounded-xl p-6">
          <h3 class="font-semibold text-lg mb-2">Does this replace a doula?</h3>
          <p class="text-tjb-gray leading-relaxed">No. A course gives you knowledge and language. A birth doula gives you continuous in-person or virtual support during labor. They serve different roles. Many families use both.</p>
        </div>
        <div class="bg-tjb-cream rounded-xl p-6">
          <h3 class="font-semibold text-lg mb-2">What if I've already had a baby?</h3>
          <p class="text-tjb-gray leading-relaxed">Even experienced parents benefit from walking through their preferences with fresh context — especially if your last birth didn't go as planned, or if you had choices made for you that you want more say over this time. The course is designed for any birth, not just first births.</p>
        </div>
        <div class="bg-tjb-cream rounded-xl p-6">
          <h3 class="font-semibold text-lg mb-2">How do I access it?</h3>
          <p class="text-tjb-gray leading-relaxed">After enrollment, you'll get access to the course platform (Thrive Apprentice). Lessons are available immediately. Watch on any device, at your own pace, as many times as you want.</p>
        </div>
        <div class="bg-tjb-cream rounded-xl p-6">
          <h3 class="font-semibold text-lg mb-2">Can I buy the course and the session together?</h3>
          <p class="text-tjb-gray leading-relaxed">They're sold separately, but they work together. Start with the course to build your plan with understanding. Then, if you want personal feedback and role-play, <a href="/birth-plan-confidence-session/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">book a Confidence Session</a>.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CTA
       ═══════════════════════════════════════════ -->
  <section id="enroll" class="py-16 bg-tjb-lavender-100">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Ready to understand every choice on your birth plan?</h2>
      <p class="text-tjb-gray mb-8">$47 one-time. ~60 minutes. Watch at your own pace, as many times as you want.</p>
      <a href="#enroll" class="btn-primary">Enroll in the birth plan course</a>
      <p class="text-sm text-tjb-gray mt-6">Don't have the free plan yet? <a href="/birth-plan-template/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">Download free birth plan</a></p>
      <p class="text-sm text-tjb-gray mt-2">Need personal support? <a href="/birth-plan-confidence-session/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">Book a Birth Plan Confidence Session</a></p>
    </div>
  </section>

  <style>
    .fade-up {
      opacity: 0;
      transform: translateY(12px);
      transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }
    .fade-up.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
    @media (prefers-reduced-motion: reduce) {
      .fade-up {
        opacity: 1;
        transform: none;
        transition: none;
      }
    }
  </style>
  <script>
    const fadeEls = document.querySelectorAll('.fade-up');
    if (fadeEls.length && 'IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });
      fadeEls.forEach(el => observer.observe(el));
    } else {
      fadeEls.forEach(el => el.classList.add('is-visible'));
    }
  </script>

</Layout>
