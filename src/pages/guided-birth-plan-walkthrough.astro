---
import Layout from '../layouts/Layout.astro';
import LeadCaptureForm from '../components/LeadCaptureForm.astro';

const breadcrumbList = [
  {"name": "Home", "url": "https://truejoybirthing.com/"},
  {"name": "Free Birth Plan", "url": "https://truejoybirthing.com/birth-plan-template/"},
  {"name": "Guided Birth Plan Walkthrough", "url": "https://truejoybirthing.com/guided-birth-plan-walkthrough/"}
];
---

<Layout
  title="Guided Birth Plan Walkthrough | True Joy Birthing"
  description="Walk through every section of your birth plan — what each choice means, what the tradeoffs are, and what to say when a provider surprises you. $47 one-time."
  canonical="https://truejoybirthing.com/guided-birth-plan-walkthrough/"
  ogImage="https://truejoybirthing.com/images/og-birth-plan-template.webp"
  breadcrumbList={breadcrumbList}
  schema={{
    "@graph": [
      {
        "@type": "WebPage",
        "@id": "https://truejoybirthing.com/guided-birth-plan-walkthrough/#webpage",
        "url": "https://truejoybirthing.com/guided-birth-plan-walkthrough/",
        "name": "Guided Birth Plan Walkthrough",
        "description": "Walk through every section of your birth plan — what each choice means, what the tradeoffs are, and what to say when a provider surprises you. $47 one-time.",
        "isPartOf": {"@id": "https://truejoybirthing.com/#website"},
        "about": {
          "@type": "Service",
          "name": "Guided Birth Plan Walkthrough",
          "provider": {"@id": "https://truejoybirthing.com/#organization"}
        }
      },
      {
        "@type": "Course",
        "@id": "https://truejoybirthing.com/guided-birth-plan-walkthrough/#course",
        "name": "Guided Birth Plan Walkthrough",
        "description": "60-minute video course walking you through the Joyful Birth Plan section by section — so you fill it out with confidence, not confusion.",
        "provider": {
          "@type": "Person",
          "name": "Shelbi Kohler, CD(DONA)"
        },
        "url": "https://truejoybirthing.com/guided-birth-plan-walkthrough/",
        "offers": {
          "@type": "Offer",
          "price": "47",
          "priceCurrency": "USD",
          "availability": "https://schema.org/OnlineOnly",
          "category": "One-time purchase"
        },
        "hasCourseInstance": {
          "@type": "CourseInstance",
          "courseMode": "online",
          "instructor": {
            "@type": "Person",
            "name": "Shelbi Kohler"
          }
        },
        "educationalLevel": "Beginner"
      },
      {
        "@type": "Product",
        "@id": "https://truejoybirthing.com/guided-birth-plan-walkthrough/#product",
        "name": "Guided Birth Plan Walkthrough",
        "description": "60-minute video course walking you through the Joyful Birth Plan section by section — so you fill it out with confidence, not confusion.",
        "brand": {"@type": "Brand", "name": "True Joy Birthing"},
        "offers": {
          "@type": "Offer",
          "price": "47",
          "priceCurrency": "USD",
          "availability": "https://schema.org/OnlineOnly"
        }
      },
      {
        "@type": "FAQPage",
        "@id": "https://truejoybirthing.com/guided-birth-plan-walkthrough/#faq",
        "mainEntity": [
          { "@type": "Question", "name": "Do I need the free birth plan first?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. This course is built to match the Joyful Birth Plan section by section. Download the free PDF first, then start the course. You'll fill in your plan as you go." } },
          { "@type": "Question", "name": "How long is the course?", "acceptedAnswer": { "@type": "Answer", "text": "About 60 minutes total — broken into short lessons you can watch in one sitting or a few at a time. Most parents finish it in an evening or two." } },
          { "@type": "Question", "name": "Can I watch it again?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — lifetime access. Watch between appointments, revisit when your plan changes, or review before a provider meeting. It's yours to keep." } },
          { "@type": "Question", "name": "Is this medical advice?", "acceptedAnswer": { "@type": "Answer", "text": "No. This is birth planning education — context, explanations, and language for talking to your provider. Always discuss your specific medical situation with your OB, midwife, or care team." } },
          { "@type": "Question", "name": "What if I want personalized feedback on my birth plan?", "acceptedAnswer": { "@type": "Answer", "text": "The course gives you knowledge and language. If you want a certified birth doula to review your completed plan line by line and practice advocacy scenarios with you, book a Birth Plan Confidence Session — a 60–75 minute live Zoom call for $250." } },
          { "@type": "Question", "name": "Does this cover induction or C-section scenarios?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Module 6 covers flexibility language for when plans change — including induction, changed recommendations, and unexpected interventions. For deeper scenario-specific guidance, see our induction and C-section birth plan pages." } }
        ]
      }
    ]
  }}
>

  <!-- ═══════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-4xl mx-auto px-6">
      <p class="eyebrow mb-3">The next step after your free birth plan</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
      <h1 class="text-[2.5rem] md:text-[3.25rem] font-bold leading-[1.12] mb-4">A guided walkthrough for your birth plan — so you fill it out with confidence, not confusion</h1>
      <p class="text-lg md:text-xl text-tjb-charcoal font-semibold mb-3">Go from a blank template to a plan you actually understand — in about an hour.</p>
      <p class="text-tjb-gray leading-relaxed max-w-2xl mb-6">
        You downloaded the free <a href="/birth-plan-template/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">Joyful Birth Plan</a>. Now a certified birth doula walks you through every section, every tradeoff, and every conversation you'll need to have — so your plan reflects what <em>you</em> want, not what the hospital assumes.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center">
        <a href="#enroll" class="btn-primary">Enroll in the birth plan course</a>
        <span class="text-sm text-tjb-gray">$47 one-time · ~60 min of short videos · Watch at your own pace</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHAT THE WALKTHROUGH COVERS
       ═══════════════════════════════════════════ -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">
      <h2>What the Guided Birth Plan Walkthrough covers</h2>
      <p>You've got a birth plan template — now what? This course picks up where the free PDF leaves off.</p>
      <ul>
        <li><strong>60 minutes of short videos</strong> — no marathon sessions. Watch between appointments, revisit before provider meetings, or knock it out in an evening.</li>
        <li><strong>Maps section-by-section to the Joyful Birth Plan</strong> — each lesson corresponds to a section of your plan, so you fill it in as you learn.</li>
        <li><strong>Real scenarios, not generic advice</strong> — what actually happens when your provider recommends induction, what "optional" really means on a newborn procedure, and how to phrase your preferences so a busy nurse reads them.</li>
      </ul>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHAT'S INCLUDED
       ═══════════════════════════════════════════ -->
  <section class="py-16 bg-tjb-cream">
    <div class="max-w-3xl mx-auto px-6">
      <p class="eyebrow mb-3 fade-up">What's included</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-8"></div>

      <div class="space-y-6">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
          <div class="flex items-start gap-4">
            <span class="text-2xl text-tjb-lavender-500">✓</span>
            <div>
              <h3 class="font-semibold text-lg mb-1">Module-by-module walkthrough</h3>
              <p class="text-tjb-gray leading-relaxed">6 modules covering every section of your birth plan — from labor preferences through newborn care and advocacy scripts. See the full curriculum below.</p>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
          <div class="flex items-start gap-4">
            <span class="text-2xl text-tjb-lavender-500">✓</span>
            <div>
              <h3 class="font-semibold text-lg mb-1">Fillable PDF included</h3>
              <p class="text-tjb-gray leading-relaxed">Don't have the PDF yet? It's included. Or bring the one you already downloaded — the course maps to the same plan, section by section.</p>
            </div>
