---
import Layout from '../layouts/Layout.astro';

const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "Free Birth Plan Template", "url": "https://truejoybirthing.com/birth-plan-template/"}, {"name": "Free Birth Plan Walkthrough", "url": "https://truejoybirthing.com/walkthrough/"}];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://truejoybirthing.com/walkthrough/#webpage",
      "url": "https://truejoybirthing.com/walkthrough/",
      "name": "Free Birth Plan Walkthrough",
      "description": "5 free video modules walking through every section of the Joyful Birth Plan — from labor preferences to newborn care. Enter your email to watch.",
      "isPartOf": {"@id": "https://truejoybirthing.com/#website"}
    },
    {
      "@type": "ItemList",
      "@id": "https://truejoybirthing.com/walkthrough/#modules",
      "name": "Free Birth Plan Video Walkthrough Modules",
      "description": "5 video modules walking through every section of the Joyful Birth Plan.",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "About Me & Your Birth Plan", "description": "How to fill in the section that helps your care team see you as a person." },
        { "@type": "ListItem", "position": 2, "name": "Labor, Delivery & Pain Management", "description": "Monitoring, IV, movement, pain management options — what each choice actually looks like in the room." },
        { "@type": "ListItem", "position": 3, "name": "Post-Delivery Preferences", "description": "Skin-to-skin, cord clamping, golden hour, feeding — decisions that happen fast after delivery." },
        { "@type": "ListItem", "position": 4, "name": "Newborn Care Preferences", "description": "Vitamin K, Hep B, eye ointment, circumcision, rooming-in — what's standard vs. optional." },
        { "@type": "ListItem", "position": 5, "name": "Advocacy, Backup Plans & More", "description": "What to say when something unexpected comes up, and how to write flexibility into your plan." }
      ]
    }
  ]
};

const moduleData = [
  { id: "01", title: "About Me & Your Birth Plan", desc: "How to fill in the section that helps your care team see you as a person.", duration: "5 min", embedSrc: "https://iframe.mediadelivery.net/embed/602267/adc27428-031a-4c06-9115-c842bef0fb6e?autoplay=false&loop=false&muted=false&preload=true&responsive=true" },
  { id: "02", title: "Labor, Delivery & Pain Management", desc: "Monitoring, IV, movement, and the full pain management ladder — what each choice looks like in the room.", duration: "8 min", embedSrc: "https://iframe.mediadelivery.net/embed/602267/a09c5a8b-d9b6-47c6-94d1-0c6aed757591?autoplay=false&loop=false&muted=false&preload=true&responsive=true" },
  { id: "03", title: "Post-Delivery Preferences", desc: "Skin-to-skin, cord clamping, golden hour, feeding — decisions that happen fast after delivery.", duration: "6 min", embedSrc: "https://iframe.mediadelivery.net/embed/602267/31901bfb-e0ec-417d-a366-07a899ce2197?autoplay=false&loop=false&muted=false&preload=true&responsive=true" },
  { id: "04", title: "Newborn Care Preferences", desc: "Vitamin K, Hep B, eye ointment, circumcision, rooming-in — what's standard vs. optional.", duration: "5 min", embedSrc: "https://iframe.mediadelivery.net/embed/602267/669ae2e9-ed90-4811-a600-aa17f96306f8?autoplay=false&loop=false&muted=false&preload=true&responsive=true" },
  { id: "05", title: "Advocacy, Backup Plans & More", desc: "What to say when something unexpected comes up — consent phrases and flexibility language.", duration: "7 min", embedSrc: "https://iframe.mediadelivery.net/embed/602267/9f8e1976-1a53-4bac-95a7-832ad2acf326?autoplay=false&loop=false&muted=false&preload=true&responsive=true" },
];
---

<Layout
  title="Free Birth Plan Walkthrough — Full Video Course | True Joy Birthing"
  description="Watch 5 free video modules with a certified doula walking through every section of your birth plan. Labor, delivery, newborn care, and advocacy."
  canonical="https://truejoybirthing.com/walkthrough/"
  ogImage="/images/og/og-walkthrough.webp?v=2"
  breadcrumbList={breadcrumbList}
  schema={schema}
>

  <!-- ═══════════════════════════════════════════
       LEAD CAPTURE SECTION (shown when no ?videos=1 param)
       ═══════════════════════════════════════════ -->
  <section id="form-section" class="bg-tjb-cream py-20 md:py-28">
    <div class="max-w-2xl mx-auto px-6 text-center">

      <div class="flex justify-center mb-8">
        <img
          src="/images/birth-plan-banner.webp"
          alt="Joyful Birth Plan checklist with sections for labor, monitoring, and postpartum preferences"
          class="w-full max-w-xs h-auto rounded-lg shadow-md"
          loading="eager"
          width="600"
          height="500"
        />
      </div>

      <p class="eyebrow mb-4">Free birth plan walkthrough</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto mb-6"></div>
      <h1 class="mb-5 text-[2.25rem] md:text-[2.75rem] leading-[1.15] text-tjb-charcoal font-bold">
        Walk through every section with a certified doula — free
      </h1>
      <p class="text-tjb-gray mb-3 max-w-xl mx-auto leading-relaxed text-lg">
        Enter your name and email for immediate access to all 5 walkthrough videos.
      </p>
      <p class="text-tjb-gray mb-8 max-w-xl mx-auto leading-relaxed">
        A certified doula walks you through every section of the Joyful Birth Plan — labor preferences, pain management, delivery, newborn care, and advocacy language.
      </p>

      <form id="walkthrough-form" class="flex flex-col gap-3 max-w-lg mx-auto mb-4">
        <div class="flex flex-col sm:flex-row gap-3">
          <input
            id="wt-name"
            name="name"
            type="text"
            placeholder="Your first name"
            class="flex-1 px-5 py-3.5 rounded-full border border-tjb-lavender-300 focus:outline-none focus:border-tjb-rose-400 bg-white transition-colors text-[0.9375rem]"
            required
          />
          <input
            id="wt-email"
            name="email"
            type="email"
            placeholder="Your email"
            class="flex-1 px-5 py-3.5 rounded-full border border-tjb-lavender-300 focus:outline-none focus:border-tjb-rose-400 bg-white transition-colors text-[0.9375rem]"
            required
          />
        </div>
        <button type="submit" id="wt-submit" class="btn-primary whitespace-nowrap">
          Get the free video walkthrough
        </button>
      </form>
      <p id="wt-status" class="text-xs hidden text-red-600 mt-2"></p>

      <p class="text-xs text-tjb-gray-300 mt-2">No spam. Just your walkthrough access and occasional tips.</p>

      <div class="mt-8 pt-6 border-t border-tjb-lavender-200/40">
        <p class="text-sm text-tjb-gray">Already have the free PDF? <a href="/birth-plan-template/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">Go back to the template</a></p>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       VIDEO SECTION (shown when ?videos=1 param present)
       ═══════════════════════════════════════════ -->
  <section id="video-section" class="hidden bg-tjb-cream py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-6">

      <p class="eyebrow mb-4">Free birth plan walkthrough</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
      <h1 class="mb-5 text-[2.25rem] md:text-[2.75rem] leading-[1.15] text-tjb-charcoal font-bold">
        Your free walkthrough videos
      </h1>
      <p class="text-tjb-gray mb-8 text-lg leading-relaxed">
        Download the PDF from your inbox and follow along. Each module maps to a section of the Joyful Birth Plan.
      </p>
      <p class="text-tjb-gray mb-8">
        Don't have the PDF yet? <a href="/true-joy-birth-plan.pdf" download="true-joy-birth-plan.pdf" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">Download the free birth plan PDF here</a>.
      </p>

      {
        moduleData.map((mod) => (
          <div class="mb-10 bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
            <h2 class="text-xl font-semibold text-tjb-charcoal mb-1">{mod.id} — {mod.title}</h2>
            <p class="text-tjb-gray text-sm mb-4">{mod.desc} <span class="text-tjb-gray-400">(~{mod.duration})</span></p>
            <div style="position:relative;padding-top:56.25%;">
              <iframe
                src={mod.embedSrc}
                loading="lazy"
                style="border:0;position:absolute;top:0;height:100%;width:100%;"
                allow="accelerometer;gyroscope;autoplay;encrypted-media;picture-in-picture;fullscreen;"
                allowfullscreen="true"
              ></iframe>
            </div>
          </div>
        ))
      }

      <div class="text-center mt-10 pt-6 border-t border-tjb-lavender-300/40">
        <p class="text-tjb-gray mb-3">Want personalized help with your birth plan?</p>
        <a href="/birth-plan-confidence-session/#book" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 transition">Book a Birth Plan Confidence Session →</a>
      </div>

    </div>
  </section>

</Layout>

<script>
  // Check URL param on page load
  const urlParams = new URLSearchParams(window.location.search);
  const formSection = document.getElementById('form-section');
  const videoSection = document.getElementById('video-section');

  if (urlParams.get('videos') === '1') {
    // Show videos, hide form
    if (formSection) formSection.classList.add('hidden');
    if (videoSection) videoSection.classList.remove('hidden');
  }

  // Handle form submission
  const wtForm = document.getElementById('walkthrough-form') as HTMLFormElement;
  const wtStatus = document.getElementById('wt-status') as HTMLParagraphElement;
  const wtBtn = document.getElementById('wt-submit') as HTMLButtonElement;
  const wtName = document.getElementById('wt-name') as HTMLInputElement;
  const wtEmail = document.getElementById('wt-email') as HTMLInputElement;

  wtForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = wtName.value.trim();
    const email = wtEmail.value.trim();

    if (!email) return;

    wtBtn.disabled = true;
    wtBtn.textContent = 'Sending...';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: name || 'Walkthrough Lead',
          email,
          message: `Birth plan walkthrough request from: ${name || email}`,
          source: 'walkthrough-page'
        }),
      });

      const data = await res.json();
      if (res.ok && data.success) {
        // Redirect to video page with access param
        window.location.href = '/walkthrough/?videos=1';
      } else {
        wtStatus.textContent = 'Something went wrong. Please try again.';
        wtStatus.className = 'text-xs text-red-600 mt-2';
        wtStatus.classList.remove('hidden');
      }
    } catch {
      wtStatus.textContent = 'Network error. Please try again.';
      wtStatus.className = 'text-xs text-red-600 mt-2';
      wtStatus.classList.remove('hidden');
    } finally {
      wtBtn.disabled = false;
      wtBtn.textContent = 'Get the free video walkthrough';
    }
  });
</script>