---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Free Birth Plan — True Joy Birthing"
  description="Build your birth plan with confidence. Free doula-crafted birth plan, in-app course, and tools for hospital-planning moms. Download the app free."
  canonical="https://truejoybirthing.com/"
  ogImage="https://truejoybirthing.com/images/og-homepage.webp"
  schema={{
    "@graph": [
      {
        "@type": "WebPage",
        "@id": "https://truejoybirthing.com/#webpage",
        "url": "https://truejoybirthing.com/",
        "name": "Free Birth Plan — True Joy Birthing",
        "description": "Build your birth plan with confidence. Free doula-crafted birth plan, in-app course, and tools for hospital-planning moms.",
        "mainEntity": {"@id": "https://truejoybirthing.com/#organization"},
        "isPartOf": {"@id": "https://truejoybirthing.com/#website"}
      },
      {
        "@type": "SoftwareApplication",
        "@id": "https://truejoybirthing.com/#app",
        "name": "True Joy Birthing",
        "applicationCategory": "HealthApplication",
        "operatingSystem": "iOS, Android",
        "offers": [
          {
            "@type": "Offer",
            "name": "Parent Mode",
            "description": "Free guided birth plan builder, in-app course, and communication-ready outputs for expectant parents.",
            "price": "0",
            "priceCurrency": "USD",
            "category": "Free"
          },
          {
            "@type": "Offer",
            "name": "Pro Mode",
            "description": "Client management, visit tracking, and care plan tools for doulas and midwives.",
            "price": "29.99",
            "priceCurrency": "USD",
            "billingPeriod": "P1M",
            "category": "Subscription"
          }
        ]
      }
    ]
  }}
>
  
  <!-- ═══════════════════════════════════════════
       HERO — Two-column 55/45: text left, photo right
       Design spec: VISUAL-TOKENS.md hero archetype
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row">

        <!-- Left: Text — 55% -->
        <div class="md:w-[55%] px-12 py-24 flex flex-col justify-center">
          <p class="eyebrow mb-3">Free birth plan</p>
          <h1 class="font-bold text-tjb-charcoal leading-[1.15] mb-4" style="font-size: clamp(2.25rem, 5vw, 3.75rem);">
            Your birth plan gives you the words when your doctor recommends something you didn't expect
          </h1>
          <p class="text-tjb-gray text-lg leading-[1.7] mb-8 max-w-[36rem]">
            A <a href="/birth-plan-template/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">doula-crafted plan</a> for your real hospital room — download the fillable PDF free, or build your plan in the <a href="https://apps.apple.com/app/true-joy-birthing" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">free app</a>.
          </p>
          <div>
            <a href="#download" class="btn-primary">
              Download free PDF
            </a>
          </div>
        </div>

        <!-- Right: Product mockup — 45%, stacked pages preview of the birth plan -->
        <div class="md:w-[45%] flex items-center justify-center px-8 py-12 md:py-0">
          <img
            src="/images/birth-plan-preview.webp"
            alt="Preview of the free birth plan template — a structured multi-page document covering labor preferences, pain management, delivery, postpartum, and newborn care"
            class="w-full max-w-md"
            loading="eager"
            fetchpriority="high"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PROVENANCE — Compact trust anchor
       ═══════════════════════════════════════════ -->
  <div class="bg-tjb-cream border-y border-tjb-lavender-200/40">
    <div class="max-w-3xl mx-auto px-6 py-4 flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-6">
      <div class="flex items-center gap-2.5">
        <img src="/images/shelbi-thumb.webp" alt="" width="32" height="32" class="w-8 h-8 rounded-full object-cover" />
        <p class="text-sm text-tjb-gray leading-snug">
          <a href="/about/" class="text-tjb-lavender-600 hover:text-tjb-lavender-700 font-medium no-underline">Shelbi Kohler</a>, certified birth doula
        </p>
      </div>
      <span class="hidden sm:inline text-tjb-rose-400 text-sm">·</span>
      <span class="text-sm text-tjb-gray-300 tracking-wide">Designed to be read by a nurse in two minutes</span>
      <span class="hidden sm:inline text-tjb-rose-400 text-sm">·</span>
      <span class="text-sm text-tjb-gray-300 tracking-wide">App Store · Google Play</span>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       TESTIMONIALS — Pull-quote editorial layout
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-6">
      <div class="text-center mb-12">
        <p class="eyebrow mb-3 fade-up">What moms are saying</p>
        <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto"></div>
      </div>
      <div class="mb-12">
        <img
          src="/images/skin-to-skin.webp"
          alt="A mother holds her newborn skin-to-skin after birth — the kind of moment a birth plan protects"
          class="w-full max-w-lg mx-auto"
          loading="lazy"
        />
      </div>
      <div class="space-y-12">
        <div class="relative pl-8 md:pl-12 border-l-2 border-tjb-rose-400">
          <svg class="absolute -top-2 left-3 md:left-5 w-8 h-8 text-tjb-rose-300" viewBox="0 0 24 24" fill="currentColor">
            <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z"/>
          </svg>
          <blockquote class="text-xl md:text-[1.375rem] text-tjb-charcoal leading-[1.65] font-serif italic mb-4">
            "When something came up that I wasn't expecting, I had my plan with me and the words ready. It felt good to walk into that conversation prepared instead of caught off guard."
          </blockquote>
          <p class="text-sm text-tjb-gray font-semibold">— Maria T., expecting her first, Dallas</p>
        </div>
        <div class="relative pl-8 md:pl-12 border-l-2 border-tjb-rose-400">
          <svg class="absolute -top-2 left-3 md:left-5 w-8 h-8 text-tjb-rose-300" viewBox="0 0 24 24" fill="currentColor">
            <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z"/>
          </svg>
          <blockquote class="text-xl md:text-[1.375rem] text-tjb-charcoal leading-[1.65] font-serif italic mb-4">
            "I filled mine out in one sitting with my partner. By the time I got to the hospital, I wasn't anxious about what to ask for — I already knew."
          </blockquote>
          <p class="text-sm text-tjb-gray font-semibold">— Danielle R., second-time mom, Fort Worth</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       HOW IT HELPS — Editorial layout with CTAs
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream py-20 md:py-28">
    <div class="max-w-5xl mx-auto px-6">
      
      <div class="text-center mb-16">
        <p class="eyebrow mb-4 fade-up">What You Get</p>
        <!-- Editorial rule between eyebrow and heading -->
        <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto mb-6"></div>
        <h2 class="text-[2.25rem] md:text-[2.75rem] leading-[1.15] max-w-2xl mx-auto">
          Your Birth Plan Should Be a Communication Tool — Not a Wish List
        </h2>
      </div>

      <!-- Three items in a vertical column — editorial, not cards -->
      <div class="space-y-0">

        <!-- Item 1 — with product mockup -->
        <div class="py-8 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-8 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">01</span>
            <div>
              <h3 class="text-2xl mb-3">Free Structured Birth Plan</h3>
              <p class="text-tjb-gray leading-relaxed mb-4 max-w-xl">
                A <a href="/birth-plan-template/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">doula-crafted birth plan template</a> that covers every stage of birth — designed to be read by a nurse in two minutes. Download the free PDF or build your plan in the <a href="https://apps.apple.com/app/true-joy-birthing" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">free app</a>. <a href="/birth-plan-for-induction/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">Being induced? There's a scenario guide for that</a>. Planning for a specific situation? See our <a href="/c-section-birth-plan/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">C-section birth plan</a> and <a href="/vbac-birth-plan/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">VBAC birth plan</a>, or explore <a href="/birth-plan-scenarios/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">all birth plan scenarios</a>.
              </p>
              <a href="#download" class="text-tjb-rose-500 font-semibold text-sm border-b border-transparent hover:border-tjb-rose-500 transition-all inline-block pb-0.5">
                Download free PDF
              </a>
            </div>
          </div>
          <div class="mt-8 md:mt-6 md:ml-16">
            <img
              src="/images/birth-plan-booklet-1.webp"
              alt="The free birth plan template — a structured multi-page document covering labor preferences, fetal monitoring, and delivery options, designed to be read by your nurse in two minutes"
              class="w-full max-w-sm mx-auto md:mx-0"
              loading="lazy"
            />
          </div>
        </div>

        <!-- Item 2 — with editorial lesson arc -->
        <div class="py-8 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-8 items-start">
            <span class="text-3xl font-bold text-tjb-rose-500 font-serif">02</span>
            <div>
              <h3 class="text-2xl mb-1">Birth Plan Mini-Course</h3>
              <p class="text-sm text-tjb-lavender-500 font-semibold mb-3">4 lessons · Free in the app</p>
              <p class="text-tjb-gray leading-relaxed mb-4 max-w-xl">
                Learn every option, every tradeoff, and the exact phrases to use when you want to slow things down or ask questions. Use the <a href="/birth-plan-checklist/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">birth plan checklist</a> to work through each preference point before you start.
              </p>
              <div class="border-t border-tjb-lavender-300/40 mt-4 mb-4">
                <div class="py-2.5 border-b border-tjb-lavender-300/40 flex gap-3 items-baseline">
                  <span class="text-sm font-semibold text-tjb-lavender-500">1</span>
                  <span class="text-sm text-tjb-gray">Talking to your OB about induction</span>
                </div>
                <div class="py-2.5 border-b border-tjb-lavender-300/40 flex gap-3 items-baseline">
                  <span class="text-sm font-semibold text-tjb-lavender-500">2</span>
                  <span class="text-sm text-tjb-gray">Pain management options and real tradeoffs</span>
                </div>
                <div class="py-2.5 border-b border-tjb-lavender-300/40 flex gap-3 items-baseline">
                  <span class="text-sm font-semibold text-tjb-rose-500">3</span>
                  <span class="text-sm text-tjb-gray">Newborn procedures — what's standard vs. optional</span>
                </div>
                <div class="py-2.5 flex gap-3 items-baseline">
                  <span class="text-sm font-semibold text-tjb-sage">4</span>
                  <span class="text-sm text-tjb-gray">What to say when a provider surprises you</span>
                </div>
              </div>
              <a href="https://apps.apple.com/app/true-joy-birthing" class="text-tjb-rose-500 font-semibold text-sm border-b border-transparent hover:border-tjb-rose-500 transition-all inline-block pb-0.5">
                Download the app free for moms
              </a>
            </div>
          </div>
        </div>

        <!-- Item 3 — with session photo -->
        <div class="py-8 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-8 items-start">
            <span class="text-3xl font-bold text-tjb-sage font-serif">03</span>
            <div>
              <h3 class="text-2xl mb-3">1:1 Confidence Session</h3>
              <p class="text-tjb-gray leading-relaxed mb-4 max-w-xl">
                Sit down with a <a href="/what-is-a-doula/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">certified birth doula</a> via Zoom and walk through your plan line by line. Get the words. Face what you fear. <a href="/benefits-of-a-doula/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">See how a doula changes outcomes</a>.
              </p>
              <a href="https://apps.apple.com/app/true-joy-birthing" class="text-tjb-rose-500 font-semibold text-sm border-b border-transparent hover:border-tjb-rose-500 transition-all inline-block pb-0.5">
                Download the app free for moms
              </a>
            </div>
          </div>
          <div class="mt-8 md:mt-6 md:ml-16">
            <img
              src="/images/doula-holding-hands.webp"
              alt="A birth doula provides hands-on comfort and support during labor — personalized guidance you can access through the True Joy Birthing app"
              class="w-full max-w-sm mx-auto md:mx-0"
              loading="lazy"
            />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       LEAD MAGNET — Conversion zone with framing
       ═══════════════════════════════════════════ -->
  <section id="download" class="bg-white border-y border-tjb-lavender-200/60 py-20 md:py-28">
     <div class="max-w-2xl mx-auto px-6 text-center">
      <p class="eyebrow mb-4 fade-up">Free Download</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto mb-6"></div>
      <h2 class="mb-5 text-[2.25rem] md:text-[2.75rem] leading-[1.15]">Download Your Free Birth Plan</h2>
      <p class="text-tjb-gray mb-8 max-w-xl mx-auto leading-relaxed">
        A fillable PDF you can print or edit — free. For the full experience with course lessons, live updates, and doula sharing, <a href="https://apps.apple.com/app/true-joy-birthing" class="text-tjb-lavender-600 font-semibold hover:text-tjb-lavender-700 border-b border-transparent hover:border-tjb-lavender-600 transition-all">get the free app</a>.
      </p>

      <a href="/true-joy-birth-plan.pdf" download="true-joy-birth-plan.pdf" class="btn-primary inline-block mb-6">
        Download free PDF
      </a>
      <p class="text-sm text-tjb-gray mb-3">Print it, fill it out, hand it to your nurse.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6">
        <a href="https://apps.apple.com/app/true-joy-birthing" class="inline-flex items-center gap-2 text-tjb-lavender-600 font-semibold hover:text-tjb-lavender-700 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
          Get the free app — richer, updatable, shareable
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FOR PROS — Two-column: text left, photo right
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-lavender-100 py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex flex-col md:flex-row items-center gap-12 md:gap-16">

        <!-- Left: Text — 55% -->
        <div class="md:w-[55%]">
          <p class="eyebrow mb-3 fade-up">For Birth Professionals</p>
          <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
          <h2 class="mb-5 text-[2.25rem] md:text-[2.75rem] leading-[1.15]">Built for Doulas and Midwives, Too</h2>
          <p class="text-lg text-tjb-gray leading-relaxed mb-10">
            When your clients build their plan in the True Joy Birthing app, it flows directly into your Pro Mode dashboard — no copy-paste, no lost details.
          </p>
          <!-- Primary CTA — official pill style per VISUAL-TOKENS -->
          <a href="https://apps.apple.com/app/true-joy-birthing" class="inline-block bg-tjb-lavender-500 text-white px-8 py-3.5 rounded-full font-semibold text-[0.9375rem] border border-transparent hover:bg-tjb-rose-500 transition-all duration-300">
            Start Pro for doulas and midwives
          </a>
          <p class="text-sm text-tjb-gray-300 mt-4">In-app subscription. Available on App Store and Google Play.</p>
        </div>

        <!-- Right: Photo — 45% -->
        <div class="md:w-[45%] flex items-center justify-center">
          <img
            src="/images/doula-teaching.webp"
            alt="A birth doula reviews a client's birth plan together — Pro Mode gives doulas and midwives the same collaborative tools"
            class="w-full max-w-md"
            loading="lazy"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       RESOURCES — Editorial typographic strip
       ═══════════════════════════════════════════ -->
  <section class="py-16 md:py-20 bg-tjb-cream">
    <div class="max-w-3xl mx-auto px-6">
      <div class="text-center mb-12">
        <p class="eyebrow mb-3 fade-up">Plan Your Birth</p>
        <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto mb-6"></div>
        <h2 class="text-[2.25rem] md:text-[2.75rem] leading-[1.15]">Everything You Need to Feel Prepared</h2>
      </div>

      <div>
        <a href="/birth-plan-template/" class="flex items-baseline justify-between gap-4 py-5 border-t border-tjb-cream-200 group">
          <span class="text-tjb-charcoal font-semibold group-hover:text-tjb-rose-500 transition">Birth Plan Template <span class="font-normal text-tjb-gray">— Free template built by a doula. Download and fill it out.</span></span>
        </a>
        <a href="/birth-plan-checklist/" class="flex items-baseline justify-between gap-4 py-5 border-t border-tjb-cream-200 group">
          <span class="text-tjb-charcoal font-semibold group-hover:text-tjb-rose-500 transition">Birth Plan Checklist <span class="font-normal text-tjb-gray">— Every preference point, organized by category.</span></span>
        </a>
        <a href="/doula-cost/" class="flex items-baseline justify-between gap-4 py-5 border-t border-tjb-cream-200 group">
          <span class="text-tjb-charcoal font-semibold group-hover:text-tjb-rose-500 transition">Doula Cost Guide <span class="font-normal text-tjb-gray">— What doulas cost, what's included, and insurance coverage.</span></span>
        </a>
        <a href="/postpartum-doula/" class="flex items-baseline justify-between gap-4 py-5 border-t border-tjb-cream-200 group">
          <span class="text-tjb-charcoal font-semibold group-hover:text-tjb-rose-500 transition">Postpartum Doula <span class="font-normal text-tjb-gray">— What they do, what they cost, and why postpartum support matters.</span></span>
        </a>
        <a href="/how-to-choose-a-doula/" class="flex items-baseline justify-between gap-4 py-5 border-t border-tjb-cream-200 group">
          <span class="text-tjb-charcoal font-semibold group-hover:text-tjb-rose-500 transition">How to Choose a Doula <span class="font-normal text-tjb-gray">— Questions to ask and what to look for in a birth doula.</span></span>
        </a>
        <a href="/faq/" class="flex items-baseline justify-between gap-4 py-5 border-t border-tjb-cream-200 group">
          <span class="text-tjb-charcoal font-semibold group-hover:text-tjb-rose-500 transition">Birth Plan FAQ <span class="font-normal text-tjb-gray">— Common questions about birth plans, doulas, and hospital advocacy.</span></span>
        </a>
        <a href="/new-doula-start-here/" class="flex items-baseline justify-between gap-4 py-5 border-t border-tjb-cream-200 group">
          <span class="text-tjb-charcoal font-semibold group-hover:text-tjb-rose-500 transition">New Doula Start Here <span class="font-normal text-tjb-gray">— Everything a new doula needs to build their practice and serve clients.</span></span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CITY RESOURCES — Typographic strip, no cards
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream py-20 md:py-24 border-t border-tjb-lavender-200/50">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-10">
        <p class="eyebrow mb-3 fade-up">Local Support</p>
        <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto mb-6"></div>
        <h2 class="mb-3 text-[2.25rem] md:text-[2.75rem] leading-[1.15]">Birth Support Resources by City</h2>
        <p class="text-tjb-gray max-w-xl mx-auto leading-relaxed">
          Local hospital info, doula costs, and Medicaid status — city by city.
        </p>
      </div>

      <!-- Horizontal typographic strip -->
      <div class="flex flex-wrap justify-center items-center gap-x-4 gap-y-2 text-tjb-gray text-[1.0625rem]">
        <a href="/birth-support/dallas-tx" class="text-tjb-charcoal font-semibold hover:text-tjb-rose-500 transition">Dallas, TX</a>
