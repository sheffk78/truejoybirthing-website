---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="True Joy Birthing"
  description="Build your birth plan with confidence. Free doula-crafted birth plan, mini-course, and 1:1 support for hospital-planning moms. Tools for doulas and midwives too."
  canonical="https://truejoybirthing.com/"
  schema={{
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://truejoybirthing.com/#organization",
        "name": "True Joy Birthing",
        "url": "https://truejoybirthing.com/",
        "description": "Birth education and planning tools — free for moms, Pro for doulas and midwives.",
        "sameAs": ["https://instagram.com/truejoybirthing"]
      },
      {
        "@type": "WebSite",
        "@id": "https://truejoybirthing.com/#website",
        "url": "https://truejoybirthing.com/",
        "name": "True Joy Birthing"
      }
    ]
  }}
>
  <!-- ═══════════════════════════════════════════
       HERO — Lavender wash + dot grid texture
       ═══════════════════════════════════════════ -->
  <section class="relative overflow-hidden curve-bottom pb-4">
    <!-- Soft lavender gradient background -->
    <div class="absolute inset-0 bg-tjb-lavender-100" />
    <!-- Subtle dot-grid texture overlay -->
    <div class="absolute inset-0 dot-grid" />

    <div class="relative max-w-6xl mx-auto px-6 pt-20 pb-28 md:pt-28 md:pb-36">
      <div class="max-w-3xl">
        <!-- Eyebrow -->
        <p class="eyebrow mb-4">Freebirthplanning.com</p>

        <!-- Headline — warm editorial serif, tight leading -->
        <h1 class="mb-6 text-[2.4rem] md:text-[3.2rem] leading-[1.1] font-bold text-tjb-charcoal">
          Know Exactly What to Say When Your Doctor Recommends Something You Didn't Expect
        </h1>

        <!-- Body — generous measure, warm gray -->
        <p class="text-lg md:text-[1.125rem] text-tjb-gray leading-relaxed mb-10 max-w-2xl">
          A doula-crafted birth plan that actually works in a hospital room — with the education and words to back it up. Free for moms. Pro tools for birth professionals.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#download" class="btn-primary text-center">
            Download Free Birth Plan
          </a>
          <a href="https://apps.apple.com/app/true-joy-birthing" class="btn-secondary text-center">
            Get the Free App
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       TRUST SIGNAL — Warm cream band
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-6">
      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
        <!-- Portrait — organic rounded shape, soft border -->
        <div class="relative shrink-0">
          <div class="w-32 h-40 md:w-40 md:h-52 rounded-[60%_40%_50%_50%/40%_50%_50%_60%] overflow-hidden border-[3px] border-tjb-rose-200-200-200 shadow-lg shadow-tjb-lavender-200/50">
            <img 
              src="/images/shelbi-portrait.webp" 
              alt="Shelbi — certified birth doula and childbirth educator" 
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>
        </div>

        <div class="text-center md:text-left">
          <p class="eyebrow mb-2">Meet Shelbi</p>
          <p class="text-tjb-charcoal-500 leading-relaxed text-[1.05rem]">
            Certified birth doula and childbirth educator. She's supported hundreds of hospital births and built the plan she wishes every mom had walking into the L&D floor.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       HOW IT HELPS — Rose-banded section, no cards
       ═══════════════════════════════════════════ -->
  <section class="relative py-20 md:py-28">
    <!-- Soft rose wash at top -->
    <div class="absolute top-0 left-0 right-0 h-32 bg-tjb-rose-50" />

    <div class="relative max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="eyebrow mb-3">What You Get</p>
        <h2 class="max-w-2xl mx-auto">
          Your Birth Plan Should Be a Communication Tool — Not a Wish List
        </h2>
      </div>

      <!-- Three-column with soft cream panels, NOT cards -->
      <div class="grid md:grid-cols-3 gap-6 md:gap-8">
        <!-- Panel 1 -->
        <div class="bg-tjb-cream-50 rounded-2xl p-8 md:p-10 border border-tjb-lavender-200/60">
          <div class="w-12 h-12 rounded-full bg-tjb-lavender-200/60 flex items-center justify-center mb-6 text-tjb-lavender-500">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/></svg>
          </div>
          <h3 class="mb-3">Free Structured Birth Plan</h3>
          <p class="text-tjb-gray leading-relaxed">
            A doula-crafted, hospital-ready plan that covers every stage of birth — designed to be read by a nurse in two minutes.
          </p>
        </div>

        <!-- Panel 2 -->
        <div class="bg-tjb-cream-50 rounded-2xl p-8 md:p-10 border border-tjb-lavender-200/60">
          <div class="w-12 h-12 rounded-full bg-tjb-rose-100/70 flex items-center justify-center mb-6 text-tjb-rose-500">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.826m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0-3a.75.75 0 100-1.5.75.75 0 000 1.5zm0-3a.75.75 0 100-1.5.75.75 0 000 1.5z"/></svg>
          </div>
          <h3 class="mb-3">Birth Plan Mini-Course</h3>
          <p class="text-tjb-gray leading-relaxed">
            Learn every option, every tradeoff, and the exact phrases to use when you want to slow things down or ask questions.
          </p>
        </div>

        <!-- Panel 3 -->
        <div class="bg-tjb-cream-50 rounded-2xl p-8 md:p-10 border border-tjb-lavender-200/60">
          <div class="w-12 h-12 rounded-full bg-tjb-sage-100/80 flex items-center justify-center mb-6 text-tjb-sage">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.76c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.076-4.076a1.526 1.526 0 011.037-.443 48.282 48.282 0 005.68-.494c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/></svg>
          </div>
          <h3 class="mb-3">1:1 Confidence Session</h3>
          <p class="text-tjb-gray leading-relaxed">
            Sit down with Shelbi via Zoom and walk through your plan line by line. Get the words. Face what you fear.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FOR PROS — Lavender wash background
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-lavender-100/70 py-20 md:py-28">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <p class="eyebrow mb-3">For Birth Professionals</p>
      <h2 class="mb-5">Built for Doulas and Midwives, Too</h2>
      <p class="text-lg text-tjb-gray leading-relaxed max-w-2xl mx-auto mb-10">
        When your clients build their plan in the True Joy Birthing app, it flows directly into your Pro Mode dashboard — no copy-paste, no lost details.
      </p>
      <a href="https://apps.apple.com/app/true-joy-birthing" class="btn-accent">
        Start Pro for Doulas and Midwives
      </a>
      <p class="text-sm text-tjb-gray-300 mt-4">In-app subscription. Available on App Store and Google Play.</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       LEAD MAGNET — White, clean, centered
       ═══════════════════════════════════════════ -->
  <section id="download" class="bg-tjb-cream-50 py-20 md:py-28">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <p class="eyebrow mb-3">Free Download</p>
      <h2 class="mb-5">Download Your Free Birth Plan</h2>
      <p class="text-tjb-gray mb-10 max-w-xl mx-auto leading-relaxed">
        Join thousands of moms who've walked into their births with a clear plan and the words to stand by it.
      </p>

      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto mb-4" action="#" method="POST">
        <input 
          name="email" 
          type="email" 
          placeholder="Your email" 
          class="flex-1 px-5 py-3.5 rounded-full border border-tjb-lavender-300 focus:outline-none focus:border-tjb-rose-200-200-400 bg-tjb-cream-50 transition-colors text-[0.9375rem]"
          required
        />
        <button type="submit" class="btn-primary whitespace-nowrap">
          Get My Plan →
        </button>
      </form>
      <p class="text-xs text-tjb-gray-300">No spam. Just a free birth plan and occasional tips you can actually use.</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CITY RESOURCES — Warm cream with subtle rose accent
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream py-20 md:py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <p class="eyebrow mb-3">Local Support</p>
        <h2 class="mb-3">Birth Support Resources by City</h2>
        <p class="text-tjb-gray max-w-xl mx-auto leading-relaxed">
          Local hospital info, doula costs, and Medicaid status — city by city.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
        <a href="/birth-support/dallas-tx" class="group block bg-tjb-cream-50 rounded-2xl py-6 px-4 text-center border border-transparent hover:border-tjb-rose-200-200-200 hover:shadow-lg hover:shadow-tjb-rose-100/30 transition-all duration-300">
          <p class="font-semibold text-tjb-charcoal">Dallas, TX</p>
        </a>
        <a href="/birth-support/houston-tx" class="group block bg-tjb-cream-50 rounded-2xl py-6 px-4 text-center border border-transparent hover:border-tjb-rose-200-200-200 hover:shadow-lg hover:shadow-tjb-rose-100/30 transition-all duration-300">
          <p class="font-semibold text-tjb-charcoal">Houston, TX</p>
        </a>
        <a href="/birth-support/austin-tx" class="group block bg-tjb-cream-50 rounded-2xl py-6 px-4 text-center border border-transparent hover:border-tjb-rose-200-200-200 hover:shadow-lg hover:shadow-tjb-rose-100/30 transition-all duration-300">
          <p class="font-semibold text-tjb-charcoal">Austin, TX</p>
        </a>
        <a href="/birth-support/san-antonio-tx" class="group block bg-tjb-cream-50 rounded-2xl py-6 px-4 text-center border border-transparent hover:border-tjb-rose-200-200-200 hover:shadow-lg hover:shadow-tjb-rose-100/30 transition-all duration-300">
          <p class="font-semibold text-tjb-charcoal">San Antonio, TX</p>
        </a>
        <a href="/birth-support/fort-worth-tx" class="group block bg-tjb-cream-50 rounded-2xl py-6 px-4 text-center border border-transparent hover:border-tjb-rose-200-200-200 hover:shadow-lg hover:shadow-tjb-rose-100/30 transition-all duration-300">
          <p class="font-semibold text-tjb-charcoal">Fort Worth, TX</p>
        </a>
      </div>

      <p class="text-center mt-8">
        <a href="/birth-support" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-200-200-500 transition-all inline-block pb-0.5">
          See all cities →
        </a>
      </p>
    </div>
  </section>

</Layout>
