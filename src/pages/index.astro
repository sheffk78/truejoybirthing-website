---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="True Joy Birthing"
  description="Build your birth plan with confidence. Free doula-crafted birth plan, mini-course, and 1:1 support for hospital-planning moms. Tools for doulas and midwives too."
  canonical="https://truejoybirthing.com/"
  schema={{
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://truejoybirthing.com/#organization",
        "name": "True Joy Birthing",
        "url": "https://truejoybirthing.com/",
        "description": "Birth education and planning tools — free for moms, Pro for doulas and midwives.",
        "sameAs": ["https://instagram.com/truejoybirthing"]
      },
      {
        "@type": "WebSite",
        "@id": "https://truejoybirthing.com/#website",
        "url": "https://truejoybirthing.com/",
        "name": "True Joy Birthing"
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What is a birth doula?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "A birth doula is a trained, non-medical support person who provides emotional, physical, and informational support to birthing families before, during, and after labor. Doulas do not deliver babies or replace medical care."
            }
          },
          {
            "@type": "Question",
            "name": "Does True Joy Birthing provide local doula services?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Shelbi provides in-person doula support in the Dallas-Fort Worth metro area and virtual birth plan confidence sessions nationwide. True Joy Birthing also provides free birth planning tools for moms everywhere and Pro Mode tools for doulas and midwives."
            }
          }
        ]
      }
    ]
  }}
>
  <!-- Hero Section -->
  <section class="bg-tjb-warm py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-3xl md:text-5xl font-bold text-tjb-charcoal mb-6 leading-tight">
        Know Exactly What to Say When Your Doctor Recommends Something You Didn't Expect
      </h1>
      <p class="text-lg md:text-xl text-tjb-soft mb-8 max-w-2xl mx-auto">
        A doula-crafted birth plan that actually works in a hospital room — with the education and words to back it up. Free for moms. Pro tools for birth professionals.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="#download-pdf" class="bg-tjb-forest text-tjb-cream px-8 py-3 rounded-lg font-semibold text-lg hover:bg-tjb-sage transition">
          Download Free Birth Plan
        </a>
        <a href="https://apps.apple.com/app/true-joy-birthing" class="bg-white text-tjb-forest border-2 border-tjb-forest px-8 py-3 rounded-lg font-semibold text-lg hover:bg-tjb-warm transition">
          Get the Free App
        </a>
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <div class="flex flex-col md:flex-row gap-8 items-center text-center md:text-left">
        <img 
          src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=200&h=200&fit=crop&crop=face" 
          alt="Shelbi — certified birth doula" 
          class="w-24 h-24 rounded-full object-cover mx-auto md:mx-0"
          loading="lazy"
        />
        <div>
          <p class="text-sm font-semibold text-tjb-forest uppercase tracking-wider mb-1">Meet Shelbi</p>
          <p class="text-tjb-charcoal">Certified birth doula and childbirth educator. She's supported hundreds of hospital births and built the plan she wishes every mom had walking into the L&D floor.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Helps -->
  <section class="py-16 bg-tjb-cream">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-12">Your Birth Plan Should Be a Communication Tool — Not a Wish List</h2>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white p-6 rounded-xl">
          <div class="text-3xl mb-3">📝</div>
          <h3 class="font-semibold text-lg mb-2">Free Structured Birth Plan</h3>
          <p class="text-sm text-tjb-soft">A doula-crafted, hospital-ready plan that covers every stage of birth — designed to be read by a nurse in two minutes.</p>
        </div>
        <div class="bg-white p-6 rounded-xl">
          <div class="text-3xl mb-3">🎓</div>
          <h3 class="font-semibold text-lg mb-2">Birth Plan Mini-Course</h3>
          <p class="text-sm text-tjb-soft">Learn every option, every tradeoff, and the exact phrases to use when you want to slow things down or ask questions.</p>
        </div>
        <div class="bg-white p-6 rounded-xl">
          <div class="text-3xl mb-3">💬</div>
          <h3 class="font-semibold text-lg mb-2">1:1 Confidence Session</h3>
          <p class="text-sm text-tjb-soft">Sit down with Shelbi via Zoom and walk through your plan line by line. Get the words. Face what you fear.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- For Doulas & Midwives -->
  <section class="py-16 bg-tjb-forest text-tjb-cream">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Built for Birth Professionals, Too</h2>
      <p class="text-lg text-tjb-cream/80 mb-8 max-w-2xl mx-auto">
        When your clients build their plan in the True Joy Birthing app, it flows directly into your Pro Mode dashboard — no copy-paste, no lost details.
      </p>
      <a href="https://apps.apple.com/app/true-joy-birthing" class="inline-block bg-tjb-cream text-tjb-forest px-8 py-3 rounded-lg font-semibold text-lg hover:bg-white transition">
        Start Pro for Doulas and Midwives
      </a>
      <p class="text-sm text-tjb-cream/60 mt-3">In-app subscription. Available on App Store and Google Play.</p>
    </div>
  </section>

  <!-- Lead Magnet Section -->
  <section id="download-pdf" class="py-16 bg-white">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Download Your Free Birth Plan</h2>
      <p class="text-tjb-soft mb-8">Join thousands of moms who've walked into their births with a clear plan and the words to stand by it.</p>
      
      <!-- ConvertKit embed — replace with your actual form code -->
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" action="#" method="POST">
        <input 
          name="email" 
          type="email" 
          placeholder="Your email" 
          class="flex-1 px-4 py-3 rounded-lg border border-tjb-rose/50 focus:outline-none focus:border-tjb-forest"
          required
        />
        <button 
          type="submit" 
          class="bg-tjb-forest text-tjb-cream px-6 py-3 rounded-lg font-semibold hover:bg-tjb-sage transition whitespace-nowrap"
        >
          Get My Plan →
        </button>
      </form>
      <p class="text-xs text-tjb-soft/70 mt-4">No spam. Just a free birth plan and occasional tips you can actually use.</p>
    </div>
  </section>

  <!-- City Support Section -->
  <section class="py-16 bg-tjb-warm">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-8">Birth Support Resources by City</h2>
      <p class="text-center text-tjb-soft mb-10">Local hospital info, doula costs, and Medicaid status — city by city.</p>
      
      <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
        <a href="/birth-support/dallas-tx" class="bg-white p-4 rounded-lg text-center hover:shadow-md transition">Dallas, TX</a>
        <a href="/birth-support/houston-tx" class="bg-white p-4 rounded-lg text-center hover:shadow-md transition">Houston, TX</a>
        <a href="/birth-support/austin-tx" class="bg-white p-4 rounded-lg text-center hover:shadow-md transition">Austin, TX</a>
        <a href="/birth-support/san-antonio-tx" class="bg-white p-4 rounded-lg text-center hover:shadow-md transition">San Antonio, TX</a>
        <a href="/birth-support/fort-worth-tx" class="bg-white p-4 rounded-lg text-center hover:shadow-md transition">Fort Worth, TX</a>
      </div>
      <p class="text-center mt-6">
        <a href="/birth-support" class="text-tjb-forest font-semibold hover:underline">See all cities →</a>
      </p>
    </div>
  </section>

</Layout>
