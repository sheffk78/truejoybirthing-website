---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="True Joy Birthing"
  description="Build your birth plan with confidence. Free doula-crafted birth plan, mini-course, and 1:1 support for hospital-planning moms. Tools for doulas and midwives too."
  canonical="https://truejoybirthing.com/"
  schema={{
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://truejoybirthing.com/#organization",
        "name": "True Joy Birthing",
        "url": "https://truejoybirthing.com/",
        "description": "Birth education and planning tools — free for moms, Pro for doulas and midwives.",
        "sameAs": ["https://instagram.com/truejoybirthing"]
      },
      {
        "@type": "WebSite",
        "@id": "https://truejoybirthing.com/#website",
        "url": "https://truejoybirthing.com/",
        "name": "True Joy Birthing"
      }
    ]
  }}
>
  
  <!-- ═══════════════════════════════════════════
       HERO — Two-column: text left, Shelbi right
       ═══════════════════════════════════════════ -->
  <section class="relative overflow-hidden curve-bottom pb-4">
    <!-- Lavender gradient background -->
    <div class="absolute inset-0 bg-tjb-lavender-100" />
    <!-- Subtle dot-grid texture overlay -->
    <div class="absolute inset-0 dot-grid" />

    <div class="relative max-w-6xl mx-auto px-6 pt-16 pb-20 md:pt-24 md:pb-28">
      <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        
        <!-- Left: Headline + CTAs -->
        <div>
          <p class="eyebrow mb-4">Birth Planning That Actually Helps</p>

          <h1 class="mb-6 text-[2.2rem] md:text-[3rem] leading-[1.12] font-bold text-tjb-charcoal">
            Know Exactly What to Say When Your Doctor Recommends Something You Didn't Expect
          </h1>

          <p class="text-lg md:text-[1.125rem] text-tjb-gray leading-relaxed mb-8 max-w-xl">
            A doula-crafted birth plan that actually works in a hospital room — with the education and words to back it up. Free for moms. Pro tools for birth professionals.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#download" class="btn-primary text-center">
              Download Free Birth Plan
            </a>
            <a href="https://apps.apple.com/app/true-joy-birthing" class="btn-secondary text-center">
              Get the Free App
            </a>
          </div>
        </div>

        <!-- Right: Shelbi portrait -->
        <div class="relative flex justify-center md:justify-end">
          <div class="w-44 h-56 md:w-52 md:h-64 rounded-[60%_40%_50%_50%/40%_50%_50%_60%] overflow-hidden border-[3px] border-tjb-rose-200 shadow-xl shadow-tjb-lavender-300/40 shrink-0">
            <img 
              src="/images/shelbi-real-hero.webp" 
              alt="Shelbi Kohler — certified birth doula and founder of True Joy Birthing" 
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>
          <!-- Floating label -->
          <div class="absolute -bottom-4 left-1/2 md:left-8 -translate-x-1/2 md:translate-x-0 bg-white px-4 py-2 rounded-full shadow-md text-xs font-semibold text-tjb-charcoal whitespace-nowrap">
            Shelbi Kohler · Certified Doula
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       TESTIMONIALS — Pull-quote, not centered plain text
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream py-10 md:py-14">
    <div class="max-w-3xl mx-auto px-6">
      <div class="relative pl-8 md:pl-12 border-l-2 border-tjb-rose-400">
        <svg class="absolute -top-2 left-3 md:left-5 w-8 h-8 text-tjb-rose-300" viewBox="0 0 24 24" fill="currentColor">
          <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z"/>
        </svg>
        <blockquote class="text-xl md:text-[1.375rem] text-tjb-charcoal leading-[1.65] font-serif italic mb-6">
          "I walked into that room knowing exactly what to say. My nurses actually read the plan. It changed everything."
        </blockquote>
        <p class="text-sm text-tjb-gray font-semibold">— Sarah M., first-time mom, Dallas, TX</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       HOW IT HELPS — Editorial layout with CTAs
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream py-20 md:py-28">
    <div class="max-w-5xl mx-auto px-6">
      
      <div class="text-center mb-16">
        <p class="eyebrow mb-4">What You Get</p>
        <!-- Editorial rule between eyebrow and heading -->
        <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto mb-6"></div>
        <h2 class="text-[2.25rem] md:text-[2.75rem] leading-[1.15] max-w-2xl mx-auto">
          Your Birth Plan Should Be a Communication Tool — Not a Wish List
        </h2>
      </div>

      <!-- Three items in a vertical column — editorial, not cards -->
      <div class="space-y-0">

        <!-- Item 1 -->
        <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-8 items-start py-8 border-t border-tjb-lavender-300/40">
          <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">01</span>
          <div>
            <h3 class="text-2xl mb-3">Free Structured Birth Plan</h3>
            <p class="text-tjb-gray leading-relaxed mb-4 max-w-xl">
              A doula-crafted, hospital-ready plan that covers every stage of birth — designed to be read by a nurse in two minutes.
            </p>
            <a href="/birth-plan-course" class="text-tjb-rose-500 font-semibold text-sm border-b border-transparent hover:border-tjb-rose-500 transition-all inline-block pb-0.5">
              Get the free plan →
            </a>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-8 items-start py-8 border-t border-tjb-lavender-300/40">
          <span class="text-3xl font-bold text-tjb-rose-500 font-serif">02</span>
          <div>
            <h3 class="text-2xl mb-3">Birth Plan Mini-Course</h3>
            <p class="text-tjb-gray leading-relaxed mb-4 max-w-xl">
              Learn every option, every tradeoff, and the exact phrases to use when you want to slow things down or ask questions.
            </p>
            <a href="/birth-plan-course" class="text-tjb-rose-500 font-semibold text-sm border-b border-transparent hover:border-tjb-rose-500 transition-all inline-block pb-0.5">
              Explore the course →
            </a>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-8 items-start py-8 border-t border-tjb-lavender-300/40">
          <span class="text-3xl font-bold text-tjb-sage font-serif">03</span>
          <div>
            <h3 class="text-2xl mb-3">1:1 Confidence Session</h3>
            <p class="text-tjb-gray leading-relaxed mb-4 max-w-xl">
              Sit down with Shelbi via Zoom and walk through your plan line by line. Get the words. Face what you fear.
            </p>
            <a href="/birth-plan-session" class="text-tjb-rose-500 font-semibold text-sm border-b border-transparent hover:border-tjb-rose-500 transition-all inline-block pb-0.5">
              Book a session →
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FOR PROS — Lavender wash, white CTA
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-lavender-100 py-20 md:py-28">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <p class="eyebrow mb-3">For Birth Professionals</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto mb-6"></div>
      <h2 class="mb-5 text-[2.25rem] md:text-[2.75rem] leading-[1.15]">Built for Doulas and Midwives, Too</h2>
      <p class="text-lg text-tjb-gray leading-relaxed max-w-2xl mx-auto mb-10">
        When your clients build their plan in the True Joy Birthing app, it flows directly into your Pro Mode dashboard — no copy-paste, no lost details.
      </p>
      <!-- White button on lavender — actually visible -->
      <a href="https://apps.apple.com/app/true-joy-birthing" class="inline-block bg-white text-tjb-charcoal px-8 py-3.5 rounded-full font-semibold text-[0.9375rem] border border-tjb-lavender-300 hover:bg-tjb-cream transition-all duration-300 shadow-sm">
        Start Pro for Doulas and Midwives
      </a>
      <p class="text-sm text-tjb-gray-300 mt-4">In-app subscription. Available on App Store and Google Play.</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       RESOURCES — Quick links to key planning pages
       ═══════════════════════════════════════════ -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-10">
        <p class="eyebrow mb-3">Plan Your Birth</p>
        <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto mb-6"></div>
        <h2 class="text-[2.25rem] md:text-[2.75rem] leading-[1.15]">Everything You Need to Feel Prepared</h2>
      </div>
      <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-6">
        <a href="/birth-plan-template/" class="border border-tjb-lavender-300 rounded-lg p-5 hover:border-tjb-lavender-500 hover:shadow-md transition text-center group">
          <h3 class="font-semibold text-tjb-charcoal mb-1 group-hover:text-tjb-rose-500 transition">Birth Plan Template</h3>
          <p class="text-sm text-tjb-gray">Free template built by a doula. Download and fill it out.</p>
        </a>
        <a href="/birth-plan-checklist/" class="border border-tjb-lavender-300 rounded-lg p-5 hover:border-tjb-lavender-500 hover:shadow-md transition text-center group">
          <h3 class="font-semibold text-tjb-charcoal mb-1 group-hover:text-tjb-rose-500 transition">Birth Plan Checklist</h3>
          <p class="text-sm text-tjb-gray">Every preference point, organized by category.</p>
        </a>
        <a href="/doula-cost/" class="border border-tjb-lavender-300 rounded-lg p-5 hover:border-tjb-lavender-500 hover:shadow-md transition text-center group">
          <h3 class="font-semibold text-tjb-charcoal mb-1 group-hover:text-tjb-rose-500 transition">Doula Cost Guide</h3>
          <p class="text-sm text-tjb-gray">What doulas cost, what's included, and insurance coverage.</p>
        </a>
        <a href="/postpartum-doula/" class="border border-tjb-lavender-300 rounded-lg p-5 hover:border-tjb-lavender-500 hover:shadow-md transition text-center group">
          <h3 class="font-semibold text-tjb-charcoal mb-1 group-hover:text-tjb-rose-500 transition">Postpartum Doula</h3>
          <p class="text-sm text-tjb-gray">What they do, what they cost, and why postpartum support matters.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       LEAD MAGNET — Clean, warm, prominent
       ═══════════════════════════════════════════ -->
  <section id="download" class="py-20 md:py-28">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <p class="eyebrow mb-4">Free Download</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto mb-6"></div>
      <h2 class="mb-5 text-[2.25rem] md:text-[2.75rem] leading-[1.15]">Download Your Free Birth Plan</h2>
      <p class="text-tjb-gray mb-10 max-w-xl mx-auto leading-relaxed">
        Join thousands of moms who've walked into their births with a clear plan and the words to stand by it.
      </p>

      <form id="lead-magnet-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto mb-4">
        <input 
          id="lead-email"
          name="email" 
          type="email" 
          placeholder="Your email" 
          class="flex-1 px-5 py-3.5 rounded-full border border-tjb-lavender-300 focus:outline-none focus:border-tjb-rose-400 bg-white transition-colors text-[0.9375rem]"
          required
        />
        <button type="submit" id="lead-submit" class="btn-primary whitespace-nowrap">
          Get My Plan →
        </button>
      </form>
      <p id="lead-status" class="text-xs hidden text-tjb-gray-300"></p>
      <p class="text-xs text-tjb-gray-300">No spam. Just a free birth plan and occasional tips you can actually use.</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CITY RESOURCES — Typographic strip, no cards
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream py-20 md:py-24 border-t border-tjb-lavender-200/50">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-10">
        <p class="eyebrow mb-3">Local Support</p>
        <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto mb-6"></div>
        <h2 class="mb-3 text-[2.25rem] md:text-[2.75rem] leading-[1.15]">Birth Support Resources by City</h2>
        <p class="text-tjb-gray max-w-xl mx-auto leading-relaxed">
          Local hospital info, doula costs, and Medicaid status — city by city.
        </p>
      </div>

      <!-- Horizontal typographic strip -->
      <div class="flex flex-wrap justify-center items-center gap-x-4 gap-y-2 text-tjb-gray text-[1.0625rem]">
        <a href="/birth-support/dallas-tx" class="text-tjb-charcoal font-semibold hover:text-tjb-rose-500 transition">Dallas, TX</a>
        <span class="text-tjb-rose-400">·</span>
        <a href="/birth-support/houston-tx" class="text-tjb-charcoal font-semibold hover:text-tjb-rose-500 transition">Houston, TX</a>
        <span class="text-tjb-rose-400">·</span>
        <a href="/birth-support/austin-tx" class="text-tjb-charcoal font-semibold hover:text-tjb-rose-500 transition">Austin, TX</a>
        <span class="text-tjb-rose-400">·</span>
        <a href="/birth-support/san-antonio-tx" class="text-tjb-charcoal font-semibold hover:text-tjb-rose-500 transition">San Antonio, TX</a>
        <span class="text-tjb-rose-400">·</span>
        <a href="/birth-support/fort-worth-tx" class="text-tjb-charcoal font-semibold hover:text-tjb-rose-500 transition">Fort Worth, TX</a>
        <span class="text-tjb-rose-400">·</span>
        <a href="/birth-support/el-paso-tx" class="text-tjb-charcoal font-semibold hover:text-tjb-rose-500 transition">El Paso, TX</a>
      </div>

      <p class="text-center mt-8">
        <a href="/birth-support" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all inline-block pb-0.5">
          See all cities →
        </a>
      </p>
    </div>
  </section>

  <script>
    const leadForm = document.getElementById('lead-magnet-form') as HTMLFormElement;
    const leadStatus = document.getElementById('lead-status') as HTMLParagraphElement;
    const leadBtn = document.getElementById('lead-submit') as HTMLButtonElement;
    const leadEmail = document.getElementById('lead-email') as HTMLInputElement;

    leadForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = leadEmail.value;

      if (!email) return;

      leadBtn.disabled = true;
      leadBtn.textContent = 'Sending...';

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: 'Lead Magnet', email, message: `Birth plan download request from: ${email}` }),
        });

        const data = await res.json();
        if (res.ok && data.success) {
          leadStatus.textContent = '✓ Check your inbox!';
          leadStatus.className = 'text-xs text-green-700 mt-2';
          leadForm.reset();
        } else {
          leadStatus.textContent = 'Something went wrong. Please try again.';
          leadStatus.className = 'text-xs text-red-600 mt-2';
        }
      } catch {
        leadStatus.textContent = 'Network error. Please try again.';
        leadStatus.className = 'text-xs text-red-600 mt-2';
      } finally {
        leadBtn.disabled = false;
        leadBtn.textContent = 'Get My Plan →';
        leadStatus.classList.remove('hidden');
      }
    });
  </script>

</Layout>
