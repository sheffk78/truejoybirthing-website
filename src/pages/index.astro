---
import Layout from '../layouts/Layout.astro';
import LeadCaptureForm from '../components/LeadCaptureForm.astro';
import AppShowcase from '../components/AppShowcase.astro';
---

<Layout
  title="Joyful Birth Plan — True Joy Birthing"
  description="Build your birth plan with confidence. Free doula-crafted birth plan, guided walkthrough course, and 1:1 coaching sessions for hospital-planning moms."
  canonical="https://truejoybirthing.com/"
  ogImage="https://truejoybirthing.com/images/og/og-homepage.png"
  schema={{
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebPage",
        "@id": "https://truejoybirthing.com/#webpage",
        "url": "https://truejoybirthing.com/",
        "name": "Joyful Birth Plan — True Joy Birthing",
        "description": "Build your birth plan with confidence. Free doula-crafted birth plan, guided walkthrough course, and 1:1 coaching sessions.",
        "mainEntity": {"@id": "https://truejoybirthing.com/#organization"},
        "isPartOf": {"@id": "https://truejoybirthing.com/#website"},
        "about": {"@id": "https://truejoybirthing.com/#organization"},
        "dateModified": "2026-06-09"
      },
      {
        "@type": "Organization",
        "@id": "https://truejoybirthing.com/#organization",
        "name": "True Joy Birthing",
        "url": "https://truejoybirthing.com/",
        "description": "Free doula-crafted birth plan templates, guided walkthrough course, and 1:1 coaching sessions for expecting families.",
        "foundingDate": "2024",
        "contactPoint": {
          "@type": "ContactPoint",
          "email": "support@truejoybirthing.com",
          "contactType": "customer service",
          "availableLanguage": ["English"]
        },
        "knowsAbout": ["Birth planning", "Birth doula support", "Birth plan template", "Pregnancy preparation", "Labor and delivery preferences"]
      },
      {
        "@type": "WebSite",
        "@id": "https://truejoybirthing.com/#website",
        "url": "https://truejoybirthing.com/",
        "name": "True Joy Birthing",
        "publisher": {"@id": "https://truejoybirthing.com/#organization"}
      },
      {
        "@type": "SoftwareApplication",
        "@id": "https://truejoybirthing.com/#app",
        "name": "True Joy Birthing",
        "applicationCategory": "HealthApplication",
        "operatingSystem": "iOS",
        "offers": [
          {
            "@type": "Offer",
            "name": "Parent Mode",
            "price": "0",
            "priceCurrency": "USD",
            "availability": "https://schema.org/InStock"
          },
          {
            "@type": "Offer",
            "name": "Pro Mode",
            "price": "0",
            "priceCurrency": "USD",
            "availability": "https://schema.org/InStock"
          }
        ]
      }
    ]
  }}
>
  
  <!-- ═══════════════════════════════════════════
       HERO — Two-column 55/45: text left, photo right
       Design spec: VISUAL-TOKENS.md hero archetype
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row">

        <!-- Left: Text — 55% -->
        <div class="md:w-[55%] px-6 md:px-12 py-20 md:py-24 flex flex-col justify-center">
          <p class="eyebrow mb-3">Free Joyful Birth Plan</p>
          <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
          <h1 class="font-bold text-tjb-charcoal leading-[1.15] mb-4" style="font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(2.25rem, 5vw, 3.75rem);">
            Your birth plan gives you the words when your doctor recommends something you didn't expect
          </h1>
          <p class="text-lg text-tjb-charcoal font-semibold mb-2">True Joy Birthing is a free birth plan tool and app for first-time moms building confidence for the delivery room.</p>
          <p class="text-tjb-gray text-lg leading-[1.7] mb-8 max-w-[36rem]">
            A <strong>birth plan</strong> is a document that spells out your preferences for labor, delivery, and postpartum care — so your medical team knows what matters to you. The <a href="/birth-plan-template/" class="text-tjb-rose-600 font-semibold hover:text-tjb-rose-500 border-b border-transparent hover:border-tjb-rose-500 transition-all">Joyful Birth Plan</a> covers every stage of birth and works in your real hospital room. Not sure <a href="/what-is-a-doula/" class="text-tjb-rose-600 font-semibold hover:text-tjb-rose-500 border-b border-transparent hover:border-tjb-rose-500 transition-all">what a doula does</a> or <a href="/benefits-of-a-doula/" class="text-tjb-rose-600 font-semibold hover:text-tjb-rose-500 border-b border-transparent hover:border-tjb-rose-500 transition-all">how doula support changes outcomes</a>? Download the fillable PDF free, or build your plan in the <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="text-tjb-rose-600 font-semibold hover:text-tjb-rose-500 border-b border-transparent hover:border-tjb-rose-500 transition-all">free app</a>.
          </p>
          <div class="flex flex-wrap items-center gap-4">
            <a href="#download" class="btn-primary">
              Get Your Free Joyful Birth Plan
            </a>
            <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="btn-secondary">
              Or try the free app →
            </a>
          </div>
          <p class="text-sm text-tjb-gray mt-4">
            Free template · Prefer the app? Build the same joyful birth plan step by step on your phone.
          </p>
        </div>

        <!-- Right: Product mockup — PDF page 1, portrait for max vertical space -->
        <div class="md:w-[45%] flex items-center justify-center px-6 py-8 md:py-0">
          <div class="w-full max-w-[400px]">
            <img
              src="/images/pdf-page-1-hero.webp"
              alt="The free Joyful Birth Plan — full page showing About Me, Labor & Delivery, and newborn care preferences"
              class="w-full h-auto rounded-lg shadow-xl"
              loading="eager"
              fetchpriority="high"
              width="612"
              height="792"
            />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PROVENANCE — Compact trust anchor
       ═══════════════════════════════════════════ -->
  <div class="bg-tjb-cream border-y border-tjb-lavender-200/40">
    <div class="max-w-3xl mx-auto px-6 py-4 flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-6">
      <div class="flex items-center gap-2.5">
        <img src="/images/shelbi-thumb.webp" alt="" width="32" height="32" class="w-8 h-8 rounded-full object-cover" />
        <p class="text-sm text-tjb-gray leading-snug">
          <a href="/about/" class="text-tjb-lavender-600 hover:text-tjb-lavender-700 font-medium no-underline">Shelbi Kohler</a>, certified birth doula
        </p>
      </div>
      <span class="hidden sm:inline text-tjb-rose-400 text-sm">·</span>
      <span class="text-sm text-tjb-gray-300 tracking-wide">Designed to be read by a nurse in two minutes</span>
      <span class="hidden sm:inline text-tjb-rose-400 text-sm">·</span>
      <span class="text-sm text-tjb-gray-300 tracking-wide">App Store · Google Play (coming soon)</span>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       APP SHOWCASE — Two-phone mockup layout
       ═══════════════════════════════════════════ -->
  <AppShowcase variant="serif" />

  <!-- ═══════════════════════════════════════════
       TESTIMONIALS — Pull-quote editorial layout
       ═══════════════════════════════════════════ -->
  <section class="bg-white py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-6">
      <div class="text-center mb-12">
        <p class="eyebrow mb-3 fade-up">What moms are saying</p>
        <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto"></div>
      </div>
      <div class="mb-12">
        <img
          src="/images/skin-to-skin.webp"
          alt="The first hour after birth — skin-to-skin contact, the moment your birth plan protects"
            class="w-full max-w-lg mx-auto rounded-xl shadow-md"
          loading="lazy"
          width="1400"
          height="933"
        />
      </div>
      <div class="space-y-12">
        <div class="relative pl-8 md:pl-12 border-l-2 border-tjb-rose-400">
          <svg class="absolute -top-2 left-3 md:left-5 w-8 h-8 text-tjb-rose-300" viewBox="0 0 24 24" fill="currentColor">
            <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z"/>
          </svg>
          <blockquote class="text-xl md:text-[1.375rem] text-tjb-charcoal leading-[1.65] font-serif italic mb-4">
            "When something came up that I wasn't expecting, I had my plan with me and the words ready. It felt good to walk into that conversation prepared instead of caught off guard."
          </blockquote>
          <p class="text-sm text-tjb-gray font-semibold">— Maria T., expecting her first, Dallas</p>
        </div>
        <div class="relative pl-8 md:pl-12 border-l-2 border-tjb-rose-400">
          <svg class="absolute -top-2 left-3 md:left-5 w-8 h-8 text-tjb-rose-300" viewBox="0 0 24 24" fill="currentColor">
            <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z"/>
          </svg>
          <blockquote class="text-xl md:text-[1.375rem] text-tjb-charcoal leading-[1.65] font-serif italic mb-4">
            "I filled mine out in one sitting with my partner. By the time I got to the hospital, I wasn't anxious about what to ask for — I already knew."
          </blockquote>
          <p class="text-sm text-tjb-gray font-semibold">— Danielle R., second-time mom, Fort Worth</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       HOW IT HELPS — Card grid with images
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-6">
      
      <div class="text-center mb-16">
        <p class="eyebrow mb-4 fade-up">What You Get</p>
        <div class="w-10 h-0.5 bg-tjb-rose-500 mx-auto mb-6"></div>
        <h2 class="text-[2.25rem] md:text-[2.75rem] leading-[1.15] max-w-2xl mx-auto" style="font-family: 'Cormorant Garamond', Georgia, serif;">
          Your Birth Plan Should Be a Communication Tool — Not a Wish List
        </h2>
      </div>

      <!-- Three cards in a grid -->
      <div class="grid md:grid-cols-3 gap-6">

        <!-- Card 1 — Joyful Birth Plan -->
        <div class="bg-white border border-tjb-lavender-200/50 rounded-xl shadow-sm hover:shadow-md transition-shadow overflow-hidden flex flex-col">
          <div class="aspect-[4/3] overflow-hidden flex items-center justify-center p-3">
            <img
              src="/images/birth-plan-mockup-square-new-5.webp"
              alt="The free Joyful Birth Plan — newborn care preferences and the birth plan introduction letter"
              class="w-full h-full object-contain rounded shadow-sm"
              loading="lazy"
              width="1200"
              height="973"
            />
          </div>
          <div class="p-5 flex flex-col flex-1">
            <span class="text-xs font-bold text-tjb-lavender-500 font-serif text-sm">01</span>
            <h3 class="text-xl font-bold text-tjb-charcoal mt-1 mb-1">Joyful Birth Plan</h3>
            <p class="text-xs text-tjb-lavender-500 font-semibold mb-3">Free · Fillable PDF</p>
            <p class="text-sm text-tjb-gray leading-relaxed flex-1">
              The free <a href="/birth-plan-template/" class="text-tjb-rose-600 font-semibold hover:text-tjb-rose-500 border-b border-transparent hover:border-tjb-rose-500 transition-all">Joyful Birth Plan</a> that covers every stage of birth — designed to be read by a nurse in two minutes. Download the free PDF or build your plan in the <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="text-tjb-rose-600 font-semibold hover:text-tjb-rose-500 border-b border-transparent hover:border-tjb-rose-500 transition-all">free app</a>.
            </p>
            <a href="#download" class="text-tjb-rose-600 font-semibold text-sm border-b border-transparent hover:border-tjb-rose-500 transition-all inline-block pb-0.5 mt-4 self-start">
              Download free birth plan →
            </a>
          </div>
        </div>

        <!-- Card 2 — Guided Birth Plan Walkthrough -->
        <div class="bg-white border border-tjb-lavender-200/50 rounded-xl shadow-sm hover:shadow-md transition-shadow overflow-hidden flex flex-col">
          <div class="aspect-[4/3] overflow-hidden flex items-center justify-center bg-tjb-lavender-100/50 p-8">
            <div class="text-center">
              <span class="block text-5xl font-bold text-tjb-lavender-500/40 font-serif">02</span>
              <svg class="w-16 h-16 text-tjb-lavender-400 mx-auto mt-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" />
              </svg>
            </div>
          </div>
          <div class="p-5 flex flex-col flex-1">
            <span class="text-xs font-bold text-tjb-rose-500 font-serif text-sm">02</span>
            <h3 class="text-xl font-bold text-tjb-charcoal mt-1 mb-1">Guided Birth Plan Walkthrough</h3>
            <p class="text-xs text-tjb-lavender-500 font-semibold mb-3">$47 one-time · ~60 min of short videos</p>
            <p class="text-sm text-tjb-gray leading-relaxed flex-1">
              A certified birth doula walks you through every section — what each choice means, the tradeoffs, and what to say when your provider recommends something you didn't expect.
            </p>
            <div class="mt-3 mb-3 space-y-1.5 text-xs text-tjb-gray">
              <div class="flex gap-2 items-baseline"><span class="font-semibold text-tjb-lavender-500">1</span><span>Talking to your OB about induction</span></div>
              <div class="flex gap-2 items-baseline"><span class="font-semibold text-tjb-lavender-500">2</span><span>Pain management options and real tradeoffs</span></div>
              <div class="flex gap-2 items-baseline"><span class="font-semibold text-tjb-rose-500">3</span><span>Newborn procedures — what's standard vs. optional</span></div>
              <div class="flex gap-2 items-baseline"><span class="font-semibold text-tjb-sage">4</span><span>What to say when a provider surprises you</span></div>
            </div>
            <a href="/guided-birth-plan-walkthrough/" class="text-tjb-rose-600 font-semibold text-sm border-b border-transparent hover:border-tjb-rose-500 transition-all inline-block pb-0.5 self-start mt-auto">
              Enroll in the birth plan course →
            </a>
          </div>
        </div>

        <!-- Card 3 — Birth Plan Confidence Session -->
        <div class="bg-white border border-tjb-lavender-200/50 rounded-xl shadow-sm hover:shadow-md transition-shadow overflow-hidden flex flex-col">
          <div class="aspect-[4/3] overflow-hidden">
            <img
              src="/images/video-call-doula.webp"
              alt="A birth doula on a video call, reviewing a birth plan with an expectant mom"
              class="w-full h-full object-cover"
              loading="lazy"
              width="1400"
              height="1050"
            />
          </div>
          <div class="p-5 flex flex-col flex-1">
            <span class="text-xs font-bold text-tjb-sage font-serif text-sm">03</span>
            <h3 class="text-xl font-bold text-tjb-charcoal mt-1 mb-1">Birth Plan Confidence Session</h3>
            <p class="text-sm text-tjb-gray leading-relaxed flex-1">
              Sit down with a certified birth doula via Zoom and walk through your plan line by line. Get the words. Practice the conversations. Walk in prepared.
            </p>
            <a href="/birth-plan-confidence-session/#book" class="text-tjb-rose-600 font-semibold text-sm border-b border-transparent hover:border-tjb-rose-500 transition-all inline-block pb-0.5 mt-4 self-start">
              Book a Birth Plan Confidence Session →
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       LEAD CAPTURE — Centered single column: image above heading + form
       Uses shared LeadCaptureForm with bannerImage prop
       ═══════════════════════════════════════════ -->
  <LeadCaptureForm
    heading="Get Your Free Birth Plan"
    body="Enter your name and email and we'll send you the free fillable birth plan PDF plus a guided walkthrough in the app. Free, no spam, just the tools you need."
    eyebrow="Free Download"
    bannerImage="/images/birth-plan-mockup-square-new-8.webp"
    bannerAlt="The free Joyful Birth Plan — a two-page overlapping stack showing the introduction letter and newborn care location preferences"
  />

  <!-- ═══════════════════════════════════════════
       FOR PROS — Two-column layout with phone-frame app screenshots
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-lavender-100 py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex flex-col md:flex-row items-center gap-12 md:gap-16">

        <!-- Left: Text — 55% -->
        <div class="md:w-[55%]">
          <p class="eyebrow mb-3 fade-up">For Doulas & Midwives</p>
          <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
          <h2 class="mb-5 text-[2.25rem] md:text-[2.75rem] leading-[1.15]" style="font-family: 'DM Sans', sans-serif;">Your Practice, Your Clients — All in One Place</h2>
          <p class="text-lg text-tjb-gray leading-relaxed mb-4">
            You already know the value you bring to families. But keeping track of client notes, prenatal records, birth plan progress, and visit schedules — that part shouldn't eat time you'd rather spend supporting your clients.
          </p>
          <p class="text-base text-tjb-gray leading-relaxed mb-6">
            The True Joy Birthing app gives you a Pro Mode dashboard that pulls everything together. When your clients build their birth plan in the app, you see their progress, their preferences, and their key info — without a single spreadsheet tab.
          </p>
          <!-- Benefit list -->
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-tjb-rose-500 mt-0.5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <div>
                <span class="font-semibold text-tjb-charcoal">Client dashboard</span>
                <p class="text-sm text-tjb-gray">Every client's due date, status, upcoming visits, and birth plan progress on one screen. No more digging through message threads to find what you need.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-tjb-rose-500 mt-0.5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <div>
                <span class="font-semibold text-tjb-charcoal">Wellness visit tracking</span>
                <p class="text-sm text-tjb-gray">Log prenatal visits, blood pressure, fetal heart rate, weight, and visit notes — all attached to the right client. Export when you need to share with providers.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-tjb-rose-500 mt-0.5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <div>
                <span class="font-semibold text-tjb-charcoal">Birth plan visibility</span>
                <p class="text-sm text-tjb-gray">Know exactly where each client is in their planning. See completed sections, what they've prioritized, and where they might need extra guidance — before they ask.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-tjb-rose-500 mt-0.5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <div>
                <span class="font-semibold text-tjb-charcoal">A free listing so families find you</span>
                <p class="text-sm text-tjb-gray">Get listed in our city-by-city directory on <a href="/birth-support/" class="text-tjb-rose-600 font-semibold hover:text-tjb-rose-500 border-b border-transparent hover:border-tjb-rose-500 transition-all">truejoybirthing.com</a>. When moms search for doula support in your city, your name comes up.</p>
              </div>
            </li>
          </ul>
          <a href="/ambassador/" class="btn-primary inline-block">
            Join the Ambassador Program
          </a>
          <p class="text-sm text-tjb-gray-300 mt-4">Free for doulas, midwives, and birth professionals. No quotas, no contracts, no tracking.</p>
        </div>

        <!-- Right: App screenshots — 45%, phone frames matching AppShowcase -->
        <div class="md:w-[45%] flex justify-center">
          <div class="relative flex items-start">
            <!-- Left phone — client dashboard, offset down -->
            <div class="phone-frame w-[46%] flex-shrink-0 mt-10 md:mt-16 z-10">
              <div class="phone-screen">
                <img
                  src="/images/app-my-clients.webp"
                  alt="Pro Mode client dashboard showing client profile with due date, status, and key actions"
                  class="w-full h-full object-cover"
                  width="390"
                  height="844"
                  loading="lazy"
                />
              </div>
            </div>
            <!-- Right phone — wellness record -->
            <div class="phone-frame w-[46%] flex-shrink-0 -ml-3 md:-ml-4 z-20">
              <div class="phone-screen">
                <img
                  src="/images/app-wellness-record.webp"
                  alt="Pro Mode wellness visit record form tracking prenatal visits, blood pressure, and fetal heart rate"
                  class="w-full h-full object-cover"
                  width="390"
                  height="844"
                  loading="lazy"
                />
