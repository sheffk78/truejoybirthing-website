---
import Layout from '../layouts/Layout.astro';

const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "Birth Plan Session", "url": "https://truejoybirthing.com/birth-plan-session/"}];
---

<Layout
  title="Birth Plan Confidence Session"
  description="Sit down with a certified doula via Zoom and walk through your birth plan line by line. Feel confident, prepared, and ready."
  canonical="https://truejoybirthing.com/birth-plan-session"
  breadcrumbList={breadcrumbList}
>

  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <h1 class="text-3xl md:text-[2.75rem] font-bold mb-4 leading-tight">Birth Plan Confidence Session</h1>
          <p class="text-lg text-tjb-gray leading-relaxed">A line-by-line walkthrough of your birth plan with a certified doula — so you walk in confident, not guessing.</p>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg shadow-tjb-lavender-300/20">
          <img src="/images/virtual-meeting.webp" alt="Virtual birth plan session over video call" class="w-full h-auto object-cover" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-tjb-cream-50">
    <div class="max-w-3xl mx-auto px-6 prose">
      <h2>What Happens in the Session</h2>
      <ul>
        <li>Review your plan against what actually happens in a hospital room</li>
        <li>Discuss the hospitals and providers on your list — what works, what doesn't</li>
        <li>Practice the exact phrases you'll use during pressure moments</li>
        <li>Build Plan B language so you're prepared even if Plan A changes</li>
      </ul>

      <div class="my-8 rounded-xl overflow-hidden shadow-md">
        <img src="/images/doula-birth-plan-couch.webp" alt="Going through a birth plan together on the couch" class="w-full h-auto" loading="lazy" />
      </div>

      <div class="bg-tjb-cream p-6 rounded-xl text-center my-8">
        <p class="text-3xl font-bold text-tjb-lavender-500 mb-2">$250</p>
        <p class="text-sm text-tjb-gray mb-4">60–75 minutes via Zoom</p>
        <button
          id="checkout-session"
          class="bg-tjb-lavender-500 text-white px-8 py-3 rounded-full font-semibold text-lg hover:bg-tjb-rose-500 transition"
          data-price-id="price_1TUJVT2lZzmsSFmdi22Zw79w"
        >Book Now — $250</button>
        <p class="text-xs text-tjb-gray mt-2">Secure checkout via Stripe. Shelbi will reach out within 24 hours to schedule your Zoom call.</p>
      </div>

      <script>
        document.getElementById('checkout-session')?.addEventListener('click', async function(e) {
          const btn = e.target;
          const originalText = btn.textContent;
          btn.textContent = 'Redirecting to checkout…';
          btn.disabled = true;
          try {
            const res = await fetch('/api/create-checkout-session', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ priceId: btn.dataset.priceId }),
            });
            const data = await res.json();
            if (data.url) {
              window.location.href = data.url;
            } else {
              throw new Error(data.error || 'Checkout failed');
            }
          } catch (err) {
            btn.textContent = originalText;
            btn.disabled = false;
            alert('Something went wrong. Please try again or email shelbi@truejoybirthing.com');
          }
        });
      </script>

      <p class="text-sm text-tjb-gray italic">Sessions are in high demand. If you need immediate support, email <a href="mailto:shelbi@truejoybirthing.com" class="text-tjb-rose-500">shelbi@truejoybirthing.com</a>.</p>
    </div>
  </section>
</Layout>
