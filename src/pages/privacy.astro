---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Privacy Policy" canonical="https://truejoybirthing.com/privacy">
  <section class="py-16 max-w-3xl mx-auto px-6 prose">
    <h1>Privacy Policy</h1>
    <p>Last updated: May 2026</p>
    <p>True Joy Birthing is committed to protecting your privacy. We collect only the information necessary to provide our services.</p>
    <h2>What We Collect</h2>
    <ul>
      <li>Email address (when you download a free resource or sign up)</li>
      <li>Payment information (for courses and consults — processed via Stripe)</li>
      <li>App usage data (to improve our products)</li>
    </ul>
    <h2>How We Use It</h2>
    <p>We use your information to deliver our services, communicate with you, and improve our offerings. We do not sell your data.</p>
    <h2>Medical Disclaimer</h2>
    <p>True Joy Birthing does not provide medical advice. Always consult your healthcare provider.</p>
  </section>
</Layout>
