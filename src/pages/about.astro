---
import Layout from '../layouts/Layout.astro';

const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "About", "url": "https://truejoybirthing.com/about/"}];
---

<Layout
  title="About True Joy Birthing"
  description="Meet Shelbi — certified birth doula and founder of True Joy Birthing, the platform that helps moms build confident birth plans and connects birth pros with powerful tools."
  canonical="https://truejoybirthing.com/about"
  breadcrumbList={breadcrumbList}
>

  <!-- Hero with real photo -->
  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <h1 class="text-3xl md:text-[2.75rem] font-bold mb-4 leading-tight">About True Joy Birthing</h1>
          <p class="text-lg text-tjb-gray leading-relaxed">You deserve to walk into your birth knowing exactly what to expect — and what to say when something unexpected happens.</p>
        </div>
        <div class="relative">
          <div class="rounded-2xl overflow-hidden shadow-lg shadow-tjb-lavender-300/20">
            <img src="/images/shelbi-real.webp" alt="Shelbi Kohler — certified birth doula" class="w-full h-auto object-cover" loading="eager" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Video introduction -->
  <section class="py-12 bg-tjb-cream">
    <div class="max-w-3xl mx-auto px-6">
      <div class="aspect-video rounded-2xl overflow-hidden shadow-lg shadow-tjb-lavender-300/20 bg-tjb-charcoal">
        <iframe
          src="https://iframe.mediadelivery.net/embed/602267/adc27428-031a-4c06-9115-c842bef0fb6e"
          loading="lazy"
          class="w-full h-full border-0"
          allow="accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture;"
          allowfullscreen
        ></iframe>
      </div>
      <p class="text-sm text-tjb-gray-300 mt-3 text-center">Hear Shelbi's story and why she became a doula.</p>
    </div>
  </section>

  <!-- Who is Shelbi -->
  <section class="py-16 bg-tjb-cream-50">
    <div class="max-w-3xl mx-auto px-6 prose">
      <h2>Hi — I'm Shelbi</h2>
      <p>I'm a certified birth doula and childbirth educator based in North Texas. I've supported hundreds of families through births in hospitals, birth centers, and at home.</p>

      <div class="my-8 rounded-xl overflow-hidden shadow-md">
        <img src="/images/doula-birth-plan-couch.webp" alt="Shelbi going through a birth plan with a client on the couch" class="w-full h-auto" loading="lazy" />
        <p class="text-sm text-tjb-gray-300 mt-2 text-center">Walking through a birth plan, one decision at a time.</p>
      </div>

      <p>I started True Joy Birthing because I kept seeing the same thing: moms who wanted to feel empowered in their births but didn't know their options, didn't have the words, and felt like the system was happening <em>to</em> them instead of <em>with</em> them.</p>

      <p>So I built something practical. A birth plan that actually works in a hospital room. Education that explains the tradeoffs, not just the buzzwords. And for doulas — tools that finally make running a practice feel organized instead of overwhelming.</p>

      <h2>What Makes True Joy Birthing Different</h2>
      <ul>
        <li><strong>Doula-crafted, not generic.</strong> Every template, every script, every lesson is built from real birth-room experience.</li>
        <li><strong>Born Connected.</strong> When a mom builds her plan in the free app, it flows directly into her doula's Pro dashboard. No lost details. No copy-paste.</li>
        <li><strong>Honest, not fear-based.</strong> We explain options and tradeoffs. We don't scare you into decisions.</li>
      </ul>

      <div class="my-8 grid md:grid-cols-2 gap-4">
        <div class="rounded-xl overflow-hidden shadow-md">
          <img src="/images/doula-holding-hands.webp" alt="Doula holding a laboring mother's hands" class="w-full h-48 object-cover" loading="lazy" />
        </div>
        <div class="rounded-xl overflow-hidden shadow-md">
          <img src="/images/doula-newborn.webp" alt="Doula encouraging a new mother with her newborn" class="w-full h-48 object-cover" loading="lazy" />
        </div>
      </div>

      <h2>For Doulas & Midwives</h2>
      <p>True Joy Birthing Pro Mode gives you everything you need to run your practice — client plans, visit tracking, notes, and simple invoicing — in one place built specifically for birth work.</p>

      <div class="my-8 rounded-xl overflow-hidden shadow-md">
        <img src="/images/online-support.webp" alt="Online doula support for first-time mothers" class="w-full h-auto" loading="lazy" />
      </div>

      <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="inline-block bg-tjb-lavender-500 text-white px-6 py-3 rounded-full font-semibold hover:bg-tjb-rose-500 transition">Start Pro</a>
    </div>
  </section>

  <!-- CTA band -->
  <section class="bg-tjb-lavender-100 py-16">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Ready to feel confident about your birth?</h2>
      <p class="text-tjb-gray mb-8">Download the free birth plan or explore the <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="text-tjb-lavender-600 font-semibold hover:text-tjb-lavender-700 border-b border-transparent hover:border-tjb-lavender-600 transition-all">free app</a>.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#download" class="btn-primary">Download Free PDF</a>
        <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="btn-secondary">Get the Free App</a>
      </div>
    </div>
  </section>
</Layout>
