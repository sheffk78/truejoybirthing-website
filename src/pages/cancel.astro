---
import Layout from '../layouts/Layout.astro';

const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "Checkout", "url": "https://truejoybirthing.com/cancel/"}];
---

<Layout
  title="Checkout — True Joy Birthing"
  description="Your checkout was not completed. No charge was made."
  canonical="https://truejoybirthing.com/cancel"
  breadcrumbList={breadcrumbList}
>

  <section class="bg-tjb-cream pt-20 pb-16">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <div class="w-16 h-16 bg-tjb-lavender-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-tjb-gray" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">Checkout not completed</h1>
      <p class="text-lg text-tjb-gray mb-2">No charge was made to your card.</p>
      <p class="text-tjb-gray mb-8">If you changed your mind or had an issue, we're here to help.</p>

      <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-300/20">
        <p class="text-sm text-tjb-gray mb-4">Common reasons checkout doesn't complete:</p>
        <ul class="text-sm text-left space-y-2 text-tjb-gray">
          <li>• Card declined — try a different card or contact your bank</li>
          <li>• Popup blocker — Stripe checkout opens in a new tab; disable your blocker</li>
          <li>• Just changed your mind — no worries, we're here when you're ready</li>
        </ul>
      </div>

      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/#download" class="btn-primary">Get the Free Birth Plan</a>
        <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="btn-secondary">Get the Free App</a>
        <a href="mailto:shelbi@truejoybirthing.com" class="text-tjb-rose-500 hover:underline text-sm">Email Shelbi for help →</a>
      </div>
    </div>
  </section>

</Layout>