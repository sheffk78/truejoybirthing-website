---
import BlogLayout from '../../layouts/PostLayout.astro';
import fs from 'node:fs';
import path from 'node:path';
import matter from 'gray-matter';

// Read all markdown posts from content/blog directory
const contentDir = 'src/content/blog';
let posts = [];

try {
  const files = fs.readdirSync(contentDir).filter(f => f.endsWith('.md') && !f.startsWith('_'));
  
  for (const filename of files) {
    const filePath = path.join(contentDir, filename);
    const raw = fs.readFileSync(filePath, 'utf-8');
    const { data } = matter(raw);
    // Skip draft posts
    if (data.draft) continue;
    
    posts.push({
      slug: data.slug || filename.replace('.md', ''),
      title: data.title,
      date: data.date,
      author: data.author || 'Shelbi Kohler',
      description: data.description,
      featuredImage: data.featuredImage,
    });
  }
  
  // Sort by date descending
  posts.sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());
} catch (e) {
  console.error('Error reading posts:', e.message);
}

const description = "Real stories and evidence-based guidance from Shelbi, a certified birth doula and mom of seven. Learn about birth plans, doula services, insurance coverage, and more.";
---

<BlogLayout
  title="Blog"
  description={description}
  canonical="https://truejoybirthing.com/blog/"
  date="2024-12-09"
  pageType="Blog"
>
  <section class="bg-tjb-cream py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-3xl md:text-5xl font-bold text-tjb-charcoal mb-4 leading-tight">True Joy Birthing Blog</h1>
      <p class="text-lg md:text-xl text-tjb-gray max-w-2xl mx-auto">Real stories, evidence-based guidance, and honest answers from a certified birth doula and mom of seven.</p>
    </div>
  </section>

  <section class="py-16 bg-tjb-cream-50">
    <div class="max-w-5xl mx-auto px-6">
      {posts.length > 0 ? (
        <div class="grid md:grid-cols-2 gap-8">
          {posts.map(post => (
            <article class="group bg-tjb-cream rounded-xl overflow-hidden hover:shadow-lg transition">
              <a href={`/blog/${post.slug}/`} class="block">
                {post.featuredImage && (
                  <div class="h-48 overflow-hidden">
                    <img src={post.featuredImage} alt={post.title} class="w-full h-full object-cover group-hover:scale-105 transition duration-500" loading="lazy" />
                  </div>
                )}
                <div class="p-6">
                  <p class="text-sm font-semibold text-tjb-lavender-500 mb-1">{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
                  <h2 class="text-xl font-bold text-tjb-charcoal mb-2 group-hover:text-tjb-lavender-500 transition">{post.title}</h2>
                  <p class="text-sm text-tjb-gray line-clamp-3">{post.description}</p>
                  <span class="inline-flex items-center mt-4 px-4 py-2 -mx-1 text-tjb-lavender-500 font-semibold text-sm group-hover:underline">Read more →</span>
                </div>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-tjb-gray text-lg">Coming soon: "What Is a Doula?", "How Much Does a Doula Cost?", "Doula vs Midwife", and more.</p>
        </div>
      )}
    </div>
  </section>

  <section class="py-12 bg-tjb-cream border-t border-tjb-lavender-200/50">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-2xl md:text-3xl font-bold text-tjb-charcoal mb-6 text-center">Popular Resources</h2>
      <div class="grid md:grid-cols-2 gap-4 max-w-2xl mx-auto">
        <a href="/what-is-a-doula/" class="flex items-center gap-3 p-4 bg-white rounded-xl border border-tjb-lavender-200 hover:border-tjb-rose-400 hover:shadow transition group">
          <span class="text-tjb-rose-500 font-bold text-lg">→</span>
          <span class="text-tjb-charcoal font-semibold group-hover:text-tjb-lavender-500 transition">What Is a Doula?</span>
        </a>
        <a href="/benefits-of-a-doula/" class="flex items-center gap-3 p-4 bg-white rounded-xl border border-tjb-lavender-200 hover:border-tjb-rose-400 hover:shadow transition group">
          <span class="text-tjb-rose-500 font-bold text-lg">→</span>
          <span class="text-tjb-charcoal font-semibold group-hover:text-tjb-lavender-500 transition">Benefits of a Doula</span>
        </a>
        <a href="/doula-cost/" class="flex items-center gap-3 p-4 bg-white rounded-xl border border-tjb-lavender-200 hover:border-tjb-rose-400 hover:shadow transition group">
          <span class="text-tjb-rose-500 font-bold text-lg">→</span>
          <span class="text-tjb-charcoal font-semibold group-hover:text-tjb-lavender-500 transition">Doula Cost Guide</span>
        </a>
        <a href="/doula-vs-midwife/" class="flex items-center gap-3 p-4 bg-white rounded-xl border border-tjb-lavender-200 hover:border-tjb-rose-400 hover:shadow transition group">
          <span class="text-tjb-rose-500 font-bold text-lg">→</span>
          <span class="text-tjb-charcoal font-semibold group-hover:text-tjb-lavender-500 transition">Doula vs Midwife</span>
        </a>
        <a href="/birth-plan-template/" class="flex items-center gap-3 p-4 bg-white rounded-xl border border-tjb-lavender-200 hover:border-tjb-rose-400 hover:shadow transition group">
          <span class="text-tjb-rose-500 font-bold text-lg">→</span>
          <span class="text-tjb-charcoal font-semibold group-hover:text-tjb-lavender-500 transition">Birth Plan Template</span>
        </a>
        <a href="/medicaid-doula-coverage/" class="flex items-center gap-3 p-4 bg-white rounded-xl border border-tjb-lavender-200 hover:border-tjb-rose-400 hover:shadow transition group">
          <span class="text-tjb-rose-500 font-bold text-lg">→</span>
          <span class="text-tjb-charcoal font-semibold group-hover:text-tjb-lavender-500 transition">Medicaid Doula Coverage</span>
        </a>
        <a href="/doula-near-me/" class="flex items-center gap-3 p-4 bg-white rounded-xl border border-tjb-lavender-200 hover:border-tjb-rose-400 hover:shadow transition group">
          <span class="text-tjb-rose-500 font-bold text-lg">→</span>
          <span class="text-tjb-charcoal font-semibold group-hover:text-tjb-lavender-500 transition">Find a Doula Near You</span>
        </a>
        <a href="/postpartum-doula/" class="flex items-center gap-3 p-4 bg-white rounded-xl border border-tjb-lavender-200 hover:border-tjb-rose-400 hover:shadow transition group">
          <span class="text-tjb-rose-500 font-bold text-lg">→</span>
          <span class="text-tjb-charcoal font-semibold group-hover:text-tjb-lavender-500 transition">Postpartum Doula Support</span>
        </a>
        <a href="/how-to-choose-a-doula/" class="flex items-center gap-3 p-4 bg-white rounded-xl border border-tjb-lavender-200 hover:border-tjb-rose-400 hover:shadow transition group md:col-span-2">
          <span class="text-tjb-rose-500 font-bold text-lg">→</span>
          <span class="text-tjb-charcoal font-semibold group-hover:text-tjb-lavender-500 transition">How to Choose a Doula</span>
        </a>
      </div>
    </div>
  </section>
</BlogLayout>
