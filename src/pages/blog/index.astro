---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Blog"
  description="Real talk about birth plans, hospital births, doula support, and feeling confident in your choices."
  canonical="https://truejoybirthing.com/blog"
>
  <section class="bg-tjb-warm pt-16 pb-12">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">Blog</h1>
      <p class="text-lg text-tjb-soft">Real talk about birth plans, hospital births, and feeling confident in your choices.</p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-tjb-soft italic">
        <p>Blog posts will appear here after migration from WordPress.</p>
        <p class="mt-2">Coming soon: "What Is a Doula?", "How Much Does a Doula Cost?", "Doula vs Midwife", and more.</p>
      </div>
    </div>
  </section>
</Layout>
