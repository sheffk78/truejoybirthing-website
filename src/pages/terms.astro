---
import Layout from '../layouts/Layout.astro';

const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "Terms of Use", "url": "https://truejoybirthing.com/terms/"}];
---

<Layout
  title="Terms of Use"
  description="Terms of Use for True Joy Birthing — including subscription pricing, auto-renewal details, and cancellation policy."
  canonical="https://truejoybirthing.com/terms/"
  breadcrumbList={breadcrumbList}
  schema={{
    "@type": "WebPage",
    "name": "Terms of Use",
    "description": "Terms of Use for True Joy Birthing products and services.",
    "url": "https://truejoybirthing.com/terms"
  }}
>
  <!-- Hero -->
  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">Terms of Use</h1>
      <p class="text-lg text-tjb-gray">Last updated: May 2026</p>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 space-y-8">

      <p class="text-tjb-gray leading-relaxed">By using True Joy Birthing products and services, you agree to these terms. If you do not agree, do not use our services.</p>

      <!-- 1. Definitions -->
      <div class="bg-tjb-cream-50 rounded-xl p-6 border border-tjb-lavender-200/50">
        <h2 class="text-xl font-bold text-tjb-charcoal mb-3">1. Definitions</h2>
        <p class="text-tjb-gray leading-relaxed">"True Joy Birthing," "we," "us," and "our" refer to True Joy Birthing, LLC. "You" and "your" refer to the user of our app, website, and services. "Pro Mode" or "True Joy Pro" refers to our paid subscription for doulas and midwives.</p>
      </div>

      <!-- 2. Not Medical Advice -->
      <div class="bg-tjb-rose-50 rounded-xl p-6 border border-tjb-rose-200/50">
        <h2 class="text-xl font-bold text-tjb-charcoal mb-3">2. Not Medical Advice</h2>
        <p class="text-tjb-gray leading-relaxed">True Joy Birthing provides educational tools and information. We are not a substitute for professional medical care. Always consult your healthcare provider for medical advice, diagnosis, or treatment. Do not disregard professional medical advice or delay seeking it because of something you read in our app or on our website.</p>
      </div>

      <!-- 3. Subscriptions -->
      <div class="space-y-4">
        <h2 class="text-xl font-bold text-tjb-charcoal">3. Subscriptions</h2>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
          <h3 class="font-semibold text-lg mb-2">3.1 True Joy Pro Subscription</h3>
          <p class="text-tjb-gray leading-relaxed">True Joy Pro is an auto-renewable subscription that unlocks professional tools for doulas and midwives, including client management, contracts, invoices, notes, and marketplace visibility.</p>
        </div>

        <div class="bg-tjb-cream-50 rounded-xl p-6 border border-tjb-lavender-200/50">
          <h3 class="font-semibold text-lg mb-2">3.2 Subscription Pricing</h3>
          <div class="flex flex-col sm:flex-row gap-4 mt-3">
            <div class="flex-1 bg-white rounded-lg p-4 text-center border border-tjb-lavender-200/50">
              <p class="text-sm font-semibold text-tjb-lavender-600 uppercase tracking-wide">Monthly</p>
              <p class="text-2xl font-bold text-tjb-charcoal mt-1">$29.99<span class="text-sm font-normal text-tjb-gray">/mo</span></p>
            </div>
            <div class="flex-1 bg-white rounded-lg p-4 text-center border border-tjb-rose-200/50">
              <p class="text-sm font-semibold text-tjb-rose-500 uppercase tracking-wide">Annual</p>
              <p class="text-2xl font-bold text-tjb-charcoal mt-1">$274.99<span class="text-sm font-normal text-tjb-gray">/yr</span></p>
              <p class="text-xs text-tjb-rose-500 font-semibold mt-1">Save $85.89</p>
            </div>
          </div>
          <p class="text-sm text-tjb-gray mt-3">Prices are in US dollars. App Store pricing may vary based on your region and local taxes. The exact price will be shown before you confirm your purchase.</p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
          <h3 class="font-semibold text-lg mb-2">3.3 Free Trial</h3>
          <p class="text-tjb-gray leading-relaxed">New subscribers are eligible for a 14-day free trial. During the trial period, you will not be charged. At the end of the trial, your subscription will automatically convert to a paid subscription at the rate selected (monthly or annual) unless you cancel before the trial ends.</p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
          <h3 class="font-semibold text-lg mb-2">3.4 Auto-Renewal</h3>
          <p class="text-tjb-gray leading-relaxed">Your subscription automatically renews unless auto-renewal is turned off at least 24 hours before the end of the current period. Your account will be charged for renewal within 24 hours prior to the end of the current period at the rate selected.</p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
          <h3 class="font-semibold text-lg mb-2">3.5 Managing Your Subscription</h3>
          <div class="space-y-2 mt-2">
            <p class="text-tjb-gray leading-relaxed"><strong class="text-tjb-charcoal">iOS:</strong> Settings → [your name] → Subscriptions on your iPhone or iPad, or App Store → [your name] → Subscriptions on Mac.</p>
            <p class="text-tjb-gray leading-relaxed"><strong class="text-tjb-charcoal">Android:</strong> Google Play Store app → Menu → Subscriptions.</p>
            <p class="text-tjb-gray leading-relaxed">Cancellation takes effect at the end of the current billing period. You will retain access to Pro features until your subscription expires.</p>
          </div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
          <h3 class="font-semibold text-lg mb-2">3.6 Refund Policy</h3>
          <p class="text-tjb-gray leading-relaxed">Subscription payments are non-refundable after the free trial period has ended. If you are not satisfied, you may cancel at any time and will retain access through the end of your current billing period.</p>
        </div>
      </div>

      <!-- 4-8: Standard terms -->
      <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
        <h2 class="text-xl font-bold text-tjb-charcoal mb-3">4. User Accounts</h2>
        <p class="text-tjb-gray leading-relaxed">You are responsible for maintaining the confidentiality of your account credentials. You agree to notify us immediately of any unauthorized use of your account.</p>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
        <h2 class="text-xl font-bold text-tjb-charcoal mb-3">5. Acceptable Use</h2>
        <p class="text-tjb-gray leading-relaxed">You agree not to misuse our services, including but not limited to: attempting to gain unauthorized access, using the service for illegal purposes, or interfering with the service's operation.</p>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
        <h2 class="text-xl font-bold text-tjb-charcoal mb-3">6. Intellectual Property</h2>
        <p class="text-tjb-gray leading-relaxed">All content, features, and functionality of True Joy Birthing — including but not limited to text, graphics, logos, and software — are owned by True Joy Birthing, LLC and are protected by copyright, trademark, and other intellectual property laws.</p>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
        <h2 class="text-xl font-bold text-tjb-charcoal mb-3">7. Limitation of Liability</h2>
        <p class="text-tjb-gray leading-relaxed">To the maximum extent permitted by law, True Joy Birthing, LLC shall not be liable for any indirect, incidental, special, consequential, or punitive damages arising from your use of our services.</p>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
        <h2 class="text-xl font-bold text-tjb-charcoal mb-3">8. Changes to Terms</h2>
        <p class="text-tjb-gray leading-relaxed">We may update these terms from time to time. We will notify you of material changes by posting the updated terms on this page with a revised "Last updated" date. Your continued use of the service after changes are posted constitutes your acceptance of the updated terms.</p>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
        <h2 class="text-xl font-bold text-tjb-charcoal mb-3">9. Contact</h2>
        <p class="text-tjb-gray leading-relaxed">For questions about these terms, contact us at <a href="mailto:support@truejoybirthing.com" class="text-tjb-rose-500 hover:text-tjb-charcoal underline underline-offset-3 transition-colors">support@truejoybirthing.com</a>.</p>
      </div>

      <div class="bg-tjb-cream-50 rounded-xl p-6 border border-tjb-lavender-200/50">
        <h2 class="text-xl font-bold text-tjb-charcoal mb-3">10. App and Subscription Refunds</h2>
        <p class="text-tjb-gray leading-relaxed">The free birth plan PDF and app features are free — no refund needed. Pro Mode subscriptions follow App Store and Google Play refund policies. If you have an issue, contact us at support@truejoybirthing.com and we'll help.</p>
      </div>

      <!-- Related links -->
      <div class="pt-8 border-t border-tjb-lavender-200/50 text-center">
        <p class="text-tjb-gray mb-4">Related: <a href="/privacy" class="text-tjb-rose-500 hover:text-tjb-charcoal underline underline-offset-3 transition-colors font-semibold">Privacy Policy</a></p>
        <a href="/" class="btn-primary">Back to Home →</a>
      </div>

    </div>
  </section>
</Layout>