---
import Layout from '../layouts/Layout.astro';

const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "Birth Plan Course", "url": "https://truejoybirthing.com/birth-plan-course/"}];
---

<Layout
  title="Joyful Birth Plan Mini-Course"
  description="Learn every option, every tradeoff, and the exact phrases to use in your birth. A doula-crafted course for hospital-planning moms."
  canonical="https://truejoybirthing.com/birth-plan-course"
  breadcrumbList={breadcrumbList}
>

  <section class="bg-tjb-cream pt-16 pb-12">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <h1 class="text-3xl md:text-[2.75rem] font-bold mb-4 leading-tight">Joyful Birth Plan Mini-Course</h1>
          <p class="text-lg text-tjb-gray leading-relaxed">Go from "I don't know what to expect" to "I know my options and have the words."</p>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg shadow-tjb-lavender-300/20">
          <img src="/images/birth-plan-couch.webp" alt="Doula helping a mother review her birth plan on the couch" class="w-full h-auto object-cover" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">
      <p class="text-lg">This isn't another birth class. It's a focused, practical education on every decision point you'll face in a hospital birth — from induction talks to newborn procedures.</p>

      <h2>What You'll Learn</h2>
      <ul>
        <li>How to talk to your OB about induction without feeling shut down</li>
        <li>Every pain management option and the real tradeoffs</li>
        <li>What newborn procedures are standard — and which you can pause or decline</li>
        <li>Exactly what to say when a provider recommends something you didn't expect</li>
      </ul>

      <div class="my-8 rounded-xl overflow-hidden shadow-md">
        <img src="/images/online-education.webp" alt="Online birth education for first-time mothers" class="w-full h-auto" loading="lazy" />
      </div>

      <div class="bg-tjb-cream p-6 rounded-xl text-center my-8">
        <p class="text-3xl font-bold text-tjb-lavender-500 mb-2">$47</p>
        <p class="text-sm text-tjb-gray mb-4">One-time purchase. Lifetime access.</p>
        <button
          id="checkout-course"
          class="bg-tjb-lavender-500 text-white px-8 py-3 rounded-full font-semibold text-lg hover:bg-tjb-rose-500 transition"
          data-price-id="price_1TUJVS2lZzmsSFmdf7yahFcF"
        >Enroll Now — $47</button>
        <p class="text-xs text-tjb-gray mt-2">Secure checkout via Stripe. Instant access after purchase.</p>
      </div>

      <script>
        document.getElementById('checkout-course')?.addEventListener('click', async function(e) {
          const btn = e.target;
          const originalText = btn.textContent;
          btn.textContent = 'Redirecting to checkout…';
          btn.disabled = true;
          try {
            const res = await fetch('/api/create-checkout-session', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ priceId: btn.dataset.priceId }),
            });
            const data = await res.json();
            if (data.url) {
              window.location.href = data.url;
            } else {
              throw new Error(data.error || 'Checkout failed');
            }
          } catch (err) {
            btn.textContent = originalText;
            btn.disabled = false;
            alert('Something went wrong. Please try again or email shelbi@truejoybirthing.com');
          }
        });
      </script>

      <h2>Instructor</h2>
      <p>Shelbi, certified birth doula and childbirth educator. She's walked this journey with hundreds of families — and she built the course she wishes every mom had before their first birth.</p>

      <div class="my-8 rounded-xl overflow-hidden shadow-md">
        <img src="/images/doula-teaching.webp" alt="Shelbi teaching birth education to expecting parents" class="w-full h-auto" loading="lazy" />
      </div>
    </div>
  </section>
</Layout>
