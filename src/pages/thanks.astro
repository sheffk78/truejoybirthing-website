---
import Layout from '../layouts/Layout.astro';

const sessionId = Astro.url.searchParams.get('session_id');
const breadcrumbList = [{"name": "Home", "url": "https://truejoybirthing.com/"}, {"name": "Thanks", "url": "https://truejoybirthing.com/thanks/"}];
---

<Layout
  title="Thank You — True Joy Birthing"
  description="Your purchase is confirmed. Check your email for next steps."
  canonical="https://truejoybirthing.com/thanks"
  breadcrumbList={breadcrumbList}
>

  <section class="bg-tjb-cream pt-20 pb-16">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <div class="w-16 h-16 bg-tjb-lavender-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-tjb-lavender-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">Thank you!</h1>
      <p class="text-lg text-tjb-gray mb-2">Your purchase is confirmed.</p>
      <p class="text-tjb-gray mb-8">Check your email for next steps. If you don't see it within 5 minutes, check your spam folder.</p>

      <div class="bg-white rounded-xl p-6 shadow-sm border border-tjb-lavender-300/20">
        <p class="text-sm text-tjb-gray mb-4">While you wait, here's what to do next:</p>
        <ul class="text-sm text-left space-y-3 text-tjb-gray">
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-tjb-lavender-100 text-tjb-lavender-500 text-xs font-bold flex items-center justify-center shrink-0">1</span>
            <span>Watch your email for your access link and login details.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-tjb-lavender-100 text-tjb-lavender-500 text-xs font-bold flex items-center justify-center shrink-0">2</span>
            <span>Download the True Joy Birthing app if you haven't already — it syncs with your purchase.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-tjb-lavender-100 text-tjb-lavender-500 text-xs font-bold flex items-center justify-center shrink-0">3</span>
            <span>For session bookings, Shelbi will reach out within 24 hours to schedule your Zoom call.</span>
          </li>
        </ul>
      </div>

      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary">Back to Home</a>
        <a href="/blog" class="btn-secondary">Read the Blog</a>
      </div>
    </div>
  </section>

</Layout>