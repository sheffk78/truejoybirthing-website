---
import Layout from '../layouts/Layout.astro';
import LeadCaptureForm from '../components/LeadCaptureForm.astro';

const breadcrumbList = [
  {"name": "Home", "url": "https://truejoybirthing.com/"},
  {"name": "Joyful Birth Plan", "url": "https://truejoybirthing.com/birth-plan-template/"},
  {"name": "Guided Birth Plan Walkthrough", "url": "https://truejoybirthing.com/guided-birth-plan-walkthrough/"},
  {"name": "Birth Plan Confidence Session", "url": "https://truejoybirthing.com/birth-plan-confidence-session/"}
];
---

<Layout
  title="Birth Plan Confidence Session | True Joy Birthing"
  description="Sit down with a certified birth doula via Zoom and walk through your plan line by line. Get answers, build confidence, and go into your birth knowing your options. $250, 60-75 minutes."
  canonical="https://truejoybirthing.com/birth-plan-confidence-session/"
  ogImage="https://truejoybirthing.com/images/og-homepage.webp"
  breadcrumbList={breadcrumbList}
  schema={{
    "@graph": [
      {
        "@type": "WebPage",
        "@id": "https://truejoybirthing.com/birth-plan-confidence-session/#webpage",
        "url": "https://truejoybirthing.com/birth-plan-confidence-session/",
        "name": "Birth Plan Confidence Session",
        "description": "Sit down with a certified birth doula via Zoom and walk through your plan line by line. Get answers, build confidence, and go into your birth knowing your options. $250, 60-75 minutes.",
        "isPartOf": {"@id": "https://truejoybirthing.com/#website"},
        "about": {
          "@type": "Service",
          "name": "Birth Plan Confidence Session",
          "provider": {"@id": "https://truejoybirthing.com/#organization"}
        }
      },
      {
        "@type": "Service",
        "@id": "https://truejoybirthing.com/birth-plan-confidence-session/#service",
        "name": "Birth Plan Confidence Session",
        "description": "A 60-75 minute live Zoom session with a certified birth doula who reviews your birth plan line by line, including advocacy role-play and hospital-specific pushback practice.",
        "provider": {
          "@type": "Person",
          "name": "Shelbi Kohler",
          "url": "https://truejoybirthing.com/about/"
        },
        "url": "https://truejoybirthing.com/birth-plan-confidence-session/",
        "areaServed": {"@type": "Country", "name": "United States"},
        "serviceType": "Birth plan consultation",
        "offers": {
          "@type": "Offer",
          "price": "250",
          "priceCurrency": "USD",
          "priceValidUntil": "2026-12-31",
          "availability": "https://schema.org/LimitedAvailability",
          "category": "Consultation"
        }
      },
      {
        "@type": "Person",
        "@id": "https://truejoybirthing.com/about/#founder",
        "name": "Shelbi Kohler",
        "jobTitle": "Certified Birth Doula",
        "description": "500+ families supported across Texas. Specializes in hospital birth advocacy and birth plan preparation.",
        "credential": "",
        "worksFor": {"@type": "Organization", "name": "True Joy Birthing"}
      },
      {
        "@type": "FAQPage",
        "@id": "https://truejoybirthing.com/birth-plan-confidence-session/#faq",
        "mainEntity": [
          { "@type": "Question", "name": "What do I need before the session?", "acceptedAnswer": { "@type": "Answer", "text": "A completed or near-complete birth plan and a quiet space for Zoom. Download the free Joyful Birth Plan if you don't have one yet, or use whatever plan you've already started." } },
          { "@type": "Question", "name": "How long is the session?", "acceptedAnswer": { "@type": "Answer", "text": "60-75 minutes. Long enough to go through your plan in detail and practice advocacy scenarios. Short enough that you don't need to block off your whole day." } },
          { "@type": "Question", "name": "Is this medical advice?", "acceptedAnswer": { "@type": "Answer", "text": "No. Shelbi is a certified birth doula, not a medical provider. This is education and advocacy coaching — helping you understand your options and communicate them clearly." } },
          { "@type": "Question", "name": "Can I book more than one session?", "acceptedAnswer": { "@type": "Answer", "text": "You can, but most parents find one is enough. The session is designed to give you everything you need to walk into your birth with confidence." } },
          { "@type": "Question", "name": "What if I haven't filled out a birth plan yet?", "acceptedAnswer": { "@type": "Answer", "text": "Start with the free Joyful Birth Plan template, or take the Guided Birth Plan Walkthrough course first. Both give you a strong foundation before the session." } },
          { "@type": "Question", "name": "Is this only for Texas residents?", "acceptedAnswer": { "@type": "Answer", "text": "No — sessions are on Zoom and available nationwide. Shelbi is based in Texas but serves expectant parents across the United States." } }
        ]
      }
    ]
  }}
>

  <!-- ═══════════════════════════════════════════
       HERO — Two-column with Shelbi photo (mirrors homepage pattern)
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row">
        <!-- Left: Text — 55% -->
        <div class="md:w-[55%] px-6 md:px-12 py-16 md:py-24 flex flex-col justify-center">
          <p class="eyebrow mb-3">1:1 birth plan coaching</p>
          <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
          <h1 class="font-bold text-tjb-charcoal leading-[1.15] mb-4" style="font-size: clamp(2.25rem, 5vw, 3.75rem);">
            Get your birth plan reviewed line by line — and practice saying what you actually want
          </h1>
          <p class="text-lg text-tjb-charcoal font-semibold mb-3">Walk into your birth feeling calm, prepared, and heard.</p>
          <p class="text-tjb-gray leading-relaxed mb-8 max-w-[36rem]">
            A 60–75 minute live Zoom call with a certified birth doula who reviews your birth plan line by line — so you know exactly what to say when your provider recommends something you didn't expect.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center">
            <a href="#book" class="btn-primary">Request a Confidence Session</a>
            <span class="text-sm text-tjb-gray">$250 · 60–75 min · Zoom · Limited spots</span>
          </div>
        </div>
        <!-- Right: Photo — 45% -->
        <div class="md:w-[45%] flex items-center justify-center px-8 py-8 md:py-0">
          <img
            src="/images/shelbi-portrait-placeholder.webp"
            srcset="/images/responsive/shelbi-portrait-placeholder-480w.webp 480w, /images/responsive/shelbi-portrait-placeholder-960w.webp 960w, /images/shelbi-portrait-placeholder.webp 1200w"
            sizes="(max-width: 480px) 480px, (max-width: 960px) 960px, 1200px"
            alt="Shelbi Kohler — certified birth doula and founder of True Joy Birthing"
            class="w-full max-w-md rounded-xl shadow-md"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHAT HAPPENS IN A SESSION
       ═══════════════════════════════════════════ -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">
      <h2>What happens in a Birth Plan Confidence Session</h2>
      <p>You and a certified birth doula sit down on Zoom with your completed birth plan and go through it together — section by section, line by line.</p>
      <p>This is not a lecture. It's a working session. You bring your plan, your questions, and the things you're unsure about. We bring the birth-room experience to make sure your plan reflects what actually happens — not just what the brochure says.</p>

      <ul>
        <li><strong>Line-by-line review of YOUR birth plan</strong> — not a template, not generic advice. Your filled-out plan, your hospital, your concerns.</li>
        <li><strong>Advocacy role-play</strong> — practice what to say when your provider suggests something you didn't plan for. "I need a minute to think," "What happens if we wait?," "Can you explain the reasoning?"</li>
        <li><strong>Walk away confident</strong> — you'll know what to communicate, when to say it, and why.</li>
      </ul>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHAT TO EXPECT — STEP-BY-STEP
       ═══════════════════════════════════════════ -->
  <section class="py-16 bg-tjb-cream">
    <div class="max-w-3xl mx-auto px-6">
      <p class="eyebrow mb-3 fade-up">What to expect</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-8"></div>

      <div class="space-y-8">
        <div class="border-l-2 border-tjb-lavender-500 pl-6">
          <h3 class="text-lg font-semibold mb-2">01 — Book your session</h3>
          <p class="text-tjb-gray leading-relaxed">Pick a time that works — evenings available. You'll fill out a brief intake form at booking so Shelbi knows what to prepare.</p>
        </div>

        <div class="border-l-2 border-tjb-lavender-500 pl-6">
          <h3 class="text-lg font-semibold mb-2">02 — Fill out the pre-session intake</h3>
          <p class="text-tjb-gray leading-relaxed">Share your plan, your hospital, and your concerns. Shelbi reviews everything before the call so your session time is spent on what matters most to you.</p>
        </div>

        <div class="border-l-2 border-tjb-lavender-500 pl-6">
          <h3 class="text-lg font-semibold mb-2">03 — Meet on Zoom</h3>
          <p class="text-tjb-gray leading-relaxed">Shelbi reviews your plan and you practice real scenarios together — the conversations you're most worried about, the decisions that feel uncertain, the moments where you want language that works.</p>
        </div>

        <div class="border-l-2 border-tjb-sage pl-6">
          <h3 class="text-lg font-semibold mb-2">04 — Walk away confident</h3>
          <p class="text-tjb-gray leading-relaxed">You'll know what to say, when to say it, and why. Your plan is nurse-readable. Your language is calm and clear. You're prepared for the moments that matter most.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHO YOU'LL WORK WITH
       ═══════════════════════════════════════════ -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6">
      <div class="flex flex-col md:flex-row gap-8 items-start">
        <div class="md:w-1/3 flex-shrink-0">
          <img
            src="/images/shelbi-portrait-small-placeholder.webp"
            alt="Shelbi Kohler — certified birth doula and founder of True Joy Birthing"
            class="w-full rounded-xl shadow-md"
            loading="lazy"
          />
        </div>
        <div class="md:w-2/3">
          <p class="eyebrow mb-3">Who you'll work with</p>
          <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
          <h2 class="text-2xl font-bold mb-4">Shelbi Kohler</h2>
          <p class="text-tjb-gray leading-relaxed mb-4">Certified birth doula and founder of <a href="/about/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">True Joy Birthing</a>. 500+ families supported. Specializes in hospital birth advocacy — she knows what happens when plans change mid-labor, and she'll help you prepare for those moments too.</p>
          <p class="text-tjb-gray leading-relaxed mb-4">Based in Texas. Available nationwide via Zoom.</p>
          <p class="text-tjb-gray leading-relaxed text-sm">Not a generic consultant — a birth doula who sits in delivery rooms.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       THIS SESSION IS FOR YOU IF
       ═══════════════════════════════════════════ -->
  <section class="py-16 bg-tjb-cream">
    <div class="max-w-3xl mx-auto px-6">
      <p class="eyebrow mb-3 fade-up">This session is for you if</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-8"></div>

      <div class="space-y-4">
        <div class="flex items-start gap-3">
          <span class="text-tjb-rose-500 mt-1 text-lg">✓</span>
          <p class="text-tjb-charcoal leading-relaxed">You've filled out a birth plan but you're not sure if it covers everything</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-tjb-rose-500 mt-1 text-lg">✓</span>
          <p class="text-tjb-charcoal leading-relaxed">You're worried about advocating for yourself during labor</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-tjb-rose-500 mt-1 text-lg">✓</span>
          <p class="text-tjb-charcoal leading-relaxed">You've had a provider dismiss your preferences before and you want to be ready this time</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-tjb-rose-500 mt-1 text-lg">✓</span>
          <p class="text-tjb-charcoal leading-relaxed">You want a real person to look at YOUR plan and YOUR hospital — not generic advice</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-tjb-rose-500 mt-1 text-lg">✓</span>
          <p class="text-tjb-charcoal leading-relaxed">You're working with a specific medical situation (<a href="/birth-plan-for-induction/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">induction</a>, <a href="/vbac-birth-plan/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">VBAC</a>, etc.) and need tailored guidance</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHAT'S DIFFERENT
       ═══════════════════════════════════════════ -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">
      <h2>What's different about this session</h2>
      <ul>
        <li><strong>Not a course</strong> — this is your plan, your hospital, your concerns. The <a href="/guided-birth-plan-walkthrough/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">Guided Birth Plan Walkthrough</a> gives you context for each section. This session gives you a live review of your specific situation.</li>
        <li><strong>Not a doula hiring pitch</strong> — this is a single session, no ongoing commitment. You get a reviewed plan and practiced advocacy scripts. That's the deliverable.</li>
        <li><strong>Advocacy role-play included</strong> — practice the hard conversation before you're in labor. "I need a minute to think," "What happens if we wait?," "Can you explain the reasoning?" These phrases work. We'll rehearse them so they feel natural.</li>
        <li><strong>Limited spots: 5–8 sessions/month</strong> — because Shelbi reviews your plan before the call. This isn't a volume product. Each session gets her full attention. She actually reads your plan before you meet.</li>
      </ul>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHAT WE COVER
       ═══════════════════════════════════════════ -->
  <section class="py-16 bg-tjb-cream">
    <div class="max-w-3xl mx-auto px-6">
      <p class="eyebrow mb-3 fade-up">What we cover</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-8"></div>

      <div class="space-y-8">
        <div class="border-l-2 border-tjb-lavender-500 pl-6">
          <h3 class="text-lg font-semibold mb-2">01 — Labor and delivery interventions</h3>
          <p class="text-tjb-gray leading-relaxed">What providers are likely to recommend, what they actually mean, and how to say yes, no, or "I need a minute" with confidence. We review your preferences for monitoring, IV, movement, induction, and augmentation — and flag gaps where the hospital's default might override what you wrote.</p>
        </div>
        <div class="border-l-2 border-tjb-lavender-500 pl-6">
          <h3 class="text-lg font-semibold mb-2">02 — Pain relief preferences</h3>
          <p class="text-tjb-gray leading-relaxed">Not just "epidural or unmedicated." We walk through the full pain management ladder — what's available, when it's typically offered, and how to keep your options open at each stage. You'll leave with language that doesn't box you in.</p>
        </div>
        <div class="border-l-2 border-tjb-lavender-500 pl-6">
          <h3 class="text-lg font-semibold mb-2">03 — Post-delivery and newborn procedures</h3>
          <p class="text-tjb-gray leading-relaxed">Skin-to-skin, cord clamping, golden hour, feeding, Vitamin K, Hep B, eye ointment, circumcision, rooming-in, screenings. These decisions come fast after delivery. We make sure your plan covers them clearly — and that your support team knows them cold.</p>
        </div>
        <div class="border-l-2 border-tjb-rose-500 pl-6">
          <h3 class="text-lg font-semibold mb-2">04 — Advocating with your provider</h3>
          <p class="text-tjb-gray leading-relaxed">This is the heart of the session. We role-play the conversations you're most worried about — induction talks, epidural timing, cesarean discussions, anything that feels like pressure. You practice the phrases, we sharpen them, and you walk away knowing what to say when the moment comes.</p>
        </div>
        <div class="border-l-2 border-tjb-sage pl-6">
          <h3 class="text-lg font-semibold mb-2">05 — Plan B, Plan C, and flexibility language</h3>
          <p class="text-tjb-gray leading-relaxed">Birth doesn't follow scripts. We help you write backup language into your plan so that if things shift — and they often do — you still have a voice. This is where most birth plans fall apart. We make sure yours doesn't.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHY IT MATTERS
       ═══════════════════════════════════════════ -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6 prose">
      <h2>Why it matters</h2>
      <p>You've done the research. You've downloaded the plan. You've watched the videos. But knowing your options and speaking up in the moment are two different things.</p>
      <p><strong>Feel prepared, not just informed.</strong> There's a difference between reading about induction and having practiced what you'll say when your OB brings it up at 39 weeks. We bridge that gap.</p>
      <p><strong>Have language that works in the room.</strong> "I prefer" sounds different than "I'd like to understand the reasoning before we decide." We help you find the words that get heard — not just said.</p>
      <p><strong>Give your partner a script, not a spotlight.</strong> Your support person wants to help but may not know what to say. Your plan gives them the words. Your session makes sure those words actually work when a nurse has three other patients and your doctor is recommending Pitocin.</p>
      <p><strong>Walk in knowing what you'll say when plans change.</strong> Most births don't follow the plan. That's not failure — that's reality. A good birth plan includes language for flexibility. A great one includes language for the conversations that happen when flexibility becomes the plan.</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       INVESTMENT
       ═══════════════════════════════════════════ -->
  <section class="py-16 bg-tjb-cream">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <p class="eyebrow mb-3 fade-up">Investment</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-8"></div>

      <div class="bg-white rounded-xl p-8 shadow-sm border border-tjb-lavender-200/50">
        <h2 class="text-2xl md:text-3xl font-bold mb-4">$250–300 per session</h2>
        <p class="text-tjb-gray mb-2">60–75 minutes · Live on Zoom · Pre-session intake included</p>
        <p class="text-tjb-gray text-sm mb-6">Shelbi reviews your plan before the call so you get maximum value from your time together.</p>
        <a href="#book" class="btn-primary">Request a Birth Plan Confidence Session</a>
        <p class="text-sm text-tjb-gray mt-4">No subscription, no ongoing commitment — one session and you're prepared.</p>
        <p class="text-sm text-tjb-gray mt-2">Limited to 5–8 sessions per month.</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       BEFORE YOU BOOK — FUNNEL ROUTING
       ═══════════════════════════════════════════ -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6">
      <p class="eyebrow mb-3 fade-up">Before you book — here's what helps most</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-8"></div>
      <h2 class="text-2xl font-bold mb-8">Three paths, depending on where you are</h2>

      <div class="space-y-6">
        <div class="bg-tjb-cream rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
          <p class="text-sm font-semibold text-tjb-lavender-600 mb-1">Haven't started a birth plan yet?</p>
          <p class="text-tjb-charcoal mb-3">Start with the free template. Fill it out, sit with it, and come back when you're ready for expert feedback.</p>
          <a href="/birth-plan-template/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">Download free birth plan →</a>
        </div>
        <div class="bg-tjb-cream rounded-xl p-6 shadow-sm border border-tjb-lavender-200/50">
          <p class="text-sm font-semibold text-tjb-lavender-600 mb-1">Have the plan but want guided help?</p>
          <p class="text-tjb-charcoal mb-3">The <a href="/guided-birth-plan-walkthrough/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">Guided Birth Plan Walkthrough</a> walks you through every section with context — what each choice means, what the tradeoffs are. If you want to understand the "why" behind every checkbox, start there. <strong>$47 one-time.</strong></p>
        </div>
        <div class="bg-tjb-lavender-50 rounded-xl p-6 border-2 border-tjb-lavender-300">
          <p class="text-sm font-semibold text-tjb-sage mb-1">Ready for personalized review?</p>
          <p class="text-tjb-charcoal font-semibold">You're in the right place. A certified birth doula reviews your plan live, practices the hard conversations with you, and makes sure you walk in prepared. <strong>$250 per session. Limited spots.</strong></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FAQ
       ═══════════════════════════════════════════ -->
  <section class="py-16 bg-tjb-cream">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-2xl font-bold mb-8">Frequently asked questions</h2>
      <div class="space-y-6">
        <div class="bg-white rounded-xl p-6">
          <h3 class="font-semibold text-lg mb-2">What do I need before the session?</h3>
          <p class="text-tjb-gray leading-relaxed">A completed or near-complete birth plan and a quiet space for Zoom. Download the <a href="/birth-plan-template/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">free Joyful Birth Plan</a> if you don't have one yet — even a rough draft gives us something to work with.</p>
        </div>
        <div class="bg-white rounded-xl p-6">
          <h3 class="font-semibold text-lg mb-2">How long is the session?</h3>
          <p class="text-tjb-gray leading-relaxed">60–75 minutes. Long enough to go through your plan in detail and practice advocacy scenarios. Short enough that you don't need to block off your whole day.</p>
        </div>
        <div class="bg-white rounded-xl p-6">
          <h3 class="font-semibold text-lg mb-2">Is this medical advice?</h3>
          <p class="text-tjb-gray leading-relaxed">No. Shelbi is a certified birth doula, not a medical provider. This is education and advocacy coaching — helping you understand your options and communicate them clearly. Always discuss your specific medical situation with your OB, midwife, or care team.</p>
        </div>
        <div class="bg-white rounded-xl p-6">
          <h3 class="font-semibold text-lg mb-2">Can I book more than one session?</h3>
          <p class="text-tjb-gray leading-relaxed">You can, but most parents find one is enough. The session is designed to give you everything you need to walk into your birth with confidence.</p>
        </div>
        <div class="bg-white rounded-xl p-6">
          <h3 class="font-semibold text-lg mb-2">What if I haven't filled out a birth plan yet?</h3>
          <p class="text-tjb-gray leading-relaxed">Start with the <a href="/birth-plan-template/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">free Joyful Birth Plan</a> and fill out as much as you can. If you're truly starting from zero, the <a href="/guided-birth-plan-walkthrough/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">Guided Birth Plan Walkthrough</a> is a great place to build your first draft before the session.</p>
        </div>
        <div class="bg-white rounded-xl p-6">
          <h3 class="font-semibold text-lg mb-2">Is this only for Texas residents?</h3>
          <p class="text-tjb-gray leading-relaxed">No — sessions are on Zoom and available nationwide. Shelbi is based in Texas but serves expectant parents across the United States.</p>
        </div>
        <div class="bg-white rounded-xl p-6">
          <h3 class="font-semibold text-lg mb-2">Can my partner join?</h3>
          <p class="text-tjb-gray leading-relaxed">Yes. Partners are welcome and encouraged. Many families find it helpful for both people to hear the review and practice the language together. No extra charge.</p>
        </div>
        <div class="bg-white rounded-xl p-6">
          <h3 class="font-semibold text-lg mb-2">Is this only for hospital births?</h3>
          <p class="text-tjb-gray leading-relaxed">No. We work with families planning hospital births, birth center births, and home births. The session is tailored to your specific setting and provider. That said, hospital-birth families tend to have the most advocacy questions — and those are the conversations we're best equipped to practice.</p>
        </div>
        <div class="bg-white rounded-xl p-6">
          <h3 class="font-semibold text-lg mb-2">What's the cancellation policy?</h3>
          <p class="text-tjb-gray leading-relaxed">Life happens, especially when you're pregnant. You can reschedule up to 24 hours before your session with no penalty. No-shows and late cancellations are non-refundable.</p>
        </div>
        <div class="bg-white rounded-xl p-6">
          <h3 class="font-semibold text-lg mb-2">Is this covered by insurance or Medicaid?</h3>
          <p class="text-tjb-gray leading-relaxed">We cannot bill insurance or Medicaid directly. Some families have been reimbursed for doula education through their HSA/FSA or state Medicaid doula benefit — check with your plan administrator. We provide a receipt you can submit.</p>
        </div>
      </div>
    </div>
  </section>

