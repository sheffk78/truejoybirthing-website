        <!-- Request form -->
        <form id="confidence-form" class="text-left">
          <div class="mb-5">
            <label for="cs-name" class="block text-sm font-medium text-tjb-charcoal mb-1.5">Name <span class="text-tjb-rose-500">*</span></label>
            <input id="cs-name" name="name" type="text" required placeholder="Your name"
              class="w-full px-5 py-3.5 rounded-xl border border-tjb-lavender-200 focus:outline-none focus:border-tjb-rose-400 focus:ring-1 focus:ring-tjb-rose-400 bg-white transition-colors text-[0.9375rem]" />
          </div>
          <div class="mb-5">
            <label for="cs-email" class="block text-sm font-medium text-tjb-charcoal mb-1.5">Email <span class="text-tjb-rose-500">*</span></label>
            <input id="cs-email" name="email" type="email" required placeholder="you@example.com"
              class="w-full px-5 py-3.5 rounded-xl border border-tjb-lavender-200 focus:outline-none focus:border-tjb-rose-400 focus:ring-1 focus:ring-tjb-rose-400 bg-white transition-colors text-[0.9375rem]" />
          </div>
          <div class="mb-5">
            <label for="cs-phone" class="block text-sm font-medium text-tjb-charcoal mb-1.5">Phone <span class="text-tjb-rose-500">*</span></label>
            <input id="cs-phone" name="phone" type="tel" required placeholder="(555) 555-5555"
              class="w-full px-5 py-3.5 rounded-xl border border-tjb-lavender-200 focus:outline-none focus:border-tjb-rose-400 focus:ring-1 focus:ring-tjb-rose-400 bg-white transition-colors text-[0.9375rem]" />
          </div>
          <div class="mb-8">
            <label for="cs-due" class="block text-sm font-medium text-tjb-charcoal mb-1.5">Due date <span class="text-tjb-gray-400 font-normal">(optional)</span></label>
            <input id="cs-due" name="dueDate" type="date"
              class="w-full px-5 py-3.5 rounded-xl border border-tjb-lavender-200 focus:outline-none focus:border-tjb-rose-400 focus:ring-1 focus:ring-tjb-rose-400 bg-white transition-colors text-[0.9375rem]" />
          </div>
          <button type="submit" id="cs-submit" class="btn-primary w-full text-center">
            Request a Confidence Session
          </button>
          <p id="cs-status" class="text-xs hidden mt-3 text-center"></p>
        </form>

        <!-- Success state -->
        <div id="cs-success" class="hidden text-center">
          <div class="bg-white rounded-xl p-8 shadow-sm border border-tjb-lavender-200">
            <p class="text-green-700 font-semibold text-lg mb-3">✓ Thank you! Your request is in.</p>
            <p class="text-tjb-gray leading-relaxed">Shelbi will reach out within 1–2 business days to schedule your Birth Plan Confidence Session and handle payment.</p>
            <p class="text-sm text-tjb-gray mt-4">In the meantime, make sure you have a birth plan draft ready — <a href="/birth-plan-template/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">download the free Joyful Birth Plan</a> if you haven't already.</p>
          </div>
        </div>

        <p class="text-sm text-tjb-gray mt-6 text-center">Don't have a plan yet? <a href="/birth-plan-template/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">Download free birth plan</a></p>
        <p class="text-sm text-tjb-gray mt-1 text-center">Want guided help first? <a href="/guided-birth-plan-walkthrough/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">Enroll in the birth plan course</a></p>
      </div>
    </div>
  </section>

  <script>
    const csForm = document.getElementById('confidence-form') as HTMLFormElement;
    const csStatus = document.getElementById('cs-status') as HTMLParagraphElement;
    const csSuccess = document.getElementById('cs-success') as HTMLDivElement;
    const csBtn = document.getElementById('cs-submit') as HTMLButtonElement;

    csForm?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const name = (document.getElementById('cs-name') as HTMLInputElement).value.trim();
      const email = (document.getElementById('cs-email') as HTMLInputElement).value.trim();
      const phone = (document.getElementById('cs-phone') as HTMLInputElement).value.trim();
      const dueDate = (document.getElementById('cs-due') as HTMLInputElement).value.trim();

      if (!name || !email || !phone) {
        csStatus.textContent = 'Please fill in all required fields.';
        csStatus.className = 'text-xs text-red-600 mt-3';
        csStatus.classList.remove('hidden');
        return;
      }

      csBtn.disabled = true;
      csBtn.textContent = 'Sending...';

      try {
        const res = await fetch('/api/confidence-session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, phone, dueDate }),
        });

        const data = await res.json();
        if (res.ok && data.success) {
          csForm.classList.add('hidden');
          csStatus.classList.add('hidden');
          csSuccess.classList.remove('hidden');
          csForm.reset();
        } else {
          csStatus.textContent = data.error || 'Something went wrong. Please try again.';
          csStatus.className = 'text-xs text-red-600 mt-3';
          csStatus.classList.remove('hidden');
        }
      } catch {
        csStatus.textContent = 'Network error. Please try again.';
        csStatus.className = 'text-xs text-red-600 mt-3';
        csStatus.classList.remove('hidden');
      } finally {
        csBtn.disabled = false;
        csBtn.textContent = 'Request a Birth Plan Confidence Session';
      }
    });
  </script>

