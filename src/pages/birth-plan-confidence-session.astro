  <section id="book" class="py-16 md:py-20 bg-white">
    <div class="max-w-xl mx-auto px-6">
      <div class="bg-tjb-cream rounded-2xl p-8 md:p-10">
        <h2 class="text-2xl md:text-3xl font-bold text-tjb-charcoal mb-2 text-center">Ready to feel confident about your birth plan?</h2>
