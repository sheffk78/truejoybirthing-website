---
import Layout from '../layouts/Layout.astro';
import LeadCaptureForm from '../components/LeadCaptureForm.astro';

const breadcrumbList = [
  {"name": "Home", "url": "https://truejoybirthing.com/"},
  {"name": "Birth Plan Scenarios", "url": "https://truejoybirthing.com/birth-plan-scenarios/"},
  {"name": "Birth Plan for Induction", "url": "https://truejoybirthing.com/birth-plan-for-induction/"}
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "@id": "https://truejoybirthing.com/birth-plan-for-induction/#faq",
      "mainEntity": [
        { "@type": "Question", "name": "Does being induced mean I'll end up with a cesarean?", "acceptedAnswer": { "@type": "Answer", "text": "No. Many induced labors result in vaginal births. The rate of cesarean delivery is higher for inductions than for spontaneous labor, especially for first-time moms, but it is not a guaranteed outcome. Your chances improve when your cervix is favorable, your baby is in a good position, and your induction method aligns with your body's readiness." } },
        { "@type": "Question", "name": "How long does an induction take?", "acceptedAnswer": { "@type": "Answer", "text": "It varies widely. Some inductions progress quickly — a few hours from start to delivery. Others take 24–36 hours, especially if your cervix isn't favorable yet. Your care team should give you realistic expectations at your scheduling appointment based on your Bishop score and the method they're using." } },
        { "@type": "Question", "name": "Can I eat during an induction?", "acceptedAnswer": { "@type": "Answer", "text": "It depends on your hospital. Some allow clear liquids and light snacks during early induction. Others restrict food once Pitocin starts, especially if an epidural or cesarean becomes more likely. Ask at your induction appointment and put your preference in your birth plan — then ask again when you arrive." } },
        { "@type": "Question", "name": "Can I move around during an induction?", "acceptedAnswer": { "@type": "Answer", "text": "Usually yes, with some limitations. Most hospitals require continuous fetal monitoring during Pitocin, which means monitors strapped to your belly. Ask about wireless telemetry monitors, birth balls near the bed, and standing positions you can use while monitored. Your birth plan should state that you want to move as much as monitoring allows." } },
        { "@type": "Question", "name": "What if my induction doesn't work?", "acceptedAnswer": { "@type": "Answer", "text": "Failed induction is one of the most common reasons for a cesarean. Your plan should include what you want to happen if labor stalls — do you want more time, a different method, or to discuss a cesarean? Having this documented before you're exhausted helps you participate in decisions you'd otherwise experience as happening to you." } },
        { "@type": "Question", "name": "Should I write a different birth plan if I was planning an unmedicated birth and now I'm being induced?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, adjust your plan. Keep your preferences, but account for the realities of induction. If you wanted an unmedicated birth, you still can — Pitocin contractions are manageable with the right support and positioning. But your plan should acknowledge continuous monitoring, an IV, and a different timeline. Write for the birth you're actually having, not the one you were planning." } },
        { "@type": "Question", "name": "What's a Bishop score and why does it matter for induction?", "acceptedAnswer": { "@type": "Answer", "text": "The Bishop score is a number (0–10) that measures how ready your cervix is for labor. It looks at dilation, effacement, station, consistency, and position. A score of 8 or higher means your body is favorable for induction — labor is likely to start and progress. A lower score means your cervix may need ripening first, and induction may take longer. Ask your provider about your Bishop score at your scheduling appointment." } }
      ]
    }
  ]
};
---

<Layout
  title="Birth Plan for Induction — What to Include, What to Skip, and How to Prepare"
  description="Being induced? Your birth plan needs induction-specific language for monitoring, pain management, and decisions about escalation. Here's what to include, what to skip, and how to prepare."
  canonical="https://truejoybirthing.com/birth-plan-for-induction/"
  ogImage="/images/og-birth-plan-for-induction.webp"
  breadcrumbList={breadcrumbList}
  schema={schema}
>

  <!-- ═══════════════════════════════════════════
       HERO — Editorial two-column, 55/45
       Portrait illustration right
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row">

        <!-- Left: Text — 55% -->
        <div class="md:w-[55%] px-6 md:px-12 py-16 md:py-24 flex flex-col justify-center">
          <p class="eyebrow mb-3">Birth Plan for Induction</p>
          <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
          <h1 class="font-bold text-tjb-charcoal leading-[1.15] mb-4" style="font-size: clamp(2.25rem, 5vw, 3.75rem);">
            How to Write a Birth Plan for an Induction
          </h1>
          <!-- Author credibility strip -->
          <div class="flex items-center gap-2.5 mb-5">
            <img src="/images/shelbi-thumb.webp" alt="" width="32" height="32" class="w-8 h-8 rounded-full object-cover" />
            <p class="text-sm text-tjb-gray leading-snug">
              <a href="/about/" class="text-tjb-lavender-600 hover:text-tjb-lavender-700 font-medium no-underline">Shelbi Kohler</a>,
              certified birth doula — 500+ families supported
            </p>
          </div>
          <p class="text-tjb-gray text-lg leading-[1.7] mb-8 max-w-[36rem]">
            Being induced changes your timeline, your options, and how your labor feels. Here's what to include in your birth plan — and what to leave out — when your birth starts with a scheduled induction.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="#download" class="btn-primary">Get the free birth plan</a>
            <a href="https://apps.apple.com/us/app/true-joy-birthing/id6760793180" class="btn-secondary">Get the free app for the full course</a>
          </div>
        </div>

        <!-- Right: Portrait — 45% -->
        <div class="md:w-[45%] flex items-center justify-center px-6 py-12 md:py-0">
          <img
            src="/images/birth-plan-for-induction-portrait.webp"
            alt="A warm, illustrated guide to writing a birth plan for an induction — covering monitoring, pain management, and decision points"
            class="w-full max-w-md rounded-md"
            loading="eager"
            fetchpriority="high"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PROVENANCE — Compact trust anchor
       ═══════════════════════════════════════════ -->
  <div class="bg-tjb-cream border-y border-tjb-lavender-200/40">
    <div class="max-w-3xl mx-auto px-6 py-4 flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-6">
      <span class="text-sm text-tjb-gray-300 tracking-wide">Induction-specific language</span>
      <span class="hidden sm:inline text-tjb-rose-400 text-sm">·</span>
      <span class="text-sm text-tjb-gray-300 tracking-wide">Copy-into-your-plan phrasing</span>
      <span class="hidden sm:inline text-tjb-rose-400 text-sm">·</span>
      <span class="text-sm text-tjb-gray-300 tracking-wide">What to skip and what to insist on</span>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       TABLE OF CONTENTS — Visual treatment
       ═══════════════════════════════════════════ -->
  <section class="bg-white py-10 border-b border-tjb-lavender-200/50">
    <div class="max-w-3xl mx-auto px-6">
      <p class="text-sm font-semibold text-tjb-gray-400 uppercase tracking-widest mb-5">In this guide</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3">
        <a href="#what-induction-means" class="group flex items-baseline gap-2 text-tjb-charcoal hover:text-tjb-rose-500 transition">
          <span class="text-sm font-semibold text-tjb-lavender-500 group-hover:text-tjb-rose-500 transition">01</span>
          <span class="text-sm font-medium">What Induction Means for Your Plan</span>
        </a>
        <a href="#what-to-include" class="group flex items-baseline gap-2 text-tjb-charcoal hover:text-tjb-rose-500 transition">
          <span class="text-sm font-semibold text-tjb-rose-500 group-hover:text-tjb-lavender-500 transition">02</span>
          <span class="text-sm font-medium">What to Include</span>
        </a>
        <a href="#what-to-skip" class="group flex items-baseline gap-2 text-tjb-charcoal hover:text-tjb-rose-500 transition">
          <span class="text-sm font-semibold text-tjb-lavender-500 group-hover:text-tjb-rose-500 transition">03</span>
          <span class="text-sm font-medium">What to Skip</span>
        </a>
        <a href="#questions-to-ask" class="group flex items-baseline gap-2 text-tjb-charcoal hover:text-tjb-rose-500 transition">
          <span class="text-sm font-semibold text-tjb-rose-500 group-hover:text-tjb-lavender-500 transition">04</span>
          <span class="text-sm font-medium">Questions for Your Appointment</span>
        </a>
        <a href="#your-hospital" class="group flex items-baseline gap-2 text-tjb-charcoal hover:text-tjb-rose-500 transition">
          <span class="text-sm font-semibold text-tjb-lavender-500 group-hover:text-tjb-rose-500 transition">05</span>
          <span class="text-sm font-medium">Your Hospital</span>
        </a>
        <a href="#doula-support" class="group flex items-baseline gap-2 text-tjb-charcoal hover:text-tjb-rose-500 transition">
          <span class="text-sm font-semibold text-tjb-rose-500 group-hover:text-tjb-lavender-500 transition">06</span>
          <span class="text-sm font-medium">How a Doula Helps</span>
        </a>
        <a href="#common-questions" class="group flex items-baseline gap-2 text-tjb-charcoal hover:text-tjb-rose-500 transition">
          <span class="text-sm font-semibold text-tjb-lavender-500 group-hover:text-tjb-rose-500 transition">07</span>
          <span class="text-sm font-medium">Common Questions</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHAT INDUCTION MEANS — Editorial numbered on cream
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream py-16 md:py-20" id="what-induction-means">
    <div class="max-w-3xl mx-auto px-6">

      <p class="eyebrow mb-4">What changes</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
      <h2 class="font-semibold text-tjb-charcoal leading-[1.15] mb-4" style="font-size: clamp(1.75rem, 4vw, 2.75rem);">
        What Induction Actually Means for Your Birth Plan
      </h2>
      <p class="text-tjb-gray text-lg leading-relaxed mb-8">
        An induction means your care team is starting labor for you — usually with Pitocin, sometimes with a Foley bulb, a membrane sweep, or breaking your water. You're not waiting for your body to decide when it's ready. That changes things. Your birth plan needs to account for:
      </p>

      <div class="space-y-0">
        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">01</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">A longer early phase.</p>
              <p class="text-tjb-gray leading-relaxed">Pitocin contractions often ramp up differently than spontaneous labor. The early phase can feel longer or more intense than you expected.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-rose-500 font-serif">02</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Continuous monitoring.</p>
              <p class="text-tjb-gray leading-relaxed">Most hospitals require fetal monitoring throughout an induction. You can still move, but you'll be tethered to monitors — ask about wireless or intermittent options up front.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">03</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">More interventions as standard protocol.</p>
              <p class="text-tjb-gray leading-relaxed">An IV, Pitocin, continuous monitoring, and restricted movement often come as a package deal with induction. Your birth plan should say which of these you consent to and which you'd like to discuss.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40 border-b">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-sage font-serif">04</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Your reasons.</p>
              <p class="text-tjb-gray leading-relaxed">Why you're being induced matters. A 41-week post-dates induction has a different feel than a 37-week induction for preeclampsia. Your plan should include your context so every new nurse who walks in understands your situation.</p>
            </div>
          </div>
        </div>
      </div>

      <p class="text-tjb-gray mt-8 leading-relaxed">
        This doesn't mean induction is a bad experience. It means your birth plan needs to be more specific about what you want, because the default settings are more of everything.
      </p>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHAT TO INCLUDE — Editorial on white with pull-quotes
       ═══════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20" id="what-to-include">
    <div class="max-w-3xl mx-auto px-6">

      <p class="eyebrow mb-4">What to include</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
      <h2 class="font-semibold text-tjb-charcoal leading-[1.15] mb-4" style="font-size: clamp(1.75rem, 4vw, 2.75rem);">
        What to Include in an Induction Birth Plan
      </h2>
      <p class="text-tjb-gray text-lg leading-relaxed mb-10">
        The <a href="/birth-plan-template/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">free birth plan template</a> organizes everything by category. For an induction, here's what to prioritize — with language you can copy directly into your plan.
      </p>

      <!-- Labor Preferences -->
      <h3 class="font-semibold text-tjb-charcoal text-xl mb-3 pt-8 border-t border-tjb-lavender-300/40">Labor Preferences</h3>
      <p class="text-tjb-gray leading-relaxed mb-4">This is where most induction-specific decisions live.</p>
      <p class="text-tjb-gray leading-relaxed mb-4"><strong class="text-tjb-charcoal">Pain management.</strong> State your preferences clearly. If you want an unmedicated birth, say that — but also say what you want if labor becomes more than you expected.</p>

      <blockquote class="bg-tjb-cream border-l-2 border-tjb-rose-400 pl-6 py-4 my-6 rounded-r-md">
        <p class="text-tjb-charcoal italic leading-relaxed"><strong class="not-italic">Copy into your plan:</strong> "I'd like to try unmedicated labor for as long as I'm comfortable. If I request an epidural, I'd like it offered within 30 minutes. Please don't offer pain medication unless I ask — I'll let you know."</p>
      </blockquote>
      <p class="text-tjb-gray leading-relaxed mb-4">If you know you want an epidural, say when:</p>
      <blockquote class="bg-tjb-cream border-l-2 border-tjb-rose-400 pl-6 py-4 my-6 rounded-r-md">
        <p class="text-tjb-charcoal italic leading-relaxed"><strong class="not-italic">Copy into your plan:</strong> "I plan to get an epidural when I'm around 4–5 cm dilated or when contractions become difficult to manage, whichever comes first."</p>
      </blockquote>

      <p class="text-tjb-gray leading-relaxed mt-6 mb-2"><strong class="text-tjb-charcoal">Monitoring.</strong> Ask for what's available:</p>
      <blockquote class="bg-tjb-cream border-l-2 border-tjb-rose-400 pl-6 py-4 my-6 rounded-r-md">
        <p class="text-tjb-charcoal italic leading-relaxed"><strong class="not-italic">Copy into your plan:</strong> "I'd like intermittent monitoring (every 30 minutes during early labor) or wireless telemetry monitoring if available, so I can move and change positions freely."</p>
      </blockquote>
      <p class="text-tjb-gray leading-relaxed mb-4">If your hospital requires continuous monitoring, add:</p>
      <blockquote class="bg-tjb-cream border-l-2 border-tjb-rose-400 pl-6 py-4 my-6 rounded-r-md">
        <p class="text-tjb-charcoal italic leading-relaxed"><strong class="not-italic">Copy into your plan:</strong> "If continuous monitoring is required, I'd like to use a wireless monitor or be able to stand and move with the monitor cables."</p>
      </blockquote>

      <p class="text-tjb-gray leading-relaxed mt-6 mb-2"><strong class="text-tjb-charcoal">Movement and positioning.</strong> Even with monitors and an IV, you can usually move:</p>
      <blockquote class="bg-tjb-cream border-l-2 border-tjb-rose-400 pl-6 py-4 my-6 rounded-r-md">
        <p class="text-tjb-charcoal italic leading-relaxed"><strong class="not-italic">Copy into your plan:</strong> "I'd like to labor out of bed as much as possible — walking, sitting on a birth ball, or using a support bar. I understand I'll have an IV and monitors, and I'd like help positioning around them."</p>
      </blockquote>

      <p class="text-tjb-gray leading-relaxed mt-6 mb-2"><strong class="text-tjb-charcoal">Eating and drinking.</strong> Some hospitals restrict food during induction:</p>
      <blockquote class="bg-tjb-cream border-l-2 border-tjb-rose-400 pl-6 py-4 my-6 rounded-r-md">
        <p class="text-tjb-charcoal italic leading-relaxed"><strong class="not-italic">Copy into your plan:</strong> "I'd like to eat light snacks and drink water during early labor. If my care team recommends restricting food, I'd like to understand why before agreeing."</p>
      </blockquote>

      <!-- Induction Method -->
      <h3 class="font-semibold text-tjb-charcoal text-xl mb-3 pt-10 border-t border-tjb-lavender-300/40">The Induction Method Itself</h3>
      <p class="text-tjb-gray leading-relaxed mb-6">Your plan should document what you know about the method they're using and what you want to happen if it takes longer than expected.</p>
      <blockquote class="bg-tjb-cream border-l-2 border-tjb-rose-400 pl-6 py-4 my-6 rounded-r-md">
        <p class="text-tjb-charcoal italic leading-relaxed"><strong class="not-italic">Copy into your plan:</strong> "We're planning to start with Pitocin. If the first method isn't effective after 6–8 hours, I'd like to discuss next steps before proceeding to additional interventions."</p>
      </blockquote>
      <p class="text-tjb-gray leading-relaxed">This matters because inductions can stall. Having language that says "let's discuss before escalating" gives you back some decision-making power in a process that can feel like it's happening to you.</p>

      <!-- Delivery Preferences -->
      <h3 class="font-semibold text-tjb-charcoal text-xl mb-3 pt-10 border-t border-tjb-lavender-300/40">Delivery Preferences</h3>
      <p class="text-tjb-gray leading-relaxed mb-4">Many induction births are vaginal — but induction also increases the likelihood of instrumental delivery and cesarean. Your delivery preferences should account for both paths.</p>

      <p class="text-tjb-charcoal font-semibold mb-2">If labor progresses to pushing:</p>
      <ul class="space-y-2 mb-4">
        <li class="text-tjb-gray leading-relaxed">I'd like to push in whatever position feels most effective. I prefer not to be on my back unless there's a medical reason.</li>
        <li class="text-tjb-gray leading-relaxed">If an assisted delivery (vacuum or forceps) is recommended, I'd like to understand why and discuss alternatives before proceeding.</li>
      </ul>

      <p class="text-tjb-charcoal font-semibold mb-2">If a cesarean becomes necessary:</p>
      <ul class="space-y-2 mb-4">
        <li class="text-tjb-gray leading-relaxed">If a cesarean is recommended, I'd like my partner present and a clear explanation of why before consent.</li>
        <li class="text-tjb-gray leading-relaxed">If my baby is stable, I'd like delayed cord clamping and skin-to-skin in the operating room if possible.</li>
      </ul>
      <p class="text-tjb-gray leading-relaxed">You don't need a separate C-section plan — just include a few lines that cover the what-if. The <a href="/birth-plan-template/" class="text-tjb-rose-500 font-semibold hover:text-tjb-rose-600 border-b border-transparent hover:border-tjb-rose-500 transition-all">free birth plan template</a> has a dedicated section for this.</p>

      <!-- Newborn Care -->
      <h3 class="font-semibold text-tjb-charcoal text-xl mb-3 pt-10 border-t border-tjb-lavender-300/40">Newborn Care and Postpartum</h3>
      <p class="text-tjb-gray leading-relaxed mb-6">This section is mostly the same regardless of induction, but include:</p>
      <blockquote class="bg-tjb-cream border-l-2 border-tjb-rose-400 pl-6 py-4 my-6 rounded-r-md">
        <p class="text-tjb-charcoal italic leading-relaxed"><strong class="not-italic">Copy into your plan:</strong> "I'd like skin-to-skin contact as soon as possible after delivery, even if there's meconium or a brief NICU evaluation — please delay routine newborn procedures for the first hour unless medically necessary."</p>
      </blockquote>
      <blockquote class="bg-tjb-cream border-l-2 border-tjb-rose-400 pl-6 py-4 my-6 rounded-r-md">
        <p class="text-tjb-charcoal italic leading-relaxed"><strong class="not-italic">Copy into your plan:</strong> "I plan to breastfeed and would like a lactation consultant available during my hospital stay."</p>
      </blockquote>
      <p class="text-tjb-gray leading-relaxed">These preferences don't change because you were induced, but they can get lost in the shuffle when there are more people in the room and more protocols in play.</p>

      <!-- If Things Change -->
      <h3 class="font-semibold text-tjb-charcoal text-xl mb-3 pt-10 border-t border-tjb-lavender-300/40">If Things Change</h3>
      <p class="text-tjb-gray leading-relaxed mb-4">This is the most important section for an induction birth plan. Inductions have more decision points than spontaneous labor. Your plan should say how you want to be involved in those decisions.</p>
      <blockquote class="bg-tjb-cream border-l-2 border-tjb-rose-400 pl-6 py-4 my-6 rounded-r-md">
        <p class="text-tjb-charcoal italic leading-relaxed"><strong class="not-italic">Copy into your plan:</strong> "If my labor stalls or my care team recommends additional interventions, I'd like to be informed of the risks and benefits and given time to discuss with my partner before making a decision — unless it's a true emergency."</p>
      </blockquote>
      <blockquote class="bg-tjb-cream border-l-2 border-tjb-rose-400 pl-6 py-4 my-6 rounded-r-md">
        <p class="text-tjb-charcoal italic leading-relaxed"><strong class="not-italic">Copy into your plan:</strong> "If at any point I feel overwhelmed or unsure, I'd like my doula or support person to help me ask questions and understand my options."</p>
      </blockquote>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHAT TO SKIP — Editorial numbered on cream
       ═══════════════════════════════════════════ -->
  <section class="bg-tjb-cream py-16 md:py-20" id="what-to-skip">
    <div class="max-w-3xl mx-auto px-6">

      <p class="eyebrow mb-4">What to skip</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
      <h2 class="font-semibold text-tjb-charcoal leading-[1.15] mb-8" style="font-size: clamp(1.75rem, 4vw, 2.75rem);">
        What to Skip in an Induction Birth Plan
      </h2>
      <p class="text-tjb-gray text-lg leading-relaxed mb-8">More isn't better. Skip these:</p>

      <div class="space-y-0">
        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">01</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Requests that contradict hospital policy for inductions.</p>
              <p class="text-tjb-gray leading-relaxed">If your hospital requires continuous monitoring during Pitocin, your birth plan can't override that. Instead, ask for the most freedom within that policy — wireless monitors, movement within range, position changes.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-rose-500 font-serif">02</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Long narrative paragraphs.</p>
              <p class="text-tjb-gray leading-relaxed">Nurses read your plan in 30 seconds. Bullet points and short statements. One preference per line.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">03</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Language about "going into labor naturally."</p>
              <p class="text-tjb-gray leading-relaxed">If you're being induced, your plan should reflect induction — not the spontaneous labor experience you were originally planning for. Adjust your plan when your circumstances change.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40 border-b">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-sage font-serif">04</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Anything that sounds like a contract.</p>
              <p class="text-tjb-gray leading-relaxed">"I prefer" and "I'd like" land better than "I refuse" or "I insist." Firm preferences, respectful tone. Your birth plan is a communication tool, not a legal document.</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       QUESTIONS FOR YOUR APPOINTMENT — Editorial numbered on white
       ═══════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20" id="questions-to-ask">
    <div class="max-w-3xl mx-auto px-6">

      <p class="eyebrow mb-4">Pre-induction questions</p>
      <div class="w-10 h-0.5 bg-tjb-rose-500 mb-6"></div>
      <h2 class="font-semibold text-tjb-charcoal leading-[1.15] mb-4" style="font-size: clamp(1.75rem, 4vw, 2.75rem);">
        Before You Go In: What to Ask at Your Induction Appointment
      </h2>
      <p class="text-tjb-gray text-lg leading-relaxed mb-10">
        Your induction probably gets scheduled at a 36- or 37-week appointment. That appointment is your chance to ask questions and get answers before you're in labor. Bring these written down:
      </p>

      <div class="space-y-0">
        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">01</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Why are we inducing?</p>
              <p class="text-tjb-gray leading-relaxed">Get the specific medical reason. "You're past your due date" is a reason. "You're 40+3 and we like to induce by 41 weeks" is a policy. Understanding the difference helps you make informed choices.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-rose-500 font-serif">02</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">What method are we using?</p>
              <p class="text-tjb-gray leading-relaxed">Pitocin, Foley bulb, Cytotec, AROM — they work differently and have different timelines. Ask which one and why.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">03</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">How long will we try before changing course?</p>
              <p class="text-tjb-gray leading-relaxed">Inductions can take 12–24+ hours. Ask what the hospital's timeline expectations are and what happens if your body needs more time.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-rose-500 font-serif">04</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">What are the signs we'd switch to a cesarean?</p>
              <p class="text-tjb-gray leading-relaxed">Know the thresholds in advance — failure to progress, fetal distress, infection risk. This isn't pessimistic; it's preparation.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-lavender-500 font-serif">05</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Can I eat, move, and use the shower/ball during induction?</p>
              <p class="text-tjb-gray leading-relaxed">Hospital policies vary. Some restrict food once Pitocin starts. Others allow light snacks. Know what yours allows.</p>
            </div>
          </div>
        </div>

        <div class="py-5 border-t border-tjb-lavender-300/40 border-b">
          <div class="grid md:grid-cols-[3rem_1fr] gap-4 md:gap-6 items-start">
            <span class="text-3xl font-bold text-tjb-sage font-serif">06</span>
            <div>
              <p class="text-tjb-charcoal font-semibold mb-1">Who will be in the room?</p>
              <p class="text-tjb-gray leading-relaxed">Ask about nursing shifts, residents, and whether your doula is welcome. If you're at a teaching hospital, you can say you'd prefer not to have students observe.</p>
            </div>
          </div>
        </div>
      </div>

      <p class="text-tjb-gray mt-8 leading-relaxed">Write the answers on your birth plan or bring them to your next prenatal appointment.</p>

    </div>
  </section>

