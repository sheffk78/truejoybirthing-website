{
  "routes": [
    {
      "routePath": "/api/ambassador",
      "mountPath": "/api",
      "method": "POST",
      "module": [
        "api/ambassador.ts:onRequestPost"
      ]
    },
    {
      "routePath": "/api/confidence-session",
      "mountPath": "/api",
      "method": "POST",
      "module": [
        "api/confidence-session.ts:onRequestPost"
      ]
    },
    {
      "routePath": "/api/contact",
      "mountPath": "/api",
      "method": "POST",
      "module": [
        "api/contact.ts:onRequestPost"
      ]
    },
    {
      "routePath": "/admin/:path*",
      "mountPath": "/admin",
      "method": "",
      "module": [
        "admin/[[path]].ts:onRequest"
      ]
    }
  ],
  "baseURL": "/"
}